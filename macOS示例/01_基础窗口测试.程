// ============================================================
// macOS Cocoa 示例 - 01 基础窗口测试
// 测试：NSWindow创建、消息循环、窗口关闭、屏幕信息
// 注意：macOS Cocoa 后端目前仅有窗口创建/消息循环/关闭功能
// ============================================================

导入 "窗口组件"

函程 主程序():
    // 获取屏幕尺寸
    设 屏宽 = 获取屏幕宽度()
    设 屏高 = 获取屏幕高度()
    输出("macOS 屏幕尺寸: " + 转文本(屏宽) + " x " + 转文本(屏高))

    // 创建窗口
    设 配置 = 窗口("Cocoa 基础窗口测试", 640, 480)
    配置.居中 = 真
    配置.背景色 = "#F0F0F0"
    设 句柄 = 创建窗口(配置)

    输出("窗口创建成功，句柄: " + 转文本(句柄))

    // 获取当前主题
    设 主题 = _获取原生主题()
    输出("当前主题: " + 转文本(主题))

    // 运行消息循环
    输出("进入 Cocoa 消息循环...")
    运行界面(句柄)
    
    输出("窗口已关闭")
结束

主程序()
