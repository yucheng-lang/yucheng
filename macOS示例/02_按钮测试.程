// ============================================================
// macOS Cocoa 示例 - 02 按钮测试
// 测试：NSButton创建（Cocoa后端所有控件都创建为NSButton）
// 注意：macOS Cocoa 后端目前仅支持创建NSButton，不支持事件绑定
// ============================================================

导入 "窗口组件"
导入 "按钮"

设 窗口句柄 = 空

函程 创建界面():
    设 配置 = 窗口("Cocoa 按钮测试", 500, 400)
    配置.居中 = 真
    配置.背景色 = "#FFFFFF"
    窗口句柄 = 创建窗口(配置)
    
    输出("窗口创建成功")
    
    // 创建多个按钮测试
    // 注意：Cocoa后端中所有控件类型都创建为NSButton
    设 按钮1配置 = 按钮("按钮1 - 点击测试", 50, 30, 200, 35, 窗口句柄)
    设 按钮1 = 创建按钮(按钮1配置)
    输出("按钮1创建成功: " + 转文本(按钮1))
    
    设 按钮2配置 = 按钮("按钮2 - 确定", 50, 80, 200, 35, 窗口句柄)
    设 按钮2 = 创建按钮(按钮2配置)
    输出("按钮2创建成功: " + 转文本(按钮2))
    
    设 按钮3配置 = 按钮("按钮3 - 取消", 50, 130, 200, 35, 窗口句柄)
    设 按钮3 = 创建按钮(按钮3配置)
    输出("按钮3创建成功: " + 转文本(按钮3))
    
    // 以下控件在Cocoa后端也会创建为NSButton
    设 按钮4配置 = 按钮("控件测试 - Cocoa", 50, 180, 200, 35, 窗口句柄)
    设 按钮4 = 创建按钮(按钮4配置)
    输出("控件4创建成功: " + 转文本(按钮4))
    
    输出("注意: Cocoa后端当前不支持事件绑定，按钮无法响应点击")
    输出("所有控件类型都映射为NSButton")
    
    // 运行消息循环
    运行界面(窗口句柄)
结束

创建界面()
