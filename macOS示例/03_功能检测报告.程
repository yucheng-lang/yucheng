    // 创建窗口验证基础功能
    设 配置 = 窗口("Cocoa 功能检测 - macOS", 600, 400)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)
    
    输出("")
    输出("窗口已创建，进入消息循环")
    运行界面(窗口句柄)
