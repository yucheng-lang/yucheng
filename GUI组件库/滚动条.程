// ============================================================
// 语程 GUI 组件库 - 滚动条
// 提供独立滚动条创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 滚动条配置 =====

函程 滚动条(X = 0, Y = 0, 宽度 = 200, 高度 = 20, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "垂直": 假,
        "最小值": 0,
        "最大值": 100,
        "当前值": 0,
        "页面大小": 10,
        "线条大小": 1
    }
结束

// 创建滚动条
函程 创建滚动条(配置):
    返回 _创建原生控件("滚动条", 配置)
结束

// 设置滚动条范围
函程 设置滚动条范围(滚动条句柄, 最小值, 最大值):
    _设置控件属性(滚动条句柄, "最小值", 最小值)
    _设置控件属性(滚动条句柄, "最大值", 最大值)
结束

// 设置滚动条当前值
函程 设置滚动条值(滚动条句柄, 值):
    _设置控件属性(滚动条句柄, "当前值", 值)
结束

// 获取滚动条当前值
函程 获取滚动条值(滚动条句柄):
    返回 _获取控件属性(滚动条句柄, "当前值")
结束

// 显示/隐藏/销毁
函程 显示滚动条(滚动条句柄):
    _设置控件属性(滚动条句柄, "可见", 真)
结束

函程 隐藏滚动条(滚动条句柄):
    _设置控件属性(滚动条句柄, "可见", 假)
结束

函程 销毁滚动条(滚动条句柄):
    _销毁原生控件(滚动条句柄)
结束
