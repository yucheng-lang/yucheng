// ============================================================
// 语程 GUI 组件库 - 热键框
// 提供热键输入框创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建热键框配置
函程 热键框(X = 0, Y = 0, 宽度 = 120, 高度 = 24, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "热键码": 0,
        "修饰键": 0,
        "热键名称": "无"
    }
结束

// 修饰键常量
常量 修饰键Alt = 0x0001
常量 修饰键Ctrl = 0x0002
常量 修饰键Shift = 0x0004
常量 修饰键Win = 0x0008

// 创建热键框
函程 创建热键框(配置):
    返回 _创建原生控件("热键框", 配置)
结束

// 获取热键码
函程 获取热键码(热键框句柄):
    返回 _获取控件属性(热键框句柄, "热键码")
结束

// 获取修饰键
函程 获取修饰键(热键框句柄):
    返回 _获取控件属性(热键框句柄, "修饰键")
结束

// 获取热键名称
函程 获取热键名称(热键框句柄):
    返回 _获取控件属性(热键框句柄, "热键名称")
结束

// 设置热键
函程 设置热键(热键框句柄, 热键码, 修饰键):
    _设置控件属性(热键框句柄, "热键码", 热键码)
    _设置控件属性(热键框句柄, "修饰键", 修饰键)
结束

// 销毁热键框
函程 销毁热键框(热键框句柄):
    _销毁原生控件(热键框句柄)
结束
