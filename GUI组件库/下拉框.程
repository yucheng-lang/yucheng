// ============================================================
// 语程 GUI 组件库 - 下拉框（组合框）
// 提供下拉选择框创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 下拉框配置 =====

函程 下拉框(X = 0, Y = 0, 宽度 = 200, 高度 = 24, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "可编辑": 假,
        "下拉行数": 8,
        "项目列表": [],
        "选中索引": -1,
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建下拉框
函程 创建下拉框(配置):
    返回 _创建原生控件("下拉框", 配置)
结束

// ===== 下拉框操作 =====

// 添加下拉项
函程 添加下拉项(下拉框句柄, 文本):
    _添加控件列表项(下拉框句柄, 文本)
结束

// 删除下拉项
函程 删除下拉项(下拉框句柄, 索引):
    _删除控件列表项(下拉框句柄, 索引)
结束

// 清空下拉列表
函程 清空下拉列表(下拉框句柄):
    _清空控件列表(下拉框句柄)
结束

// 获取下拉项数量
函程 获取下拉项数(下拉框句柄):
    返回 _获取控件属性(下拉框句柄, "项目数")
结束

// 获取选中项索引
函程 获取下拉选中索引(下拉框句柄):
    返回 _获取控件属性(下拉框句柄, "选中索引")
结束

// 设置选中项索引
函程 设置下拉选中索引(下拉框句柄, 索引):
    _设置控件属性(下拉框句柄, "选中索引", 索引)
结束

// 获取选中项文本
函程 获取下拉选中项(下拉框句柄):
    设 索引 = 获取下拉选中索引(下拉框句柄)
    如果 索引 >= 0:
        返回 _获取控件列表项(下拉框句柄, 索引)
    否则:
        返回 ""
结束

// 获取下拉框文本（可编辑模式下）
函程 获取下拉框文本(下拉框句柄):
    返回 _获取控件属性(下拉框句柄, "文本")
结束

// 设置下拉框文本（可编辑模式下）
函程 设置下拉框文本(下拉框句柄, 文本):
    _设置控件属性(下拉框句柄, "文本", 文本)
结束

// 显示/隐藏/销毁
函程 显示下拉框(下拉框句柄):
    _设置控件属性(下拉框句柄, "可见", 真)
结束

函程 隐藏下拉框(下拉框句柄):
    _设置控件属性(下拉框句柄, "可见", 假)
结束

函程 销毁下拉框(下拉框句柄):
    _销毁原生控件(下拉框句柄)
结束
