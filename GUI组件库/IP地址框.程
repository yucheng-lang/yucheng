// ============================================================
// 语程 GUI 组件库 - IP地址框
// 提供 IP 地址输入框创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建IP地址框配置
函程 IP地址框(X = 0, Y = 0, 宽度 = 150, 高度 = 24, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "IP地址": "0.0.0.0"
    }
结束

// 创建IP地址框
函程 创建IP地址框(配置):
    返回 _创建原生控件("IP地址框", 配置)
结束

// 获取IP地址
函程 获取IP地址(IP地址框句柄):
    返回 _获取控件属性(IP地址框句柄, "IP地址")
结束

// 设置IP地址
函程 设置IP地址(IP地址框句柄, 地址):
    _设置控件属性(IP地址框句柄, "IP地址", 地址)
结束

// 清空IP地址
函程 清空IP地址(IP地址框句柄):
    设置IP地址(IP地址框句柄, "0.0.0.0")
结束

// 显示/隐藏/销毁
函程 显示IP地址框(IP地址框句柄):
    _设置控件属性(IP地址框句柄, "可见", 真)
结束

函程 隐藏IP地址框(IP地址框句柄):
    _设置控件属性(IP地址框句柄, "可见", 假)
结束

函程 销毁IP地址框(IP地址框句柄):
    _销毁原生控件(IP地址框句柄)
结束
