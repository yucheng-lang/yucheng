// ============================================================
// 语程 GUI 组件库 - 搜索框
// 提供带搜索图标的输入框功能
// ============================================================

导入 "窗口组件"

// 创建搜索框配置
函程 搜索框(X = 0, Y = 0, 宽度 = 200, 高度 = 28, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "占位符文本": "搜索...",
        "搜索文本": "",
        "自动搜索": 假,
        "搜索延迟": 300,
        "显示搜索按钮": 真,
        "显示清除按钮": 真,
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建搜索框
函程 创建搜索框(配置):
    返回 _创建原生控件("搜索框", 配置)
结束

// 获取搜索文本
函程 获取搜索文本(搜索框句柄):
    返回 _获取控件属性(搜索框句柄, "搜索文本")
结束

// 设置搜索文本
函程 设置搜索文本(搜索框句柄, 文本):
    _设置控件属性(搜索框句柄, "搜索文本", 文本)
结束

// 清空搜索文本
函程 清空搜索框(搜索框句柄):
    设置搜索文本(搜索框句柄, "")
结束

// 显示/隐藏/销毁
函程 显示搜索框(搜索框句柄):
    _设置控件属性(搜索框句柄, "可见", 真)
结束

函程 隐藏搜索框(搜索框句柄):
    _设置控件属性(搜索框句柄, "可见", 假)
结束

函程 销毁搜索框(搜索框句柄):
    _销毁原生控件(搜索框句柄)
结束
