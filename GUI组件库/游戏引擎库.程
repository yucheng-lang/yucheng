// ============================================================
// 语程 GUI 组件库 - 游戏引擎库
// 提供简单的 2D 游戏开发功能
// ============================================================

导入 "窗口组件"
导入 "绘图"

// ===== 游戏配置 =====

// 创建游戏窗口配置
函程 游戏窗口(标题, 宽度 = 800, 高度 = 600):
    设 配置 = 窗口(标题, 宽度, 高度)
    配置.居中 = 真
    配置.可调整大小 = 假
    配置.背景色 = "#000000"
    返回 配置
结束

// ===== 游戏循环 =====

// 启动游戏循环
// 参数：窗口句柄, 游戏帧函数, 帧率(默认60)
// 游戏帧函数：每帧调用一次，参数为定时器ID（通常忽略）
// 在帧函数中通过全局变量访问绘图上下文
// 示例：
//   设 上下文 = 获取绘图上下文(句柄)
//   函程 游戏帧(定时器ID):
//       清除区域(上下文, 0, 0, 800, 600, "#000000")
//       绘制文本(上下文, "Hello!", 10, 10, "#FFFFFF")
//   结束
//   启动游戏循环(句柄, 游戏帧, 60)
函程 启动游戏循环(窗口句柄, 游戏帧函数, 帧率 = 60):
    设 间隔 = 1000 / 帧率
    设 定时器ID = 1
    设 上下文 = 获取绘图上下文(窗口句柄)

    // 注册游戏循环定时器
    _设置原生定时器(窗口句柄, 定时器ID, 间隔, 游戏帧函数)
结束

// 停止游戏循环
函程 停止游戏循环(窗口句柄):
    删除定时器(窗口句柄, 1)
结束

// ===== 精灵 =====

// 创建精灵
函程 创建精灵(图像路径, X = 0, Y = 0, 宽度 = 0, 高度 = 0):
    设 图像 = 加载图像(图像路径)
    设 实际宽度 = 宽度
    设 实际高度 = 高度
    如果 宽度 == 0:
        实际宽度 = _获取图像宽度(图像)
    如果 高度 == 0:
        实际高度 = _获取图像高度(图像)
    返回 {
        "图像": 图像,
        "X": X,
        "Y": Y,
        "宽度": 实际宽度,
        "高度": 实际高度,
        "速度X": 0,
        "速度Y": 0,
        "可见": 真,
        "透明度": 1.0,
        "旋转角度": 0,
        "翻转水平": 假,
        "翻转垂直": 假
    }
结束

// 绘制精灵
函程 绘制精灵(上下文, 精灵):
    如果 精灵.可见:
        绘制图像(上下文, 精灵.图像, 精灵.X, 精灵.Y, 精灵.宽度, 精灵.高度)
结束

// 更新精灵位置
函程 更新精灵位置(精灵, 间隔):
    精灵.X = 精灵.X + 精灵.速度X * 间隔 / 1000
    精灵.Y = 精灵.Y + 精灵.速度Y * 间隔 / 1000
结束

// 碰撞检测（矩形碰撞）
函程 矩形碰撞(精灵1, 精灵2):
    返回 精灵1.X < 精灵2.X + 精灵2.宽度 且
           精灵1.X + 精灵1.宽度 > 精灵2.X 且
           精灵1.Y < 精灵2.Y + 精灵2.高度 且
           精灵1.Y + 精灵1.高度 > 精灵2.Y
结束

// 释放精灵资源
函程 释放精灵(精灵):
    释放图像(精灵.图像)
结束

// ===== 键盘状态 =====

// 检查按键是否按下
函程 按键按下(键码):
    返回 _获取按键状态(键码)
结束

// ===== 鼠标状态 =====

// 获取鼠标位置
函程 获取鼠标位置(窗口句柄):
    返回 _获取鼠标位置(窗口句柄)
结束

// 检查鼠标按钮是否按下
函程 鼠标按下(按钮 = 0):
    返回 _获取鼠标按钮状态(按钮)
结束

// ===== 场景管理 =====

// 创建场景
函程 创建场景(名称):
    返回 {
        "名称": 名称,
        "精灵列表": [],
        "活动": 假
    }
结束

// 添加精灵到场景
函程 添加精灵到场景(场景, 精灵):
    数组添加(场景.精灵列表, 精灵)
结束

// 从场景移除精灵
函程 从场景移除精灵(场景, 精灵):
    设 索引 = 数组索引(场景.精灵列表, 精灵)
    如果 索引 >= 0:
        数组删除(场景.精灵列表, 索引)
结束

