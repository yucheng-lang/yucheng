// ============================================================
// 语程 GUI 组件库 - 动画控件
// 提供动画播放控件创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建动画控件配置
函程 动画控件(X = 0, Y = 0, 宽度 = 200, 高度 = 200, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "自动播放": 假,
        "循环播放": 假,
        "播放速度": 1.0,
        "帧列表": [],
        "当前帧": 0,
        "帧间隔": 100,
        "透明背景": 假
    }
结束

// 创建动画控件
函程 创建动画控件(配置):
    返回 _创建原生控件("动画控件", 配置)
结束

// 加载动画帧（从图片文件列表）
函程 加载动画帧(动画控件句柄, 帧文件列表):
    _设置控件属性(动画控件句柄, "帧列表", 帧文件列表)
结束

// 播放动画
函程 播放动画(动画控件句柄):
    _设置控件属性(动画控件句柄, "播放中", 真)
结束

// 暂停动画
函程 暂停动画(动画控件句柄):
    _设置控件属性(动画控件句柄, "播放中", 假)
结束

// 停止动画（回到第一帧）
函程 停止动画(动画控件句柄):
    _设置控件属性(动画控件句柄, "播放中", 假)
    _设置控件属性(动画控件句柄, "当前帧", 0)
结束

// 设置播放速度（1.0 = 正常速度）
函程 设置播放速度(动画控件句柄, 速度):
    _设置控件属性(动画控件句柄, "播放速度", 速度)
结束

// 设置帧间隔（毫秒）
函程 设置帧间隔(动画控件句柄, 间隔):
    _设置控件属性(动画控件句柄, "帧间隔", 间隔)
结束

// 获取当前帧索引
函程 获取当前帧(动画控件句柄):
    返回 _获取控件属性(动画控件句柄, "当前帧")
结束

// 设置当前帧索引
函程 设置当前帧(动画控件句柄, 帧索引):
    _设置控件属性(动画控件句柄, "当前帧", 帧索引)
结束

// 获取总帧数
函程 获取总帧数(动画控件句柄):
    返回 _获取控件属性(动画控件句柄, "帧数")
结束

// 显示/隐藏/销毁
函程 显示动画控件(动画控件句柄):
    _设置控件属性(动画控件句柄, "可见", 真)
结束

函程 隐藏动画控件(动画控件句柄):
    _设置控件属性(动画控件句柄, "可见", 假)
结束

函程 销毁动画控件(动画控件句柄):
    _销毁原生控件(动画控件句柄)
结束
