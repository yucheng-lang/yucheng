// ============================================================
// 语程 GUI 组件库 - 标签
// 提供文本标签创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 标签边框样式 =====

常量 无边框 = 0
常量 凹陷边框 = 1
常量 黑色边框 = 2
常量 灰色边框 = 3
常量 白色边框 = 4
常量 黑色填充 = 5
常量 灰色填充 = 6
常量 白色填充 = 7

// ===== 文本对齐常量 =====
常量 左对齐 = 0
常量 居中对齐 = 1
常量 右对齐 = 2

// ===== 标签配置 =====

// 创建标签配置
函程 标签(文本, X = 0, Y = 0, 宽度 = 100, 高度 = 25, 父窗口 = 空, 标识符 = 0):
    返回 {
        "文本": 文本,
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "文字对齐": 左对齐,
        "边框样式": 无边框,
        "文字颜色": "",
        "背景透明": 假,
        "字体名称": "微软雅黑",
        "字体大小": 14,
        "字体粗细": 400,
        "字体斜体": 假,
        "字体下划线": 假
    }
结束

// 创建字体配置
函程 字体配置(大小 = 14, 名称 = "微软雅黑", 粗细 = 400, 斜体 = 假, 下划线 = 假):
    返回 {
        "大小": 大小,
        "名称": 名称,
        "粗细": 粗细,
        "斜体": 斜体,
        "下划线": 下划线
    }
结束

// ===== 标签创建 =====

// 创建标签
函程 创建标签(配置):
    返回 _创建原生控件("标签", 配置)
结束

// ===== 标签操作 =====

// 设置标签文本
函程 设置标签文本(标签句柄, 文本):
    _设置控件属性(标签句柄, "文本", 文本)
结束

// 获取标签文本
函程 获取标签文本(标签句柄):
    返回 _获取控件属性(标签句柄, "文本")
结束

// 设置标签位置
函程 设置标签位置(标签句柄, X, Y):
    _设置控件属性(标签句柄, "X", X)
    _设置控件属性(标签句柄, "Y", Y)
结束

// 设置标签大小
函程 设置标签大小(标签句柄, 宽度, 高度):
    _设置控件属性(标签句柄, "宽度", 宽度)
    _设置控件属性(标签句柄, "高度", 高度)
结束

// 设置标签位置和大小
函程 设置标签位置和大小(标签句柄, X, Y, 宽度, 高度):
    设置标签位置(标签句柄, X, Y)
    设置标签大小(标签句柄, 宽度, 高度)
结束

// 设置标签字体
函程 设置标签字体(标签句柄, 字体名称, 字体大小):
    _设置控件属性(标签句柄, "字体名称", 字体名称)
    _设置控件属性(标签句柄, "字体大小", 字体大小)
结束

// 设置标签文字颜色
函程 设置标签文字颜色(标签句柄, 颜色):
    _设置控件属性(标签句柄, "文字颜色", 颜色)
结束

// 设置标签背景透明
函程 设置标签背景透明(标签句柄, 透明):
    _设置控件属性(标签句柄, "背景透明", 透明)
结束

// 显示标签
函程 显示标签(标签句柄):
    _设置控件属性(标签句柄, "可见", 真)
结束

// 隐藏标签
函程 隐藏标签(标签句柄):
    _设置控件属性(标签句柄, "可见", 假)
结束

// 启用标签
函程 启用标签(标签句柄):
    _设置控件属性(标签句柄, "启用", 真)
结束

// 禁用标签
函程 禁用标签(标签句柄):
    _设置控件属性(标签句柄, "启用", 假)
结束

// 销毁标签
函程 销毁标签(标签句柄):
    _销毁原生控件(标签句柄)
结束
