// ============================================================
// 语程 GUI 组件库 - 滑块条
// 提供滑块条创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 滑块条配置 =====

函程 滑块条(X = 0, Y = 0, 宽度 = 200, 高度 = 30, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "最小值": 0,
        "最大值": 100,
        "当前值": 0,
        "垂直": 假,
        "显示刻度": 假,
        "刻度频率": 10,
        "选择范围": 假,
        "选择起始": 0,
        "选择结束": 0,
        "线条大小": 1,
        "页面大小": 10
    }
结束

// 创建滑块条
函程 创建滑块条(配置):
    返回 _创建原生控件("滑块条", 配置)
结束

// 设置滑块条范围
函程 设置滑块条范围(滑块条句柄, 最小值, 最大值):
    _设置控件属性(滑块条句柄, "最小值", 最小值)
    _设置控件属性(滑块条句柄, "最大值", 最大值)
结束

// 设置滑块条当前值
函程 设置滑块条值(滑块条句柄, 值):
    _设置控件属性(滑块条句柄, "当前值", 值)
结束

// 获取滑块条当前值
函程 获取滑块条值(滑块条句柄):
    返回 _获取控件属性(滑块条句柄, "当前值")
结束

// 设置滑块条刻度频率
函程 设置滑块条刻度(滑块条句柄, 频率):
    _设置控件属性(滑块条句柄, "刻度频率", 频率)
结束

// 显示滑块条
函程 显示滑块条(滑块条句柄):
    _设置控件属性(滑块条句柄, "可见", 真)
结束

// 隐藏滑块条
函程 隐藏滑块条(滑块条句柄):
    _设置控件属性(滑块条句柄, "可见", 假)
结束

// 启用滑块条
函程 启用滑块条(滑块条句柄):
    _设置控件属性(滑块条句柄, "启用", 真)
结束

// 禁用滑块条
函程 禁用滑块条(滑块条句柄):
    _设置控件属性(滑块条句柄, "启用", 假)
结束

// 销毁滑块条
函程 销毁滑块条(滑块条句柄):
    _销毁原生控件(滑块条句柄)
结束
