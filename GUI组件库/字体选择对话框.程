// ============================================================
// 语程 GUI 组件库 - 字体选择对话框
// 提供字体选择对话框功能
// ============================================================

导入 "窗口组件"

// 打开字体选择对话框
// 返回：字体配置字典 {"名称", "大小", "粗细", "斜体", "下划线", "删除线"}，取消返回空
函程 选择字体(父窗口 = 空, 默认字体 = "微软雅黑", 默认大小 = 14):
    返回 _打开字体选择对话框(父窗口, 默认字体, 默认大小)
结束

// 应用字体到控件
函程 应用字体(控件句柄, 字体配置):
    _设置控件属性(控件句柄, "字体名称", 取值(字体配置, "名称", "微软雅黑"))
    _设置控件属性(控件句柄, "字体大小", 取值(字体配置, "大小", 14))
    _设置控件属性(控件句柄, "字体粗细", 取值(字体配置, "粗细", 400))
    _设置控件属性(控件句柄, "字体斜体", 取值(字体配置, "斜体", 假))
    _设置控件属性(控件句柄, "字体下划线", 取值(字体配置, "下划线", 假))
结束
