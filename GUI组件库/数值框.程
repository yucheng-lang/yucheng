// ============================================================
// 语程 GUI 组件库 - 数值框
// 提供数值输入框创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 数值框配置 =====

函程 数值框(X = 0, Y = 0, 宽度 = 100, 高度 = 24, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "只读": 假,
        "最小值": 0,
        "最大值": 100,
        "当前值": 0,
        "步长": 1,
        "小数位数": 0,
        "前缀": "",
        "后缀": "",
        "千分位分隔符": 假,
        "十六进制模式": 假,
        "加速键": 真,
        "换行": 假,
        "文字颜色": "",
        "背景颜色": "",
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建数值框
函程 创建数值框(配置):
    返回 _创建原生控件("数值框", 配置)
结束

// 设置数值框范围
函程 设置数值框范围(数值框句柄, 最小值, 最大值):
    _设置控件属性(数值框句柄, "最小值", 最小值)
    _设置控件属性(数值框句柄, "最大值", 最大值)
结束

// 设置数值框当前值
函程 设置数值框值(数值框句柄, 值):
    _设置控件属性(数值框句柄, "当前值", 值)
结束

// 获取数值框当前值
函程 获取数值框值(数值框句柄):
    返回 _获取控件属性(数值框句柄, "当前值")
结束

// 设置数值框步长
函程 设置数值框步长(数值框句柄, 步长):
    _设置控件属性(数值框句柄, "步长", 步长)
结束

// 增加数值
函程 增加数值(数值框句柄):
    设 当前 = 获取数值框值(数值框句柄)
    设 步长 = _获取控件属性(数值框句柄, "步长")
    设置数值框值(数值框句柄, 当前 + 步长)
结束

// 减少数值
函程 减少数值(数值框句柄):
    设 当前 = 获取数值框值(数值框句柄)
    设 步长 = _获取控件属性(数值框句柄, "步长")
    设置数值框值(数值框句柄, 当前 - 步长)
结束

// 显示数值框
函程 显示数值框(数值框句柄):
    _设置控件属性(数值框句柄, "可见", 真)
结束

// 隐藏数值框
函程 隐藏数值框(数值框句柄):
    _设置控件属性(数值框句柄, "可见", 假)
结束

// 销毁数值框
函程 销毁数值框(数值框句柄):
    _销毁原生控件(数值框句柄)
结束
