// ============================================================
// 语程 GUI 组件库 - 富文本框
// 提供富文本编辑器创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建富文本框配置
函程 富文本框(X = 0, Y = 0, 宽度 = 400, 高度 = 300, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "只读": 假,
        "多行": 真,
        "自动换行": 真,
        "显示工具栏": 真,
        "字体名称": "微软雅黑",
        "字体大小": 14,
        "文本内容": "",
        "背景颜色": "#FFFFFF"
    }
结束

// 创建富文本框
函程 创建富文本框(配置):
    返回 _创建原生控件("富文本框", 配置)
结束

// ===== 文本操作 =====

// 获取富文本内容
函程 获取富文本内容(富文本框句柄):
    返回 _获取控件属性(富文本框句柄, "文本内容")
结束

// 设置富文本内容
函程 设置富文本内容(富文本框句柄, 内容):
    _设置控件属性(富文本框句柄, "文本内容", 内容)
结束

// 追加富文本
函程 追加富文本(富文本框句柄, 内容):
    设 当前 = 获取富文本内容(富文本框句柄)
    设置富文本内容(富文本框句柄, 当前 + 内容)
结束

// 清空富文本
函程 清空富文本(富文本框句柄):
    设置富文本内容(富文本框句柄, "")
结束

// ===== 格式操作 =====

// 设置选中文字加粗
函程 设置富文本加粗(富文本框句柄, 加粗):
    _设置富文本格式(富文本框句柄, "加粗", 加粗)
结束

// 设置选中文字斜体
函程 设置富文本斜体(富文本框句柄, 斜体):
    _设置富文本格式(富文本框句柄, "斜体", 斜体)
结束

// 设置选中文字下划线
函程 设置富文本下划线(富文本框句柄, 下划线):
    _设置富文本格式(富文本框句柄, "下划线", 下划线)
结束

// 设置选中文字删除线
函程 设置富文本删除线(富文本框句柄, 删除线):
    _设置富文本格式(富文本框句柄, "删除线", 删除线)
结束

// 设置选中文字颜色
函程 设置富文本颜色(富文本框句柄, 颜色):
    _设置富文本格式(富文本框句柄, "颜色", 颜色)
结束

// 设置选中文字字体
函程 设置富文本字体(富文本框句柄, 字体名称):
    _设置富文本格式(富文本框句柄, "字体", 字体名称)
结束

// 设置选中文字大小
函程 设置富文本大小(富文本框句柄, 字体大小):
    _设置富文本格式(富文本框句柄, "大小", 字体大小)
结束

// 设置选中文字对齐方式
函程 设置富文本对齐(富文本框句柄, 对齐方式):
    _设置富文本格式(富文本框句柄, "对齐", 对齐方式)
结束

// ===== 导入导出 =====

// 导出为纯文本
函程 导出纯文本(富文本框句柄):
    返回 _获取控件属性(富文本框句柄, "纯文本")
结束

// 导出为HTML
函程 导出HTML(富文本框句柄):
    返回 _获取控件属性(富文本框句柄, "HTML")
结束

// 显示/隐藏/销毁
函程 显示富文本框(富文本框句柄):
    _设置控件属性(富文本框句柄, "可见", 真)
结束

函程 隐藏富文本框(富文本框句柄):
    _设置控件属性(富文本框句柄, "可见", 假)
结束

函程 销毁富文本框(富文本框句柄):
    _销毁原生控件(富文本框句柄)
结束
