// ===== 批量操作 =====

// 创建一组单选按钮
// 参数：选项列表, X, Y, 宽度, 高度, 父窗口, 起始标识符, 分组编号
函程 创建单选按钮组(选项列表, X, Y, 宽度 = 120, 高度 = 25, 父窗口 = 空, 起始标识符 = 0, 分组编号 = 1):
    设 按钮列表 = []
    设 当前Y = Y
    遍 选项 于 选项列表:
        设 配置 = 单选按钮(选项, X, 当前Y, 宽度, 高度, 父窗口, 起始标识符, 分组编号)
        设 句柄 = 创建单选按钮(配置)
        数组添加(按钮列表, 句柄)
        当前Y = 当前Y + 高度 + 5
        起始标识符 = 起始标识符 + 1
    结束
    返回 按钮列表
结束
