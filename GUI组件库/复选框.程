// ============================================================
// 语程 GUI 组件库 - 复选框
// 提供复选框创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 复选框配置 =====

// 创建复选框配置
函程 复选框(文本, X = 0, Y = 0, 宽度 = 120, 高度 = 25, 父窗口 = 空, 标识符 = 0):
    返回 {
        "文本": 文本,
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "选中": 假,
        "三态": 假,
        "文字在左侧": 假,
        "扁平风格": 假,
        "自动选中": 真,
        "文字颜色": "",
        "背景颜色": "",
        "工具提示文本": "",
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// ===== 复选框创建 =====

// 创建复选框
函程 创建复选框(配置):
    返回 _创建原生控件("复选框", 配置)
结束

// ===== 复选框操作 =====

// 获取复选框选中状态
函程 获取复选框状态(复选框句柄):
    返回 _获取控件属性(复选框句柄, "选中")
结束

// 设置复选框选中状态
函程 设置复选框状态(复选框句柄, 选中):
    _设置控件属性(复选框句柄, "选中", 选中)
结束

// 切换复选框状态
函程 切换复选框状态(复选框句柄):
    设 当前 = 获取复选框状态(复选框句柄)
    设置复选框状态(复选框句柄, 非 当前)
结束

// 设置复选框文本
函程 设置复选框文本(复选框句柄, 文本):
    _设置控件属性(复选框句柄, "文本", 文本)
结束

// 获取复选框文本
函程 获取复选框文本(复选框句柄):
    返回 _获取控件属性(复选框句柄, "文本")
结束

// 显示复选框
函程 显示复选框(复选框句柄):
    _设置控件属性(复选框句柄, "可见", 真)
结束

// 隐藏复选框
函程 隐藏复选框(复选框句柄):
    _设置控件属性(复选框句柄, "可见", 假)
结束

// 启用复选框
函程 启用复选框(复选框句柄):
    _设置控件属性(复选框句柄, "启用", 真)
结束

// 禁用复选框
函程 禁用复选框(复选框句柄):
    _设置控件属性(复选框句柄, "启用", 假)
结束

// 销毁复选框
函程 销毁复选框(复选框句柄):
    _销毁原生控件(复选框句柄)
结束
