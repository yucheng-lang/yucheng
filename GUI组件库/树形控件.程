// ============================================================
// 语程 GUI 组件库 - 树形控件
// 提供树形列表创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 树形控件配置 =====

函程 树形控件(X = 0, Y = 0, 宽度 = 200, 高度 = 200, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "显示连线": 假,
        "显示按钮": 真,
        "显示根线": 假,
        "多选": 假,
        "可编辑": 假,
        "整行选中": 假,
        "自动展开": 假,
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建树形控件
函程 创建树形控件(配置):
    返回 _创建原生控件("树形控件", 配置)
结束

// ===== 节点操作 =====

// 添加根节点
函程 添加根节点(树形控件句柄, 文本):
    返回 _添加树形节点(树形控件句柄, 空, 文本)
结束

// 添加子节点
函程 添加子节点(树形控件句柄, 父节点句柄, 文本):
    返回 _添加树形节点(树形控件句柄, 父节点句柄, 文本)
结束

// 删除节点
函程 删除节点(树形控件句柄, 节点句柄):
    _删除树形节点(树形控件句柄, 节点句柄)
结束

// 清空所有节点
函程 清空树形(树形控件句柄):
    _清空树形节点(树形控件句柄)
结束

// 获取节点文本
函程 获取节点文本(树形控件句柄, 节点句柄):
    返回 _获取树形节点属性(树形控件句柄, 节点句柄, "文本")
结束

// 设置节点文本
函程 设置节点文本(树形控件句柄, 节点句柄, 文本):
    _设置树形节点属性(树形控件句柄, 节点句柄, "文本", 文本)
结束

// ===== 展开/折叠 =====

// 展开节点
函程 展开节点(树形控件句柄, 节点句柄):
    _设置树形节点属性(树形控件句柄, 节点句柄, "展开", 真)
结束

// 折叠节点
函程 折叠节点(树形控件句柄, 节点句柄):
    _设置树形节点属性(树形控件句柄, 节点句柄, "展开", 假)
结束

// 展开全部节点
函程 展开全部(树形控件句柄):
    _展开全部树形节点(树形控件句柄)
结束

// 折叠全部节点
函程 折叠全部(树形控件句柄):
    _折叠全部树形节点(树形控件句柄)
结束

// ===== 选中操作 =====

// 获取选中节点
函程 获取选中节点(树形控件句柄):
    返回 _获取控件属性(树形控件句柄, "选中节点")
结束

// 设置选中节点
函程 设置选中节点(树形控件句柄, 节点句柄):
    _设置控件属性(树形控件句柄, "选中节点", 节点句柄)
结束

// 显示/隐藏/销毁
函程 显示树形控件(树形控件句柄):
