// ============================================================
// 语程 GUI 组件库 - 工具提示
// 提供控件工具提示功能
// ============================================================

导入 "窗口组件"

// 为控件设置工具提示
函程 设置工具提示(控件句柄, 文本):
    _设置控件属性(控件句柄, "工具提示文本", 文本)
结束

// 获取控件工具提示
函程 获取工具提示(控件句柄):
    返回 _获取控件属性(控件句柄, "工具提示文本")
结束

// 设置工具提示延迟时间（毫秒）
函程 设置提示延迟(控件句柄, 延迟):
    _设置控件属性(控件句柄, "提示延迟", 延迟)
结束

// 设置工具提示最大宽度
函程 设置提示最大宽度(控件句柄, 宽度):
    _设置控件属性(控件句柄, "提示最大宽度", 宽度)
结束
