// 创建窗口配置
// 参数：标题、宽度、高度、X、Y 等
// 返回：窗口配置字典
函程 默认窗口配置():
    返回 {
        "标题": "",
        "宽度": 800,
        "高度": 600,
        "X": 0,
        "Y": 0,
        "居中": 真,
        "顶层": 假,
        "可调整大小": 真,
        "最小化按钮": 真,
        "最大化按钮": 真,
        "系统菜单": 真,
        "标题栏": 真,
        "可见": 真,
        "启用": 真,
        "最小宽度": 0,
        "最小高度": 0,
        "最大宽度": 0,
        "最大高度": 0,
        "边框": 真,
        "工具窗口": 假,
        "帮助按钮": 假,
        "水平滚动条": 假,
        "垂直滚动条": 假,
        "窗口动画": 真,
        "任务栏显示": 真,
        "背景色": "#FFFFFF"
    }
结束

// 快捷创建窗口配置
函程 窗口(标题, 宽度 = 800, 高度 = 600, 居中 = 真, 可调整大小 = 真):
    设 配置 = 默认窗口配置()
    配置.标题 = 标题
    配置.宽度 = 宽度
    配置.高度 = 高度
    配置.居中 = 居中
    配置.可调整大小 = 可调整大小
    返回 配置
结束

// ===== 窗口创建与管理 =====

// 创建窗口
// 参数：配置 - 窗口配置字典
// 返回：窗口句柄（字符串标识）
函程 创建窗口(配置):
    设 标题 = 取值(配置, "标题", "")
    设 宽度 = 取值(配置, "宽度", 800)
    设 高度 = 取值(配置, "高度", 600)
    设 居中 = 取值(配置, "居中", 真)
    设 背景色 = 取值(配置, "背景色", "#FFFFFF")

    // 调用底层GUI创建窗口
    设 句柄 = _创建原生窗口(标题, 宽度, 高度, 居中, 背景色)

    如果 居中:
        窗口居中(句柄)
    
    返回 句柄
结束

// 运行窗口消息循环
// 参数：窗口句柄
函程 运行界面(窗口句柄):
    _运行消息循环(窗口句柄)
结束

// 创建并运行窗口（快捷方式）
函程 运行窗口(配置):
    设 句柄 = 创建窗口(配置)
    运行界面(句柄)
结束

