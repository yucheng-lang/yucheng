// ===== 窗口样式常量 =====

常量 标题栏 = 0x00C00000
常量 系统菜单 = 0x00080000
常量 可调整大小 = 0x00040000
常量 最小化按钮 = 0x00020000
常量 最大化按钮 = 0x00010000
常量 边框 = 0x00800000
常量 帮助按钮 = 0x00008000
常量 水平滚动条 = 0x00100000
常量 垂直滚动条 = 0x00200000

// 窗口显示状态
常量 显示正常 = 1
常量 显示最小化 = 2
常量 显示最大化 = 3
常量 隐藏 = 0

// ===== 窗口事件常量 =====

常量 事件创建 = 0x0001
常量 事件销毁 = 0x0002
常量 事件移动 = 0x0003
常量 事件调整大小 = 0x0005
常量 事件激活 = 0x0006
常量 事件获得焦点 = 0x0007
常量 事件失去焦点 = 0x0008
常量 事件启用 = 0x000A
常量 事件显示 = 0x0018
常量 事件关闭 = 0x0010
常量 事件绘制 = 0x000F
常量 事件定时器 = 0x0113
常量 事件命令 = 0x0111

// 鼠标事件
常量 事件鼠标移动 = 0x0200
常量 事件左键按下 = 0x0201
常量 事件左键释放 = 0x0202
常量 事件左键双击 = 0x0203
常量 事件右键按下 = 0x0204
常量 事件右键释放 = 0x0205
常量 事件中键按下 = 0x0207
常量 事件中键释放 = 0x0208
常量 事件鼠标滚轮 = 0x020A

// 键盘事件
常量 事件键盘按下 = 0x0100
常量 事件键盘释放 = 0x0101
常量 事件字符输入 = 0x0102

// 按钮通知
常量 通知点击 = 0
常量 通知双击 = 5
常量 通知获得焦点 = 6
常量 通知失去焦点 = 7

