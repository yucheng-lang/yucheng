// ============================================================
// 语程 GUI 组件库 - 进度条
// 提供进度条创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 进度条配置 =====

函程 进度条(X = 0, Y = 0, 宽度 = 200, 高度 = 20, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "最小值": 0,
        "最大值": 100,
        "当前值": 0,
        "垂直": 假,
        "平滑": 真,
        "进度颜色": "",
        "背景颜色": ""
    }
结束

// 创建进度条
函程 创建进度条(配置):
    返回 _创建原生控件("进度条", 配置)
结束

// 设置进度条范围
函程 设置进度条范围(进度条句柄, 最小值, 最大值):
    _设置控件属性(进度条句柄, "最小值", 最小值)
    _设置控件属性(进度条句柄, "最大值", 最大值)
结束

// 设置进度条当前值
函程 设置进度条值(进度条句柄, 值):
    _设置控件属性(进度条句柄, "当前值", 值)
结束

// 获取进度条当前值
函程 获取进度条值(进度条句柄):
    返回 _获取控件属性(进度条句柄, "当前值")
结束

// 推进进度条（增加指定偏移量）
函程 推进进度条(进度条句柄, 偏移量):
    设 当前 = 获取进度条值(进度条句柄)
    设置进度条值(进度条句柄, 当前 + 偏移量)
结束

// 设置进度条进度颜色
函程 设置进度条颜色(进度条句柄, 颜色):
    _设置控件属性(进度条句柄, "进度颜色", 颜色)
结束

// 设置进度条背景颜色
函程 设置进度条背景色(进度条句柄, 颜色):
    _设置控件属性(进度条句柄, "背景颜色", 颜色)
结束

// 显示进度条
函程 显示进度条(进度条句柄):
    _设置控件属性(进度条句柄, "可见", 真)
结束

// 隐藏进度条
函程 隐藏进度条(进度条句柄):
    _设置控件属性(进度条句柄, "可见", 假)
结束

// 销毁进度条
函程 销毁进度条(进度条句柄):
    _销毁原生控件(进度条句柄)
结束
