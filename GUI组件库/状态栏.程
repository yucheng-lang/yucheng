// ============================================================
// 语程 GUI 组件库 - 状态栏
// 提供状态栏创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建状态栏
函程 创建状态栏(窗口句柄):
    返回 _创建原生状态栏(窗口句柄)
结束

// 设置状态栏文本
函程 设置状态栏文本(状态栏句柄, 文本, 面板索引 = 0):
    _设置状态栏面板文本(状态栏句柄, 面板索引, 文本)
结束

// 获取状态栏文本
函程 获取状态栏文本(状态栏句柄, 面板索引 = 0):
    返回 _获取状态栏面板文本(状态栏句柄, 面板索引)
结束

// 添加状态栏面板
函程 添加状态栏面板(状态栏句柄, 宽度 = 100):
    _添加状态栏面板(状态栏句柄, 宽度)
结束

// 设置状态栏面板宽度
函程 设置状态栏面板宽度(状态栏句柄, 面板索引, 宽度):
    _设置状态栏面板宽度(状态栏句柄, 面板索引, 宽度)
结束

// 显示/隐藏状态栏
函程 显示状态栏(状态栏句柄):
    _设置控件属性(状态栏句柄, "可见", 真)
结束

函程 隐藏状态栏(状态栏句柄):
    _设置控件属性(状态栏句柄, "可见", 假)
结束
