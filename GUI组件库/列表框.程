// ============================================================
// 语程 GUI 组件库 - 列表框
// 提供列表框创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 列表框配置 =====

函程 列表框(X = 0, Y = 0, 宽度 = 200, 高度 = 150, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "多选": 假,
        "排序列表": 假,
        "水平滚动条": 假,
        "垂直滚动条": 真,
        "项目列表": [],
        "选中索引": -1,
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建列表框
函程 创建列表框(配置):
    返回 _创建原生控件("列表框", 配置)
结束

// ===== 列表项操作 =====

// 添加列表项
函程 添加列表项(列表框句柄, 文本):
    _添加控件列表项(列表框句柄, 文本)
结束

// 插入列表项
函程 插入列表项(列表框句柄, 索引, 文本):
    _插入控件列表项(列表框句柄, 索引, 文本)
结束

// 删除列表项
函程 删除列表项(列表框句柄, 索引):
    _删除控件列表项(列表框句柄, 索引)
结束

// 清空列表
函程 清空列表(列表框句柄):
    _清空控件列表(列表框句柄)
结束

// 获取列表项数量
函程 获取列表项数(列表框句柄):
    返回 _获取控件属性(列表框句柄, "项目数")
结束

// 获取列表项文本
函程 获取列表项(列表框句柄, 索引):
    返回 _获取控件列表项(列表框句柄, 索引)
结束

// ===== 选中操作 =====

// 获取选中项索引
函程 获取选中索引(列表框句柄):
    返回 _获取控件属性(列表框句柄, "选中索引")
结束

// 设置选中项索引
函程 设置选中索引(列表框句柄, 索引):
    _设置控件属性(列表框句柄, "选中索引", 索引)
结束

// 获取选中项文本
函程 获取选中项(列表框句柄):
    设 索引 = 获取选中索引(列表框句柄)
    如果 索引 >= 0:
        返回 获取列表项(列表框句柄, 索引)
    否则:
        返回 ""
结束

// 查找列表项
函程 查找列表项(列表框句柄, 文本):
    返回 _查找控件列表项(列表框句柄, 文本)
结束

// 显示/隐藏/启用/禁用/销毁
函程 显示列表框(列表框句柄):
    _设置控件属性(列表框句柄, "可见", 真)
结束

函程 隐藏列表框(列表框句柄):
    _设置控件属性(列表框句柄, "可见", 假)
结束

函程 销毁列表框(列表框句柄):
    _销毁原生控件(列表框句柄)
结束
