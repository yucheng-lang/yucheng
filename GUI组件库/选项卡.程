// ============================================================
// 语程 GUI 组件库 - 选项卡
// 提供选项卡（标签页）创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 选项卡配置 =====

函程 选项卡(X = 0, Y = 0, 宽度 = 400, 高度 = 300, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "标签页列表": [],
        "当前页": 0,
        "标签在底部": 假,
        "多行标签": 假,
        "扁平风格": 假,
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建选项卡
函程 创建选项卡(配置):
    返回 _创建原生控件("选项卡", 配置)
结束

// ===== 标签页操作 =====

// 添加标签页
函程 添加标签页(选项卡句柄, 标题):
    _添加选项卡页(选项卡句柄, 标题)
结束

// 删除标签页
函程 删除标签页(选项卡句柄, 页索引):
    _删除选项卡页(选项卡句柄, 页索引)
结束

// 获取标签页数量
函程 获取标签页数(选项卡句柄):
    返回 _获取控件属性(选项卡句柄, "页数")
结束

// 获取当前标签页索引
函程 获取当前页(选项卡句柄):
    返回 _获取控件属性(选项卡句柄, "当前页")
结束

// 设置当前标签页
函程 设置当前页(选项卡句柄, 页索引):
    _设置控件属性(选项卡句柄, "当前页", 页索引)
结束

// 设置标签页标题
函程 设置标签页标题(选项卡句柄, 页索引, 标题):
    _设置选项卡页属性(选项卡句柄, 页索引, "标题", 标题)
结束

// 显示/隐藏/销毁
函程 显示选项卡(选项卡句柄):
    _设置控件属性(选项卡句柄, "可见", 真)
结束

函程 隐藏选项卡(选项卡句柄):
    _设置控件属性(选项卡句柄, "可见", 假)
结束

函程 销毁选项卡(选项卡句柄):
    _销毁原生控件(选项卡句柄)
结束
