// ============================================================
// 语程 GUI 组件库 - 编辑框
// 提供文本输入框创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 文本对齐常量 =====
常量 左对齐 = 0
常量 居中对齐 = 1
常量 右对齐 = 2

// ===== 编辑框配置 =====

// 创建编辑框配置
函程 编辑框(标题 = "", X = 0, Y = 0, 宽度 = 200, 高度 = 24, 父窗口 = 空, 标识符 = 0):
    返回 {
        "标题": 标题,
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "只读": 假,
        "多行": 假,
        "密码框": 假,
        "数字输入": 假,
        "大写": 假,
        "小写": 假,
        "水平滚动条": 假,
        "垂直滚动条": 假,
        "自动水平滚动": 假,
        "自动垂直滚动": 假,
        "文本对齐": 左对齐,
        "最大长度": 0,
        "密码字符": "*",
        "字体名称": "微软雅黑",
        "字体大小": 14,
        "字体粗细": 400,
        "字体颜色": "",
        "背景颜色": "",
        "边框样式": 0,
        "占位符文本": "",
        "Tab停止": 真,
        "工具提示": ""
    }
结束

// ===== 编辑框创建 =====

// 创建编辑框
函程 创建编辑框(配置):
    返回 _创建原生控件("编辑框", 配置)
结束

// ===== 编辑框文本操作 =====

// 获取编辑框文本
函程 获取编辑框文本(编辑框句柄):
    返回 _获取控件属性(编辑框句柄, "文本")
结束

// 设置编辑框文本
函程 设置编辑框文本(编辑框句柄, 文本):
    _设置控件属性(编辑框句柄, "文本", 文本)
结束

// 获取编辑框选中范围
// 返回: [起始位置, 结束位置]
函程 获取编辑框选中范围(编辑框句柄):
    返回 _获取控件属性(编辑框句柄, "选中范围")
结束

// 设置编辑框选中范围
函程 设置编辑框选中范围(编辑框句柄, 开始, 结束):
    _设置控件属性(编辑框句柄, "选中起始", 开始)
    _设置控件属性(编辑框句柄, "选中结束", 结束)
结束

// 选中全部文本
函程 全选编辑框(编辑框句柄):
    设 文本 = 获取编辑框文本(编辑框句柄)
    设置编辑框选中范围(编辑框句柄, 0, 字符串长度(文本))
结束

// 清空编辑框文本
函程 清空编辑框(编辑框句柄):
    设置编辑框文本(编辑框句柄, "")
结束

// ===== 多行编辑框 =====

// 获取编辑框行数
函程 获取编辑框行数(编辑框句柄):
    返回 _获取控件属性(编辑框句柄, "行数")
结束

// 获取编辑框指定行长度
函程 获取编辑框行长度(编辑框句柄, 行号):
    返回 _获取控件属性(编辑框句柄, "行长度")
结束

// ===== 编辑框状态 =====

// 设置编辑框只读
函程 设置编辑框只读(编辑框句柄, 只读):
    _设置控件属性(编辑框句柄, "只读", 只读)
结束

