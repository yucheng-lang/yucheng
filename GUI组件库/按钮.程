// ============================================================
// 语程 GUI 组件库 - 按钮
// 提供按钮创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 按钮类型常量 =====

常量 普通按钮 = 0
常量 默认按钮 = 1
常量 复选框按钮 = 2
常量 自动复选框 = 3
常量 单选按钮类型 = 4
常量 三态复选框 = 5
常量 自动三态复选框 = 6
常量 分组框按钮 = 7
常量 自绘按钮 = 11

// ===== 文本对齐常量 =====
常量 左对齐 = 0
常量 居中对齐 = 1
常量 右对齐 = 2
常量 顶部对齐 = 0
常量 垂直居中 = 2
常量 底部对齐 = 1

// ===== 按钮配置 =====

// 创建按钮配置
函程 按钮(文本, X = 0, Y = 0, 宽度 = 100, 高度 = 30, 父窗口 = 空, 标识符 = 0):
    返回 {
        "文本": 文本,
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "按钮类型": 普通按钮,
        "多行文本": 假,
        "扁平风格": 假,
        "文字对齐": 居中对齐,
        "垂直对齐": 垂直居中,
        "文字在左侧": 假,
        "分组": 假,
        "分组编号": 0,
        "初始选中": 假,
        "文字颜色": "",
        "背景颜色": "",
        "工具提示文本": "",
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// ===== 按钮创建 =====

// 创建按钮
函程 创建按钮(配置):
    返回 _创建原生控件("按钮", 配置)
结束

// ===== 按钮操作 =====

// 设置按钮文本
函程 设置按钮文本(按钮句柄, 文本):
    _设置控件属性(按钮句柄, "文本", 文本)
结束

// 获取按钮文本
函程 获取按钮文本(按钮句柄):
    返回 _获取控件属性(按钮句柄, "文本")
结束

// 设置按钮位置
函程 设置按钮位置(按钮句柄, X, Y):
    _设置控件属性(按钮句柄, "X", X)
    _设置控件属性(按钮句柄, "Y", Y)
结束

// 设置按钮大小
函程 设置按钮大小(按钮句柄, 宽度, 高度):
    _设置控件属性(按钮句柄, "宽度", 宽度)
    _设置控件属性(按钮句柄, "高度", 高度)
结束

// 设置按钮位置和大小
函程 设置按钮位置和大小(按钮句柄, X, Y, 宽度, 高度):
    设置按钮位置(按钮句柄, X, Y)
    设置按钮大小(按钮句柄, 宽度, 高度)
结束

// 显示按钮
函程 显示按钮(按钮句柄):
    _设置控件属性(按钮句柄, "可见", 真)
结束

// 隐藏按钮
函程 隐藏按钮(按钮句柄):
    _设置控件属性(按钮句柄, "可见", 假)
结束

// 启用按钮
函程 启用按钮(按钮句柄):
    _设置控件属性(按钮句柄, "启用", 真)
结束

// 禁用按钮
函程 禁用按钮(按钮句柄):
    _设置控件属性(按钮句柄, "启用", 假)
结束

// 设置按钮焦点
函程 设置按钮焦点(按钮句柄):
    _设置控件焦点(按钮句柄)
结束

// 模拟点击按钮
函程 点击按钮(按钮句柄):
