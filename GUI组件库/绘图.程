// ===== 颜色工具函数 =====

// 通过 RGB 值创建颜色字符串
函程 RGB(红, 绿, 蓝):
    设 红值 = 转十六进制(绝对值(红 % 256))
    设 绿值 = 转十六进制(绝对值(绿 % 256))
    设 蓝值 = 转十六进制(绝对值(蓝 % 256))
    如果 字符串长度(红值) == 1:
        红值 = "0" + 红值
    如果 字符串长度(绿值) == 1:
        绿值 = "0" + 绿值
    如果 字符串长度(蓝值) == 1:
        蓝值 = "0" + 蓝值
    返回 "#" + 红值 + 绿值 + 蓝值
结束

