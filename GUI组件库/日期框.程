// ============================================================
// 语程 GUI 组件库 - 日期框
// 提供日期选择器创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建日期框配置
函程 日期框(X = 0, Y = 0, 宽度 = 150, 高度 = 24, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "格式": "YYYY-MM-DD",
        "日期": "",
        "最小日期": "",
        "最大日期": "",
        "显示下拉": 真,
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建日期框
函程 创建日期框(配置):
    返回 _创建原生控件("日期框", 配置)
结束

// 获取日期
函程 获取日期(日期框句柄):
    返回 _获取控件属性(日期框句柄, "日期")
结束

// 设置日期
函程 设置日期(日期框句柄, 日期):
    _设置控件属性(日期框句柄, "日期", 日期)
结束

// 设置日期范围
函程 设置日期范围(日期框句柄, 最小日期, 最大日期):
    _设置控件属性(日期框句柄, "最小日期", 最小日期)
    _设置控件属性(日期框句柄, "最大日期", 最大日期)
结束

// 获取当前日期（今天）
函程 获取今天():
    返回 当前日期()
结束

// 显示/隐藏/销毁
函程 显示日期框(日期框句柄):
    _设置控件属性(日期框句柄, "可见", 真)
结束

函程 隐藏日期框(日期框句柄):
    _设置控件属性(日期框句柄, "可见", 假)
结束

函程 销毁日期框(日期框句柄):
    _销毁原生控件(日期框句柄)
结束
