// ============================================================
// 语程 GUI 组件库 - 文件选择对话框
// 提供文件打开/保存对话框功能
// ============================================================

导入 "窗口组件"

// 打开文件选择对话框
// 参数：父窗口, 标题, 初始目录, 过滤器
// 过滤器格式：[["文本文件", "*.txt"], ["所有文件", "*.*"]]
// 返回：选中文件路径，取消返回空字符串
函程 选择文件(父窗口 = 空, 标题 = "打开文件", 初始目录 = "", 过滤器 = []):
    返回 _打开文件选择对话框(父窗口, 标题, 初始目录, 过滤器, 假)
结束

// 打开多文件选择对话框
// 返回：选中文件路径列表
函程 选择多个文件(父窗口 = 空, 标题 = "打开文件", 初始目录 = "", 过滤器 = []):
    返回 _打开文件选择对话框(父窗口, 标题, 初始目录, 过滤器, 真)
结束

// 保存文件选择对话框
// 返回：选中保存路径，取消返回空字符串
函程 选择保存文件(父窗口 = 空, 标题 = "保存文件", 初始目录 = "", 默认文件名 = "", 过滤器 = []):
    返回 _打开保存文件对话框(父窗口, 标题, 初始目录, 默认文件名, 过滤器)
结束

// 常用文件过滤器
函程 文本文件过滤器():
    返回 [["文本文件", "*.txt"], ["所有文件", "*.*"]]
结束

函程 图片文件过滤器():
    返回 [["图片文件", "*.png;*.jpg;*.jpeg;*.bmp;*.gif"], ["所有文件", "*.*"]]
结束

函程 所有文件过滤器():
    返回 [["所有文件", "*.*"]]
结束
