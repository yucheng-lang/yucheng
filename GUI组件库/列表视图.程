// ============================================================
// 语程 GUI 组件库 - 列表视图
// 提供多列列表视图创建与操作功能
// ============================================================

导入 "窗口组件"

// 列表视图样式
常量 图标视图 = 0
常量 小图标视图 = 1
常量 列表视图 = 2
常量 报表视图 = 3

// ===== 列表视图配置 =====

函程 列表视图(X = 0, Y = 0, 宽度 = 400, 高度 = 200, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "视图模式": 报表视图,
        "多选": 假,
        "显示网格线": 假,
        "整行选中": 真,
        "列标题": [],
        "列宽度": [],
        "数据行": [],
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建列表视图
函程 创建列表视图(配置):
    返回 _创建原生控件("列表视图", 配置)
结束

// ===== 列操作 =====

// 添加列
函程 添加列(列表视图句柄, 列标题, 列宽度 = 100):
    _添加视图列(列表视图句柄, 列标题, 列宽度)
结束

// 设置列标题
函程 设置列标题(列表视图句柄, 列索引, 标题):
    _设置视图列属性(列表视图句柄, 列索引, "标题", 标题)
结束

// 设置列宽度
函程 设置列宽度(列表视图句柄, 列索引, 宽度):
    _设置视图列属性(列表视图句柄, 列索引, "宽度", 宽度)
结束

// ===== 行操作 =====

// 添加行
函程 添加行(列表视图句柄, 行数据):
    _添加视图行(列表视图句柄, 行数据)
结束

// 删除行
函程 删除行(列表视图句柄, 行索引):
    _删除视图行(列表视图句柄, 行索引)
结束

// 清空所有行
函程 清空行(列表视图句柄):
    _清空视图行(列表视图句柄)
结束

// 获取行数
函程 获取行数(列表视图句柄):
    返回 _获取控件属性(列表视图句柄, "行数")
结束

// 设置单元格文本
函程 设置单元格(列表视图句柄, 行索引, 列索引, 文本):
    _设置视图单元格(列表视图句柄, 行索引, 列索引, 文本)
结束

// 获取单元格文本
函程 获取单元格(列表视图句柄, 行索引, 列索引):
    返回 _获取视图单元格(列表视图句柄, 行索引, 列索引)
结束

// ===== 选中操作 =====

// 获取选中行索引
函程 获取选中行(列表视图句柄):
    返回 _获取控件属性(列表视图句柄, "选中行")
结束

// 设置选中行
函程 设置选中行(列表视图句柄, 行索引):
    _设置控件属性(列表视图句柄, "选中行", 行索引)
结束

// 显示/隐藏/销毁
函程 显示列表视图(列表视图句柄):
    _设置控件属性(列表视图句柄, "可见", 真)
结束

函程 隐藏列表视图(列表视图句柄):
    _设置控件属性(列表视图句柄, "可见", 假)
结束

函程 销毁列表视图(列表视图句柄):
    _销毁原生控件(列表视图句柄)
结束
