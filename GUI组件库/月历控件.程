// ============================================================
// 语程 GUI 组件库 - 月历控件
// 提供月历创建与操作功能
// ============================================================

导入 "窗口组件"

// 创建月历控件配置
函程 月历控件(X = 0, Y = 0, 宽度 = 230, 高度 = 180, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "选中日期": "",
        "今日高亮": 真,
        "显示周数": 假,
        "多选": 假,
        "选择范围": 0,
        "字体名称": "微软雅黑",
        "字体大小": 12
    }
结束

// 创建月历控件
函程 创建月历控件(配置):
    返回 _创建原生控件("月历控件", 配置)
结束

// 获取选中日期
函程 获取月历选中日期(月历句柄):
    返回 _获取控件属性(月历句柄, "选中日期")
结束

// 设置选中日期
函程 设置月历选中日期(月历句柄, 日期):
    _设置控件属性(月历句柄, "选中日期", 日期)
结束

// 设置月历日期范围
函程 设置月历日期范围(月历句柄, 最小日期, 最大日期):
    _设置控件属性(月历句柄, "最小日期", 最小日期)
    _设置控件属性(月历句柄, "最大日期", 最大日期)
结束

// 显示/隐藏/销毁
函程 显示月历控件(月历句柄):
    _设置控件属性(月历句柄, "可见", 真)
结束

函程 隐藏月历控件(月历句柄):
    _设置控件属性(月历句柄, "可见", 假)
结束

函程 销毁月历控件(月历句柄):
    _销毁原生控件(月历句柄)
结束
