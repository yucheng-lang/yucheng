// ============================================================
// 语程 GUI 组件库 - 分组框
// 提供分组框创建与操作功能
// ============================================================

导入 "窗口组件"

// ===== 分组框配置 =====

函程 分组框(文本 = "", X = 0, Y = 0, 宽度 = 200, 高度 = 150, 父窗口 = 空, 标识符 = 0):
    返回 {
        "文本": 文本,
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "圆角": 假,
        "边框颜色": "",
        "背景颜色": "",
        "字体名称": "微软雅黑",
        "字体大小": 14
    }
结束

// 创建分组框
函程 创建分组框(配置):
    返回 _创建原生控件("分组框", 配置)
结束

// 设置分组框文本
函程 设置分组框文本(分组框句柄, 文本):
    _设置控件属性(分组框句柄, "文本", 文本)
结束

// 获取分组框文本
函程 获取分组框文本(分组框句柄):
    返回 _获取控件属性(分组框句柄, "文本")
结束

// 显示/隐藏/销毁
函程 显示分组框(分组框句柄):
    _设置控件属性(分组框句柄, "可见", 真)
结束

函程 隐藏分组框(分组框句柄):
    _设置控件属性(分组框句柄, "可见", 假)
结束

函程 销毁分组框(分组框句柄):
    _销毁原生控件(分组框句柄)
结束
