// ============================================================
// 语程 GUI 组件库 - 颜色选择器
// 提供颜色选择对话框功能
// ============================================================

导入 "窗口组件"

// ===== 颜色常量 =====
常量 黑色 = "#000000"
常量 白色 = "#FFFFFF"
常量 红色 = "#FF0000"
常量 绿色 = "#00FF00"
常量 蓝色 = "#0000FF"

// 打开颜色选择对话框
// 返回: 选中颜色的十六进制字符串，取消返回空字符串
函程 选择颜色(父窗口 = 空, 默认颜色 = 黑色):
    返回 _打开颜色选择对话框(父窗口, 默认颜色)
结束

// 创建颜色选择器控件（内嵌在窗口中）
函程 颜色选择器(X = 0, Y = 0, 宽度 = 200, 高度 = 200, 父窗口 = 空, 标识符 = 0):
    返回 {
        "X": X,
        "Y": Y,
        "宽度": 宽度,
        "高度": 高度,
        "父窗口": 父窗口,
        "标识符": 标识符,
        "可见": 真,
        "启用": 真,
        "当前颜色": 黑色,
        "显示透明度": 假,
        "透明度": 1.0
    }
结束

// 创建颜色选择器控件
函程 创建颜色选择器(配置):
    返回 _创建原生控件("颜色选择器", 配置)
结束

// 获取选中颜色
函程 获取选中颜色(颜色选择器句柄):
    返回 _获取控件属性(颜色选择器句柄, "当前颜色")
结束

// 设置选中颜色
函程 设置选中颜色(颜色选择器句柄, 颜色):
    _设置控件属性(颜色选择器句柄, "当前颜色", 颜色)
结束

// 销毁颜色选择器
函程 销毁颜色选择器(颜色选择器句柄):
    _销毁原生控件(颜色选择器句柄)
结束
