// 异步 - Promise/Future 异步编程模式
// 语程对象按值传递，且嵌套函数的 assign_back 只写当前作用域。
// 因此采用「返回修改后对象」模式，不使用回调/闭包。
// 语程是同步单线程语言，异步模式仅为代码组织方式。

// === Promise（期约）===

函程 创建期约(): // 公开
    返回 {
        状态: "等待中",
        值: 空,
        错误: 空
    }

函程 兑现期约(期约, 值): // 公开
    期约.状态 = "已兑现"
    期约.值 = 值
    返回 期约

函程 拒绝期约(期约, 错误): // 公开
    期约.状态 = "已拒绝"
    期约.错误 = 错误
    返回 期约

// === Promise 静态方法 ===

函程 期约已兑现(值): // 公开
    返回 {
        状态: "已兑现",
        值: 值,
        错误: 空
    }

函程 期约已拒绝(错误): // 公开
    返回 {
        状态: "已拒绝",
        值: 空,
        错误: 错误
    }

函程 全部兑现(期约列表): // 公开
    设 结果 = []
    遍 项 于 期约列表:
        如果 项.状态 == "已拒绝":
            返回 期约已拒绝(项.错误)
        如果 项.状态 != "已兑现":
            返回 期约已拒绝("存在未完成的期约")
        结果 = 追加(结果, 项.值)
    返回 期约已兑现(结果)

函程 任一兑现(期约列表): // 公开
    遍 项 于 期约列表:
        如果 项.状态 == "已兑现":
            返回 项
    遍 项 于 期约列表:
        如果 项.状态 == "已拒绝":
            返回 项
    返回 期约已拒绝("所有期约均未完成")

函程 是已兑现(期约): // 公开
    返回 期约.状态 == "已兑现"

函程 是已拒绝(期约): // 公开
    返回 期约.状态 == "已拒绝"

函程 是等待中(期约): // 公开
    返回 期约.状态 == "等待中"

函程 获取期约值(期约): // 公开
    如果 期约.状态 == "已兑现":
        返回 期约.值
    否则 如果 期约.状态 == "已拒绝":
        抛出 期约.错误
    否则:
        抛出 "期约仍在等待中"

// === Future（期值）===

函程 创建期值(来源): // 公开
    返回 {
        状态: "等待中",
        值: 空,
        错误: 空,
        来源: 来源
    }

函程 完成期值(期值, 值): // 公开
    如果 期值.状态 != "等待中":
        抛出 "期值已完成，不能重复完成"
    期值.状态 = "已完成"
    期值.值 = 值
    返回 期值

函程 失败期值(期值, 错误): // 公开
    如果 期值.状态 != "等待中":
        抛出 "期值已完成，不能重复失败"
    期值.状态 = "已失败"
    期值.错误 = 错误
    返回 期值

函程 读取期值(期值): // 公开
    如果 期值.状态 == "已完成":
        返回 期值.值
    否则 如果 期值.状态 == "已失败":
        抛出 期值.错误
    否则:
        抛出 "期值仍在进行中"

函程 是期值已完成(期值): // 公开
    返回 期值.状态 == "已完成"

函程 是期值已失败(期值): // 公开
    返回 期值.状态 == "已失败"

函程 是期值等待中(期值): // 公开
    返回 期值.状态 == "等待中"

// === 异步执行器 ===

函程 异步执行(函数): // 公开
    设 期值 = 创建期值("异步执行")
    尝试:
        设 结果 = 函数()
        期值 = 完成期值(期值, 结果)
    捕获 错误:
        期值 = 失败期值(期值, 错误)
    返回 期值

// === 异步管道 ===

函程 创建管道(): // 公开
    返回 {
        步骤: [],
        当前值: 空,
        错误: 空,
        状态: "等待中"
    }

函程 管道添加(管道, 函数): // 公开
    设 新步骤 = 追加(管道.步骤, 函数)
    管道.步骤 = 新步骤
    返回 管道

函程 管道执行(管道, 初始值): // 公开
    设 当前 = 初始值
    遍 步骤 于 管道.步骤:
        尝试:
            当前 = 步骤(当前)
        捕获 错误:
            管道.错误 = 错误
            管道.状态 = "已失败"
            返回 管道
    管道.当前值 = 当前
    管道.状态 = "已完成"
    返回 管道

// === 超时控制 ===

函程 创建超时(毫秒): // 公开
    返回 {
        超时时间: 毫秒,
        开始时间: 系统时间(),
        已超时: 假
    }

函程 检查超时(超时对象): // 公开
    设 已过 = 系统时间() - 超时对象.开始时间
    如果 已过 >= 超时对象.超时时间:
        超时对象.已超时 = 真
    返回 超时对象.已超时

// === 重试机制 ===

函程 创建重试器(函数, 最大次数, 间隔): // 公开
    返回 {
        函数: 函数,
        最大次数: 最大次数,
        间隔: 间隔,
        当前次数: 0,
        最后错误: 空
    }

函程 执行重试(重试器): // 公开
    循环 重试器.当前次数 < 重试器.最大次数:
        尝试:
            设 结果 = 重试器.函数()
            重试器.当前次数 = 重试器.当前次数 + 1
            返回 {重试器: 重试器, 结果: 结果, 错误: 空}
        捕获 错误:
            重试器.当前次数 = 重试器.当前次数 + 1
            重试器.最后错误 = 错误
    返回 {重试器: 重试器, 结果: 空, 错误: 重试器.最后错误}
