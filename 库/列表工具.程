// ===== 语程标准库：列表工具 =====
// 提供列表操作常用函数
//
// 公开接口：求和、平均值、最大项、最小项、反转列表、
//           包含、移除、去重、连接、截取、映射、过滤、归约

函程 求和(列表): // 公开
    设 总 = 0
    遍 项 于 列表:
        总 = 总 + 项
    返回 总

函程 平均值(列表): // 公开
    如果 数组长度(列表) == 0:
        返回 0
    返回 求和(列表) / 数组长度(列表)

函程 最大项(列表): // 公开
    如果 数组长度(列表) == 0:
        返回 0
    设 最大 = 列表[0]
    遍 项 于 列表:
        如果 项 > 最大:
            最大 = 项
    返回 最大

函程 最小项(列表): // 公开
    如果 数组长度(列表) == 0:
        返回 0
    设 最小 = 列表[0]
    遍 项 于 列表:
        如果 项 < 最小:
            最小 = 项
    返回 最小

函程 反转列表(列表): // 公开
    设 结果 = []
    设 i = 数组长度(列表) - 1
    循环 i >= 0:
        结果.添加(列表[i])
        i = i - 1
    返回 结果

函程 包含(列表, 目标): // 公开
    遍 项 于 列表:
        如果 项 == 目标:
            返回 真
    返回 假

函程 移除(列表, 目标): // 公开
    设 结果 = []
    设 已移除 = 假
    遍 项 于 列表:
        如果 项 == 目标 且 非 已移除:
            已移除 = 真
        否则:
            结果.添加(项)
    返回 结果

函程 去重(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        如果 非 包含(结果, 项):
            结果.添加(项)
    返回 结果

函程 连接(列表, 分隔符): // 公开
    如果 数组长度(列表) == 0:
        返回 ""
    设 结果 = 转字符串(列表[0])
    设 i = 1
    循环 i < 数组长度(列表):
        结果 = 结果 + 分隔符 + 转字符串(列表[i])
        i = i + 1
    返回 结果

函程 截取(列表, 起始, 终止): // 公开
    设 结果 = []
    设 i = 起始
    循环 i < 终止 且 i < 数组长度(列表):
        结果.添加(列表[i])
        i = i + 1
    返回 结果

函程 映射(列表, 函): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(函(项))
    返回 结果

函程 过滤(列表, 条件函): // 公开
    设 结果 = []
    遍 项 于 列表:
        如果 条件函(项):
            结果.添加(项)
    返回 结果

函程 归约(列表, 函, 初始值): // 公开
    设 累积 = 初始值
    遍 项 于 列表:
        累积 = 函(累积, 项)
    返回 累积
