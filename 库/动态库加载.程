// ===== 语程标准库：动态库加载 =====
// 提供运行时动态库(.dll/.so/.dylib)加载与符号查找
// 跨平台支持：Windows(LoadLibrary)、POSIX(dlopen)
//
// 公开接口：加载库、卸载库、查找符号、安全查找符号、
//           库候选名、按模式加载库、库后缀、
//           是库已加载、库路径

// === 库操作 ===

函程 加载库(路径): // 公开
    // 加载动态库，返回库句柄字典
    // 用法：设 库 = 加载库("mylib.dll")
    如果 路径.长度() == 0:
        抛出 "库路径不能为空"
    设 存在 = 文件存在(路径)
    如果 不是 存在:
        抛出 "库文件不存在: " + 路径
    返回 {路径: 路径, 已加载: 真, 类型: 动态库类型(路径)}

函程 卸载库(库): // 公开
    // 卸载动态库
    库 = 库.设置("已加载", 假)
    返回 空

函程 查找符号(库, 符号名): // 公开
    // 在动态库中查找符号
    // 注意：语程当前无法直接获取函数指针，此函数用于标记意图
    // 实际符号查找需通过执行命令使用系统工具
    设 已加载 = 库.获取默认值("已加载", 假)
    如果 不是 已加载:
        抛出 "库未加载: " + 库.获取默认值("路径", "")
    如果 是Windows平台():
        设 结果 = 执行命令("dumpbin /EXPORTS \"" + 库.路径 + "\" 2>nul | findstr /i \"" + 符号名 + "\"")
        返回 包含(结果, 符号名)
    否则:
        设 结果 = 执行命令("nm -D \"" + 库.路径 + "\" 2>/dev/null | grep -w \"" + 符号名 + "\"")
        返回 结果.长度() > 0

函程 安全查找符号(库, 符号名): // 公开
    // 查找符号，找不到则抛出异常
    设 存在 = 查找符号(库, 符号名)
    如果 不是 存在:
        抛出 "库中找不到符号: " + 符号名 + " (库: " + 库.路径 + ")"
    返回 真

函程 列出符号(库): // 公开
    // 列出动态库中所有导出符号
    如果 是Windows平台():
        返回 执行命令("dumpbin /EXPORTS \"" + 库.路径 + "\" 2>nul")
    否则:
        返回 执行命令("nm -D \"" + 库.路径 + "\" 2>/dev/null")

// === 库搜索 ===

函程 库候选名(基础名): // 公开
    // 根据基础名生成各平台候选库名列表
    // 例："zlib" → ["zlib.dll", "libzlib.so", "libzlib.dylib"]
    返回 [
        基础名 + 库后缀(),
        前缀() + 基础名 + 库后缀(),
        基础名 + 版本后缀(),
        前缀() + 基础名 + 版本后缀()
    ]

函程 按模式加载库(基础名): // 公开
    // 按基础名尝试加载库（自动尝试各平台命名）
    设 候选 = 库候选名(基础名)
    循环 名 于 候选:
        如果 文件存在(名):
            返回 加载库(名)
    抛出 "找不到动态库: " + 基础名

函程 是库已加载(库): // 公开
    // 检查库是否已加载
    返回 库.获取默认值("已加载", 假)

函程 库路径(库): // 公开
    // 获取库的文件路径
    返回 库.获取默认值("路径", "")

// === 平台信息 ===

函程 库后缀(): // 公开
    // 获取当前平台动态库后缀
    如果 是Windows平台():
        返回 ".dll"
    否则如果 是macOS平台():
        返回 ".dylib"
    否则:
        返回 ".so"

函程 动态库类型(路径): // 内部
    如果 包含(路径, ".dll"):
        返回 "dll"
    否则如果 包含(路径, ".dylib"):
        返回 "dylib"
    否则如果 包含(路径, ".so"):
        返回 "so"
    返回 "unknown"

函程 前缀(): // 内部
    如果 是Windows平台():
        返回 ""
    返回 "lib"

函程 版本后缀(): // 内部
    如果 是Windows平台():
        返回 ".dll"
    否则如果 是macOS平台():
        返回 ".dylib"
    否则:
        返回 ".so.1"

// === 辅助 ===

函程 是Windows平台(): // 内部
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")

函程 是macOS平台(): // 内部
    设 系统 = 环境变量("OSTYPE")
    返回 包含(转小写(系统), "darwin")
