// 序列化库 - 数据序列化与反序列化
// 提供将数据结构转换为文本格式和从文本还原的功能

// 公开接口：序列化、反序列化、转义字符串、反转义字符串

函程 转义字符串(文本): // 公开
    // 将字符串中的特殊字符转义
    设 结果 = ""
    设 i = 0
    循环 i < 长度(文本):
        设 字符 = 文本[i]
        如果 字符 == '"':
            结果 = 结果 + "\\\""
        否则如果 字符 == '\\':
            结果 = 结果 + "\\\\"
        否则如果 字符 == '\n':
            结果 = 结果 + "\\n"
        否则如果 字符 == '\r':
            结果 = 结果 + "\\r"
        否则如果 字符 == '\t':
            结果 = 结果 + "\\t"
        否则:
            结果 = 结果 + 字符
        i = i + 1
    返回 结果

函程 反转义字符串(文本): // 公开
    // 将转义字符还原
    设 结果 = ""
    设 i = 0
    循环 i < 长度(文本):
        如果 文本[i] == '\\' 且 i + 1 < 长度(文本):
            设 下一个 = 文本[i+1]
            如果 下一个 == '"':
                结果 = 结果 + '"'
            否则如果 下一个 == '\\':
                结果 = 结果 + '\\'
            否则如果 下一个 == 'n':
                结果 = 结果 + "\n"
            否则如果 下一个 == 'r':
                结果 = 结果 + "\r"
            否则如果 下一个 == 't':
                结果 = 结果 + "\t"
            否则:
                结果 = 结果 + 下一个
            i = i + 2
        否则:
            结果 = 结果 + 文本[i]
            i = i + 1
    返回 结果

函程 序列化(值, 缩进 = 0, 当前缩进 = 0): // 公开
    // 将值序列化为可读的文本格式
    // 缩进大于0时使用格式化输出
    
    如果 值 == 空:
        返回 "空"
    
    如果 是逻辑值(值):
        如果 值:
            返回 "真"
        否则:
            返回 "假"
    
    如果 是整数(值):
        返回 转文本(值)
    
    如果 是浮点数(值):
        返回 转文本(值)
    
    如果 是字符串(值):
        返回 "\"" + 转义字符串(值) + "\""
    
    如果 是列表(值):
        如果 长度(值) == 0:
            返回 "[]"
        设 结果 = "["
        设 下一缩进 = 当前缩进 + 缩进
        设 i = 0
        循环 i < 长度(值):
            如果 缩进 > 0:
                结果 = 结果 + "\n" + 重复(" ", 下一缩进)
            否则如果 i > 0:
                结果 = 结果 + " "
            结果 = 结果 + 序列化(值[i], 缩进, 下一缩进)
            如果 i < 长度(值) - 1:
                结果 = 结果 + ","
            i = i + 1
        如果 缩进 > 0:
            结果 = 结果 + "\n" + 重复(" ", 当前缩进)
        结果 = 结果 + "]"
        返回 结果
    
    如果 是字典(值):
        设 键列表 = 值.键
        如果 长度(键列表) == 0:
            返回 "{}"
        设 结果 = "{"
        设 下一缩进 = 当前缩进 + 缩进
        设 i = 0
        循环 i < 长度(键列表):
            设 键 = 键列表[i]
            如果 缩进 > 0:
                结果 = 结果 + "\n" + 重复(" ", 下一缩进)
            否则如果 i > 0:
                结果 = 结果 + " "
            结果 = 结果 + "\"" + 转义字符串(键) + "\": " + 序列化(取值(值, 键, 空), 缩进, 下一缩进)
            如果 i < 长度(键列表) - 1:
                结果 = 结果 + ","
            i = i + 1
        如果 缩进 > 0:
            结果 = 结果 + "\n" + 重复(" ", 当前缩进)
        结果 = 结果 + "}"
        返回 结果
    
    返回 转文本(值)

// === 反序列化 ===
// 由于语程是值传递，不能用列表模拟可变引用
// 改用返回 [值, 新位置] 的方式传递解析位置

函程 内跳过空白(文本, 位置): // 内部
    // 跳过空白字符，返回新位置
    设 位置2 = 位置
    循环 位置2 < 长度(文本):
        设 字符 = 文本[位置2]
        如果 字符 == ' ' 或 字符 == '\n' 或 字符 == '\r' 或 字符 == '\t':
            位置2 = 位置2 + 1
        否则:
            跳出
    返回 位置2

函程 内解析数字(文本, 位置): // 内部
    // 解析数字，返回 [值, 新位置]
    设 位置2 = 位置
    设 符号 = 1
    如果 位置2 < 长度(文本) 且 文本[位置2] == '-':
        符号 = -1
        位置2 = 位置2 + 1
    否则如果 位置2 < 长度(文本) 且 文本[位置2] == '+':
        位置2 = 位置2 + 1
    设 整数值 = 0
    设 小数值 = 0
    设 小数位数 = 0
    设 有小数 = 假
    设 找到数字 = 假
    循环 位置2 < 长度(文本):
        设 字符 = 文本[位置2]
        设 编码 = 字符编码(字符)
        如果 编码 >= 48 且 编码 <= 57:
            如果 有小数:
                小数值 = 小数值 * 10 + (编码 - 48)
                小数位数 = 小数位数 + 1
            否则:
                整数值 = 整数值 * 10 + (编码 - 48)
            找到数字 = 真
        否则如果 字符 == '.' 且 非 有小数:
            有小数 = 真
        否则:
            跳出
        位置2 = 位置2 + 1
    如果 非 找到数字:
        返回 [0, 位置2]
    如果 有小数:
        返回 [(整数值 + 小数值 / 幂(10, 小数位数)) * 符号, 位置2]
    否则:
        返回 [整数值 * 符号, 位置2]

函程 内解析字符串(文本, 位置): // 内部
    // 解析字符串值，返回 [值, 新位置]
    设 位置2 = 位置 + 1  // 跳过开始引号
    设 结果 = ""
    循环 位置2 < 长度(文本):
        设 字符 = 文本[位置2]
        如果 字符 == '"':
            位置2 = 位置2 + 1
            返回 [结果, 位置2]
        如果 字符 == '\\' 且 位置2 + 1 < 长度(文本):
            位置2 = 位置2 + 1
            设 转义字符 = 文本[位置2]
            如果 转义字符 == 'n':
                结果 = 结果 + "\n"
            否则如果 转义字符 == 'r':
                结果 = 结果 + "\r"
            否则如果 转义字符 == 't':
                结果 = 结果 + "\t"
            否则:
                结果 = 结果 + 转义字符
        否则:
            结果 = 结果 + 字符
        位置2 = 位置2 + 1
    返回 [结果, 位置2]

函程 内解析值(文本, 位置): // 内部
    // 解析一个值，返回 [值, 新位置]
    设 位置2 = 内跳过空白(文本, 位置)
    如果 位置2 >= 长度(文本):
        返回 [空, 位置2]
    设 字符 = 文本[位置2]
    // 解析字符串
    如果 字符 == '"':
        返回 内解析字符串(文本, 位置2)
    // 解析列表
    如果 字符 == '[':
        返回 内解析列表(文本, 位置2)
    // 解析字典
    如果 字符 == '{':
        返回 内解析字典(文本, 位置2)
    // 解析关键字（空、真、假）
    如果 字符 == '空':
        返回 [空, 位置2 + 1]
    如果 字符 == '真':
        返回 [真, 位置2 + 1]
    如果 字符 == '假':
        返回 [假, 位置2 + 1]
    // 解析数字
    返回 内解析数字(文本, 位置2)

函程 内解析列表(文本, 位置): // 内部
    // 解析列表值，返回 [值, 新位置]
    设 位置2 = 位置 + 1  // 跳过 [
    设 结果 = []
    位置2 = 内跳过空白(文本, 位置2)
    如果 位置2 < 长度(文本) 且 文本[位置2] == ']':
        返回 [结果, 位置2 + 1]
    循环 真:
        位置2 = 内跳过空白(文本, 位置2)
        设 解析 = 内解析值(文本, 位置2)
        设 元素 = 解析[0]
        位置2 = 解析[1]
        结果.添加(元素)
        位置2 = 内跳过空白(文本, 位置2)
        如果 位置2 >= 长度(文本):
            跳出
        如果 文本[位置2] == ',':
            位置2 = 位置2 + 1
        否则如果 文本[位置2] == ']':
            位置2 = 位置2 + 1
            跳出
    返回 [结果, 位置2]

函程 内解析字典(文本, 位置): // 内部
    // 解析字典值，返回 [值, 新位置]
    设 位置2 = 位置 + 1  // 跳过 {
    设 结果 = {}
    位置2 = 内跳过空白(文本, 位置2)
    如果 位置2 < 长度(文本) 且 文本[位置2] == '}':
        返回 [结果, 位置2 + 1]
    循环 真:
        位置2 = 内跳过空白(文本, 位置2)
        设 键解析 = 内解析值(文本, 位置2)
        设 键 = 键解析[0]
        位置2 = 键解析[1]
        设 键文本 = 转文本(键)
        位置2 = 内跳过空白(文本, 位置2)
        // 跳过冒号
        如果 位置2 < 长度(文本) 且 文本[位置2] == ':':
            位置2 = 位置2 + 1
        位置2 = 内跳过空白(文本, 位置2)
        设 值解析 = 内解析值(文本, 位置2)
        设 值 = 值解析[0]
        位置2 = 值解析[1]
        设值(结果, 键文本, 值)
        位置2 = 内跳过空白(文本, 位置2)
        如果 位置2 >= 长度(文本):
            跳出
        如果 文本[位置2] == ',':
            位置2 = 位置2 + 1
        否则如果 文本[位置2] == '}':
            位置2 = 位置2 + 1
            跳出
    返回 [结果, 位置2]

函程 反序列化(文本): // 公开
    // 从文本格式反序列化为数据结构
    设 结果 = 内解析值(文本, 0)
    返回 结果[0]