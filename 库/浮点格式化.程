// ===== 语程标准库：浮点格式化 =====
// 提供高精度浮点数格式化功能
// 借鉴空灵语言 formatfloat 库的设计思想
//
// 公开接口：格式化浮点、定点格式、科学格式、
//           精度格式、百分号格式、货币格式、
//           千分位格式、补零格式、
//           是NaN、是无穷、是负零、
//           浮点相等、浮点比较

// === 核心格式化 ===

函程 格式化浮点(数值, 格式=""): // 公开
    // 格式化浮点数
    // 格式规范：[[填充]对齐][符号][#][0][最小宽度][.精度][类型]
    // 对齐: < 左对齐, > 右对齐, ^ 居中
    // 符号: + 显示正负号, - 仅显示负号, 空格 正数显示空格
    // 类型: f 定点, e 科学计数, g 自动, % 百分号
    如果 格式.长度() == 0:
        返回 默认格式(数值)
    设 解析 = 解析格式(格式)
    设 结果 = 按类型格式化(数值, 解析.类型, 解析.精度)
    结果 = 添加符号(结果, 数值, 解析.符号)
    结果 = 添加填充(结果, 解析.最小宽度, 解析.填充, 解析.对齐)
    返回 结果

函程 定点格式(数值, 小数位数=2): // 公开
    // 定点格式化（如 3.14）
    返回 按类型格式化(数值, "f", 小数位数)

函程 科学格式(数值, 小数位数=6): // 公开
    // 科学计数法格式化（如 3.14e+00）
    返回 按类型格式化(数值, "e", 小数位数)

函程 精度格式(数值, 有效位数=6): // 公开
    // 有效位数格式化
    返回 按类型格式化(数值, "g", 有效位数)

函程 百分号格式(数值, 小数位数=2): // 公开
    // 百分号格式化（如 31.40%）
    设 结果 = 按类型格式化(数值 * 100, "f", 小数位数)
    返回 结果 + "%"

函程 货币格式(数值, 货币符号="¥", 小数位数=2, 千分位=真): // 公开
    // 货币格式化
    设 结果 = 定点格式(绝对值(数值), 小数位数)
    如果 千分位:
        结果 = 添加千分位(结果)
    如果 数值 < 0:
        结果 = "-" + 货币符号 + 结果
    否则:
        结果 = 货币符号 + 结果
    返回 结果

函程 千分位格式(数值, 小数位数=2): // 公开
    // 千分位分隔格式化（如 1,234,567.89）
    设 结果 = 定点格式(绝对值(数值), 小数位数)
    结果 = 添加千分位(结果)
    如果 数值 < 0:
        结果 = "-" + 结果
    返回 结果

// === 特殊值检测 ===

函程 是NaN(数值): // 公开
    // 检查是否为 NaN
    返回 数值 != 数值

函程 是无穷(数值): // 公开
    // 检查是否为无穷大
    设 非NaN = 不是 是NaN(数值)
    返回 (数值 == 数值 * 2) 且 非NaN 且 数值 != 0

函程 是负零(数值): // 公开
    // 检查是否为负零
    返回 数值 == 0 且 转文本(数值).长度() > 1

// === 浮点比较 ===

函程 浮点相等(甲, 乙, 精度=0.000001): // 公开
    // 在指定精度内比较两个浮点数是否相等
    返回 绝对值(甲 - 乙) < 精度

函程 浮点比较(甲, 乙, 精度=0.000001): // 公开
    // 比较两个浮点数，返回 -1/0/1
    如果 浮点相等(甲, 乙, 精度):
        返回 0
    如果 甲 < 乙:
        返回 -1
    返回 1

// === 内部实现 ===

函程 默认格式(数值): // 内部
    设 结果 = 转文本(数值)
    // 确保小数点存在
    设 有点 = 包含(结果, ".")
    如果 不是 有点:
        结果 = 结果 + ".0"
    返回 结果

函程 解析格式(格式): // 内部
    设 填充 = " "
    设 对齐 = ">"
    设 符号 = "-"
    设 最小宽度 = 0
    设 精度 = 6
    设 类型 = "g"
    设 位置 = 0
    设 长度 = 格式.长度()
    // 解析填充和对齐
    如果 长度 >= 2:
        设 第二 = 子串(格式, 1, 1)
        如果 第二 == "<" 或 第二 == ">" 或 第二 == "^":
            填充 = 子串(格式, 0, 1)
            对齐 = 第二
            位置 = 2
    // 解析符号
    如果 位置 < 长度:
        设 字 = 子串(格式, 位置, 1)
        如果 字 == "+" 或 字 == "-" 或 字 == " ":
            符号 = 字
            位置 = 位置 + 1
    // 跳过 # 和 0 标志
    循环 当 位置 < 长度:
        设 字 = 子串(格式, 位置, 1)
        如果 字 == "#" 或 字 == "0":
            位置 = 位置 + 1
        否则:
            停止
    // 解析最小宽度
    设 宽度串 = ""
    循环 当 位置 < 长度:
        设 字 = 子串(格式, 位置, 1)
        如果 字 >= "0" 且 字 <= "9":
            宽度串 = 宽度串 + 字
            位置 = 位置 + 1
        否则:
            停止
    如果 宽度串.长度() > 0:
        最小宽度 = 转整数(宽度串)
    // 解析精度
    如果 位置 < 长度 且 子串(格式, 位置, 1) == ".":
        位置 = 位置 + 1
        设 精度串 = ""
        循环 当 位置 < 长度:
            设 字 = 子串(格式, 位置, 1)
            如果 字 >= "0" 且 字 <= "9":
                精度串 = 精度串 + 字
                位置 = 位置 + 1
            否则:
                停止
        如果 精度串.长度() > 0:
            精度 = 转整数(精度串)
    // 解析类型
    如果 位置 < 长度:
        类型 = 子串(格式, 位置, 1)
    返回 {填充: 填充, 对齐: 对齐, 符号: 符号, 最小宽度: 最小宽度, 精度: 精度, 类型: 类型}

函程 按类型格式化(数值, 类型, 精度): // 内部
    如果 类型 == "f":
        返回 定点格式化(数值, 精度)
    否则如果 类型 == "e":
        返回 科学格式化(数值, 精度)
    否则如果 类型 == "%":
        返回 定点格式化(数值 * 100, 精度) + "%"
    否则:
        返回 自动格式化(数值, 精度)

函程 定点格式化(数值, 小数位数): // 内部
    设 结果 = 转文本(数值)
    设 点位 = 查找(结果, ".")
    如果 点位 < 0:
        结果 = 结果 + "."
        点位 = 结果.长度() - 1
    设 当前小数 = 结果.长度() - 点位 - 1
    循环 当 当前小数 < 小数位数:
        结果 = 结果 + "0"
        当前小数 = 当前小数 + 1
    如果 当前小数 > 小数位数:
        结果 = 子串(结果, 0, 点位 + 1 + 小数位数)
    返回 结果

函程 科学格式化(数值, 小数位数): // 内部
    // 简化科学计数法实现
    设 指数 = 0
    设 绝对 = 绝对值(数值)
    如果 绝对 >= 10:
        循环 当 绝对 >= 10:
            绝对 = 绝对 / 10
            指数 = 指数 + 1
    否则如果 绝对 > 0 且 绝对 < 1:
        循环 当 绝对 < 1:
            绝对 = 绝对 * 10
            指数 = 指数 - 1
    设 尾数 = 定点格式化(绝对, 小数位数)
    如果 数值 < 0:
        尾数 = "-" + 尾数
    返回 尾数 + "e" + (指数 >= 0 ? "+" : "") + 转文本(指数)

函程 自动格式化(数值, 有效位数): // 内部
    设 结果 = 转文本(数值)
    如果 结果.长度() <= 有效位数 + 2:
        返回 结果
    返回 科学格式化(数值, 有效位数 - 1)

函程 添加符号(结果, 数值, 符号类型): // 内部
    设 有负号 = 包含(结果, "-")
    如果 符号类型 == "+":
        如果 数值 >= 0 且 不是 有负号:
            返回 "+" + 结果
    否则如果 符号类型 == " ":
        如果 数值 >= 0 且 不是 有负号:
            返回 " " + 结果
    返回 结果

函程 添加填充(结果, 最小宽度, 填充, 对齐): // 内部
    设 当前宽度 = 结果.长度()
    如果 当前宽度 >= 最小宽度:
        返回 结果
    设 填充数 = 最小宽度 - 当前宽度
    设 填充串 = 重复(填充, 填充数)
    如果 对齐 == "<":
        返回 结果 + 填充串
    否则如果 对齐 == "^":
        设 左 = 填充数 / 2
        设 右 = 填充数 - 左
        返回 重复(填充, 左) + 结果 + 重复(填充, 右)
    否则:
        返回 填充串 + 结果

函程 添加千分位(数字串): // 内部
    设 部分 = 数字串.分割(".")
    设 整数部分 = 部分[0]
    设 小数部分 = ""
    如果 部分.长度() > 1:
        小数部分 = "." + 部分[1]
    设 结果 = ""
    设 计 = 0
    设 i = 整数部分.长度() - 1
    循环 当 i >= 0:
        如果 计 > 0 且 计 % 3 == 0:
            结果 = "," + 结果
        结果 = 子串(整数部分, i, 1) + 结果
        计 = 计 + 1
        i = i - 1
    返回 结果 + 小数部分

函程 重复(字符, 次数): // 内部
    设 结果 = ""
    设 i = 0
    循环 i < 次数:
        结果 = 结果 + 字符
        i = i + 1
    返回 结果
