// 编辑距离库 - 字符串相似度计算
// 提供编辑距离（Levenshtein距离）及相似度计算功能

// 公开接口：编辑距离、相似度、汉明距离、最长公共子序列

函程 编辑距离(甲, 乙): // 公开
    // 计算两个字符串之间的Levenshtein编辑距离
    设 甲长 = 长度(甲)
    设 乙长 = 长度(乙)
    
    如果 甲长 == 0:
        返回 乙长
    如果 乙长 == 0:
        返回 甲长
    
    // 简单实现：递归（适合短字符串）
    返回 编辑距离递归(甲, 乙, 甲长, 乙长)

函程 编辑距离递归(甲, 乙, 甲长, 乙长): // 内部
    如果 甲长 == 0:
        返回 乙长
    如果 乙长 == 0:
        返回 甲长
    
    如果 甲[甲长-1] == 乙[乙长-1]:
        返回 编辑距离递归(甲, 乙, 甲长-1, 乙长-1)
    
    设 删除 = 编辑距离递归(甲, 乙, 甲长-1, 乙长)
    设 插入 = 编辑距离递归(甲, 乙, 甲长, 乙长-1)
    设 替换 = 编辑距离递归(甲, 乙, 甲长-1, 乙长-1)
    
    设 最小 = 删除
    如果 插入 < 最小:
        最小 = 插入
    如果 替换 < 最小:
        最小 = 替换
    
    返回 1 + 最小

函程 相似度(甲, 乙): // 公开
    // 计算两个字符串的相似度，返回0到1之间的值
    设 距离 = 编辑距离(甲, 乙)
    设 最大长度 = 长度(甲)
    设 乙长 = 长度(乙)
    如果 乙长 > 最大长度:
        最大长度 = 乙长
    如果 最大长度 == 0:
        返回 1.0
    返回 1.0 - 距离 / 最大长度

函程 汉明距离(甲, 乙): // 公开
    // 计算两个等长字符串的汉明距离
    设 甲长 = 长度(甲)
    设 乙长 = 长度(乙)
    如果 甲长 != 乙长:
        返回 -1
    设 距离 = 0
    设 i = 0
    循环 i < 甲长:
        如果 甲[i] != 乙[i]:
            距离 = 距离 + 1
        i = i + 1
    返回 距离

函程 最长公共子序列(甲, 乙): // 公开
    // 计算两个字符串的最长公共子序列长度
    设 甲长 = 长度(甲)
    设 乙长 = 长度(乙)
    
    如果 甲长 == 0 或 乙长 == 0:
        返回 0
    
    返回 LCS递归(甲, 乙, 甲长, 乙长)

函程 LCS递归(甲, 乙, 甲长, 乙长): // 内部
    如果 甲长 == 0 或 乙长 == 0:
        返回 0
    
    如果 甲[甲长-1] == 乙[乙长-1]:
        返回 1 + LCS递归(甲, 乙, 甲长-1, 乙长-1)
    
    设 上值 = LCS递归(甲, 乙, 甲长-1, 乙长)
    设 左值 = LCS递归(甲, 乙, 甲长, 乙长-1)
    
    如果 上值 > 左值:
        返回 上值
    否则:
        返回 左值

函程 最长公共子串(甲, 乙): // 公开
    // 计算两个字符串的最长公共子串长度
    设 甲长 = 长度(甲)
    设 乙长 = 长度(乙)
    
    如果 甲长 == 0 或 乙长 == 0:
        返回 0
    
    设 最大长度 = 0
    设 i = 0
    循环 i < 甲长:
        设 j = 0
        循环 j < 乙长:
            设 k = 0
            循环 当 i+k < 甲长 且 j+k < 乙长 且 甲[i+k] == 乙[j+k]:
                k = k + 1
            如果 k > 最大长度:
                最大长度 = k
            j = j + 1
        i = i + 1
    
    返回 最大长度

函程 模糊匹配(模式, 目标): // 公开
    // 模糊匹配：检查模式是否为目标的子序列
    设 模式长 = 长度(模式)
    设 目标长 = 长度(目标)
    
    如果 模式长 == 0:
        返回 真
    如果 模式长 > 目标长:
        返回 假
    
    设 模式索引 = 0
    设 目标索引 = 0
    循环 目标索引 < 目标长 且 模式索引 < 模式长:
        如果 模式[模式索引] == 目标[目标索引]:
            模式索引 = 模式索引 + 1
        目标索引 = 目标索引 + 1
    
    返回 模式索引 == 模式长
