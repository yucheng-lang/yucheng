// ===== 语程标准库：大整数 =====
// 提供任意精度整数运算
//
// 公开接口：创建大整数、大整数加、大整数减、大整数乘、
//           大整数除、大整数模、大整数幂、大整数幂模、
//           大整数绝对值、大整数相反数、
//           大整数比较、大整数相等、
//           大整数转字符串、字符串转大整数、大整数转数字、
//           大整数最大公约数、大整数逆模、
//           大整数阶乘、大整数斐波那契

// ===== 大整数表示 =====
// 内部用列表存储各位数字（低位在前），正负号用单独字段
// 例如：1234 → {数字: [4, 3, 2, 1], 为负: 假}

函程 创建大整数(值 = 0): // 公开
    设 t = 类型(值)
    如果 t == "数字" 或 t == "整数" 或 t == "浮点数":
        返回 数字转大整数(值)
    如果 t == "字符串":
        返回 字符串转大整数(值)
    返回 {数字: [0], 为负: 假}

函程 数字转大整数(n): // 内部
    如果 n < 0:
        返回 {数字: _绝对值数字列表(0 - n), 为负: 真}
    返回 {数字: _绝对值数字列表(n), 为负: 假}

函程 _绝对值数字列表(n): // 内部
    如果 n == 0:
        返回 [0]
    设 数字 = []
    循环 当 n > 0:
        数字.添加(模(n, 10))
        n = 向下取整(n / 10)
    返回 数字

// ===== 基本运算 =====

函程 大整数加(a, b): // 公开
    设 甲 = _确保大整数(a)
    设 乙 = _确保大整数(b)
    如果 甲.为负 且 乙.为负:
        返回 _大整数取负(_大整数绝对值加(甲, 乙))
    如果 甲.为负:
        返回 大整数减(乙, _大整数取负(甲))
    如果 乙.为负:
        返回 大整数减(甲, _大整数取负(乙))
    返回 _大整数绝对值加(甲, 乙)

函程 _大整数绝对值加(a, b): // 内部
    设 结果 = []
    设 进位 = 0
    设 i = 0
    设 甲长 = 数组长度(a.数字)
    设 乙长 = 数组长度(b.数字)
    循环 当 i < 甲长 或 i < 乙长 或 进位 > 0:
        设 甲位 = 0
        设 乙位 = 0
        如果 i < 甲长:
            甲位 = a.数字[i]
        如果 i < 乙长:
            乙位 = b.数字[i]
        设 和 = 甲位 + 乙位 + 进位
        结果.添加(模(和, 10))
        进位 = 向下取整(和 / 10)
        i = i + 1
    返回 {数字: 结果, 为负: 假}

函程 大整数减(a, b): // 公开
    设 甲 = _确保大整数(a)
    设 乙 = _确保大整数(b)
    如果 甲.为负 且 乙.为负:
        返回 大整数减(_大整数取负(乙), _大整数取负(甲))
    如果 甲.为负:
        返回 _大整数取负(_大整数绝对值加(甲, 乙))
    如果 乙.为负:
        返回 _大整数绝对值加(甲, 乙)
    // 两者都正
    设 比较 = _大整数绝对值比较(甲, 乙)
    如果 比较 == 0:
        返回 {数字: [0], 为负: 假}
    如果 比较 < 0:
        返回 _大整数取负(_大整数绝对值减(乙, 甲))
    返回 _大整数绝对值减(甲, 乙)

函程 _大整数绝对值减(a, b): // 内部
    // a 的绝对值 >= b 的绝对值
    设 结果 = []
    设 借位 = 0
    设 i = 0
    设 甲长 = 数组长度(a.数字)
    设 乙长 = 数组长度(b.数字)
    循环 当 i < 甲长:
        设 甲位 = a.数字[i]
        设 乙位 = 0
        如果 i < 乙长:
            乙位 = b.数字[i]
        设 差 = 甲位 - 乙位 - 借位
        如果 差 < 0:
            差 = 差 + 10
            借位 = 1
        否则:
            借位 = 0
        结果.添加(差)
        i = i + 1
    // 去除前导零
    循环 当 数组长度(结果) > 1 且 结果[数组长度(结果) - 1] == 0:
        结果 = 数组切片(结果, 0, 数组长度(结果) - 1)
    返回 {数字: 结果, 为负: 假}

函程 大整数乘(a, b): // 公开
    设 甲 = _确保大整数(a)
    设 乙 = _确保大整数(b)
    设 符号 = 甲.为负 != 乙.为负
    设 结果 = _大整数绝对值乘(甲, 乙)
    结果.为负 = 符号
    如果 _大整数是零(结果):
        结果.为负 = 假
    返回 结果

函程 _大整数绝对值乘(a, b): // 内部
    设 甲长 = 数组长度(a.数字)
    设 乙长 = 数组长度(b.数字)
    设 结果 = []
    设 i = 0
    循环 当 i < 甲长 + 乙长:
        结果.添加(0)
        i = i + 1
    设 i = 0
    循环 当 i < 甲长:
        设 进位 = 0
        设 j = 0
        循环 当 j < 乙长 或 进位 > 0:
            设 乙位 = 0
            如果 j < 乙长:
                乙位 = b.数字[j]
            设 积 = 结果[i + j] + a.数字[i] * 乙位 + 进位
            结果[i + j] = 模(积, 10)
            进位 = 向下取整(积 / 10)
            j = j + 1
        i = i + 1
    // 去除前导零
    循环 当 数组长度(结果) > 1 且 结果[数组长度(结果) - 1] == 0:
        结果 = 数组切片(结果, 0, 数组长度(结果) - 1)
    返回 {数字: 结果, 为负: 假}

函程 大整数除(a, b): // 公开
    // 返回 {商: 大整数, 余数: 大整数}
    设 甲 = _确保大整数(a)
    设 乙 = _确保大整数(b)
    如果 _大整数是零(乙):
        返回 {商: 创建大整数(0), 余数: 创建大整数(0)}
    设 符号商 = 甲.为负 != 乙.为负
    设 符号余 = 甲.为负
    设 比较 = _大整数绝对值比较(甲, 乙)
    如果 比较 < 0:
        设 余 = _大整数复制(甲)
        余.为负 = 符号余
        如果 _大整数是零(余):
            余.为负 = 假
        返回 {商: 创建大整数(0), 余数: 余}
    如果 比较 == 0:
        设 商 = 创建大整数(1)
        商.为负 = 符号商
        返回 {商: 商, 余数: 创建大整数(0)}
    // 长除法
    设 商数字 = []
    设 当前 = {数字: [0], 为负: 假}
    设 i = 数组长度(甲.数字) - 1
    循环 当 i >= 0:
        当前 = _大整数左移一位(当前)
        当前.数字[0] = 甲.数字[i]
        // 去除当前前导零
        当前 = _大整数去除前导零(当前)
        设 计数 = 0
        循环 当 _大整数绝对值比较(当前, 乙) >= 0:
            当前 = _大整数绝对值减(当前, 乙)
            计数 = 计数 + 1
        商数字.添加(计数)
        i = i - 1
    // 反转商数字
    设 商结果 = []
    设 j = 数组长度(商数字) - 1
    循环 当 j >= 0:
        商结果.添加(商数字[j])
        j = j - 1
    设 商 = {数字: 商结果, 为负: 符号商}
    商 = _大整数去除前导零(商)
    当前.为负 = 符号余
    如果 _大整数是零(当前):
        当前.为负 = 假
    返回 {商: 商, 余数: 当前}

函程 大整数模(a, b): // 公开
    设 结果 = 大整数除(a, b)
    返回 结果.余数

函程 大整数整除(a, b): // 公开
    设 结果 = 大整数除(a, b)
    返回 结果.商

// ===== 幂运算 =====

函程 大整数幂(底, 指数): // 公开
    设 甲 = _确保大整数(底)
    设 乙 = _确保大整数(指数)
    如果 _大整数是零(乙):
        返回 创建大整数(1)
    如果 _大整数是零(甲):
        返回 创建大整数(0)
    设 结果 = 创建大整数(1)
    设 当前 = _大整数复制(甲)
    设 n = 大整数转数字(乙)
    循环 当 n > 0:
        如果 模(n, 2) == 1:
            结果 = 大整数乘(结果, 当前)
        当前 = 大整数乘(当前, 当前)
        n = 向下取整(n / 2)
    如果 甲.为负 且 模(乙.数字[0], 2) == 1:
        结果.为负 = 真
    返回 结果

函程 大整数幂模(底, 指数, 模): // 公开
    // 快速模幂
    设 甲 = _确保大整数(底)
    设 乙 = _确保大整数(指数)
    设 丙 = _确保大整数(模)
    如果 _大整数是零(丙):
        返回 创建大整数(0)
    设 结果 = 创建大整数(1)
    设 当前 = 大整数模(甲, 丙)
    设 n = 大整数转数字(乙)
    循环 当 n > 0:
        如果 模(n, 2) == 1:
            结果 = 大整数模(大整数乘(结果, 当前), 丙)
        当前 = 大整数模(大整数乘(当前, 当前), 丙)
        n = 向下取整(n / 2)
    返回 结果

// ===== 比较 =====

函程 大整数比较(a, b): // 公开
    // 返回 -1（小于）、0（等于）、1（大于）
    设 甲 = _确保大整数(a)
    设 乙 = _确保大整数(b)
    如果 甲.为负 且 非 乙.为负:
        返回 -1
    如果 非 甲.为负 且 乙.为负:
        返回 1
    设 结果 = _大整数绝对值比较(甲, 乙)
    如果 甲.为负:
        返回 0 - 结果
    返回 结果

函程 大整数相等(a, b): // 公开
    返回 大整数比较(a, b) == 0

函程 大整数小于(a, b): // 公开
    返回 大整数比较(a, b) < 0

函程 大整数小于等于(a, b): // 公开
    返回 大整数比较(a, b) <= 0

函程 大整数大于(a, b): // 公开
    返回 大整数比较(a, b) > 0

函程 大整数大于等于(a, b): // 公开
    返回 大整数比较(a, b) >= 0

// ===== 转换 =====

函程 大整数转字符串(a): // 公开
    设 甲 = _确保大整数(a)
    如果 _大整数是零(甲):
        返回 "0"
    设 结果 = ""
    如果 甲.为负:
        结果 = "-"
    设 i = 数组长度(甲.数字) - 1
    循环 当 i >= 0:
        结果 = 结果 + 转字符串(甲.数字[i])
        i = i - 1
    返回 结果

函程 字符串转大整数(s): // 公开
    设 为负 = 假
    设 文本 = s
    如果 子串(文本, 0, 1) == "-":
        为负 = 真
        文本 = 子串(文本, 1, 字符串长度(文本))
    否则 如果 子串(文本, 0, 1) == "+":
        文本 = 子串(文本, 1, 字符串长度(文本))
    设 数字 = []
    设 i = 字符串长度(文本) - 1
    循环 当 i >= 0:
        设 字 = 子串(文本, i, 1)
        设 值 = 转整数(字)
        数字.添加(值)
        i = i - 1
    如果 数组长度(数字) == 0:
        数字 = [0]
    返回 {数字: 数字, 为负: 为负}

函程 大整数转数字(a): // 公开
    // 如果值在范围内则转为普通数字，否则返回 0
    设 甲 = _确保大整数(a)
    设 结果 = 0
    设 倍数 = 1
    遍 位 于 甲.数字:
        结果 = 结果 + 位 * 倍数
        倍数 = 倍数 * 10
    如果 甲.为负:
        结果 = 0 - 结果
    返回 结果

// ===== 数学函数 =====

函程 大整数绝对值(a): // 公开
    设 甲 = _确保大整数(a)
    设 结果 = _大整数复制(甲)
    结果.为负 = 假
    返回 结果

函程 大整数相反数(a): // 公开
    设 甲 = _确保大整数(a)
    如果 _大整数是零(甲):
        返回 _大整数复制(甲)
    设 结果 = _大整数复制(甲)
    结果.为负 = 非 甲.为负
    返回 结果

函程 大整数最大公约数(a, b): // 公开
    设 甲 = 大整数绝对值(a)
    设 乙 = 大整数绝对值(b)
    循环 当 非 大整数相等(乙, 创建大整数(0)):
        设 临时 = 大整数模(甲, 乙)
        甲 = 乙
        乙 = 临时
    返回 甲

函程 大整数逆模(a, 模): // 公开
    // 扩展欧几里得算法求模逆
    设 甲 = 大整数绝对值(a)
    设 丙 = _确保大整数(模)
    如果 _大整数是零(丙):
        返回 空
    设 旧余 = _确保大整数(丙)
    设 新余 = 大整数模(甲, 丙)
    设 旧系数 = 创建大整数(1)
    设 新系数 = 创建大整数(0)
    循环 当 非 _大整数是零(新余):
        设 除结果 = 大整数除(旧余, 新余)
        设 商 = 除结果.商
        设 临时余 = 新余
        新余 = 大整数减(旧余, 大整数乘(商, 新余))
        旧余 = 临时余
        设 临时系数 = 新系数
        新系数 = 大整数减(旧系数, 大整数乘(商, 新系数))
        旧系数 = 临时系数
    如果 大整数比较(旧余, 创建大整数(1)) != 0:
        返回 空  // 无逆元
    如果 旧系数.为负:
        旧系数 = 大整数加(旧系数, 丙)
    返回 旧系数

// ===== 常用数学 =====

函程 大整数阶乘(n): // 公开
    设 结果 = 创建大整数(1)
    设 i = 2
    循环 当 i <= n:
        结果 = 大整数乘(结果, 创建大整数(i))
        i = i + 1
    返回 结果

函程 大整数斐波那契(n): // 公开
    如果 n <= 0:
        返回 创建大整数(0)
    如果 n == 1:
        返回 创建大整数(1)
    设 甲 = 创建大整数(0)
    设 乙 = 创建大整数(1)
    设 i = 2
    循环 当 i <= n:
        设 临时 = 大整数加(甲, 乙)
        甲 = 乙
        乙 = 临时
        i = i + 1
    返回 乙

// ===== 内部辅助 =====

函程 _确保大整数(值): // 内部
    设 t = 类型(值)
    如果 t == "数字" 或 t == "整数" 或 t == "浮点数":
        返回 数字转大整数(值)
    如果 t == "字符串":
        返回 字符串转大整数(值)
    返回 值

函程 _大整数是零(a): // 内部
    返回 数组长度(a.数字) == 1 且 a.数字[0] == 0

函程 _大整数取负(a): // 内部
    设 结果 = _大整数复制(a)
    如果 _大整数是零(结果):
        返回 结果
    结果.为负 = 非 结果.为负
    返回 结果

函程 _大整数复制(a): // 内部
    设 数字 = []
    遍 位 于 a.数字:
        数字.添加(位)
    返回 {数字: 数字, 为负: a.为负}

函程 _大整数绝对值比较(a, b): // 内部
    设 甲长 = 数组长度(a.数字)
    设 乙长 = 数组长度(b.数字)
    如果 甲长 != 乙长:
        如果 甲长 > 乙长:
            返回 1
        返回 -1
    设 i = 甲长 - 1
    循环 当 i >= 0:
        如果 a.数字[i] != b.数字[i]:
            如果 a.数字[i] > b.数字[i]:
                返回 1
            返回 -1
        i = i - 1
    返回 0

函程 _大整数左移一位(a): // 内部
    // 左移一位相当于乘以10
    设 数字 = [0]
    遍 位 于 a.数字:
        数字.添加(位)
    返回 {数字: 数字, 为负: a.为负}

函程 _大整数去除前导零(a): // 内部
    设 数字 = []
    遍 位 于 a.数字:
        数字.添加(位)
    循环 当 数组长度(数字) > 1 且 数字[数组长度(数字) - 1] == 0:
        数字 = 数组切片(数字, 0, 数组长度(数字) - 1)
    返回 {数字: 数字, 为负: a.为负}
