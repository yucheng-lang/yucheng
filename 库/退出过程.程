// ===== 语程标准库：退出过程 =====
// 提供程序退出时的钩子函数注册与执行
// 类似 C 的 atexit()，按后进先出(LIFO)顺序执行
//
// 公开接口：注册退出过程、移除退出过程、清空退出过程、
//           设置退出码、获取退出码、执行退出过程、
//           退出程序、立即退出、崩溃退出

// 全局退出过程列表
设 退出过程列表 = []

// === 注册与移除 ===

函程 注册退出过程(过程): // 公开
    // 注册一个在程序退出时执行的过程（函数）
    // 按后进先出(LIFO)顺序执行
    退出过程列表.添加(过程)

函程 移除退出过程(过程): // 公开
    // 移除已注册的退出过程
    设 新列表 = []
    循环 项 于 退出过程列表:
        如果 项 != 过程:
            新列表.添加(项)
    退出过程列表 = 新列表

函程 清空退出过程(): // 公开
    // 清空所有已注册的退出过程
    退出过程列表 = []

// === 退出码管理 ===

函程 设置退出码(码): // 公开
    // 设置程序退出码
    设置环境变量("__YUCHENG_EXIT_CODE__", 转文本(码))

函程 获取退出码(): // 公开
    // 获取当前设置的退出码
    设 码 = 环境变量("__YUCHENG_EXIT_CODE__")
    如果 码.长度() > 0:
        返回 转整数(码)
    返回 0

// === 退出执行 ===

函程 执行退出过程(): // 公开
    // 手动执行所有注册的退出过程（LIFO顺序）
    // 通常不需要手动调用
    设 计 = 退出过程列表.长度() - 1
    循环 当 计 >= 0:
        设 过程 = 退出过程列表[计]
        尝试:
            过程()
        捕获 错误:
            输出("退出过程执行错误: " + 转文本(错误))
        计 = 计 - 1
    退出过程列表 = []

函程 退出程序(退出码=0): // 公开
    // 正常退出程序
    // 先执行所有退出过程，再退出
    执行退出过程()
    退出(退出码)

函程 立即退出(退出码=1): // 公开
    // 立即退出程序，不执行退出过程
    退出(退出码)

函程 崩溃退出(消息): // 公开
    // 输出错误消息后退出
    输出("致命错误: " + 消息)
    退出程序(1)

// === 信号退出 ===

函程 注册中断处理(过程): // 公开
    // 注册 Ctrl+C 中断处理
    // 在程序被中断时执行清理
    注册退出过程(过程)
