// ===== 子集与超集 =====

函程 是子集(子集, 超集): // 公开
    遍 项 于 子集:
        如果 非 集合包含(超集, 项):
            返回 假
    返回 真

函程 是超集(超集, 子集): // 公开
    返回 是子集(子集, 超集)

函程 是真子集(子集, 超集): // 公开
    如果 集合相等(子集, 超集):
        返回 假
    返回 是子集(子集, 超集)

// ===== 集合转换 =====

函程 集合添加(集合, 元素): // 公开
    如果 集合包含(集合, 元素):
        返回 集合
    设 结果 = []
    遍 项 于 集合:
        结果.添加(项)
    结果.添加(元素)
    返回 结果

函程 集合移除(集合, 元素): // 公开
    设 结果 = []
    遍 项 于 集合:
        如果 项 != 元素:
            结果.添加(项)
    返回 结果
