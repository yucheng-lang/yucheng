// 数据结构工具
// 提供双端队列、堆、链表等数据结构

// === 双端队列 ===

函程 创建双端队列(): // 公开
    // 创建双端队列
    返回 {
        数据: [],
        大小(): 返回 长度(数据)
    }

函程 队首入队(队列, 元素): // 公开
    // 从队首添加元素
    设 新数据 = [元素]
    遍 项 于 队列.数据:
        新数据 = 追加(新数据, 项)
    队列.数据 = 新数据
    返回 队列

函程 队尾入队(队列, 元素): // 公开
    // 从队尾添加元素
    队列.数据 = 追加(队列.数据, 元素)
    返回 队列

函程 队首出队(队列): // 公开
    // 从队首移除并返回元素
    如果 长度(队列.数据) == 0:
        返回 空
    设 元素 = 队列.数据[0]
    设 新数据 = []
    设 计 = 1
    循环 计 < 长度(队列.数据):
        新数据 = 追加(新数据, 队列.数据[计])
        计 = 计 + 1
    队列.数据 = 新数据
    返回 元素

函程 队尾出队(队列): // 公开
    // 从队尾移除并返回元素
    如果 长度(队列.数据) == 0:
        返回 空
    设 元素 = 队列.数据[长度(队列.数据) - 1]
    设 新数据 = []
    设 计 = 0
    循环 计 < 长度(队列.数据) - 1:
        新数据 = 追加(新数据, 队列.数据[计])
        计 = 计 + 1
    队列.数据 = 新数据
    返回 元素

函程 查看队首(队列): // 公开
    如果 长度(队列.数据) == 0:
        返回 空
    返回 队列.数据[0]

函程 查看队尾(队列): // 公开
    如果 长度(队列.数据) == 0:
        返回 空
    返回 队列.数据[长度(队列.数据) - 1]

函程 队列是否为空(队列): // 公开
    返回 长度(队列.数据) == 0

// === 堆（最小堆）===

函程 创建堆(): // 公开
    返回 {数据: []}

函程 堆插入(堆, 元素): // 公开
    // 向堆中插入元素
    堆.数据 = 追加(堆.数据, 元素)
    堆上浮(堆, 长度(堆.数据) - 1)
    返回 堆

函程 堆弹出(堆): // 公开
    // 弹出堆顶元素
    如果 长度(堆.数据) == 0:
        返回 空
    设 顶部 = 堆.数据[0]
    堆.数据[0] = 堆.数据[长度(堆.数据) - 1]
    // 移除最后一个元素
    设 新数据 = []
    设 计 = 0
    循环 计 < 长度(堆.数据) - 1:
        新数据 = 追加(新数据, 堆.数据[计])
        计 = 计 + 1
    堆.数据 = 新数据
    堆下沉(堆, 0)
    返回 顶部

函程 查看堆顶(堆): // 公开
    如果 长度(堆.数据) == 0:
        返回 空
    返回 堆.数据[0]

函程 堆大小(堆): // 公开
    返回 长度(堆.数据)

函程 堆是否为空(堆): // 公开
    返回 长度(堆.数据) == 0

函程 堆上浮(堆, 索引): // 内部
    循环 索引 > 0:
        设 父索引 = (索引 - 1) / 2
        如果 堆.数据[索引] < 堆.数据[父索引]:
            交换元素(堆.数据, 索引, 父索引)
            索引 = 父索引
        否则:
            中断

函程 堆下沉(堆, 索引): // 内部
    设 长度值 = 长度(堆.数据)
    循环 真:
        设 最小 = 索引
        设 左 = 2 * 索引 + 1
        设 右 = 2 * 索引 + 2
        如果 左 < 长度值 且 堆.数据[左] < 堆.数据[最小]:
            最小 = 左
        如果 右 < 长度值 且 堆.数据[右] < 堆.数据[最小]:
            最小 = 右
        如果 最小 != 索引:
            交换元素(堆.数据, 索引, 最小)
            索引 = 最小
        否则:
            中断

函程 堆排序(列表): // 公开
    // 使用堆排序返回排序后的列表
    设 堆 = 创建堆()
    遍 项 于 列表:
        堆插入(堆, 项)
    设 结果 = []
    循环 非 堆是否为空(堆):
        结果 = 追加(结果, 堆弹出(堆))
    返回 结果

函程 取前N个最大(列表, n): // 公开
    // 取列表中最大的N个元素
    设 堆 = 创建堆()
    遍 项 于 列表:
        堆插入(堆, 项)
        如果 堆大小(堆) > n:
            堆弹出(堆)
    设 结果 = []
    循环 非 堆是否为空(堆):
        结果 = 追加(结果, 堆弹出(堆))
    返回 结果

// === 栈 ===

函程 创建栈(): // 公开
    返回 {数据: []}

函程 入栈(栈, 元素): // 公开
    栈.数据 = 追加(栈.数据, 元素)
    返回 栈

函程 出栈(栈): // 公开
    如果 长度(栈.数据) == 0:
        返回 空
    设 元素 = 栈.数据[长度(栈.数据) - 1]
    设 新数据 = []
    设 计 = 0
    循环 计 < 长度(栈.数据) - 1:
        新数据 = 追加(新数据, 栈.数据[计])
        计 = 计 + 1
    栈.数据 = 新数据
    返回 元素

函程 查看栈顶(栈): // 公开
    如果 长度(栈.数据) == 0:
        返回 空
    返回 栈.数据[长度(栈.数据) - 1]

函程 栈是否为空(栈): // 公开
    返回 长度(栈.数据) == 0

函程 栈大小(栈): // 公开
    返回 长度(栈.数据)

// === 链表节点 ===

函程 创建链表节点(值, 下一个 = 空): // 公开
    返回 {值: 值, 下一个: 下一个}

函程 创建链表(): // 公开
    返回 {头: 空, 尾: 空, 长度: 0}

函程 链表头部插入(链表, 值): // 公开
    设 节点 = 创建链表节点(值, 链表.头)
    链表.头 = 节点
    如果 链表.尾 == 空:
        链表.尾 = 节点
    链表.长度 = 链表.长度 + 1
    返回 链表

函程 链表尾部插入(链表, 值): // 公开
    设 节点 = 创建链表节点(值)
    如果 链表.尾 == 空:
        链表.头 = 节点
        链表.尾 = 节点
    否则:
        链表.尾.下一个 = 节点
        链表.尾 = 节点
    链表.长度 = 链表.长度 + 1
    返回 链表

函程 链表转列表(链表): // 公开
    设 结果 = []
    设 当前 = 链表.头
    循环 当前 != 空:
        结果 = 追加(结果, 当前.值)
        当前 = 当前.下一个
    返回 结果

函程 列表转链表(列表): // 公开
    设 链表 = 创建链表()
    遍 项 于 列表:
        链表尾部插入(链表, 项)
    返回 链表

// === 计数器 ===

函程 创建计数器(): // 公开
    返回 {}

函程 计数(计数器, 元素): // 公开
    // 对元素计数加一
    如果 计数器.包含(元素):
        计数器[元素] = 计数器[元素] + 1
    否则:
        计数器[元素] = 1
    返回 计数器

函程 批量计数(计数器, 列表): // 公开
    遍 项 于 列表:
        计数(计数器, 项)
    返回 计数器

函程 最常见(计数器, n = 10): // 公开
    // 返回出现次数最多的n个元素
    设 对列表 = []
    遍 键, 值 于 计数器:
        对列表 = 追加(对列表, {元素: 键, 次数: 值})
    // 简单排序
    设 排序后 = 按字段降序(对列表, "次数")
    设 结果 = []
    设 限制 = 最小值(n, 长度(排序后))
    设 计 = 0
    循环 计 < 限制:
        结果 = 追加(结果, 排序后[计])
        计 = 计 + 1
    返回 结果

函程 按字段降序(列表, 字段): // 内部
    // 简单冒泡排序
    设 结果 = []
    遍 项 于 列表:
        结果 = 追加(结果, 项)
    设 n = 长度(结果)
    设 i = 0
    循环 i < n - 1:
        设 j = 0
        循环 j < n - 1 - i:
            如果 结果[j][字段] < 结果[j+1][字段]:
                设 临时 = 结果[j]
                结果[j] = 结果[j+1]
                结果[j+1] = 临时
            j = j + 1
        i = i + 1
    返回 结果

// === 辅助 ===

函程 交换元素(列表, i, j): // 内部
    设 临时 = 列表[i]
    列表[i] = 列表[j]
    列表[j] = 临时

函程 最小值(a, b): // 内部
    如果 a < b:
        返回 a
    返回 b
