// PEG解析工具
// 解析表达式语法（Parsing Expression Grammar）模式匹配

// === PEG表达式 ===

函程 字面匹配(文本, 目标, 位置 = 0): // 公开
    // 在指定位置尝试匹配字面字符串
    如果 位置 + 文本.长度() > 目标.长度():
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    设 截取 = 目标.子串(位置, 文本.长度())
    如果 截取 == 文本:
        返回 {匹配: 真, 长度: 文本.长度(), 位置: 位置}
    返回 {匹配: 假, 长度: 0, 位置: 位置}

函程 字符类匹配(字符列表, 目标, 位置 = 0): // 公开
    // 匹配字符类中的任一字符
    如果 位置 >= 目标.长度():
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    设 字符 = 目标[位置]
    循环 项 于 字符列表:
        如果 字符 == 项:
            返回 {匹配: 真, 长度: 1, 位置: 位置}
    返回 {匹配: 假, 长度: 0, 位置: 位置}

函程 字符范围匹配(起始字符, 结束字符, 目标, 位置 = 0): // 公开
    // 匹配字符范围内的一个字符
    如果 位置 >= 目标.长度():
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    设 字符 = 目标[位置]
    如果 字符 >= 起始字符 且 字符 <= 结束字符:
        返回 {匹配: 真, 长度: 1, 位置: 位置}
    返回 {匹配: 假, 长度: 0, 位置: 位置}

函程 任意字符匹配(目标, 位置 = 0): // 公开
    // 匹配任意一个字符
    如果 位置 < 目标.长度():
        返回 {匹配: 真, 长度: 1, 位置: 位置}
    返回 {匹配: 假, 长度: 0, 位置: 位置}

// === 组合子 ===

函程 顺序匹配(规则列表, 目标, 位置 = 0): // 公开
    // 顺序组合：依次匹配所有规则
    设 当前位置 = 位置
    设 总长度 = 0
    设 捕获列表 = []
    
    循环 规则 于 规则列表:
        设 结果 = 规则(目标, 当前位置)
        如果 非 结果.匹配:
            返回 {匹配: 假, 长度: 0, 位置: 位置}
        当前位置 = 当前位置 + 结果.长度
        总长度 = 总长度 + 结果.长度
        如果 结果.包含("捕获") 且 结果.捕获.长度() > 0:
            循环 项 于 结果.捕获:
                捕获列表.添加(项)
    
    返回 {匹配: 真, 长度: 总长度, 位置: 位置, 捕获: 捕获列表}

函程 选择匹配(规则列表, 目标, 位置 = 0): // 公开
    // 有序选择：尝试第一个成功的规则
    循环 规则 于 规则列表:
        设 结果 = 规则(目标, 位置)
        如果 结果.匹配:
            返回 结果
    返回 {匹配: 假, 长度: 0, 位置: 位置}

函程 零或多次(规则, 目标, 位置 = 0): // 公开
    // 匹配零次或多次（*）
    设 当前位置 = 位置
    设 总长度 = 0
    设 捕获列表 = []
    
    循环 当 真:
        设 结果 = 规则(目标, 当前位置)
        如果 非 结果.匹配:
            跳出
        当前位置 = 当前位置 + 结果.长度
        总长度 = 总长度 + 结果.长度
        如果 结果.包含("捕获") 且 结果.捕获.长度() > 0:
            循环 项 于 结果.捕获:
                捕获列表.添加(项)
    
    返回 {匹配: 真, 长度: 总长度, 位置: 位置, 捕获: 捕获列表}

函程 一或多次(规则, 目标, 位置 = 0): // 公开
    // 匹配一次或多次（+）
    设 结果 = 零或多次(规则, 目标, 位置)
    如果 结果.长度 == 0:
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    返回 结果

函程 零或一次(规则, 目标, 位置 = 0): // 公开
    // 匹配零次或一次（?）
    设 结果 = 规则(目标, 位置)
    如果 结果.匹配:
        返回 结果
    返回 {匹配: 真, 长度: 0, 位置: 位置}

函程 否定前瞻(规则, 目标, 位置 = 0): // 公开
    // 否定前瞻（!）：如果规则不匹配则成功，不消耗字符
    设 结果 = 规则(目标, 位置)
    如果 结果.匹配:
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    返回 {匹配: 真, 长度: 0, 位置: 位置}

函程 肯定前瞻(规则, 目标, 位置 = 0): // 公开
    // 肯定前瞻（&）：如果规则匹配则成功，不消耗字符
    设 结果 = 规则(目标, 位置)
    如果 结果.匹配:
        返回 {匹配: 真, 长度: 0, 位置: 位置}
    返回 {匹配: 假, 长度: 0, 位置: 位置}

// === 常用规则构造 ===

函程 数字匹配(目标, 位置 = 0): // 公开
    返回 字符范围匹配("0", "9", 目标, 位置)

函程 字母匹配(目标, 位置 = 0): // 公开
    设 结果 = 字符范围匹配("a", "z", 目标, 位置)
    如果 结果.匹配:
        返回 结果
    返回 字符范围匹配("A", "Z", 目标, 位置)

函程 空白匹配(目标, 位置 = 0): // 公开
    返回 字符类匹配([" ", "\t", "\n", "\r"], 目标, 位置)

函程 标识符匹配(目标, 位置 = 0): // 公开
    // 匹配标识符：字母或下划线开头，后跟字母数字下划线
    如果 位置 >= 目标.长度():
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    设 首 = 目标[位置]
    如果 非 ((首 >= "a" 且 首 <= "z") 或 (首 >= "A" 且 首 <= "Z") 或 首 == "_"):
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    设 长度 = 1
    循环 当 位置 + 长度 < 目标.长度():
        设 字 = 目标[位置 + 长度]
        如果 (字 >= "a" 且 字 <= "z") 或 (字 >= "A" 且 字 <= "Z") 或 (字 >= "0" 且 字 <= "9") 或 字 == "_":
            长度 = 长度 + 1
        否则:
            跳出
    返回 {匹配: 真, 长度: 长度, 位置: 位置}

函程 整数匹配(目标, 位置 = 0): // 公开
    // 匹配整数（可选正负号）
    设 当前 = 位置
    如果 当前 < 目标.长度() 且 (目标[当前] == "+" 或 目标[当前] == "-"):
        当前 = 当前 + 1
    设 长度 = 当前 - 位置
    循环 当 当前 < 目标.长度() 且 目标[当前] >= "0" 且 目标[当前] <= "9":
        当前 = 当前 + 1
        长度 = 长度 + 1
    如果 长度 == 0 或 (长度 == 1 且 (目标[位置] == "+" 或 目标[位置] == "-")):
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    返回 {匹配: 真, 长度: 长度, 位置: 位置}

函程 浮点数匹配(目标, 位置 = 0): // 公开
    // 匹配浮点数
    设 当前 = 位置
    如果 当前 < 目标.长度() 且 (目标[当前] == "+" 或 目标[当前] == "-"):
        当前 = 当前 + 1
    设 整数部分 = 0
    循环 当 当前 < 目标.长度() 且 目标[当前] >= "0" 且 目标[当前] <= "9":
        当前 = 当前 + 1
        整数部分 = 整数部分 + 1
    设 小数部分 = 0
    如果 当前 < 目标.长度() 且 目标[当前] == ".":
        当前 = 当前 + 1
        循环 当 当前 < 目标.长度() 且 目标[当前] >= "0" 且 目标[当前] <= "9":
            当前 = 当前 + 1
            小数部分 = 小数部分 + 1
    设 指数部分 = 0
    如果 当前 < 目标.长度() 且 (目标[当前] == "e" 或 目标[当前] == "E"):
        当前 = 当前 + 1
        如果 当前 < 目标.长度() 且 (目标[当前] == "+" 或 目标[当前] == "-"):
            当前 = 当前 + 1
        循环 当 当前 < 目标.长度() 且 目标[当前] >= "0" 且 目标[当前] <= "9":
            当前 = 当前 + 1
            指数部分 = 指数部分 + 1
    设 总长度 = 当前 - 位置
    如果 总长度 == 0:
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    返回 {匹配: 真, 长度: 总长度, 位置: 位置}

函程 引号字符串匹配(引号 = "\"", 目标, 位置 = 0): // 公开
    // 匹配引号内的字符串
    如果 位置 >= 目标.长度() 或 目标[位置] != 引号:
        返回 {匹配: 假, 长度: 0, 位置: 位置}
    设 当前 = 位置 + 1
    循环 当 当前 < 目标.长度():
        如果 目标[当前] == "\\" 且 当前 + 1 < 目标.长度():
            当前 = 当前 + 2
        否则 如果 目标[当前] == 引号:
            返回 {匹配: 真, 长度: 当前 - 位置 + 1, 位置: 位置}
        否则:
            当前 = 当前 + 1
    返回 {匹配: 假, 长度: 0, 位置: 位置}

// === PEG解析器 ===

函程 创建解析器(规则表): // 公开
    // 创建PEG解析器
    // 规则表为 {规则名: 函数} 的字典
    返回 {
        规则: 规则表,
        起始规则: "开始"
    }

函程 解析(解析器, 文本, 起始规则 = ""): // 公开
    // 使用解析器解析文本
    设 规则名 = 起始规则
    如果 规则名.长度() == 0:
        规则名 = 解析器.起始规则
    如果 非 解析器.规则.包含(规则名):
        返回 {成功: 假, 错误: "未知规则: " + 规则名}
    设 规则 = 解析器.规则[规则名]
    设 结果 = 规则(文本, 0)
    如果 结果.匹配:
        返回 {成功: 真, 匹配长度: 结果.长度, 位置: 结果.位置, 捕获: 结果.读取("捕获", [])}
    返回 {成功: 假, 错误: "匹配失败", 位置: 0}
