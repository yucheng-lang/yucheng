// ===== 语程标准库：有理数 =====
// 提供有理数运算工具函数
//
// 公开接口：创建有理数、有理数分子、有理数分母、
//           有理数加、有理数减、有理数乘、有理数除、
//           有理数约分、有理数转浮点、有理数转字符串、
//           有理数相等、有理数比较、有理数绝对值、有理数幂

// ===== 有理数构造 =====
// 有理数用列表 [分子, 分母] 表示

函程 创建有理数(分子, 分母): // 公开
    如果 分母 == 0:
        返回 [0, 1]
    设 结果 = 有理数约分([分子, 分母])
    返回 结果

函程 有理数分子(有理数): // 公开
    返回 有理数[0]

函程 有理数分母(有理数): // 公开
    返回 有理数[1]

// ===== 有理数约分 =====

函程 有理数约分(有理数): // 公开
    设 分子 = 有理数[0]
    设 分母 = 有理数[1]
    如果 分母 == 0:
        返回 [0, 1]
    // 保证分母为正
    如果 分母 < 0:
        分子 = -分子
        分母 = -分母
    设 公约 = 最大公约数(绝对值(分子), 绝对值(分母))
    如果 公约 == 0:
        返回 [0, 1]
    返回 [分子 / 公约, 分母 / 公约]

// ===== 有理数运算 =====

函程 有理数加(a, b): // 公开
    设 分子 = a[0] * b[1] + b[0] * a[1]
    设 分母 = a[1] * b[1]
    返回 有理数约分([分子, 分母])

函程 有理数减(a, b): // 公开
    设 分子 = a[0] * b[1] - b[0] * a[1]
    设 分母 = a[1] * b[1]
    返回 有理数约分([分子, 分母])

函程 有理数乘(a, b): // 公开
    设 分子 = a[0] * b[0]
    设 分母 = a[1] * b[1]
    返回 有理数约分([分子, 分母])

函程 有理数除(a, b): // 公开
    如果 b[0] == 0:
        返回 [0, 1]
    设 分子 = a[0] * b[1]
    设 分母 = a[1] * b[0]
    返回 有理数约分([分子, 分母])

// ===== 有理数比较 =====

函程 有理数相等(a, b): // 公开
    设 约a = 有理数约分(a)
    设 约b = 有理数约分(b)
    返回 约a[0] == 约b[0] 且 约a[1] == 约b[1]

函程 有理数比较(a, b): // 公开
    设 差 = 有理数减(a, b)
    返回 差[0]

函程 有理数小于(a, b): // 公开
    返回 有理数比较(a, b) < 0

函程 有理数大于(a, b): // 公开
    返回 有理数比较(a, b) > 0

// ===== 有理数转换 =====

函程 有理数转浮点(有理数): // 公开
    返回 转浮点数(有理数[0]) / 转浮点数(有理数[1])

函程 有理数转字符串(有理数): // 公开
    返回 转字符串(有理数[0]) + "/" + 转字符串(有理数[1])

// ===== 有理数其他 =====

函程 有理数绝对值(有理数): // 公开
    返回 有理数约分([绝对值(有理数[0]), 绝对值(有理数[1])])

函程 有理数幂(有理数, 指数): // 公开
    如果 指数 == 0:
        返回 [1, 1]
    如果 指数 < 0:
        设 倒数 = 有理数约分([有理数[1], 有理数[0]])
        返回 有理数幂(倒数, -指数)
    设 分子 = 有理数[0]
    设 分母 = 有理数[1]
    设 i = 1
    循环 i < 指数:
        分子 = 分子 * 有理数[0]
        分母 = 分母 * 有理数[1]
        i = i + 1
    返回 有理数约分([分子, 分母])

函程 有理数倒数(有理数): // 公开
    如果 有理数[0] == 0:
        返回 [0, 1]
    返回 有理数约分([有理数[1], 有理数[0]])
