// 浏览器 - 打开默认浏览器
// 跨平台：Windows 用 start，macOS 用 open，Linux 用 xdg-open

// === 打开浏览器 ===

函程 打开浏览器(URL): // 公开
    // 使用用户默认浏览器打开URL
    如果 字符串长度(URL) == 0:
        抛出 "URL不能为空"
    设 完整URL = 准备URL(URL)
    执行命令(获取打开命令() + " " + 引号包裹(完整URL))

函程 打开空白页(): // 公开
    // 在默认浏览器中打开空白页
    执行命令(获取打开命令() + " " + 引号包裹("about:blank"))

函程 打开搜索(查询词, 搜索引擎="百度"): // 公开
    // 在默认浏览器中打开搜索结果
    设 URL = 获取搜索URL(查询词, 搜索引擎)
    打开浏览器(URL)

函程 打开HTML(HTML内容): // 公开
    // 将HTML内容写入临时文件并在浏览器中打开
    设 临时路径 = 临时目录() + "/语程_预览_" + 转字符串(时间戳()) + ".html"
    写入文件(临时路径, HTML内容)
    打开浏览器(临时路径)

// === URL准备 ===

函程 准备URL(路径): // 公开
    // 准备URL，如果不是完整URL则添加file://协议
    如果 包含(路径, "://"):
        返回 路径
    否则:
        返回 "file://" + 路径

函程 获取搜索URL(查询词, 搜索引擎): // 公开
    // 获取搜索引擎的搜索URL
    设 编码查询 = URL编码(查询词)
    设 引擎表 = {
        "百度": "https://www.baidu.com/s?wd=",
        "谷歌": "https://www.google.com/search?q=",
        "必应": "https://www.bing.com/search?q=",
        "搜狗": "https://www.sogou.com/web?query=",
        "360": "https://www.so.com/s?q=",
        "DuckDuckGo": "https://duckduckgo.com/?q="
    }
    设 基础URL = 引擎表.获取默认值(搜索引擎, 引擎表["百度"])
    返回 基础URL + 编码查询

// === 系统命令 ===

函程 获取打开命令(): // 公开
    // 获取操作系统特定的打开命令
    设 系统 = 环境变量("OS")
    如果 包含(转小写(系统), "windows"):
        返回 "start"
    否则如果 包含(转小写(系统), "darwin") 或 包含(转小写(系统), "macos"):
        返回 "open"
    否则:
        返回 "xdg-open"

函程 引号包裹(文本): // 公开
    // 根据操作系统用引号包裹文本
    设 系统 = 环境变量("OS")
    如果 包含(转小写(系统), "windows"):
        返回 '"' + 文本 + '"'
    否则:
        返回 "'" + 替换(文本, "'", "'\\''") + "'"
