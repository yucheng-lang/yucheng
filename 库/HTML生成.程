// ===== 语程标准库：HTML生成 =====
// 提供声明式HTML代码生成工具
// 借鉴空灵语言 htmlgen 库的设计思想
//
// 公开接口：生成标签、生成自闭合标签、转义HTML、转义属性、
//           HTML文档、HTML页面、
//           加粗、斜体、下划线、删除线、链接、图片、
//           标题、段落、换行、水平线、列表、表格、
//           表单、输入框、按钮、选择框、文本域、
//           div、span、头部、主体、样式、脚本、
//           CSS样式、CSS类

// ===== HTML转义 =====

函程 转义HTML(文本): // 公开
    设 结果 = 文本
    结果 = 替换(结果, "&", "&amp;")
    结果 = 替换(结果, "<", "&lt;")
    结果 = 替换(结果, ">", "&gt;")
    返回 结果

函程 转义属性(文本): // 公开
    设 结果 = 转义HTML(文本)
    结果 = 替换(结果, "\"", "&quot;")
    结果 = 替换(结果, "'", "&#39;")
    返回 结果

// ===== 核心标签生成 =====

函程 生成标签(标签名, 内容="", 属性表={}): // 公开
    设 属性串 = 生成属性(属性表)
    设 结果 = "<" + 标签名
    如果 属性串.长度() > 0:
        结果 = 结果 + " " + 属性串
    结果 = 结果 + ">" + 内容 + "</" + 标签名 + ">"
    返回 结果

函程 生成自闭合标签(标签名, 属性表={}): // 公开
    设 属性串 = 生成属性(属性表)
    设 结果 = "<" + 标签名
    如果 属性串.长度() > 0:
        结果 = 结果 + " " + 属性串
    结果 = 结果 + " />"
    返回 结果

函程 生成属性(属性表): // 公开
    设 部分 = []
    循环 键, 值 于 属性表:
        如果 值 == "":
            部分.添加(键)
        否则:
            部分.添加(键 + "=\"" + 转义属性(转文本(值)) + "\"")
    返回 连接(部分, " ")

// ===== 文档结构 =====

函程 HTML文档(标题, 主体内容, 编码="utf-8", 语言="zh-CN"): // 公开
    设 头部 = 生成标签("meta", "", {charset: 编码})
    头部 = 头部 + 生成标签("title", 转义HTML(标题))
    设 头 = 生成标签("head", 头部)
    设 体 = 生成标签("body", 主体内容)
    返回 "<!DOCTYPE html>" + 生成标签("html", 头 + 体, {lang: 语言})

函程 HTML页面(标题, 主体内容, 样式="", 脚本="", 编码="utf-8"): // 公开
    设 头部 = 生成标签("meta", "", {charset: 编码})
    头部 = 头部 + 生成标签("title", 转义HTML(标题))
    如果 样式.长度() > 0:
        头部 = 头部 + 生成标签("style", 样式)
    如果 脚本.长度() > 0:
        头部 = 头部 + 生成标签("script", 脚本)
    设 头 = 生成标签("head", 头部)
    设 体 = 生成标签("body", 主体内容)
    返回 "<!DOCTYPE html>" + 生成标签("html", 头 + 体, {lang: "zh-CN"})

// ===== 文本标签 =====

函程 标题(内容, 级别=1): // 公开
    返回 生成标签("h" + 转文本(级别), 转义HTML(内容))

函程 段落(内容): // 公开
    返回 生成标签("p", 转义HTML(内容))

函程 换行(): // 公开
    返回 生成自闭合标签("br")

函程 水平线(): // 公开
    返回 生成自闭合标签("hr")

函程 加粗(内容): // 公开
    返回 生成标签("strong", 转义HTML(内容))

函程 斜体(内容): // 公开
    返回 生成标签("em", 转义HTML(内容))

函程 下划线(内容): // 公开
    返回 生成标签("u", 转义HTML(内容))

函程 删除线(内容): // 公开
    返回 生成标签("del", 转义HTML(内容))

函程 上标(内容): // 公开
    返回 生成标签("sup", 转义HTML(内容))

函程 下标(内容): // 公开
    返回 生成标签("sub", 转义HTML(内容))

函程 代码(内容): // 公开
    返回 生成标签("code", 转义HTML(内容))

函程 预格式(内容): // 公开
    返回 生成标签("pre", 转义HTML(内容))

函程 引用(内容, 来源=""): // 公开
    如果 来源.长度() > 0:
        返回 生成标签("blockquote", 转义HTML(内容) + 生成标签("cite", 转义HTML(来源)))
    返回 生成标签("blockquote", 转义HTML(内容))

// ===== 链接与媒体 =====

函程 链接(地址, 文本, 新窗口=假): // 公开
    如果 新窗口:
        返回 生成标签("a", 转义HTML(文本), {href: 地址, target: "_blank", rel: "noopener noreferrer"})
    返回 生成标签("a", 转义HTML(文本), {href: 地址})

函程 图片(地址, 替代文本="", 宽度="", 高度=""): // 公开
    设 属性 = {src: 地址}
    如果 替代文本.长度() > 0:
        属性 = 属性.设置("alt", 替代文本)
    如果 宽度.长度() > 0:
        属性 = 属性.设置("width", 宽度)
    如果 高度.长度() > 0:
        属性 = 属性.设置("height", 高度)
    返回 生成自闭合标签("img", 属性)

函程 音频(地址, 控制器=真, 自动播放=假): // 公开
    设 属性 = {src: 地址}
    如果 控制器:
        属性 = 属性.设置("controls", "")
    如果 自动播放:
        属性 = 属性.设置("autoplay", "")
    返回 生成标签("audio", "您的浏览器不支持音频播放", 属性)

函程 视频(地址, 控制器=真, 宽度="", 高度=""): // 公开
    设 属性 = {src: 地址}
    如果 控制器:
        属性 = 属性.设置("controls", "")
    如果 宽度.长度() > 0:
        属性 = 属性.设置("width", 宽度)
    如果 高度.长度() > 0:
        属性 = 属性.设置("height", 高度)
    返回 生成标签("video", "您的浏览器不支持视频播放", 属性)

// ===== 列表 =====

函程 无序列表(项目列表, 样式类=""): // 公开
    设 属性 = {}
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    设 内容 = ""
    循环 项 于 项目列表:
        内容 = 内容 + 列表项(项)
    返回 生成标签("ul", 内容, 属性)

函程 有序列表(项目列表, 起始=1, 样式类=""): // 公开
    设 属性 = {}
    如果 起始 != 1:
        属性 = 属性.设置("start", 转文本(起始))
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    设 内容 = ""
    循环 项 于 项目列表:
        内容 = 内容 + 列表项(项)
    返回 生成标签("ol", 内容, 属性)

函程 列表项(内容): // 公开
    返回 生成标签("li", 转义HTML(内容))

// ===== 表格 =====

函程 表格(数据, 表头行="", 样式类=""): // 公开
    设 属性 = {}
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    设 内容 = ""
    如果 表头行.长度() > 0:
        设 表头内容 = ""
        循环 单元格 于 表头行:
            表头内容 = 表头内容 + 生成标签("th", 转义HTML(单元格))
        内容 = 内容 + 生成标签("tr", 表头内容)
    循环 行 于 数据:
        设 行内容 = ""
        循环 单元格 于 行:
            行内容 = 行内容 + 生成标签("td", 转义HTML(单元格))
        内容 = 内容 + 生成标签("tr", 行内容)
    返回 生成标签("table", 内容, 属性)

// ===== 表单 =====

函程 表单(动作, 方法="post", 内容="", 样式类=""): // 公开
    设 属性 = {action: 动作, method: 方法}
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    返回 生成标签("form", 内容, 属性)

函程 输入框(类型="text", 名称="", 值="", 占位符=""): // 公开
    设 属性 = {type: 类型}
    如果 名称.长度() > 0:
        属性 = 属性.设置("name", 名称)
    如果 值.长度() > 0:
        属性 = 属性.设置("value", 值)
    如果 占位符.长度() > 0:
        属性 = 属性.设置("placeholder", 占位符)
    返回 生成自闭合标签("input", 属性)

函程 按钮(文本, 类型="submit"): // 公开
    返回 生成标签("button", 转义HTML(文本), {type: 类型})

函程 文本域(名称, 行数=4, 列数=50, 内容=""): // 公开
    设 属性 = {name: 名称, rows: 转文本(行数), cols: 转文本(列数)}
    返回 生成标签("textarea", 转义HTML(内容), 属性)

函程 标签(文本, 关联ID=""): // 公开
    如果 关联ID.长度() > 0:
        返回 生成标签("label", 转义HTML(文本), {for: 关联ID})
    返回 生成标签("label", 转义HTML(文本))

// ===== 布局标签 =====

函程 div(内容, 样式类="", 标识=""): // 公开
    设 属性 = {}
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    如果 标识.长度() > 0:
        属性 = 属性.设置("id", 标识)
    返回 生成标签("div", 内容, 属性)

函程 span(内容, 样式类="", 标识=""): // 公开
    设 属性 = {}
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    如果 标识.长度() > 0:
        属性 = 属性.设置("id", 标识)
    返回 生成标签("span", 转义HTML(内容), 属性)

函程 头部(内容): // 公开
    返回 生成标签("header", 内容)

函程 主体(内容): // 公开
    返回 生成标签("main", 内容)

函程 页脚(内容): // 公开
    返回 生成标签("footer", 内容)

函程 导航(内容): // 公开
    返回 生成标签("nav", 内容)

函程 侧栏(内容): // 公开
    返回 生成标签("aside", 内容)

函程 区域(内容, 样式类=""): // 公开
    设 属性 = {}
    如果 样式类.长度() > 0:
        属性 = 属性.设置("class", 样式类)
    返回 生成标签("section", 内容, 属性)

函程 文章(内容): // 公开
    返回 生成标签("article", 内容)

// ===== 样式与脚本 =====

函程 样式(CSS内容): // 公开
    返回 生成标签("style", CSS内容)

函程 脚本(JS内容, 来源=""): // 公开
    如果 来源.长度() > 0:
        返回 生成标签("script", "", {src: 来源})
    返回 生成标签("script", JS内容)

函程 外部样式表(地址): // 公开
    返回 生成自闭合标签("link", {rel: "stylesheet", href: 地址})

函程 外部脚本(地址): // 公开
    返回 生成标签("script", "", {src: 地址})

// ===== 内联样式 =====

函程 CSS样式(属性表): // 公开
    设 部分 = []
    循环 键, 值 于 属性表:
        部分.添加(键 + ": " + 转文本(值))
    返回 连接(部分, "; ")

函程 CSS类(选择器, 属性表): // 公开
    返回 选择器 + " { " + CSS样式(属性表) + " }"

// ===== 辅助函数 =====

函程 连接(列表, 分隔符): // 内部
    如果 列表.长度() == 0:
        返回 ""
    设 结果 = 转文本(列表[0])
    设 i = 1
    循环 i < 列表.长度():
        结果 = 结果 + 分隔符 + 转文本(列表[i])
        i = i + 1
    返回 结果
