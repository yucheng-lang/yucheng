// ===== 语程标准库：字典工具 =====
// 提供字典操作常用函数
//
// 公开接口：所有键、所有值、键存在、取值、设置键值、删除键、
//           合并字典、深度合并、映射值、映射键、过滤字典、
//           字典大小、字典为空、查找键、值计数、
//           反转字典、字典转列表、列表转字典、
//           遍历字典、收集键、收集值、
//           按键排序、按值排序、选择键、排除键

// ===== 基本操作 =====

函程 所有键(字典): // 公开
    返回 字典.键

函程 所有值(字典): // 公开
    设 结果 = []
    遍 k 于 字典.键:
        结果.添加(字典[k])
    返回 结果

函程 键存在(字典, 键): // 公开
    返回 字典.包含(键)

函程 取值(字典, 键, 默认): // 公开
    如果 字典.包含(键):
        返回 字典[键]
    返回 默认

函程 设置键值(字典, 键, 值): // 公开
    字典[键] = 值
    返回 字典

函程 删除键(字典, 键): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        如果 k != 键:
            结果[k] = 字典[k]
    返回 结果

// ===== 合并与更新 =====

函程 合并字典(字典1, 字典2): // 公开
    设 结果 = {}
    遍 k 于 字典1.键:
        结果[k] = 字典1[k]
    遍 k 于 字典2.键:
        结果[k] = 字典2[k]
    返回 结果

函程 深度合并(基础, 覆盖): // 公开
    设 结果 = {}
    // 先复制基础字典
    遍 k 于 基础.键:
        结果[k] = 基础[k]
    // 覆盖或合并
    遍 k 于 覆盖.键:
        结果[k] = 覆盖[k]
    返回 结果

// ===== 映射与过滤 =====

函程 映射值(字典, 函): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        结果[k] = 函(字典[k])
    返回 结果

函程 映射键(字典, 函): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        设 新键 = 函(k)
        结果[新键] = 字典[k]
    返回 结果

函程 过滤字典(字典, 条件函): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        如果 条件函(k, 字典[k]):
            结果[k] = 字典[k]
    返回 结果

// ===== 查询与统计 =====

函程 字典大小(字典): // 公开
    返回 字典.长度

函程 字典为空(字典): // 公开
    返回 字典.长度 == 0

函程 查找键(字典, 值): // 公开
    遍 k 于 字典.键:
        如果 字典[k] == 值:
            返回 k
    返回 ""

函程 值计数(字典): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        设 v = 转字符串(字典[k])
        如果 结果.包含(v):
            结果[v] = 结果[v] + 1
        否则:
            结果[v] = 1
    返回 结果

// ===== 反转与转换 =====

函程 反转字典(字典): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        结果[转字符串(字典[k])] = k
    返回 结果

函程 字典转列表(字典): // 公开
    设 结果 = []
    遍 k 于 字典.键:
        结果.添加([k, 字典[k]])
    返回 结果

函程 列表转字典(列表): // 公开
    设 结果 = {}
    遍 对 于 列表:
        结果[对[0]] = 对[1]
    返回 结果

// ===== 遍历工具 =====

函程 遍历字典(字典, 函): // 公开
    遍 k 于 字典.键:
        函(k, 字典[k])

函程 收集键(字典, 函): // 公开
    设 结果 = []
    遍 k 于 字典.键:
        结果.添加(函(k))
    返回 结果

函程 收集值(字典, 函): // 公开
    设 结果 = []
    遍 k 于 字典.键:
        结果.添加(函(字典[k]))
    返回 结果

// ===== 排序 =====

函程 按键排序(字典): // 公开
    设 键列表 = 排序(字典.键)
    设 结果 = {}
    遍 k 于 键列表:
        结果[k] = 字典[k]
    返回 结果

函程 按值排序(字典): // 公开
    设 对列表 = 字典转列表(字典)
    // 冒泡排序按值
    设 n = 数组长度(对列表)
    设 i = 0
    循环 i < n - 1:
        设 j = 0
        循环 j < n - 1 - i:
            如果 对列表[j][1] > 对列表[j + 1][1]:
                设 临时 = 对列表[j]
                对列表[j] = 对列表[j + 1]
                对列表[j + 1] = 临时
            j = j + 1
        i = i + 1
    返回 列表转字典(对列表)

// ===== 选择与提取 =====

函程 选择键(字典, 键列表): // 公开
    设 结果 = {}
    遍 k 于 键列表:
        如果 字典.包含(k):
            结果[k] = 字典[k]
    返回 结果

函程 排除键(字典, 键列表): // 公开
    设 结果 = {}
    遍 k 于 字典.键:
        设 保留 = 真
        遍 排 于 键列表:
            如果 k == 排:
                保留 = 假
        如果 保留:
            结果[k] = 字典[k]
    返回 结果
