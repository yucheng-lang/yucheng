// 性能分析 - 性能计时与统计
// 使用时间戳()进行计时

// === 计时器 ===

函程 创建计时器(): // 公开
    返回 {开始时间: 0, 累计秒: 0, 运行中: 假}

函程 开始计时(计时器): // 公开
    计时器.开始时间 = 时间戳()
    计时器.运行中 = 真

函程 停止计时(计时器): // 公开
    如果 计时器.运行中:
        设 经过 = 时间戳() - 计时器.开始时间
        计时器.累计秒 = 计时器.累计秒 + 经过
        计时器.运行中 = 假
        返回 经过
    返回 0

函程 重置计时器(计时器): // 公开
    计时器.累计秒 = 0
    计时器.运行中 = 假

函程 获取经过秒(计时器): // 公开
    设 累计 = 计时器.累计秒
    如果 计时器.运行中:
        累计 = 累计 + (时间戳() - 计时器.开始时间)
    返回 累计

函程 获取经过毫秒(计时器): // 公开
    返回 获取经过秒(计时器) * 1000

函程 获取经过微秒(计时器): // 公开
    返回 获取经过秒(计时器) * 1000000

// === 便捷计时 ===

函程 计时执行(函数, 次数=1): // 公开
    设 计时器 = 创建计时器()
    开始计时(计时器)
    设 结果 = 空
    设 i = 0
    循环 当 i < 次数:
        结果 = 函数()
        i = i + 1
    停止计时(计时器)
    返回 {结果: 结果, 秒: 获取经过秒(计时器), 毫秒: 获取经过毫秒(计时器), 微秒: 获取经过微秒(计时器)}

函程 比较性能(函数列表, 标签列表=[], 次数=100): // 公开
    设 结果列表 = []
    设 索引 = 0
    循环 当 索引 < 函数列表.长度():
        设 函 = 函数列表[索引]
        设 标签 = "函数" + 转文本(索引 + 1)
        如果 索引 < 标签列表.长度():
            标签 = 标签列表[索引]
        设 计时器 = 创建计时器()
        开始计时(计时器)
        设 i = 0
        循环 当 i < 次数:
            函()
            i = i + 1
        停止计时(计时器)
        结果列表.添加({
            标签: 标签,
            总毫秒: 获取经过毫秒(计时器),
            平均毫秒: 获取经过毫秒(计时器) / 次数,
            每秒操作: 次数 / 获取经过秒(计时器)
        })
        索引 = 索引 + 1
    返回 结果列表

// === 基准测试 ===

函程 基准测试(函数, 最短时间秒=1, 次数上限=1000000): // 公开
    设 开始 = 时间戳()
    设 执行次数 = 0

    循环 当 执行次数 < 次数上限:
        函数()
        执行次数 = 执行次数 + 1
        设 经过 = 时间戳() - 开始
        如果 经过 >= 最短时间秒:
            跳出

    设 总秒 = 时间戳() - 开始
    返回 {
        执行次数: 执行次数,
        总时间秒: 总秒,
        总时间毫秒: 总秒 * 1000,
        平均秒: 总秒 / 执行次数,
        平均毫秒: 总秒 * 1000 / 执行次数,
        每秒操作: 执行次数 / 总秒
    }

// === 辅助函数 ===

函程 格式化时间(秒): // 公开
    如果 秒 < 0.000001:
        返回 转文本(秒 * 1000000000) + " ns"
    否则如果 秒 < 0.001:
        返回 转文本(秒 * 1000000) + " μs"
    否则如果 秒 < 1:
        返回 转文本(秒 * 1000) + " ms"
    否则:
        返回 转文本(秒) + " s"
