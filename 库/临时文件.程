// 临时文件 - 临时文件与目录管理

// === 临时文件创建 ===

函程 创建临时文件(前缀="语程_", 后缀=".tmp", 目录=""): // 公开
    // 创建临时文件并返回文件路径
    设 临时目录路径 = 临时目录()
    如果 字符串长度(目录) > 0:
        临时目录路径 = 目录
    设 文件名 = 前缀 + 生成唯一标识() + 后缀
    设 完整路径 = 路径合并(临时目录路径, 文件名)
    写入文件(完整路径, "")
    返回 完整路径

函程 创建临时目录(前缀="语程_", 目录=""): // 公开
    // 创建临时目录并返回目录路径
    设 临时目录路径 = 临时目录()
    如果 字符串长度(目录) > 0:
        临时目录路径 = 目录
    设 目录名 = 前缀 + 生成唯一标识()
    设 完整路径 = 路径合并(临时目录路径, 目录名)
    创建目录(完整路径)
    返回 完整路径

// === 临时文件带内容 ===

函程 创建临时文件带内容(内容, 前缀="语程_", 后缀=".tmp", 目录=""): // 公开
    设 路径 = 创建临时文件(前缀, 后缀, 目录)
    写入文件(路径, 内容)
    返回 路径

函程 创建临时文本文件(内容, 目录=""): // 公开
    返回 创建临时文件带内容(内容, "语程_文本_", ".txt", 目录)

函程 创建临时JSON文件(内容, 目录=""): // 公开
    返回 创建临时文件带内容(内容, "语程_JSON_", ".json", 目录)

函程 创建临时HTML文件(内容, 目录=""): // 公开
    返回 创建临时文件带内容(内容, "语程_HTML_", ".html", 目录)

// === 临时资源管理 ===

函程 使用临时文件(操作函数, 前缀="语程_", 后缀=".tmp"): // 公开
    设 路径 = 创建临时文件(前缀, 后缀)
    尝试:
        设 结果 = 操作函数(路径)
        返回 结果
    最后:
        删除文件(路径)

函程 使用临时目录(操作函数, 前缀="语程_"): // 公开
    设 路径 = 创建临时目录(前缀)
    尝试:
        设 结果 = 操作函数(路径)
        返回 结果
    最后:
        删除目录(路径)

// === 唯一标识生成 ===

函程 生成唯一标识(): // 公开
    返回 转字符串(时间戳()) + "_" + 转字符串(随机整数(10000, 99999))

函程 生成临时文件名(前缀="语程_", 后缀=".tmp"): // 公开
    返回 前缀 + 生成唯一标识() + 后缀
