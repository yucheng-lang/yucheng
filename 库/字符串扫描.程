// ===== 语程标准库：字符串扫描 =====
// 提供类似scanf的字符串模式匹配函数
//
// 公开接口：扫描整数、扫描浮点数、扫描标识符、扫描字符、
//           扫描空白、扫描直到、扫描贪婪、
//           扫描匹配、扫描日期、扫描IP地址、
//           分割扫描行、扫描键值对

// ===== 基础扫描函数 =====

函程 扫描整数(文本, 起始=0): // 公开
    // 从指定位置扫描整数，返回[成功, 值, 消耗字符数]
    设 i = 起始
    设 符号 = 1
    设 结果 = 0
    设 有数字 = 假
    如果 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "+":
            i = i + 1
        否则如果 子串(文本, i, i + 1) == "-":
            符号 = -1
            i = i + 1
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 >= "0" 且 字 <= "9":
            结果 = 结果 * 10 + (字符编码(字) - 字符编码("0"))
            有数字 = 真
        否则如果 字 == "_":
            忽略
        否则:
            跳出
        i = i + 1
    如果 有数字:
        返回 [真, 符号 * 结果, i - 起始]
    返回 [假, 0, 0]

函程 扫描浮点数(文本, 起始=0): // 公开
    // 从指定位置扫描浮点数，返回[成功, 值, 消耗字符数]
    设 i = 起始
    设 符号 = 1
    设 整数部分 = 0
    设 小数部分 = 0
    设 小数位数 = 0
    设 有数字 = 假
    设 有小数 = 假
    如果 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "+":
            i = i + 1
        否则如果 子串(文本, i, i + 1) == "-":
            符号 = -1
            i = i + 1
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 >= "0" 且 字 <= "9":
            如果 有小数:
                小数部分 = 小数部分 * 10 + (字符编码(字) - 字符编码("0"))
                小数位数 = 小数位数 + 1
            否则:
                整数部分 = 整数部分 * 10 + (字符编码(字) - 字符编码("0"))
            有数字 = 真
        否则如果 字 == "." 且 非 有小数:
            有小数 = 真
        否则如果 字 == "_":
            忽略
        否则如果 (字 == "e" 或 字 == "E") 且 有数字:
            i = i + 1
            设 指符号 = 1
            设 指数值 = 0
            如果 i < 字符串长度(文本):
                如果 子串(文本, i, i + 1) == "+":
                    i = i + 1
                否则如果 子串(文本, i, i + 1) == "-":
                    指符号 = -1
                    i = i + 1
            设 指数有数字 = 假
            循环 i < 字符串长度(文本):
                设 e字 = 子串(文本, i, i + 1)
                如果 e字 >= "0" 且 e字 <= "9":
                    指数值 = 指数值 * 10 + (字符编码(e字) - 字符编码("0"))
                    指数有数字 = 真
                否则:
                    跳出
                i = i + 1
            如果 指数有数字:
                设 基数 = 符号 * (整数部分 + 小数部分 / 幂(10, 小数位数))
                返回 [真, 基数 * 幂(10, 指符号 * 指数值), i - 起始]
            跳出
        否则:
            跳出
        i = i + 1
    如果 有数字:
        设 值 = 整数部分 + 小数部分 / 幂(10, 小数位数)
        返回 [真, 符号 * 值, i - 起始]
    返回 [假, 0, 0]

函程 扫描标识符(文本, 起始=0): // 公开
    // 扫描ASCII标识符，返回[成功, 标识符, 消耗字符数]
    设 i = 起始
    设 结果 = ""
    如果 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 (字 >= "a" 且 字 <= "z") 或 (字 >= "A" 且 字 <= "Z") 或 字 == "_":
            结果 = 结果 + 字
            i = i + 1
            循环 i < 字符串长度(文本):
                设 字2 = 子串(文本, i, i + 1)
                如果 (字2 >= "a" 且 字2 <= "z") 或 (字2 >= "A" 且 字2 <= "Z") 或 (字2 >= "0" 且 字2 <= "9") 或 字2 == "_":
                    结果 = 结果 + 字2
                    i = i + 1
                否则:
                    跳出
    如果 字符串长度(结果) > 0:
        返回 [真, 结果, 字符串长度(结果)]
    返回 [假, "", 0]

函程 扫描字符(文本, 起始=0): // 公开
    // 扫描单个字符，返回[成功, 字符, 消耗字符数]
    如果 起始 < 字符串长度(文本):
        返回 [真, 子串(文本, 起始, 起始 + 1), 1]
    返回 [假, "", 0]

函程 扫描空白(文本, 起始=0): // 公开
    // 跳过空白字符，返回消耗的字符数
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 == " " 或 字 == "\t" 或 字 == "\n" 或 字 == "\r":
            i = i + 1
        否则:
            跳出
    返回 i - 起始

函程 扫描直到(文本, 结束串, 起始=0): // 公开
    // 扫描直到遇到指定字符串，返回[内容, 消耗字符数]
    // 内容不包含结束串
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 匹配 = 真
        设 j = 0
        循环 j < 字符串长度(结束串) 且 i + j < 字符串长度(文本):
            如果 子串(文本, i + j, i + j + 1) != 子串(结束串, j, j + 1):
                匹配 = 假
            j = j + 1
        如果 匹配 且 j == 字符串长度(结束串):
            返回 [子串(文本, 起始, i), i - 起始 + 字符串长度(结束串)]
        i = i + 1
    返回 [子串(文本, 起始, 字符串长度(文本)), 字符串长度(文本) - 起始]

函程 扫描贪婪(文本, 结束串, 起始=0): // 公开
    // 扫描至少一个字符直到遇到结束串，返回[成功, 内容, 消耗字符数]
    设 结果 = 扫描直到(文本, 结束串, 起始)
    设 内容 = 结果[0]
    设 长度 = 结果[1]
    如果 字符串长度(内容) > 0:
        返回 [真, 内容, 长度]
    返回 [假, "", 0]

// ===== 高级扫描模式 =====

函程 扫描匹配(文本, 模式): // 公开
    // 简易模式匹配，支持以下占位符：
    // $i - 整数, $f - 浮点数, $w - 标识符, $s - 空白, $+ - 贪婪文本, $* - 可选文本
    // 返回[成功, 捕获列表]
    设 位置 = 0
    设 模式位置 = 0
    设 捕获列表 = []
    设 成功 = 真

    循环 模式位置 < 字符串长度(模式) 且 成功:
        如果 子串(模式, 模式位置, 模式位置 + 1) == "$":
            模式位置 = 模式位置 + 1
            如果 模式位置 >= 字符串长度(模式):
                成功 = 假
            否则:
                设 标记 = 子串(模式, 模式位置, 模式位置 + 1)
                如果 标记 == "i":
                    设 结果 = 扫描整数(文本, 位置)
                    如果 结果[0]:
                        捕获列表.添加(结果[1])
                        位置 = 位置 + 结果[2]
                    否则:
                        成功 = 假
                否则如果 标记 == "f":
                    设 结果 = 扫描浮点数(文本, 位置)
                    如果 结果[0]:
                        捕获列表.添加(结果[1])
                        位置 = 位置 + 结果[2]
                    否则:
                        成功 = 假
                否则如果 标记 == "w":
                    设 结果 = 扫描标识符(文本, 位置)
                    如果 结果[0]:
                        捕获列表.添加(结果[1])
                        位置 = 位置 + 结果[2]
                    否则:
                        成功 = 假
                否则如果 标记 == "s":
                    位置 = 位置 + 扫描空白(文本, 位置)
                否则如果 标记 == "+":
                    // 贪婪匹配直到下一个模式字符
                    设 下个模式 = ""
                    如果 模式位置 + 1 < 字符串长度(模式):
                        下个模式 = 子串(模式, 模式位置 + 1, 模式位置 + 2)
                    设 结果 = 扫描贪婪(文本, 下个模式, 位置)
                    如果 结果[0]:
                        捕获列表.添加(结果[1])
                        位置 = 位置 + 结果[2]
                    否则:
                        成功 = 假
                否则如果 标记 == "*":
                    // 可选匹配直到下一个模式字符
                    设 下个模式 = ""
                    如果 模式位置 + 1 < 字符串长度(模式):
                        下个模式 = 子串(模式, 模式位置 + 1, 模式位置 + 2)
                    设 结果 = 扫描直到(文本, 下个模式, 位置)
                    捕获列表.添加(结果[0])
                    位置 = 位置 + 结果[1]
                否则如果 标记 == "$":
                    // 匹配$字符本身
                    如果 位置 < 字符串长度(文本) 且 子串(文本, 位置, 位置 + 1) == "$":
                        位置 = 位置 + 1
                    否则:
                        成功 = 假
                否则:
                    成功 = 假
                模式位置 = 模式位置 + 1
        否则:
            // 字面量匹配
            如果 位置 < 字符串长度(文本) 且 子串(文本, 位置, 位置 + 1) == 子串(模式, 模式位置, 模式位置 + 1):
                位置 = 位置 + 1
                模式位置 = 模式位置 + 1
            否则:
                成功 = 假

    返回 [成功, 捕获列表]

函程 扫描日期(文本): // 公开
    // 扫描ISO日期格式 YYYY-MM-DD
    设 结果 = 扫描匹配(文本, "$i-$i-$i")
    如果 结果[0] 且 长度(结果[1]) >= 3:
        设 年 = 结果[1][0]
        设 月 = 结果[1][1]
        设 日 = 结果[1][2]
        返回 [真, 年, 月, 日]
    返回 [假, 0, 0, 0]

函程 扫描IP地址(文本): // 公开
    // 扫描IPv4地址 x.x.x.x
    设 部分 = 分割(文本, ".")
    如果 长度(部分) != 4:
        返回 [假, 0, 0, 0, 0]
    设 a = 转数字(部分[0])
    设 b = 转数字(部分[1])
    设 c = 转数字(部分[2])
    设 d = 转数字(部分[3])
    如果 a >= 0 且 a <= 255 且 b >= 0 且 b <= 255 且 c >= 0 且 c <= 255 且 d >= 0 且 d <= 255:
        返回 [真, a, b, c, d]
    返回 [假, 0, 0, 0, 0]

// ===== 实用扫描函数 =====

函程 分割扫描行(文本): // 公开
    // 按行分割文本并去除每行首尾空白
    设 行列表 = 分割(文本, "\n")
    设 结果 = []
    遍 行 于 行列表:
        设 去空行 = 去除空白(行)
        如果 字符串长度(去空行) > 0:
            结果.添加(去空行)
    返回 结果

函程 扫描键值对(文本, 分隔符="="): // 公开
    // 扫描键值对，返回字典
    设 结果 = {}
    设 行列表 = 分割扫描行(文本)
    遍 行 于 行列表:
        如果 字符串长度(行) > 0 且 子串(行, 0, 1) != "#":
            设 位置 = 查找(行, 分隔符)
            如果 位置 >= 0:
                设 键 = 去除空白(子串(行, 0, 位置))
            设 值 = 去除空白(子串(行, 位置 + 字符串长度(分隔符), 字符串长度(行)))
                结果[键] = 值
    返回 结果
