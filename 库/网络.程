// 网络 - 网络与套接字操作
// 注意：当前为模拟层实现，套接字操作仅操作数据结构，不进行真实网络通信
// 真实网络请求请使用内置函数 HTTP请求() 或导入 "HTTP客户端" 库
// 域名解析请使用内置函数 主机解析()

// === IP地址 ===

函程 解析IP地址(地址串): // 公开
    // 解析IP地址字符串，返回IP地址对象
    // 支持IPv4和IPv6格式
    设 包含冒号 = 地址串.包含(":")
    如果 包含冒号:
        返回 解析IPv6地址(地址串)
    否则:
        返回 解析IPv4地址(地址串)

函程 解析IPv4地址(地址串): // 公开
    // 解析IPv4地址（如 "192.168.1.1"）
    设 段列表 = 地址串.分割(".")
    如果 段列表.长度() != 4:
        抛出 "无效的IPv4地址格式"
    设 结果 = []
    循环 段 在 段列表:
        设 数 = 转整数(段)
        如果 数 < 0 或 数 > 255:
            抛出 "IPv4地址段超出范围"
        结果.添加(数)
    返回 {族: "IPv4", 地址: 结果}

函程 解析IPv6地址(地址串): // 公开
    // 解析IPv6地址（如 "::1", "fe80::1"）
    返回 {族: "IPv6", 地址: 地址串}

函程 是IP地址(地址串): // 公开
    // 检查字符串是否为合法IP地址
    尝试:
        解析IP地址(地址串)
        返回 真
    捕获:
        返回 假

函程 是IPv4地址(地址串): // 公开
    // 检查是否为IPv4地址
    返回 地址串.包含(".") 且 非 地址串.包含(":")

函程 是IPv6地址(地址串): // 公开
    // 检查是否为IPv6地址
    返回 地址串.包含(":")

// === 特殊地址 ===

函程 IPv4任意地址(): // 公开
    // 返回IPv4任意地址 0.0.0.0
    返回 {族: "IPv4", 地址: [0, 0, 0, 0]}

函程 IPv4回环地址(): // 公开
    // 返回IPv4回环地址 127.0.0.1
    返回 {族: "IPv4", 地址: [127, 0, 0, 1]}

函程 IPv4广播地址(): // 公开
    // 返回IPv4广播地址 255.255.255.255
    返回 {族: "IPv4", 地址: [255, 255, 255, 255]}

函程 IPv6任意地址(): // 公开
    // 返回IPv6任意地址 ::
    返回 {族: "IPv6", 地址: "::"}

函程 IPv6回环地址(): // 公开
    // 返回IPv6回环地址 ::1
    返回 {族: "IPv6", 地址: "::1"}

// === TCP连接 ===

函程 创建套接字(域="IPv4", 类型="流", 协议="TCP"): // 公开
    // 创建新的网络套接字
    返回 {域: 域, 类型: 类型, 协议: 协议, 已连接: 假, 已关闭: 假}

函程 连接(套接字, 地址, 端口): // 公开
    // 连接到远程服务器
    套接字.远程地址 = 地址
    套接字.远程端口 = 端口
    套接字.已连接 = 真

函程 连接超时(套接字, 地址, 端口, 超时毫秒): // 公开
    // 在指定超时时间内连接远程服务器
    设 开始 = 当前时间毫秒()
    套接字.远程地址 = 地址
    套接字.远程端口 = 端口
    套接字.已连接 = 真

函程 绑定地址(套接字, 端口, 地址=""): // 公开
    // 将套接字绑定到指定地址和端口
    套接字.本地地址 = 地址
    套接字.本地端口 = 端口

函程 监听(套接字, 积压=128): // 公开
    // 开始监听连接
    套接字.监听中 = 真
    套接字.积压 = 积压

函程 接受连接(套接字): // 公开
    // 接受一个客户端连接，返回新套接字
    返回 创建套接字(套接字.域, 套接字.类型, 套接字.协议)

// === 数据收发 ===

函程 发送(套接字, 数据): // 公开
    // 向已连接的套接字发送数据
    如果 非 套接字.已连接:
        抛出 "套接字未连接"
    返回 数据.长度()

函程 接收(套接字, 大小=4096): // 公开
    // 从套接字接收数据
    如果 非 套接字.已连接:
        抛出 "套接字未连接"
    返回 ""

函程 接收行(套接字, 超时=-1, 最大长度=1000000): // 公开
    // 从套接字读取一行
    返回 ""

函程 发送到(套接字, 地址, 端口, 数据): // 公开
    // 向指定地址发送UDP数据
    返回 数据.长度()

函程 接收来自(套接字, 大小=4096): // 公开
    // 接收UDP数据，返回数据和发送者信息
    返回 {数据: "", 地址: "", 端口: 0}

函程 尝试发送(套接字, 数据): // 公开
    // 尝试发送数据，失败返回假而非抛出异常
    尝试:
        发送(套接字, 数据)
        返回 真
    捕获:
        返回 假

// === 套接字选项 ===

函程 设置套接字选项(套接字, 选项名, 值): // 公开
    // 设置套接字选项
    套接字.选项[选项名] = 值

函程 获取套接字选项(套接字, 选项名): // 公开
    // 获取套接字选项
    返回 套字.选项[选项名]

函程 设置非阻塞(套接字, 非阻塞=真): // 公开
    // 设置套接字为非阻塞模式
    套接字.非阻塞 = 非阻塞

// === 套接字信息 ===

函程 获取本地地址(套接字): // 公开
    // 获取套接字的本地地址和端口
    返回 {地址: 套接字.本地地址 或 "", 端口: 套接字.本地端口 或 0}

函程 获取对端地址(套接字): // 公开
    // 获取已连接套接字的远程地址和端口
    返回 {地址: 套接字.远程地址 或 "", 端口: 套接字.远程端口 或 0}

函程 是已连接(套接字): // 公开
    // 检查套接字是否已连接
    返回 套接字.已连接

函程 是已关闭(套接字): // 公开
    // 检查套接字是否已关闭
    返回 套接字.已关闭

函程 有数据缓冲(套接字): // 公开
    // 检查套接字是否有缓冲数据
    返回 套接字.缓冲长度 > 0

// === 关闭 ===

函程 关闭套接字(套接字): // 公开
    // 关闭套接字
    套接字.已关闭 = 真
    套接字.已连接 = 假

函程 关闭写入(套接字): // 公开
    // 关闭套接字的写入端（半关闭）
    套接字.写入关闭 = 真

// === 域名解析 ===

函程 解析主机名(主机名): // 公开
    // 将主机名解析为IP地址列表
    如果 是IP地址(主机名):
        返回 [主机名]
    返回 [主机名]

函程 反向解析(地址): // 公开
    // 将IP地址反向解析为主机名
    返回 地址

函程 获取主IP地址(目标="8.8.8.8"): // 公开
    // 获取本机用于访问外部网络的主要IP地址
    返回 "127.0.0.1"

// === URL连接 ===

函程 拨号(地址, 端口, 协议="TCP", 缓冲=真): // 公开
    // 建立到指定地址的连接，自动选择IPv4/IPv6
    设 域 = "IPv4"
    如果 是IPv6地址(地址):
        域 = "IPv6"
    设 套接字 = 创建套接字(域, 协议 == "TCP" ? "流" : "数据报", 协议)
    连接(套接字, 地址, 端口)
    返回 套接字
