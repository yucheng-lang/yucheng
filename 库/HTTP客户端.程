// HTTP客户端工具
// 提供HTTP请求发送功能
// 跨平台：使用内置 HTTP请求() 函数，无需外部 curl 依赖

导入 "JSON工具"
导入 "Cookie"
导入 "URI工具"

// === HTTP请求 ===

函程 发送请求(方法, 网址, 头部 = {}, 数据 = "", 超时秒 = 30): // 公开
    // 发送HTTP请求
    设 请求 = {
        方法: 方法,
        网址: 网址,
        头部: 头部,
        数据: 数据,
        超时: 超时秒,
        Cookie: {}
    }
    设 响应 = 执行请求(请求)
    返回 响应

函程 HTTP获取(网址, 头部 = {}, 超时秒 = 30): // 公开
    // 发送GET请求
    返回 发送请求("GET", 网址, 头部, "", 超时秒)

函程 HTTP提交(网址, 数据 = "", 头部 = {}, 超时秒 = 30): // 公开
    // 发送POST请求
    返回 发送请求("POST", 网址, 头部, 数据, 超时秒)

函程 HTTP更新(网址, 数据 = "", 头部 = {}, 超时秒 = 30): // 公开
    // 发送PUT请求
    返回 发送请求("PUT", 网址, 头部, 数据, 超时秒)

函程 HTTP删除(网址, 头部 = {}, 超时秒 = 30): // 公开
    // 发送DELETE请求
    返回 发送请求("DELETE", 网址, 头部, "", 超时秒)

函程 HTTP补丁(网址, 数据 = "", 头部 = {}, 超时秒 = 30): // 公开
    // 发送PATCH请求
    返回 发送请求("PATCH", 网址, 头部, 数据, 超时秒)

函程 HTTP头部(网址, 头部 = {}, 超时秒 = 30): // 公开
    // 发送HEAD请求
    返回 发送请求("HEAD", 网址, 头部, "", 超时秒)

// === 请求执行 ===

函程 执行请求(请求): // 内部
    // 执行HTTP请求，返回响应对象
    // 使用内置 HTTP请求() 函数（跨平台，基于 reqwest，无需 curl）
    设 响应 = {
        状态码: 0,
        状态文本: "",
        头部: {},
        内容: "",
        Cookie: {},
        编码: "utf-8",
        网址: 请求.网址
    }
    
    // 构建头部字符串
    设 头部文本 = ""
    循环 键, 值 于 请求.头部:
        如果 头部文本.长度() > 0:
            头部文本 = 头部文本 + "\n"
        头部文本 = 头部文本 + 键 + ": " + 值
    
    // 添加Cookie到头部
    如果 请求.Cookie.长度() > 0:
        设 Cookie串 = Cookie.生成Cookie头部(请求.Cookie)
        如果 头部文本.长度() > 0:
            头部文本 = 头部文本 + "\n"
        头部文本 = 头部文本 + "Cookie: " + Cookie串
    
    // 使用内置 HTTP请求 函数（跨平台，基于 Rust reqwest 库）
    设 结果 = HTTP请求(请求.网址, 请求.方法, 头部文本, 请求.数据)
    
    // 解析结果
    如果 是字符串(结果):
        响应.内容 = 结果
        响应.状态码 = 200
    否则如果 是字典(结果):
        // 如果返回字典，提取各字段
        如果 结果.包含("状态码"):
            响应.状态码 = 结果.状态码
        否则:
            响应.状态码 = 200
        如果 结果.包含("内容"):
            响应.内容 = 结果.内容
        否则如果 结果.包含("body"):
            响应.内容 = 结果.body
        否则:
            响应.内容 = 转文本(结果)
        如果 结果.包含("头部"):
            响应.头部 = 结果.头部
    否则:
        响应.内容 = 转文本(结果)
        响应.状态码 = 200
    
    返回 响应

// === 便捷方法 ===

函程 获取JSON(网址, 头部 = {}): // 公开
    // GET请求并解析JSON响应
    设 响应 = HTTP获取(网址, 头部)
    如果 响应.状态码 == 200:
        返回 JSON工具.解析JSON(响应.内容)
    返回 空

函程 提交JSON(网址, 数据): // 公开
    // POST提交JSON数据
    设 头部 = {"Content-Type": "application/json"}
    设 JSON数据 = JSON工具.生成JSON(数据)
    返回 HTTP提交(网址, JSON数据, 头部)

函程 提交表单(网址, 表单数据): // 公开
    // POST提交表单数据
    设 头部 = {"Content-Type": "application/x-www-form-urlencoded"}
    设 编码数据 = 编码表单(表单数据)
    返回 HTTP提交(网址, 编码数据, 头部)

函程 下载文件(网址, 保存路径): // 公开
    // 下载文件
    设 响应 = HTTP获取(网址)
    如果 响应.状态码 == 200:
        写入文件(保存路径, 响应.内容)
        返回 真
    返回 假

// === 辅助函数 ===

函程 编码表单(数据): // 内部
    // 编码表单数据为 application/x-www-form-urlencoded 格式
    设 对列表 = []
    循环 键, 值 于 数据:
        对列表.添加(URI工具.URL编码(键) + "=" + URI工具.URL编码(值.转文本()))
    返回 对列表.连接("&")

// === 状态码判断 ===

函程 是成功(状态码): // 公开
    返回 状态码 >= 200 且 状态码 < 300

函程 是重定向(状态码): // 公开
    返回 状态码 >= 300 且 状态码 < 400

函程 是客户端错误(状态码): // 公开
    返回 状态码 >= 400 且 状态码 < 500

函程 是服务端错误(状态码): // 公开
    返回 状态码 >= 500 且 状态码 < 600

函程 状态码描述(状态码): // 公开
    设 描述表 = {
        200: "OK",
        201: "Created",
        204: "No Content",
        301: "Moved Permanently",
        302: "Found",
        304: "Not Modified",
        400: "Bad Request",
        401: "Unauthorized",
        403: "Forbidden",
        404: "Not Found",
        405: "Method Not Allowed",
        408: "Request Timeout",
        409: "Conflict",
        422: "Unprocessable Entity",
        429: "Too Many Requests",
        500: "Internal Server Error",
        502: "Bad Gateway",
        503: "Service Unavailable",
        504: "Gateway Timeout"
    }
    如果 描述表.包含(状态码):
        返回 描述表[状态码]
    返回 "未知状态"
