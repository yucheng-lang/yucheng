// 字符串格式化库 - 模板字符串与格式化输出
// 提供模板字符串格式化和数值格式化功能

// 公开接口：格式化、格式化整数、格式化浮点数、对齐文本

函程 格式化(模板, 参数): // 公开
    // 使用字典参数格式化模板字符串
    // 模板中使用 {键名} 作为占位符
    // 例如：格式化("你好，{名字}！今天是{星期}", {"名字": "小明", "星期": "星期一"})
    设 结果 = ""
    设 i = 0
    设 模板长度 = 长度(模板)
    
    循环 i < 模板长度:
        如果 模板[i] == '{':
            // 查找结束大括号
            设 j = i + 1
            循环 j < 模板长度 且 模板[j] != '}':
                j = j + 1
            如果 j < 模板长度:
                设 键名 = 子串(模板, i + 1, j - i - 1)
                // 检查是否有格式说明符（用冒号分隔）
                设 冒号位置 = 查找(键名, ":")
                如果 冒号位置 >= 0:
                    设 实际键 = 子串(键名, 0, 冒号位置)
                    设 格式说明 = 子串(键名, 冒号位置 + 1, 长度(键名) - 冒号位置 - 1)
                    设 值 = 取值(参数, 实际键, "")
                    结果 = 结果 + 应用格式(值, 格式说明)
                否则:
                    设 值 = 取值(参数, 键名, "")
                    结果 = 结果 + 转文本(值)
                i = j + 1
            否则:
                结果 = 结果 + "{"
                i = i + 1
        否则如果 模板[i] == '}' 且 i + 1 < 模板长度 且 模板[i+1] == '}':
            // 转义的大括号
            结果 = 结果 + "}"
            i = i + 2
        否则如果 模板[i] == '{' 且 i + 1 < 模板长度 且 模板[i+1] == '{':
            // 转义的大括号
            结果 = 结果 + "{"
            i = i + 2
        否则:
            结果 = 结果 + 模板[i]
            i = i + 1
    
    返回 结果

函程 应用格式(值, 格式说明): // 内部
    /* 应用格式说明到值
       支持的格式：
         >N  - 右对齐，宽度N
         <N  - 左对齐，宽度N
         ^N  - 居中对齐，宽度N
         .Nf - 浮点数保留N位小数
         0Nd - 整数零填充到N位
         x   - 十六进制
         o   - 八进制
         b   - 二进制 */
    
    设 文本值 = 转文本(值)
    
    如果 长度(格式说明) == 0:
        返回 文本值
    
    // 浮点数格式
    如果 格式说明[0] == '.':
        设 精度文本 = 子串(格式说明, 1, 长度(格式说明) - 1)
        设 精度 = 解析整数(精度文本)
        如果 精度 != 空:
            返回 格式化浮点数(值, 精度)
        返回 文本值
    
    // 零填充
    如果 长度(格式说明) >= 2 且 格式说明[0] == '0':
        设 宽度文本 = 子串(格式说明, 0, 长度(格式说明) - 1)
        设 宽度 = 解析整数(宽度文本)
        如果 宽度 != 空:
            设 类型字符 = 格式说明[长度(格式说明) - 1]
            如果 类型字符 == 'd' 或 类型字符 == 'i':
                返回 零填充(值, 宽度)
            返回 文本值
    
    // 进制转换
    如果 格式说明 == "x" 或 格式说明 == "X":
        返回 整数到十六进制(值, 格式说明 == "X")
    如果 格式说明 == "o":
        返回 整数到八进制(值)
    如果 格式说明 == "b":
        返回 整数到二进制(值)
    
    // 对齐
    如果 长度(格式说明) >= 2:
        设 对齐方式 = 格式说明[0]
        设 宽度文本 = 子串(格式说明, 1, 长度(格式说明) - 1)
        设 宽度 = 解析整数(宽度文本)
        如果 宽度 != 空:
            如果 对齐方式 == '>':
                返回 左填充(文本值, 宽度, ' ')
            否则如果 对齐方式 == '<':
                返回 右填充(文本值, 宽度, ' ')
            否则如果 对齐方式 == '^':
                返回 居中填充(文本值, 宽度, ' ')
    
    返回 文本值

函程 格式化整数(值, 宽度 = 0, 填充字符 = ' '): // 公开
    // 格式化整数输出
    设 文本 = 转文本(值)
    如果 宽度 <= 长度(文本):
        返回 文本
    返回 左填充(文本, 宽度, 填充字符)

函程 格式化浮点数(值, 小数位数 = 2): // 公开
    // 格式化浮点数输出，指定小数位数
    设 文本 = 转文本(值)
    设 点位置 = 查找(文本, ".")
    
    如果 点位置 < 0:
        // 没有小数点，添加
        文本 = 文本 + "."
        设 i = 0
        循环 i < 小数位数:
            文本 = 文本 + "0"
            i = i + 1
        返回 文本
    
    设 当前小数位 = 长度(文本) - 点位置 - 1
    如果 当前小数位 == 小数位数:
        返回 文本
    如果 当前小数位 > 小数位数:
        // 截断多余小数位
        返回 子串(文本, 0, 点位置 + 1 + 小数位数)
    // 补零
    设 i = 0
    循环 i < 小数位数 - 当前小数位:
        文本 = 文本 + "0"
        i = i + 1
    返回 文本

函程 对齐文本(文本, 宽度, 对齐方式 = "左"): // 公开
    // 对齐文本到指定宽度
    // 对齐方式：左、右、中
    如果 长度(文本) >= 宽度:
        返回 文本
    如果 对齐方式 == "左":
        返回 右填充(文本, 宽度, ' ')
    如果 对齐方式 == "右":
        返回 左填充(文本, 宽度, ' ')
    如果 对齐方式 == "中":
        返回 居中填充(文本, 宽度, ' ')
    返回 文本

函程 左填充(文本, 宽度, 字符): // 内部
    设 填充数 = 宽度 - 长度(文本)
    设 结果 = 文本
    循环 填充数 > 0:
        结果 = 字符 + 结果
        填充数 = 填充数 - 1
    返回 结果

函程 右填充(文本, 宽度, 字符): // 内部
    设 填充数 = 宽度 - 长度(文本)
    设 结果 = 文本
    循环 填充数 > 0:
        结果 = 结果 + 字符
        填充数 = 填充数 - 1
    返回 结果

函程 居中填充(文本, 宽度, 字符): // 内部
    设 填充数 = 宽度 - 长度(文本)
    设 左填充数 = 整数部分(填充数 / 2)
    设 右填充数 = 填充数 - 左填充数
    设 结果 = 文本
    设 i = 0
    循环 i < 右填充数:
        结果 = 结果 + 字符
        i = i + 1
    i = 0
    循环 i < 左填充数:
        结果 = 字符 + 结果
        i = i + 1
    返回 结果

函程 零填充(值, 宽度): // 内部
    设 文本 = 转文本(值)
    返回 左填充(文本, 宽度, '0')

函程 整数到十六进制(值, 大写 = 假): // 内部
    设 字符表 = "0123456789abcdef"
    如果 大写:
        字符表 = "0123456789ABCDEF"
    设 数字 = 值
    如果 数字 < 0:
        数字 = -数字
    如果 数字 == 0:
        返回 "0"
    设 结果 = ""
    循环 数字 > 0:
        设 余数 = 数字 % 16
        结果 = 子串(字符表, 余数, 1) + 结果
        数字 = 整数部分(数字 / 16)
    如果 值 < 0:
        结果 = "-" + 结果
    返回 结果

函程 整数到八进制(值): // 内部
    设 数字 = 值
    如果 数字 < 0:
        数字 = -数字
    如果 数字 == 0:
        返回 "0"
    设 结果 = ""
    循环 数字 > 0:
        设 余数 = 数字 % 8
        结果 = 转文本(余数) + 结果
        数字 = 整数部分(数字 / 8)
    如果 值 < 0:
        结果 = "-" + 结果
    返回 结果

函程 整数到二进制(值): // 内部
    设 数字 = 值
    如果 数字 < 0:
        数字 = -数字
    如果 数字 == 0:
        返回 "0"
    设 结果 = ""
    循环 数字 > 0:
        设 余数 = 数字 % 2
        如果 余数 == 0:
            结果 = "0" + 结果
        否则:
            结果 = "1" + 结果
        数字 = 整数部分(数字 / 2)
    如果 值 < 0:
        结果 = "-" + 结果
    返回 结果
