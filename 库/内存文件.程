// 内存文件 - 基于字符串缓冲的内存映射文件模拟
// 语程对象按值传递，所有修改文件的函数均返回修改后的文件对象。
// 调用者必须使用 文件 = 函数(文件, ...) 模式赋值回去。

// === 内存文件 ===

函程 创建内存文件(初始内容, 文件名): // 公开
    如果 初始内容 == 空:
        初始内容 = ""
    如果 文件名 == 空:
        文件名 = "匿名"
    返回 {
        数据: 初始内容,
        位置: 0,
        文件名: 文件名,
        大小: 长度(初始内容),
        已打开: 真,
        模式: "读写"
    }

函程 打开内存文件(路径, 模式): // 公开
    设 内容 = ""
    如果 文件存在(路径):
        内容 = 读取文件(路径)
    设 文件 = 创建内存文件(内容, 路径)
    如果 模式 != 空:
        文件.模式 = 模式
    返回 文件

// === 读写操作 ===

函程 内存读取(文件, 大小): // 公开
    如果 非 文件.已打开:
        抛出 "内存文件未打开"
    设 可读 = 文件.大小 - 文件.位置
    设 结果数据 = ""
    设 新位置 = 文件.位置
    如果 可读 > 0:
        设 实际大小 = 大小
        如果 大小 > 可读:
            实际大小 = 可读
        结果数据 = 子串(文件.数据, 文件.位置, 文件.位置 + 实际大小)
        新位置 = 文件.位置 + 实际大小
    文件.位置 = 新位置
    返回 {文件: 文件, 数据: 结果数据}

函程 内存写入(文件, 数据): // 公开
    如果 非 文件.已打开:
        抛出 "内存文件未打开"
    如果 文件.模式 == "只读":
        抛出 "内存文件为只读模式"
    如果 文件.位置 >= 文件.大小:
        文件.数据 = 文件.数据 + 数据
    否则:
        设 前 = 子串(文件.数据, 0, 文件.位置)
        设 后位置 = 文件.位置 + 长度(数据)
        设 后 = ""
        如果 后位置 < 文件.大小:
            后 = 子串(文件.数据, 后位置)
        文件.数据 = 前 + 数据 + 后
    文件.位置 = 文件.位置 + 长度(数据)
    文件.大小 = 长度(文件.数据)
    返回 文件

函程 内存读取全部(文件): // 公开
    如果 非 文件.已打开:
        抛出 "内存文件未打开"
    返回 文件.数据

函程 内存读取行(文件): // 公开
    如果 非 文件.已打开:
        抛出 "内存文件未打开"
    设 开始 = 文件.位置
    设 位置 = 开始
    设 行 = ""
    设 新位置 = 文件.大小
    循环 位置 < 文件.大小:
        设 字符 = 子串(文件.数据, 位置, 位置 + 1)
        如果 字符 == "\n":
            行 = 子串(文件.数据, 开始, 位置)
            新位置 = 位置 + 1
            中断
        位置 = 位置 + 1
    如果 新位置 == 文件.大小 且 行 == "":
        行 = 子串(文件.数据, 开始)
    文件.位置 = 新位置
    返回 {文件: 文件, 数据: 行}

函程 内存按行迭代(文件): // 公开
    设 保存位置 = 文件.位置
    文件.位置 = 0
    设 结果 = []
    循环 文件.位置 < 文件.大小:
        设 读取结果 = 内存读取行(文件)
        文件 = 读取结果.文件
        结果 = 追加(结果, 读取结果.数据)
    文件.位置 = 保存位置
    返回 {文件: 文件, 数据: 结果}

// === 位置和大小 ===

函程 获取位置(文件): // 公开
    返回 文件.位置

函程 设置位置(文件, 位置): // 公开
    如果 位置 < 0:
        位置 = 0
    如果 位置 > 文件.大小:
        位置 = 文件.大小
    文件.位置 = 位置
    返回 文件

函程 获取大小(文件): // 公开
    返回 文件.大小

函程 调整大小(文件, 新大小): // 公开
    如果 新大小 < 0:
        抛出 "内存文件大小不能为负数"
    如果 新大小 < 文件.大小:
        文件.数据 = 子串(文件.数据, 0, 新大小)
    否则:
        设 填充 = ""
        设 计 = 文件.大小
        循环 计 < 新大小:
            填充 = 填充 + "\0"
            计 = 计 + 1
        文件.数据 = 文件.数据 + 填充
    文件.大小 = 新大小
    返回 文件

// === 持久化 ===

函程 刷新到磁盘(文件, 路径): // 公开
    设 目标路径 = 路径
    如果 目标路径 == 空 或 目标路径 == "":
        目标路径 = 文件.文件名
    如果 目标路径 == "匿名":
        抛出 "无法刷新匿名内存文件，请指定路径"
    写入文件(目标路径, 文件.数据)
    返回 文件

函程 关闭内存文件(文件): // 公开
    文件.已打开 = 假
    返回 文件

// === 内存文件切片迭代 ===

函程 内存文件切片迭代(文件, 分隔符): // 公开
    如果 分隔符 == 空 或 分隔符 == "":
        分隔符 = "\n"
    设 结果 = []
    设 开始 = 0
    设 位置 = 0
    循环 位置 < 文件.大小:
        设 字符 = 子串(文件.数据, 位置, 位置 + 1)
        如果 字符 == 分隔符:
            设 切片 = 子串(文件.数据, 开始, 位置)
            结果 = 追加(结果, 切片)
            开始 = 位置 + 1
        位置 = 位置 + 1
    如果 开始 < 文件.大小:
        设 切片 = 子串(文件.数据, 开始)
        结果 = 追加(结果, 切片)
    返回 结果
