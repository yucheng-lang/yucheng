// URI工具库 - 统一资源标识符解析与构建
// 提供URI解析、构建和编解码功能

// 公开接口：解析URI、编码URL、解码URL、构建查询字符串

函程 编码URL(文本, 使用加号=真): // 公开
    // 按RFC3986编码URL
    设 安全字符 = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._~"
    设 结果 = ""
    设 i = 0
    循环 i < 文本.长度():
        设 当前字符 = 文本[i]
        设 位置 = 安全字符.查找(当前字符)
        如果 位置 >= 0:
            结果 = 结果 + 当前字符
        否则如果 当前字符 == " ":
            如果 使用加号:
                结果 = 结果 + "+"
            否则:
                结果 = 结果 + "%20"
        否则:
            设 编码值 = 字符编码(当前字符)
            设 高位 = 编码值 >> 4
            设 低位 = 编码值 - 高位 * 16
            结果 = 结果 + "%" + 十六进制字符(高位) + 十六进制字符(低位)
        i = i + 1
    返回 结果

函程 十六进制字符(值): // 内部
    // 将0-15的值转换为十六进制字符
    如果 值 < 10:
        返回 字符(值 + 48)
    否则:
        返回 字符(值 + 55)

函程 解码十六进制(高字符, 低字符): // 内部
    // 将两个十六进制字符转换为一个整数值
    设 高位 = 十六进制值(高字符)
    设 低位 = 十六进制值(低字符)
    返回 高位 * 16 + 低位

函程 十六进制值(字符): // 内部
    // 将十六进制字符转换为数值
    设 编码 = 字符编码(字符)
    如果 编码 >= 48 且 编码 <= 57:
        返回 编码 - 48
    如果 编码 >= 65 且 编码 <= 70:
        返回 编码 - 55
    如果 编码 >= 97 且 编码 <= 102:
        返回 编码 - 87
    返回 0

函程 解码URL(文本, 解码加号=真): // 公开
    // 按RFC3986解码URL
    设 结果 = ""
    设 i = 0
    设 文本长度 = 文本.长度()
    循环 i < 文本长度:
        设 当前字符 = 文本[i]
        如果 当前字符 == "%":
            如果 i + 2 < 文本长度:
                设 解码值 = 解码十六进制(文本[i+1], 文本[i+2])
                结果 = 结果 + 字符(解码值)
                i = i + 3
            否则:
                结果 = 结果 + 当前字符
                i = i + 1
        否则如果 当前字符 == "+" 且 解码加号:
            结果 = 结果 + " "
            i = i + 1
        否则:
            结果 = 结果 + 当前字符
            i = i + 1
    返回 结果

函程 解析URI(地址): // 公开
    // 解析URI字符串，返回包含各部分的字典
    设 结果 = {}
    结果["协议"] = ""
    结果["用户名"] = ""
    结果["密码"] = ""
    结果["主机名"] = ""
    结果["端口"] = ""
    结果["路径"] = ""
    结果["查询"] = ""
    结果["片段"] = ""
    
    设 位置 = 0
    设 地址长度 = 地址.长度()
    
    // 解析协议
    设 协议结束 = 地址.查找("://")
    如果 协议结束 >= 0:
        结果["协议"] = 地址.子串(0, 协议结束)
        位置 = 协议结束 + 3
    否则:
        如果 位置 + 1 < 地址长度 且 地址[位置] == "/" 且 地址[位置+1] == "/":
            位置 = 位置 + 2
        否则:
            结果["路径"] = 地址
            返回 结果
    
    // 解析权限部分
    设 权限结束 = 位置
    循环 权限结束 < 地址长度:
        设 字符 = 地址[权限结束]
        如果 字符 == "/" 或 字符 == "?" 或 字符 == "#":
            跳出
        权限结束 = 权限结束 + 1
    
    设 权限部分 = 地址.子串(位置, 权限结束 - 位置)
    位置 = 权限结束
    
    // 解析用户信息
    设 纵号位置 = 权限部分.查找("@")
    如果 纵号位置 >= 0:
        设 用户信息 = 权限部分.子串(0, 纵号位置)
        设 冒号位置 = 用户信息.查找(":")
        如果 冒号位置 >= 0:
            结果["用户名"] = 用户信息.子串(0, 冒号位置)
            结果["密码"] = 用户信息.子串(冒号位置 + 1)
        否则:
            结果["用户名"] = 用户信息
        权限部分 = 权限部分.子串(纵号位置 + 1)
    
    // 解析主机和端口
    设 冒号位置 = 权限部分.查找(":")
    如果 冒号位置 >= 0:
        结果["主机名"] = 权限部分.子串(0, 冒号位置)
        结果["端口"] = 权限部分.子串(冒号位置 + 1)
    否则:
        结果["主机名"] = 权限部分
    
    // 解析路径
    如果 位置 < 地址长度 且 地址[位置] != "?" 且 地址[位置] != "#":
        设 路径结束 = 位置
        循环 路径结束 < 地址长度:
            设 字符 = 地址[路径结束]
            如果 字符 == "?" 或 字符 == "#":
                跳出
            路径结束 = 路径结束 + 1
        结果["路径"] = 地址.子串(位置, 路径结束 - 位置)
        位置 = 路径结束
    
    // 解析查询
    如果 位置 < 地址长度 且 地址[位置] == "?":
        位置 = 位置 + 1
        设 查询结束 = 位置
        循环 查询结束 < 地址长度:
            如果 地址[查询结束] == "#":
                跳出
            查询结束 = 查询结束 + 1
        结果["查询"] = 地址.子串(位置, 查询结束 - 位置)
        位置 = 查询结束
    
    // 解析片段
    如果 位置 < 地址长度 且 地址[位置] == "#":
        位置 = 位置 + 1
        结果["片段"] = 地址.子串(位置)
    
    返回 结果

函程 构建查询字符串(参数, 分隔符="&"): // 公开
    // 将字典构建为URL查询字符串
    设 结果 = ""
    设 键列表 = 参数.键
    设 i = 0
    循环 i < 键列表.长度():
        设 键 = 键列表[i]
        设 值 = 参数[键]
        如果 结果.长度() > 0:
            结果 = 结果 + 分隔符
        结果 = 结果 + 编码URL(键) + "=" + 编码URL(值.转文本())
        i = i + 1
    返回 结果

函程 解析查询字符串(查询, 分隔符="&"): // 公开
    // 解析URL查询字符串，返回字典
    设 结果 = {}
    设 起始 = 0
    设 查询长度 = 查询.长度()
    
    循环 起始 < 查询长度:
        设 结束位置 = 起始
        循环 结束位置 < 查询长度:
            如果 查询[结束位置] == 分隔符[0]:
                跳出
            结束位置 = 结束位置 + 1
        
        设 对文本 = 查询.子串(起始, 结束位置 - 起始)
        
        设 等号位置 = 对文本.查找("=")
        如果 等号位置 >= 0:
            设 键 = 解码URL(对文本.子串(0, 等号位置))
            设 值 = 解码URL(对文本.子串(等号位置 + 1))
            结果[键] = 值
        否则:
            设 键 = 解码URL(对文本)
            结果[键] = ""
        
        起始 = 结束位置 + 1
    
    返回 结果

函程 是绝对URI(地址): // 公开
    // 判断URI是否为绝对URI（包含协议）
    设 解析结果 = 解析URI(地址)
    返回 解析结果["协议"].长度() > 0

函程 合并路径(基础路径, 附加路径): // 公开
    // 合并两个路径部分
    如果 基础路径.长度() == 0:
        返回 附加路径
    如果 附加路径.长度() == 0:
        返回 基础路径
    设 基础结尾 = 基础路径[基础路径.长度() - 1]
    设 附加开头 = 附加路径[0]
    如果 基础结尾 == "/" 且 附加开头 == "/":
        返回 基础路径 + 附加路径.子串(1)
    如果 基础结尾 != "/" 且 附加开头 != "/":
        返回 基础路径 + "/" + 附加路径
    返回 基础路径 + 附加路径

函程 是安全URL(地址): // 公开
    // 检查URL是否安全（非javascript等危险协议）
    设 解析结果 = 解析URI(地址)
    设 协议 = 解析结果["协议"].转小写()
    返回 协议 == "https" 或 协议 == "http" 或 协议 == "ftp" 或 协议 == "mailto"
