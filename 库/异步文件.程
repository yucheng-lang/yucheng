// 异步文件 - 基于回调模式的文件读写操作
// 语程对象按值传递，修改对象的函数返回修改后的对象。
// 采用「返回 {文件, 结果}」模式：函数同时返回修改后的文件和数据。

// === 异步文件对象 ===

函程 打开异步文件(路径, 模式): // 公开
    设 文件 = {
        路径: 路径,
        模式: 模式,
        位置: 0,
        已打开: 假,
        大小: 0,
        数据: ""
    }
    尝试:
        如果 模式 == "读":
            文件.数据 = 读取文件(路径)
        否则 如果 模式 == "写":
            文件.数据 = ""
        否则:
            如果 文件存在(路径):
                文件.数据 = 读取文件(路径)
            否则:
                文件.数据 = ""
        文件.大小 = 长度(文件.数据)
        文件.已打开 = 真
    捕获 错误:
        文件.已打开 = 假
    返回 文件

// === 异步读取（返回 {文件, 数据, 错误}）===

函程 异步读取(文件, 大小): // 公开
    如果 非 文件.已打开:
        返回 {文件: 文件, 数据: "", 错误: "文件未打开"}
    尝试:
        设 可读 = 文件.大小 - 文件.位置
        设 实际大小 = 大小
        如果 大小 > 可读:
            实际大小 = 可读
        设 结果 = 子串(文件.数据, 文件.位置, 文件.位置 + 实际大小)
        文件.位置 = 文件.位置 + 实际大小
        返回 {文件: 文件, 数据: 结果, 错误: 空}
    捕获 错误:
        返回 {文件: 文件, 数据: "", 错误: 错误}

函程 异步读取全部(文件): // 公开
    如果 非 文件.已打开:
        返回 {文件: 文件, 数据: "", 错误: "文件未打开"}
    返回 {文件: 文件, 数据: 文件.数据, 错误: 空}

函程 异步读取行(文件): // 公开
    如果 非 文件.已打开:
        返回 {文件: 文件, 数据: "", 错误: "文件未打开"}
    尝试:
        设 开始 = 文件.位置
        设 位置 = 开始
        循环 位置 < 文件.大小:
            设 字符 = 子串(文件.数据, 位置, 位置 + 1)
            如果 字符 == "\n":
                设 行 = 子串(文件.数据, 开始, 位置)
                文件.位置 = 位置 + 1
                返回 {文件: 文件, 数据: 行, 错误: 空}
            位置 = 位置 + 1
        设 行 = 子串(文件.数据, 开始)
        文件.位置 = 文件.大小
        返回 {文件: 文件, 数据: 行, 错误: 空}
    捕获 错误:
        返回 {文件: 文件, 数据: "", 错误: 错误}

// === 异步写入（返回 {文件, 写入数, 错误}）===

函程 异步写入(文件, 数据): // 公开
    如果 非 文件.已打开:
        返回 {文件: 文件, 写入数: 0, 错误: "文件未打开"}
    如果 文件.模式 == "读":
        返回 {文件: 文件, 写入数: 0, 错误: "文件为只读模式"}
    尝试:
        如果 文件.位置 >= 文件.大小:
            文件.数据 = 文件.数据 + 数据
        否则:
            设 前 = 子串(文件.数据, 0, 文件.位置)
            设 后位置 = 文件.位置 + 长度(数据)
            设 后 = ""
            如果 后位置 < 文件.大小:
                后 = 子串(文件.数据, 后位置)
            文件.数据 = 前 + 数据 + 后
        文件.位置 = 文件.位置 + 长度(数据)
        文件.大小 = 长度(文件.数据)
        返回 {文件: 文件, 写入数: 长度(数据), 错误: 空}
    捕获 错误:
        返回 {文件: 文件, 写入数: 0, 错误: 错误}

// === 位置和大小 ===

函程 获取文件位置(文件): // 公开
    返回 文件.位置

函程 设置文件位置(文件, 位置): // 公开
    如果 位置 < 0:
        位置 = 0
    如果 位置 > 文件.大小:
        位置 = 文件.大小
    文件.位置 = 位置
    返回 文件

函程 获取文件大小(文件): // 公开
    返回 文件.大小

函程 设置文件大小(文件, 新大小): // 公开
    如果 新大小 < 文件.大小:
        文件.数据 = 子串(文件.数据, 0, 新大小)
    否则:
        设 填充 = ""
        设 计 = 文件.大小
        循环 计 < 新大小:
            填充 = 填充 + "\0"
            计 = 计 + 1
        文件.数据 = 文件.数据 + 填充
    文件.大小 = 新大小
    返回 文件

// === 刷新和关闭 ===

函程 异步刷新(文件): // 公开
    如果 非 文件.已打开:
        返回 {文件: 文件, 错误: "文件未打开"}
    尝试:
        写入文件(文件.路径, 文件.数据)
        返回 {文件: 文件, 错误: 空}
    捕获 错误:
        返回 {文件: 文件, 错误: 错误}

函程 异步关闭(文件): // 公开
    如果 文件.已打开 且 文件.模式 != "读":
        尝试:
            写入文件(文件.路径, 文件.数据)
        捕获 错误:
            返回 {文件: 文件, 错误: 错误}
    文件.已打开 = 假
    返回 {文件: 文件, 错误: 空}

// === 批量操作 ===

函程 批量异步读取(路径列表): // 公开
    设 结果 = []
    遍 路径 于 路径列表:
        尝试:
            设 内容 = 读取文件(路径)
            结果 = 追加(结果, {路径: 路径, 内容: 内容, 错误: 空})
        捕获 错误:
            结果 = 追加(结果, {路径: 路径, 内容: 空, 错误: 错误})
    返回 结果

函程 批量异步写入(写入列表): // 公开
    设 结果 = []
    遍 项 于 写入列表:
        尝试:
            写入文件(项.路径, 项.内容)
            结果 = 追加(结果, {路径: 项.路径, 成功: 真, 错误: 空})
        捕获 错误:
            结果 = 追加(结果, {路径: 项.路径, 成功: 假, 错误: 错误})
    返回 结果
