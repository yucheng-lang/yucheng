// Base64编码库 - Base64编解码
// 提供Base64编码和解码功能

// 公开接口：编码、解码、URL安全编码

// Base64字符表
设 标准字符表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/" // 内部
设 安全字符表 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_" // 内部

函程 编码(数据, 安全模式 = 假): // 公开
    // 将字符串编码为Base64格式
    // 安全模式为真时使用URL安全字符表（-和_替代+和/）
    设 字符表 = 标准字符表
    如果 安全模式:
        字符表 = 安全字符表
    
    设 结果 = ""
    设 长度值 = 长度(数据)
    设 i = 0
    
    循环 i + 2 < 长度值:
        设 字节1 = 字符编码(数据[i])
        设 字节2 = 字符编码(数据[i+1])
        设 字节3 = 字符编码(数据[i+2])
        设 合并 = (字节1 * 65536) + (字节2 * 256) + 字节3
        结果 = 结果 + 字符表[位右移(合并, 18) % 64]
        结果 = 结果 + 字符表[位右移(合并, 12) % 64]
        结果 = 结果 + 字符表[位右移(合并, 6) % 64]
        结果 = 结果 + 字符表[合并 % 64]
        i = i + 3
    
    // 处理剩余字符
    设 余数 = 长度值 % 3
    如果 余数 == 1:
        设 字节1 = 字符编码(数据[i])
        设 合并 = 字节1 * 65536
        结果 = 结果 + 字符表[位右移(合并, 18) % 64]
        结果 = 结果 + 字符表[位右移(合并, 12) % 64]
        结果 = 结果 + "=="
    否则如果 余数 == 2:
        设 字节1 = 字符编码(数据[i])
        设 字节2 = 字符编码(数据[i+1])
        设 合并 = (字节1 * 65536) + (字节2 * 256)
        结果 = 结果 + 字符表[位右移(合并, 18) % 64]
        结果 = 结果 + 字符表[位右移(合并, 12) % 64]
        结果 = 结果 + 字符表[位右移(合并, 6) % 64]
        结果 = 结果 + "="
    
    返回 结果

函程 解码(数据): // 公开
    // 将Base64字符串解码为原始字符串
    // 支持标准Base64和URL安全Base64
    设 字符表 = 标准字符表
    
    // 构建反向查找表
    设 查找表 = {} // 内部
    设 i = 0
    循环 i < 64:
        设 键 = 子串(字符表, i, 1)
        设值(查找表, 键, i)
        i = i + 1
    // URL安全字符
    设值(查找表, "-", 62)
    设值(查找表, "_", 63)
    
    // 去除空白和填充
    设 清理数据 = ""
    设 i = 0
    循环 i < 长度(数据):
        设 字符 = 数据[i]
        如果 字符 != ' ' 且 字符 != '\n' 且 字符 != '\r' 且 字符 != '\t':
            清理数据 = 清理数据 + 字符
        i = i + 1
    
    设 结果 = ""
    设 数据长度 = 长度(清理数据)
    
    // 计算填充长度
    设 填充数 = 0
    如果 数据长度 > 0 且 清理数据[数据长度-1] == '=':
        填充数 = 1
    如果 数据长度 > 1 且 清理数据[数据长度-2] == '=':
        填充数 = 2
    
    设 i = 0
    循环 i + 3 < 数据长度:
        设 值1 = 取值(查找表, 子串(清理数据, i, 1), 0)
        设 值2 = 取值(查找表, 子串(清理数据, i+1, 1), 0)
        设 值3 = 取值(查找表, 子串(清理数据, i+2, 1), 0)
        设 值4 = 取值(查找表, 子串(清理数据, i+3, 1), 0)
        设 合并 = (值1 * 262144) + (值2 * 4096) + (值3 * 64) + 值4
        结果 = 结果 + 字符(位右移(合并, 16) % 256)
        结果 = 结果 + 字符(位右移(合并, 8) % 256)
        结果 = 结果 + 字符(合并 % 256)
        i = i + 4
    
    // 处理剩余
    设 剩余 = 数据长度 - i
    如果 剩余 >= 2:
        设 值1 = 取值(查找表, 子串(清理数据, i, 1), 0)
        设 值2 = 取值(查找表, 子串(清理数据, i+1, 1), 0)
        如果 剩余 >= 3:
            设 值3 = 取值(查找表, 子串(清理数据, i+2, 1), 0)
            设 合并 = (值1 * 262144) + (值2 * 4096) + (值3 * 64)
            结果 = 结果 + 字符(位右移(合并, 16) % 256)
            如果 填充数 == 0:
                结果 = 结果 + 字符(位右移(合并, 8) % 256)
        否则:
            设 合并 = (值1 * 262144) + (值2 * 4096)
            结果 = 结果 + 字符(位右移(合并, 16) % 256)
    
    返回 结果

函程 URL安全编码(数据): // 公开
    // URL安全的Base64编码（不含+、/和=）
    设 结果 = 编码(数据, 真)
    // 去除填充字符
    设 长度值 = 长度(结果)
    设 结束位置 = 长度值
    设 i = 长度值 - 1
    循环 i >= 0:
        如果 结果[i] != '=':
            结束位置 = i + 1
            跳出
        i = i - 1
    返回 子串(结果, 0, 结束位置)
