// ===== 语程标准库：数学工具 =====
// 提供常用数学函数
//
// 公开接口：绝对值、最大值、最小值、限制范围、阶乘、幂、斐波那契、
//           最大公约数、最小公倍数、是质数、质数列表、等差求和

函程 绝对值(x): // 公开
    如果 x < 0:
        返回 -x
    返回 x

函程 最大值(a, b): // 公开
    如果 a >= b:
        返回 a
    返回 b

函程 最小值(a, b): // 公开
    如果 a <= b:
        返回 a
    返回 b

函程 限制范围(值, 低, 高): // 公开
    如果 值 < 低:
        返回 低
    如果 值 > 高:
        返回 高
    返回 值

函程 阶乘(n): // 公开
    如果 n <= 1:
        返回 1
    返回 n * 阶乘(n - 1)

函程 幂(底, 指): // 公开
    如果 指 == 0:
        返回 1
    如果 指 < 0:
        返回 1 / 幂(底, -指)
    设 结果 = 1
    循环 指 > 0:
        结果 = 结果 * 底
        指 = 指 - 1
    返回 结果

函程 斐波那契(n): // 公开
    如果 n <= 0:
        返回 0
    如果 n == 1:
        返回 1
    设 上 = 0
    设 当 = 1
    设 序 = 2
    循环 序 <= n:
        设 下 = 上 + 当
        上 = 当
        当 = 下
        序 = 序 + 1
    返回 当

函程 最大公约数(a, b): // 公开
    设 x = 绝对值(a)
    设 y = 绝对值(b)
    循环 y != 0:
        设 余 = x - (x / y) * y
        x = y
        y = 余
    返回 x

函程 最小公倍数(a, b): // 公开
    如果 a == 0 或 b == 0:
        返回 0
    返回 绝对值(a * b) / 最大公约数(a, b)

函程 是质数(n): // 公开
    如果 n < 2:
        返回 假
    如果 n == 2:
        返回 真
    如果 n - (n / 2) * 2 == 0:
        返回 假
    设 i = 3
    循环 i * i <= n:
        如果 n - (n / i) * i == 0:
            返回 假
        i = i + 2
    返回 真

函程 质数列表(上限): // 公开
    设 结果 = []
    设 i = 2
    循环 i <= 上限:
        如果 是质数(i):
            结果.添加(i)
        i = i + 1
    返回 结果

函程 等差求和(首项, 末项, 项数): // 公开
    返回 (首项 + 末项) * 项数 / 2
