// ============================================
// FFmpeg 路径自动检测
// ============================================

设 FFmpeg程序 = ""
设 FFprobe程序 = ""
设 FFmpeg已初始化 = 假

函程 _规范化路径(路径):
    // 规范化路径，处理 .. 和 .
    // 先统一分隔符
    设 临时路径 = 替换(路径, "/", "\\")
    
    // 手动分割路径
    设 部分 = []
    设 开始 = 0
    设 位置 = 查找(临时路径, "\\")
    
    循环 位置 >= 0:
        如果 位置 > 开始:
            部分.添加(子串(临时路径, 开始, 位置))
        开始 = 位置 + 1
        位置 = 查找(子串(临时路径, 开始, 字符串长度(临时路径)), "\\")
        如果 位置 >= 0:
            位置 = 位置 + 开始
    
    // 添加最后一部分
    如果 开始 < 字符串长度(临时路径):
        部分.添加(子串(临时路径, 开始, 字符串长度(临时路径)))
    
    // 处理 .. 和 .
    设 栈 = []
    遍 部分 于 部分:
        如果 部分 == "..":
            如果 数组长度(栈) > 0:
                设 新栈 = []
                设 i = 0
                循环 i < 数组长度(栈) - 1:
                    新栈.添加(栈[i])
                    i = i + 1
                栈 = 新栈
        否则 如果 部分 != "." 且 字符串长度(部分) > 0:
            栈.添加(部分)
    
    // 重新构建路径
    设 结果 = ""
    设 i = 0
    循环 i < 数组长度(栈):
        如果 结果 == "":
            结果 = 栈[i]
        否则:
            结果 = 结果 + "\\" + 栈[i]
        i = i + 1
    
    返回 结果

函程 _检测FFmpeg路径():
    // 自动检测FFmpeg路径，返回找到的路径或空字符串
    设 候选路径 = []
    
    // 尝试获取当前工作目录
    设 当前目录值 = 当前目录()
    输出 "[FFmpeg] 当前目录: " + 当前目录值
    
    // 基于当前目录的绝对路径检测
    如果 当前目录值 != "":
        候选路径.添加(当前目录值 + "\\ffmpeg\\bin")
        候选路径.添加(当前目录值 + "\\..\\ffmpeg\\bin")
        候选路径.添加(当前目录值 + "\\..\\..\\ffmpeg\\bin")
    
    // 相对路径检测（作为备选）
    候选路径.添加("ffmpeg\\bin")
    候选路径.添加("..\\ffmpeg\\bin")
    候选路径.添加("..\\..\\ffmpeg\\bin")
    
    遍 路径 于 候选路径:
        设 ffmpeg候选 = 路径 + "\\ffmpeg.exe"
        设 ffprobe候选 = 路径 + "\\ffprobe.exe"
        输出 "[FFmpeg] 检测: " + ffmpeg候选
        如果 文件存在(ffmpeg候选) 且 文件存在(ffprobe候选):
            输出 "[FFmpeg] 找到: " + 路径
            返回 路径
    返回 ""

函程 初始化FFmpeg(自定义路径 = ""):
    // 初始化FFmpeg路径，可传入自定义路径
    如果 自定义路径 != "":
        设 ffmpeg候选 = 自定义路径 + "\\ffmpeg.exe"
        设 ffprobe候选 = 自定义路径 + "\\ffprobe.exe"
        如果 文件存在(ffmpeg候选) 且 文件存在(ffprobe候选):
            FFmpeg程序 = ffmpeg候选
            FFprobe程序 = ffprobe候选
            FFmpeg已初始化 = 真
            输出 "[FFmpeg] 使用自定义路径: " + 自定义路径
            返回 真
        否则:
            输出 "[FFmpeg] 自定义路径无效: " + 自定义路径
    
    设 检测路径 = _检测FFmpeg路径()
    如果 检测路径 != "":
        FFmpeg程序 = 检测路径 + "\\ffmpeg.exe"
        FFprobe程序 = 检测路径 + "\\ffprobe.exe"
        FFmpeg已初始化 = 真
        输出 "[FFmpeg] 自动检测路径: " + 检测路径
        返回 真
    
    FFmpeg程序 = "ffmpeg"
    FFprobe程序 = "ffprobe"
    FFmpeg已初始化 = 真
    输出 "[FFmpeg] 使用系统环境变量"
    返回 真

函程 设置FFmpeg路径(路径):
    // 手动设置FFmpeg路径
    返回 初始化FFmpeg(路径)

函程 获取FFmpeg路径():
    // 获取当前FFmpeg路径
    如果 FFmpeg程序 != "":
        返回 FFmpeg程序
    返回 "未设置"

初始化FFmpeg()

// ============================================
// 内部辅助函数
// ============================================

函程 _执行命令(命令):
    // 执行系统命令并返回结果
    返回 操作系统.执行命令(命令)

函程 _格式化时间(秒):
    // 将秒数格式化为 HH:MM:SS 格式
    设 总秒 = 转整数(秒)
    设 小时 = 转整数(总秒 / 3600)
    设 剩余 = 总秒 % 3600
    设 分钟 = 转整数(剩余 / 60)
    设 秒数 = 剩余 % 60
    设 时字符串 = ""
    设 分字符串 = ""
    设 秒字符串 = ""
    如果 小时 < 10:
        时字符串 = "0" + 转字符串(小时)
    否则:
        时字符串 = 转字符串(小时)
    如果 分钟 < 10:
        分字符串 = "0" + 转字符串(分钟)
    否则:
        分字符串 = 转字符串(分钟)
    如果 秒数 < 10:
        秒字符串 = "0" + 转字符串(秒数)
    否则:
        秒字符串 = 转字符串(秒数)
    返回 时字符串 + ":" + 分字符串 + ":" + 秒字符串

函程 _构建参数(选项):
    // 根据选项字典构建FFmpeg参数
    设 参数 = ""
    如果 选项.包含("视频编码器"):
        参数 = 参数 + " -c:v " + 选项.视频编码器
    如果 选项.包含("音频编码器"):
        参数 = 参数 + " -c:a " + 选项.音频编码器
    如果 选项.包含("视频比特率"):
        参数 = 参数 + " -b:v " + 选项.视频比特率
    如果 选项.包含("音频比特率"):
        参数 = 参数 + " -b:a " + 选项.音频比特率
    如果 选项.包含("分辨率"):
        参数 = 参数 + " -s " + 选项.分辨率
    如果 选项.包含("帧率"):
        参数 = 参数 + " -r " + 选项.帧率
    如果 选项.包含("CRF"):
        参数 = 参数 + " -crf " + 转字符串(选项.CRF)
    如果 选项.包含("预设"):
        参数 = 参数 + " -preset " + 选项.预设
    返回 参数

// ============================================
// 信息查询功能
// ============================================

函程 获取视频时长(文件路径):
    // 获取视频文件时长（秒）
    设 命令 = FFprobe程序 + " -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 \"" + 文件路径 + "\""
    设 结果 = _执行命令(命令)
    返回 转浮点数(结果.去除空白())

函程 获取视频分辨率(文件路径):
    // 获取视频分辨率，返回 [宽度, 高度]
    设 命令 = FFprobe程序 + " -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 \"" + 文件路径 + "\""
    设 结果 = _执行命令(命令)
    设 部分 = 分割(结果.去除空白(), "x")
    返回 [转整数(部分[0]), 转整数(部分[1])]

函程 获取视频帧率(文件路径):
    // 获取视频帧率
    设 命令 = FFprobe程序 + " -v error -select_streams v:0 -show_entries stream=r_frame_rate -of default=noprint_wrappers=1:nokey=1 \"" + 文件路径 + "\""
    设 结果 = _执行命令(命令)
    设 部分 = 分割(结果.去除空白(), "/")
    返回 转浮点数(部分[0]) / 转浮点数(部分[1])

函程 获取视频比特率(文件路径):
    // 获取视频比特率
    设 命令 = FFprobe程序 + " -v error -select_streams v:0 -show_entries stream=bit_rate -of default=noprint_wrappers=1:nokey=1 \"" + 文件路径 + "\""
    设 结果 = _执行命令(命令)
    返回 转整数(结果.去除空白())

函程 获取媒体信息(文件路径):
    // 获取完整媒体信息
    设 信息 = {}
    信息.文件路径 = 文件路径
    信息.时长 = 获取视频时长(文件路径)
    设 分辨率 = 获取视频分辨率(文件路径)
    信息.宽度 = 分辨率[0]
    信息.高度 = 分辨率[1]
    信息.帧率 = 获取视频帧率(文件路径)
    信息.比特率 = 获取视频比特率(文件路径)
    返回 信息

函程 检查FFmpeg安装():
    // 检查FFmpeg是否正确安装
    返回 文件存在(FFmpeg程序) 且 文件存在(FFprobe程序)

// ============================================
// 基础转换功能
