函程 转换视频(输入文件, 输出文件, 选项 = {}):
    // 通用视频转换函数
    设 参数 = _构建参数(选项)
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\"" + 参数 + " -y \"" + 输出文件 + "\""
    输出 "[转换] " + 输入文件 + " -> " + 输出文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 转换格式(输入文件, 输出文件):
    // 简单格式转换（保持原质量）
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -c copy -y \"" + 输出文件 + "\""
    输出 "[转换格式] " + 输入文件 + " -> " + 输出文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 压缩视频(输入文件, 输出文件, 质量 = "medium"):
    // 压缩视频
    设 CRF值 = 23
    如果 质量 == "low":
        CRF值 = 28
    否则如果 质量 == "medium":
        CRF值 = 23
    否则如果 质量 == "high":
        CRF值 = 18
    否则如果 质量 == "ultra":
        CRF值 = 15
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -c:v libx264 -crf " + 转字符串(CRF值) + " -c:a aac -b:a 128k -y \"" + 输出文件 + "\""
    输出 "[压缩] " + 输入文件 + " (质量: " + 质量 + ")"
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 音频处理功能
// ============================================

函程 提取音频(输入文件, 输出文件, 音频格式 = "mp3"):
    // 从视频中提取音频
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vn -c:a " + 音频格式 + " -y \"" + 输出文件 + "\""
    输出 "[提取音频] " + 输入文件 + " -> " + 输出文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 转换音频(输入文件, 输出文件, 格式 = "mp3", 比特率 = "192k"):
    // 音频格式转换
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -c:a " + 格式 + " -b:a " + 比特率 + " -y \"" + 输出文件 + "\""
    输出 "[转换音频] " + 输入文件 + " -> " + 输出文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 合并音视频(视频文件, 音频文件, 输出文件):
    // 合并视频和音频
    设 命令 = FFmpeg程序 + " -i \"" + 视频文件 + "\" -i \"" + 音频文件 + "\" -c:v copy -c:a aac -y \"" + 输出文件 + "\""
    输出 "[合并音视频] " + 视频文件 + " + " + 音频文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 替换音频(视频文件, 新音频, 输出文件):
    // 替换视频中的音频
    设 命令 = FFmpeg程序 + " -i \"" + 视频文件 + "\" -i \"" + 新音频 + "\" -c:v copy -c:a aac -map 0:v:0 -map 1:a:0 -y \"" + 输出文件 + "\""
    输出 "[替换音频] " + 视频文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 调整音量(输入文件, 输出文件, 音量倍数):
    // 调整音量
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -af \"volume=" + 转字符串(音量倍数) + "\" -y \"" + 输出文件 + "\""
    输出 "[调整音量] " + 输入文件 + " (倍数: " + 转字符串(音量倍数) + ")"
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 去除音频(输入文件, 输出文件):
    // 去除视频中的音频
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -an -c:v copy -y \"" + 输出文件 + "\""
    输出 "[去除音频] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 视频剪辑功能
// ============================================

函程 截取视频(输入文件, 输出文件, 开始时间, 结束时间):
    // 截取视频片段
    设 开始秒 = 开始时间
    设 时长 = 结束时间 - 开始时间
    设 命令 = FFmpeg程序 + " -ss " + 转字符串(开始秒) + " -i \"" + 输入文件 + "\" -t " + 转字符串(时长) + " -c copy -y \"" + 输出文件 + "\""
    输出 "[截取] " + 输入文件 + " (" + 转字符串(开始时间) + "s - " + 转字符串(结束时间) + "s)"
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 拼接视频(视频列表, 输出文件):
    // 拼接多个视频
    设 输入参数 = ""
    遍 视频 于 视频列表:
        输入参数 = 输入参数 + " -i \"" + 视频 + "\""
    设 命令 = FFmpeg程序 + 输入参数 + " -filter_complex \"concat=n=" + 转字符串(数组长度(视频列表)) + ":v=1:a=1\" -y \"" + 输出文件 + "\""
    输出 "[拼接] " + 转字符串(数组长度(视频列表)) + " 个视频"
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 视频滤镜功能
// ============================================

函程 裁剪视频(输入文件, 输出文件, 宽, 高, x = 0, y = 0):
    // 裁剪视频区域
    设 滤镜 = "crop=" + 转字符串(宽) + ":" + 转字符串(高) + ":" + 转字符串(x) + ":" + 转字符串(y)
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[裁剪] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 缩放视频(输入文件, 输出文件, 宽度, 高度 = -1):
    // 缩放视频
    设 滤镜 = "scale=" + 转字符串(宽度) + ":" + 转字符串(高度)
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[缩放] " + 输入文件 + " -> " + 转字符串(宽度) + "x" + 转字符串(高度)
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 旋转视频(输入文件, 输出文件, 角度):
    // 旋转视频
    设 滤镜 = ""
    如果 角度 == 90:
        滤镜 = "transpose=1"
    否则如果 角度 == 180:
        滤镜 = "transpose=1,transpose=1"
    否则如果 角度 == 270:
        滤镜 = "transpose=2"
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[旋转] " + 输入文件 + " (" + 转字符串(角度) + "度)"
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 水平翻转(输入文件, 输出文件):
    // 水平翻转视频
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"hflip\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[水平翻转] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 垂直翻转(输入文件, 输出文件):
    // 垂直翻转视频
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"vflip\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[垂直翻转] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 添加文字水印(输入文件, 输出文件, 文字, x = 10, y = 10, 字体大小 = 24, 颜色 = "white"):
    // 添加文字水印
    设 滤镜 = "drawtext=text='" + 文字 + "':x=" + 转字符串(x) + ":y=" + 转字符串(y) + ":fontsize=" + 转字符串(字体大小) + ":fontcolor=" + 颜色
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[添加文字水印] " + 文字
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 模糊处理(输入文件, 输出文件, 强度 = 5):
    // 模糊视频
    设 滤镜 = "boxblur=" + 转字符串(强度) + ":" + 转字符串(强度)
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[模糊处理] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 灰度转换(输入文件, 输出文件):
    // 转换为灰度视频
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"format=gray\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[灰度转换] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 调整亮度对比度(输入文件, 输出文件, 亮度 = 0, 对比度 = 1, 饱和度 = 1):
    // 调整亮度、对比度、饱和度
    设 滤镜 = "eq=brightness=" + 转字符串(亮度) + ":contrast=" + 转字符串(对比度) + ":saturation=" + 转字符串(饱和度)
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[调整亮度对比度] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 截图和GIF功能
// ============================================

函程 截取帧(输入文件, 输出图片, 时间点 = 0):
    // 截取指定时间的帧
    设 命令 = FFmpeg程序 + " -ss " + 转字符串(时间点) + " -i \"" + 输入文件 + "\" -vframes 1 -y \"" + 输出图片 + "\""
    输出 "[截取帧] " + 输入文件 + " (" + 转字符串(时间点) + "s)"
    _执行命令(命令)
    返回 文件存在(输出图片)

函程 批量截图(输入文件, 输出目录, 间隔秒数 = 1):
    // 按时间间隔批量截图
    设 时长 = 获取视频时长(输入文件)
    设 计数 = 0
    设 时间 = 0
    循环 时间 < 时长:
        设 输出图片 = 输出目录 + "\\frame_" + 转字符串(计数) + ".jpg"
        截取帧(输入文件, 输出图片, 时间)
        计数 = 计数 + 1
        时间 = 时间 + 间隔秒数
    输出 "[批量截图] 共截取 " + 转字符串(计数) + " 帧"

函程 生成GIF(输入文件, 输出文件, 开始时间, 持续时间, 宽度 = 480, 帧率 = 10):
    // 从视频生成GIF
    设 滤镜 = "fps=" + 转字符串(帧率) + ",scale=" + 转字符串(宽度) + ":-1:flags=lanczos,split[s0][s1];[s0]palettegen=max_colors=128[p];[s1][p]paletteuse"
    设 命令 = FFmpeg程序 + " -ss " + 转字符串(开始时间) + " -t " + 转字符串(持续时间) + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -loop 0 -y \"" + 输出文件 + "\""
    输出 "[生成GIF] " + 输入文件 + " -> " + 输出文件
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 字幕功能
// ============================================

函程 添加字幕(输入文件, 字幕文件, 输出文件):
    // 添加字幕到视频
    设 滤镜 = "subtitles='" + 字幕文件 + "'"
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[添加字幕] " + 字幕文件
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 硬件加速功能
// ============================================

函程 使用NVENC编码(输入文件, 输出文件):
    // 使用NVIDIA硬件加速编码
    设 命令 = FFmpeg程序 + " -hwaccel cuda -i \"" + 输入文件 + "\" -c:v h264_nvenc -c:a copy -y \"" + 输出文件 + "\""
    输出 "[NVENC编码] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 使用QSV编码(输入文件, 输出文件):
    // 使用Intel Quick Sync硬件加速编码
    设 命令 = FFmpeg程序 + " -hwaccel qsv -i \"" + 输入文件 + "\" -c:v h264_qsv -c:a copy -y \"" + 输出文件 + "\""
    输出 "[QSV编码] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 特效功能
// ============================================

函程 改变播放速度(输入文件, 输出文件, 速度倍数):
    // 改变视频播放速度
    设 滤镜 = "setpts=" + 转字符串(1/速度倍数) + "*PTS"
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf \"" + 滤镜 + "\" -c:a copy -y \"" + 输出文件 + "\""
    输出 "[改变速度] " + 转字符串(速度倍数) + "x"
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 视频倒放(输入文件, 输出文件):
    // 视频倒放
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -vf reverse -af areverse -y \"" + 输出文件 + "\""
    输出 "[视频倒放] " + 输入文件
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 设置视频质量(输入文件, 输出文件, CRF值 = 23):
    // 设置视频质量（CRF，0-51，越小质量越好）
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -c:v libx264 -crf " + 转字符串(CRF值) + " -c:a aac -y \"" + 输出文件 + "\""
    输出 "[设置质量] CRF=" + 转字符串(CRF值)
    _执行命令(命令)
    返回 文件存在(输出文件)

函程 设置编码预设(输入文件, 输出文件, 预设 = "medium"):
    // 设置编码预设
    设 命令 = FFmpeg程序 + " -i \"" + 输入文件 + "\" -c:v libx264 -preset " + 预设 + " -c:a aac -y \"" + 输出文件 + "\""
    输出 "[设置预设] " + 预设
    _执行命令(命令)
    返回 文件存在(输出文件)

// ============================================
// 批量处理功能
// ============================================

函程 批量转换(输入目录, 输出目录, 源格式, 目标格式):
    // 批量转换目录中的视频文件
    输出 "[批量转换] " + 输入目录 + " -> " + 输出目录
    如果 非 目录存在(输出目录):
        创建目录(输出目录)
    设 文件列表 = 目录列表(输入目录)
    设 计数 = 0
    遍 文件名 于 文件列表:
        如果 文件名.结尾是("." + 源格式):
            设 输入路径 = 输入目录 + "\\" + 文件名
            设 输出文件名 = 子串(文件名, 0, 字符串长度(文件名) - 字符串长度(源格式) - 1) + "." + 目标格式
            设 输出路径 = 输出目录 + "\\" + 输出文件名
            转换格式(输入路径, 输出路径)
            计数 = 计数 + 1
    输出 "[完成] 共转换 " + 转字符串(计数) + " 个文件"

函程 批量提取音频(输入目录, 输出目录, 音频格式 = "mp3"):
    // 批量提取音频
    输出 "[批量提取音频] " + 输入目录
    如果 非 目录存在(输出目录):
        创建目录(输出目录)
    设 文件列表 = 目录列表(输入目录)
    设 计数 = 0
    遍 文件名 于 文件列表:
        如果 文件名.结尾是(".mp4") 或 文件名.结尾是(".mkv") 或 文件名.结尾是(".avi"):
            设 输入路径 = 输入目录 + "\\" + 文件名
            设 输出文件名 = 子串(文件名, 0, 字符串长度(文件名) - 4) + "." + 音频格式
            设 输出路径 = 输出目录 + "\\" + 输出文件名
            提取音频(输入路径, 输出路径, 音频格式)
            计数 = 计数 + 1
    输出 "[完成] 共提取 " + 转字符串(计数) + " 个音频"
