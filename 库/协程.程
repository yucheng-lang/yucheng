// 协程 - 基于生成器的协作式多任务调度
// 语程对象按值传递，所有修改对象的函数均返回修改后的对象。
// 调用者必须使用 调度器 = 函数(调度器, ...) 模式赋值回去。

// === 协程状态 ===

函程 创建协程(函数, 名称): // 公开
    返回 {
        函数: 函数,
        状态: "已创建",
        名称: 名称,
        挂起时间: 0,
        上次运行: 0,
        结果: 空,
        错误: 空,
        步骤: 0
    }

// === 协程调度器 ===

函程 创建调度器(): // 公开
    返回 {
        协程列表: [],
        当前索引: 0,
        运行中: 假
    }

函程 添加协程(调度器, 协程): // 公开
    设 新列表 = 追加(调度器.协程列表, 协程)
    调度器.协程列表 = 新列表
    返回 调度器

函程 移除协程(调度器, 协程): // 公开
    设 新列表 = []
    遍 项 于 调度器.协程列表:
        如果 项.名称 != 协程.名称:
            新列表 = 追加(新列表, 项)
    调度器.协程列表 = 新列表
    返回 调度器

函程 挂起(协程, 秒数): // 公开
    协程.状态 = "挂起"
    协程.挂起时间 = 秒数
    协程.上次运行 = 系统时间()
    返回 协程

函程 恢复(协程): // 公开
    如果 协程.状态 == "挂起":
        协程.状态 = "执行中"
        协程.挂起时间 = 0
    返回 协程

函程 是存活(协程): // 公开
    返回 协程.状态 != "已完成"

函程 是挂起(协程): // 公开
    返回 协程.状态 == "挂起"

// === 调度器运行 ===

函程 运行调度器(调度器): // 公开
    调度器.运行中 = 真
    循环 长度(调度器.协程列表) > 0:
        设 计 = 0
        设 活跃数 = 0
        设 新列表 = []
        循环 计 < 长度(调度器.协程列表):
            设 协程 = 调度器.协程列表[计]
            设 已完成 = 假
            // 检查挂起的协程是否可以恢复
            如果 协程.状态 == "挂起":
                设 已过 = 系统时间() - 协程.上次运行
                如果 协程.挂起时间 > 0 且 已过 < 协程.挂起时间:
                    新列表 = 追加(新列表, 协程)
                    计 = 计 + 1
                    继续执行
                协程.状态 = "执行中"
            // 执行协程一步
            如果 协程.状态 == "已创建" 或 协程.状态 == "执行中":
                活跃数 = 活跃数 + 1
                尝试:
                    设 结果 = 协程.函数(协程)
                    如果 结果 == "完成" 或 结果 == 空:
                        协程.状态 = "已完成"
                        协程.结果 = 结果
                        已完成 = 真
                    否则 如果 结果 == "挂起":
                        协程.状态 = "挂起"
                    否则:
                        协程.结果 = 结果
                        协程.步骤 = 协程.步骤 + 1
                捕获 错误:
                    协程.状态 = "已完成"
                    协程.错误 = 错误
                    已完成 = 真
            如果 非 已完成:
                新列表 = 追加(新列表, 协程)
            计 = 计 + 1
        调度器.协程列表 = 新列表
        如果 活跃数 == 0:
            中断
    调度器.运行中 = 假
    返回 调度器

// === 便捷函数 ===

函程 启动协程(函数, 名称): // 公开
    返回 创建协程(函数, 名称)

函程 运行全部(协程列表): // 公开
    设 调度器 = 创建调度器()
    遍 项 于 协程列表:
        调度器 = 添加协程(调度器, 项)
    调度器 = 运行调度器(调度器)
    返回 调度器

函程 协程结果(协程): // 公开
    返回 协程.结果

函程 协程错误(协程): // 公开
    返回 协程.错误
