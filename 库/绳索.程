// 绳索 - Rope数据结构
// 用于高效表示超长字符串的连接树
// 连接操作O(1)，只在转换为字符串时才展平
//
// 公开接口：创建绳索、绳索连接、绳索长度、绳索索引、
//           绳索展平、叶子遍历、绳索切片、
//           绳索格式化、绳索插入、绳索删除

// === 创建绳索 ===

函程 创建绳索(文本 = ""): // 公开
    // 从字符串创建绳索
    如果 字符串长度(文本) == 0:
        返回 空
    返回 {
        类型: "叶子",
        数据: 文本,
        长度: 字符串长度(文本)
    }

函程 从整数创建绳索(值): // 公开
    返回 创建绳索(转文本(值))

// === 绳索连接 ===

函程 绳索连接(左, 右): // 公开
    如果 左 == 空:
        返回 右
    如果 右 == 空:
        返回 左
    返回 {
        类型: "内部",
        左: 左,
        右: 右,
        长度: 绳索长度(左) + 绳索长度(右)
    }

函程 绳索追加(绳索, 文本): // 公开
    返回 绳索连接(绳索, 创建绳索(文本))

函程 绳索前置(文本, 绳索): // 公开
    返回 绳索连接(创建绳索(文本), 绳索)

// === 绳索查询 ===

函程 绳索长度(绳索): // 公开
    如果 绳索 == 空:
        返回 0
    返回 绳索.长度

函程 绳索为空(绳索): // 公开
    返回 绳索 == 空 或 绳索.长度 == 0

函程 绳索索引(绳索, 位置): // 公开
    如果 绳索 == 空 或 位置 < 0 或 位置 >= 绳索.长度:
        返回 ""
    设 当前 = 绳索
    设 偏移 = 位置
    循环 当 真:
        如果 当前.类型 == "叶子":
            返回 子串(当前.数据, 偏移, 1)
        // 内部节点
        如果 偏移 < 绳索长度(当前.左):
            当前 = 当前.左
        否则:
            偏移 = 偏移 - 绳索长度(当前.左)
            当前 = 当前.右

// === 绳索展平 ===

函程 绳索展平(绳索): // 公开
    如果 绳索 == 空:
        返回 ""
    如果 绳索.类型 == "叶子":
        返回 绳索.数据
    返回 绳索展平(绳索.左) + 绳索展平(绳索.右)

// === 叶子遍历 ===

函程 绳索叶子列表(绳索): // 公开
    如果 绳索 == 空:
        返回 []
    如果 绳索.类型 == "叶子":
        返回 [绳索.数据]
    设 结果 = 绳索叶子列表(绳索.左)
    遍 项 于 绳索叶子列表(绳索.右):
        结果.添加(项)
    返回 结果

函程 绳索字符列表(绳索): // 公开
    设 结果 = []
    遍 叶子 于 绳索叶子列表(绳索):
        设 i = 0
        循环 当 i < 字符串长度(叶子):
            结果.添加(子串(叶子, i, 1))
            i = i + 1
    返回 结果

// === 绳索切片 ===

函程 绳索切片(绳索, 起始, 末位): // 公开
    // 获取绳索的子绳索[start, end)
    如果 绳索 == 空:
        返回 空
    设 长 = 绳索长度(绳索)
    如果 起始 < 0:
        起始 = 0
    如果 末位 > 长:
        末位 = 长
    如果 起始 >= 末位:
        返回 空
    返回 绳索切片内部(绳索, 起始, 末位)

函程 绳索切片内部(绳索, 起始, 末位): // 内部
    如果 绳索.类型 == "叶子":
        返回 创建绳索(子串(绳索.数据, 起始, 末位 - 起始))
    设 左长 = 绳索长度(绳索.左)
    如果 末位 <= 左长:
        返回 绳索切片内部(绳索.左, 起始, 末位)
    如果 起始 >= 左长:
        返回 绳索切片内部(绳索.右, 起始 - 左长, 末位 - 左长)
    设 左部分 = 绳索切片内部(绳索.左, 起始, 左长)
    设 右部分 = 绳索切片内部(绳索.右, 0, 末位 - 左长)
    返回 绳索连接(左部分, 右部分)

// === 绳索插入 ===

函程 绳索插入(绳索, 位置, 文本): // 公开
    设 长 = 绳索长度(绳索)
    如果 位置 <= 0:
        返回 绳索连接(创建绳索(文本), 绳索)
    如果 位置 >= 长:
        返回 绳索连接(绳索, 创建绳索(文本))
    设 前部 = 绳索切片(绳索, 0, 位置)
    设 后部 = 绳索切片(绳索, 位置, 长)
    返回 绳索连接(绳索连接(前部, 创建绳索(文本)), 后部)

// === 绳索删除 ===

函程 绳索删除(绳索, 起始, 末位): // 公开
    设 长 = 绳索长度(绳索)
    如果 起始 >= 末位 或 起始 >= 长:
        返回 绳索
    如果 末位 > 长:
        末位 = 长
    如果 起始 <= 0:
        返回 绳索切片(绳索, 末位, 长)
    设 前部 = 绳索切片(绳索, 0, 起始)
    设 后部 = 绳索切片(绳索, 末位, 长)
    返回 绳索连接(前部, 后部)

// === 绳索替换 ===

函程 绳索替换(绳索, 起始, 末位, 新文本): // 公开
    设 长 = 绳索长度(绳索)
    设 前 = 绳索切片(绳索, 0, 起始)
    设 后 = 绳索切片(绳索, 末位, 长)
    返回 绳索连接(绳索连接(前, 创建绳索(新文本)), 后)

// === 绳索分割 ===

函程 绳索分割(绳索, 位置): // 公开
    设 长 = 绳索长度(绳索)
    返回 {
        左: 绳索切片(绳索, 0, 位置),
        右: 绳索切片(绳索, 位置, 长)
    }

// === 绳索格式化 ===

函程 绳索格式化(格式串, 参数列表): // 公开
    设 结果 = 空
    设 i = 0
    设 参数索引 = 0
    循环 当 i < 字符串长度(格式串):
        设 字符 = 子串(格式串, i, 1)
        如果 字符 == "$":
            i = i + 1
            如果 i >= 字符串长度(格式串):
                跳出
            设 下一个 = 子串(格式串, i, 1)
            如果 下一个 == "$":
                结果 = 绳索追加(结果, "$")
                i = i + 1
            否则如果 下一个 == "#":
                如果 参数索引 < 参数列表.长度():
                    结果 = 绳索连接(结果, 参数列表[参数索引])
                    参数索引 = 参数索引 + 1
                i = i + 1
            否则如果 下一个 >= "1" 且 下一个 <= "9":
                设 编号 = 转整数(下一个) - 1
                i = i + 1
                如果 编号 < 参数列表.长度():
                    结果 = 绳索连接(结果, 参数列表[编号])
            否则:
                结果 = 绳索追加(结果, "$")
        否则:
            结果 = 绳索追加(结果, 字符)
            i = i + 1
    返回 结果

// === 绳索平衡 ===

函程 绳索深度(绳索): // 公开
    如果 绳索 == 空 或 绳索.类型 == "叶子":
        返回 0
    设 左深 = 绳索深度(绳索.左)
    设 右深 = 绳索深度(绳索.右)
    如果 左深 > 右深:
        返回 左深 + 1
    返回 右深 + 1

函程 绳索平衡(绳索): // 公开
    如果 绳索 == 空:
        返回 空
    设 文本 = 绳索展平(绳索)
    返回 创建绳索(文本)

函程 绳索统计(绳索): // 公开
    返回 {
        长度: 绳索长度(绳索),
        深度: 绳索深度(绳索),
        叶子数: 绳索叶子列表(绳索).长度()
    }
