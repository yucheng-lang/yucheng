// ===== 语程标准库：字节序 =====
// 提供字节序（大小端）操作函数
//
// 公开接口：交换字节序16、交换字节序32、交换字节序64、
//           交换字节序、
//           小端编码16、小端编码32、小端编码64、
//           大端编码16、大端编码32、大端编码64、
//           小端解码16、小端解码32、小端解码64、
//           大端解码16、大端解码32、大端解码64、
//           是小端序

// ===== 字节交换 =====

函程 交换字节序16(值): // 公开
    // 交换16位整数的字节序
    设 低 = 值 与 0xFF
    设 高 = (值 与 0xFF00) / 256
    返回 低 * 256 + 高

函程 交换字节序32(值): // 公开
    // 交换32位整数的字节序
    设 b0 = 值 与 0xFF
    设 b1 = (值 与 0xFF00) / 256
    设 b2 = (值 与 0xFF0000) / 65536
    设 b3 = (值 与 0xFF000000) / 16777216
    返回 b0 * 16777216 + b1 * 65536 + b2 * 256 + b3

函程 交换字节序64(值): // 公开
    // 交换64位整数的字节序
    设 结果 = 0
    设 临时 = 值
    遍 i 于 范围(8):
        设 字节 = 临时 与 0xFF
        结果 = 结果 * 256 + 字节
        临时 = 临时 / 256
    返回 结果

函程 交换字节序(值, 位数=32): // 公开
    // 按指定位数交换字节序
    如果 位数 == 16:
        返回 交换字节序16(值)
    如果 位数 == 32:
        返回 交换字节序32(值)
    如果 位数 == 64:
        返回 交换字节序64(值)
    返回 值

// ===== 系统字节序检测 =====

函程 是小端序(): // 公开
    // 检测当前系统是否为小端序
    设 值 = 1
    返回 (值 与 0xFF) == 1

// ===== 主机序与网络序转换 =====

函程 主机序转网络序16(值): // 公开
    // 将主机字节序的16位值转为网络字节序（大端序）
    如果 是小端序():
        返回 交换字节序16(值)
    返回 值

函程 主机序转网络序32(值): // 公开
    // 将主机字节序的32位值转为网络字节序（大端序）
    如果 是小端序():
        返回 交换字节序32(值)
    返回 值

函程 网络序转主机序16(值): // 公开
    // 将网络字节序的16位值转为主机字节序
    如果 是小端序():
        返回 交换字节序16(值)
    返回 值

函程 网络序转主机序32(值): // 公开
    // 将网络字节序的32位值转为主机字节序
    如果 是小端序():
        返回 交换字节序32(值)
    返回 值

// ===== 小端编码 =====

函程 小端编码16(值): // 公开
    // 将16位值编码为小端字节序列
    // 返回字节列表 [低字节, 高字节]
    返回 [值 与 0xFF, (值 与 0xFF00) / 256]

函程 小端编码32(值): // 公开
    // 将32位值编码为小端字节序列
    返回 [值 与 0xFF, (值 与 0xFF00) / 256, (值 与 0xFF0000) / 65536, (值 与 0xFF000000) / 16777216]

函程 小端编码64(值): // 公开
    // 将64位值编码为小端字节序列
    设 结果 = []
    设 临时 = 值
    遍 i 于 范围(8):
        结果 = 追加(结果, 临时 与 0xFF)
        临时 = 临时 / 256
    返回 结果

// ===== 大端编码 =====

函程 大端编码16(值): // 公开
    // 将16位值编码为大端字节序列
    // 返回字节列表 [高字节, 低字节]
    返回 [(值 与 0xFF00) / 256, 值 与 0xFF]

函程 大端编码32(值): // 公开
    // 将32位值编码为大端字节序列
    返回 [(值 与 0xFF000000) / 16777216, (值 与 0xFF0000) / 65536, (值 与 0xFF00) / 256, 值 与 0xFF]

函程 大端编码64(值): // 公开
    // 将64位值编码为大端字节序列
    设 临时 = 值
    设 字节列表 = []
    遍 i 于 范围(8):
        字节列表 = 追加(字节列表, 临时 与 0xFF)
        临时 = 临时 / 256
    // 反转得到大端序
    设 结果 = []
    设 n = 长度(字节列表)
    遍 i 于 范围(n):
        结果 = 追加(结果, 字节列表[n - 1 - i])
    返回 结果

// ===== 小端解码 =====

函程 小端解码16(字节列表): // 公开
    // 从小端字节序列解码16位值
    如果 长度(字节列表) < 2:
        返回 0
    返回 字节列表[0] + 字节列表[1] * 256

函程 小端解码32(字节列表): // 公开
    // 从小端字节序列解码32位值
    如果 长度(字节列表) < 4:
        返回 0
    返回 字节列表[0] + 字节列表[1] * 256 + 字节列表[2] * 65536 + 字节列表[3] * 16777216

函程 小端解码64(字节列表): // 公开
    // 从小端字节序列解码64位值
    如果 长度(字节列表) < 8:
        返回 0
    设 结果 = 0
    设 乘数 = 1
    遍 i 于 范围(8):
        结果 = 结果 + 字节列表[i] * 乘数
        乘数 = 乘数 * 256
    返回 结果

// ===== 大端解码 =====

函程 大端解码16(字节列表): // 公开
    // 从大端字节序列解码16位值
    如果 长度(字节列表) < 2:
        返回 0
    返回 字节列表[0] * 256 + 字节列表[1]

函程 大端解码32(字节列表): // 公开
    // 从大端字节序列解码32位值
    如果 长度(字节列表) < 4:
        返回 0
    返回 字节列表[0] * 16777216 + 字节列表[1] * 65536 + 字节列表[2] * 256 + 字节列表[3]

函程 大端解码64(字节列表): // 公开
    // 从大端字节序列解码64位值
    如果 长度(字节列表) < 8:
        返回 0
    设 结果 = 0
    遍 i 于 范围(8):
        结果 = 结果 * 256 + 字节列表[i]
    返回 结果
