// ===== 语程标准库：配置解析 =====
// 提供配置文件解析与生成工具
//
// 公开接口：解析INI、生成INI、解析键值对、生成键值对、
//           取配置值、设配置值、加载INI文件、保存INI文件、
//           解析CSV行、解析CSV、生成CSV行、生成CSV、
//           加载JSON配置、保存JSON配置

// ===== INI 风格配置 =====

函程 解析INI(文本): // 公开
    设 结果 = {}
    设 当前节 = "默认"
    结果["默认"] = {}
    设 行列表 = 分割行(文本)
    遍 行 于 行列表:
        设 去空 = 去除空白(行)
        // 跳过空行和注释
        如果 字符串长度(去空) == 0:
            继续
        如果 子串(去空, 0, 1) == "#" 或 子串(去空, 0, 1) == ";":
            继续
        // 解析节名
        如果 子串(去空, 0, 1) == "[":
            设 结束位 = 查找(去空, "]")
            如果 结束位 > 0:
                当前节 = 子串(去空, 1, 结束位)
                如果 非 结果.包含(当前节):
                    结果[当前节] = {}
            继续
        // 解析键值对
        设 等号位 = 查找(去空, "=")
        如果 等号位 > 0:
            设 键 = 去除空白(子串(去空, 0, 等号位))
            设 值 = 去除空白(子串(去空, 等号位 + 1, 字符串长度(去空)))
            // 去除值中的注释
            设 注释位 = 查找(值, "#")
            如果 注释位 > 0:
                值 = 去除空白(子串(值, 0, 注释位))
            如果 结果.包含(当前节):
                设 节 = 结果[当前节]
                节[键] = 值
                结果[当前节] = 节
    返回 结果

函程 生成INI(配置): // 公开
    设 结果 = ""
    遍 节名 于 配置.键:
        如果 节名 != "默认":
            结果 = 结果 + "[" + 节名 + "]\n"
        如果 配置.包含(节名):
            设 节 = 配置[节名]
            遍 键 于 节.键:
                结果 = 结果 + 键 + " = " + 转字符串(节[键]) + "\n"
        结果 = 结果 + "\n"
    返回 结果

// ===== 键值对配置 =====

函程 解析键值对(文本): // 公开
    设 结果 = {}
    设 行列表 = 分割行(文本)
    遍 行 于 行列表:
        设 去空 = 去除空白(行)
        如果 字符串长度(去空) == 0:
            继续
        如果 子串(去空, 0, 1) == "#":
            继续
        设 等号位 = 查找(去空, "=")
        如果 等号位 > 0:
            设 键 = 去除空白(子串(去空, 0, 等号位))
            设 值 = 去除空白(子串(去空, 等号位 + 1, 字符串长度(去空)))
            结果[键] = 值
    返回 结果

函程 生成键值对(配置): // 公开
    设 结果 = ""
    遍 k 于 配置.键:
        结果 = 结果 + k + " = " + 转字符串(配置[k]) + "\n"
    返回 结果

// ===== 配置查询 =====

函程 取配置值(配置, 节名, 键, 默认值): // 公开
    如果 配置.包含(节名):
        设 节 = 配置[节名]
        如果 节.包含(键):
            返回 节[键]
    返回 默认值

函程 设配置值(配置, 节名, 键, 值): // 公开
    如果 非 配置.包含(节名):
        配置[节名] = {}
    设 节 = 配置[节名]
    节[键] = 值
    配置[节名] = 节
    返回 配置

函程 加载INI文件(路径): // 公开
    如果 非 文件存在(路径):
        返回 {}
    设 文本 = 读取文件(路径)
    返回 解析INI(文本)

函程 保存INI文件(路径, 配置): // 公开
    设 文本 = 生成INI(配置)
    写入文件(路径, 文本)

// ===== CSV 简易解析 =====

函程 解析CSV行(行, 分隔符): // 公开
    设 结果 = []
    设 当前 = ""
    设 i = 0
    循环 i < 字符串长度(行):
        设 字 = 子串(行, i, i + 1)
        如果 字 == 分隔符:
            结果.添加(当前)
            当前 = ""
        否则:
            当前 = 当前 + 字
        i = i + 1
    结果.添加(当前)
    返回 结果

函程 解析CSV(文本, 分隔符): // 公开
    设 结果 = []
    设 行列表 = 分割行(文本)
    遍 行 于 行列表:
        如果 字符串长度(去除空白(行)) > 0:
            结果.添加(解析CSV行(行, 分隔符))
    返回 结果

函程 生成CSV行(列, 分隔符): // 公开
    设 结果 = ""
    设 i = 0
    循环 i < 数组长度(列):
        如果 i > 0:
            结果 = 结果 + 分隔符
        结果 = 结果 + 转字符串(列[i])
        i = i + 1
    返回 结果

函程 生成CSV(数据, 分隔符): // 公开
    设 结果 = ""
    遍 行 于 数据:
        结果 = 结果 + 生成CSV行(行, 分隔符) + "\n"
    返回 结果

// ===== JSON 配置 =====

函程 加载JSON配置(路径): // 公开
    如果 非 文件存在(路径):
        返回 {}
    设 文本 = 读取文件(路径)
    返回 JSON解析(文本)

函程 保存JSON配置(路径, 配置): // 公开
    设 文本 = JSON格式化(配置)
    写入文件(路径, 文本)
