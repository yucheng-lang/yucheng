// CGI工具
// 提供CGI（通用网关接口）辅助函数

// === CGI环境 ===

函程 请求方法(): // 公开
    返回 环境变量("REQUEST_METHOD")

函程 请求网址(): // 公开
    设 网址 = 环境变量("REQUEST_URI")
    如果 网址 == "":
        返回 "/"
    返回 网址

函程 查询字符串(): // 公开
    返回 环境变量("QUERY_STRING")

函程 服务器名称(): // 公开
    设 名称 = 环境变量("SERVER_NAME")
    如果 名称 == "":
        返回 "localhost"
    返回 名称

函程 服务器端口(): // 公开
    设 端口 = 环境变量("SERVER_PORT")
    如果 端口 == "":
        返回 "80"
    返回 端口

函程 协议类型(): // 公开
    设 协议 = 环境变量("SERVER_PROTOCOL")
    如果 协议 == "":
        返回 "HTTP/1.1"
    返回 协议

函程 内容类型(): // 公开
    返回 环境变量("CONTENT_TYPE")

函程 内容长度(): // 公开
    设 长度文本 = 环境变量("CONTENT_LENGTH")
    如果 长度文本 == "":
        返回 0
    返回 转整数(长度文本)

函程 用户代理(): // 公开
    返回 环境变量("HTTP_USER_AGENT")

函程 来源页面(): // 公开
    返回 环境变量("HTTP_REFERER")

函程 客户端地址(): // 公开
    设 地址 = 环境变量("REMOTE_ADDR")
    如果 地址 == "":
        返回 "127.0.0.1"
    返回 地址

函程 是否HTTPS(): // 公开
    返回 环境变量("HTTPS") == "on"

// === 参数解析 ===

函程 获取参数(): // 公开
    设 方法 = 请求方法()
    如果 方法 == "GET":
        返回 解析查询字符串(查询字符串())
    返回 {}

函程 解析查询字符串(查询串): // 公开
    设 结果 = {}
    如果 长度(查询串) == 0:
        返回 结果
    设 对列表 = 分割(查询串, "&")
    循环 对 于 对列表:
        设 等号位 = 查找(对, "=")
        如果 等号位 >= 0:
            设 键 = 子串(对, 0, 等号位)
            设 值 = 子串(对, 等号位 + 1, 长度(对))
            结果[键] = 值
        否则:
            结果[对] = ""
    返回 结果

// === 响应生成 ===

函程 输出头部(类型 = "text/html", 编码 = "utf-8", 状态码 = 200): // 公开
    设 状态描述 = "OK"
    如果 状态码 == 404:
        状态描述 = "Not Found"
    否则 如果 状态码 == 500:
        状态描述 = "Internal Server Error"
    
    输出 "Status: " + 转字符串(状态码) + " " + 状态描述
    输出 "Content-Type: " + 类型 + "; charset=" + 编码
    输出 ""

函程 输出HTML(内容, 状态码 = 200): // 公开
    输出头部("text/html", "utf-8", 状态码)
    输出 内容

函程 输出文本(内容, 状态码 = 200): // 公开
    输出头部("text/plain", "utf-8", 状态码)
    输出 内容

函程 重定向(网址): // 公开
    输出 "Status: 302 Found"
    输出 "Location: " + 网址
    输出 ""

函程 设置Cookie(名, 值, 路径 = "/", 过期天 = 0): // 公开
    设 Cookie串 = 名 + "=" + 值
    如果 长度(路径) > 0:
        Cookie串 = Cookie串 + "; Path=" + 路径
    如果 过期天 > 0:
        Cookie串 = Cookie串 + "; Max-Age=" + 转字符串(过期天 * 86400)
    输出 "Set-Cookie: " + Cookie串

// === 错误页面 ===

函程 错误页面(状态码, 消息 = ""): // 公开
    设 描述 = "错误"
    如果 状态码 == 404:
        描述 = "页面未找到"
    否则 如果 状态码 == 500:
        描述 = "服务器内部错误"
    
    如果 长度(消息) == 0:
        消息 = 描述
    
    设 HTML = "<!DOCTYPE html><html><head><meta charset=\"utf-8\">"
    HTML = HTML + "<title>" + 转字符串(状态码) + " " + 描述 + "</title></head>"
    HTML = HTML + "<body><h1>" + 转字符串(状态码) + " " + 描述 + "</h1>"
    HTML = HTML + "<p>" + 消息 + "</p></body></html>"
    输出HTML(HTML, 状态码)
