// ===== 语程标准库：解析工具 =====
// 提供字符串解析工具函数
//
// 公开接口：跳过空白、跳过令牌、跳过直到、跳过同时、
//           解析直到、解析同时、捕获之间、
//           解析整数、解析浮点数、解析二进制、解析八进制、解析十六进制、
//           解析标识符、解析尺寸

// ===== 跳过操作 =====

函程 跳过空白(文本, 起始=0): // 公开
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 == " " 或 字 == "\t" 或 字 == "\n" 或 字 == "\r" 或 字 == "\v" 或 字 == "\f":
            i = i + 1
        否则:
            跳出
    返回 i - 起始

函程 跳过令牌(文本, 令牌, 起始=0): // 公开
    设 i = 0
    循环 i < 字符串长度(令牌) 且 起始 + i < 字符串长度(文本):
        如果 子串(文本, 起始 + i, 起始 + i + 1) != 子串(令牌, i, i + 1):
            返回 0
        i = i + 1
    如果 i == 字符串长度(令牌):
        返回 字符串长度(令牌)
    返回 0

函程 跳过令牌忽略大小写(文本, 令牌, 起始=0): // 公开
    设 i = 0
    循环 i < 字符串长度(令牌) 且 起始 + i < 字符串长度(文本):
        设 a = 转小写(子串(文本, 起始 + i, 起始 + i + 1))
        设 b = 转小写(子串(令牌, i, i + 1))
        如果 a != b:
            返回 0
        i = i + 1
    如果 i == 字符串长度(令牌):
        返回 字符串长度(令牌)
    返回 0

函程 跳过直到字符(文本, 目标, 起始=0): // 公开
    设 i = 起始
    循环 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == 目标:
            返回 i - 起始
        i = i + 1
    返回 字符串长度(文本) - 起始

函程 跳过直到字符集(文本, 字符集, 起始=0): // 公开
    // 字符集为逗号分隔的字符列表
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        设 找到 = 假
        遍 c 于 分割(字符集, ","):
            如果 字 == c:
                找到 = 真
        如果 找到:
            返回 i - 起始
        i = i + 1
    返回 字符串长度(文本) - 起始

函程 跳过同时(文本, 字符集, 起始=0): // 公开
    // 跳过所有在字符集中的字符
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        设 属于 = 假
        遍 c 于 分割(字符集, ","):
            如果 字 == c:
                属于 = 真
        如果 非 属于:
            跳出
        i = i + 1
    返回 i - 起始

// ===== 解析操作 =====

函程 解析直到字符(文本, 目标, 起始=0): // 公开
    设 i = 起始
    循环 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == 目标:
            返回 子串(文本, 起始, i)
        i = i + 1
    返回 子串(文本, 起始, 字符串长度(文本))

函程 解析直到字符串(文本, 目标, 起始=0): // 公开
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 匹配 = 真
        设 j = 0
        循环 j < 字符串长度(目标) 且 i + j < 字符串长度(文本):
            如果 子串(文本, i + j, i + j + 1) != 子串(目标, j, j + 1):
                匹配 = 假
            j = j + 1
        如果 匹配 且 j == 字符串长度(目标):
            返回 子串(文本, 起始, i)
        i = i + 1
    返回 子串(文本, 起始, 字符串长度(文本))

函程 解析同时(文本, 字符集, 起始=0): // 公开
    // 解析所有在字符集中的连续字符
    设 i = 起始
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        设 属于 = 假
        遍 c 于 分割(字符集, ","):
            如果 字 == c:
                属于 = 真
        如果 非 属于:
            跳出
        i = i + 1
    返回 子串(文本, 起始, i)

函程 捕获之间(文本, 起始符, 结束符="", 起始=0): // 公开
    // 捕获起始符和结束符之间的内容
    // 如果结束符为空，则使用起始符作为结束符
    设 尾符 = 结束符
    如果 尾符 == "":
        尾符 = 起始符
    设 i = 起始
    // 先找到起始符
    循环 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == 起始符:
            i = i + 1
            跳出
        i = i + 1
    // 收集直到结束符
    设 结果 = ""
    循环 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == 尾符:
            返回 结果
        结果 = 结果 + 子串(文本, i, i + 1)
        i = i + 1
    返回 结果

// ===== 数字解析 =====

函程 解析整数(文本, 起始=0): // 公开
    // 解析十进制整数，返回解析结果和消耗的字符数
    设 i = 起始
    设 符号 = 1
    设 结果 = 0
    设 有数字 = 假
    如果 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "+":
            i = i + 1
        否则如果 子串(文本, i, i + 1) == "-":
            符号 = -1
            i = i + 1
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 >= "0" 且 字 <= "9":
            结果 = 结果 * 10 + (字符编码(字) - 字符编码("0"))
            有数字 = 真
        否则如果 字 == "_":
            忽略
        否则:
            跳出
        i = i + 1
    如果 有数字:
        返回 符号 * 结果
    返回 0

函程 解析整数长度(文本, 起始=0): // 内部
    // 返回解析整数消耗的字符数
    设 i = 起始
    如果 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "+" 或 子串(文本, i, i + 1) == "-":
            i = i + 1
    设 开始 = i
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 (字 >= "0" 且 字 <= "9") 或 字 == "_":
            i = i + 1
        否则:
            跳出
    返回 i - 开始

函程 解析浮点数(文本, 起始=0): // 公开
    // 解析浮点数
    设 i = 起始
    设 符号 = 1
    设 整数部分 = 0
    设 小数部分 = 0
    设 小数位数 = 0
    设 有数字 = 假
    设 有小数 = 假
    如果 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "+":
            i = i + 1
        否则如果 子串(文本, i, i + 1) == "-":
            符号 = -1
            i = i + 1
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 >= "0" 且 字 <= "9":
            如果 有小数:
                小数部分 = 小数部分 * 10 + (字符编码(字) - 字符编码("0"))
                小数位数 = 小数位数 + 1
            否则:
                整数部分 = 整数部分 * 10 + (字符编码(字) - 字符编码("0"))
            有数字 = 真
        否则如果 字 == "." 且 非 有小数:
            有小数 = 真
        否则如果 字 == "_":
            忽略
        否则如果 (字 == "e" 或 字 == "E") 且 有数字:
            // 科学计数法
            设 指符号 = 1
            设 指数值 = 0
            i = i + 1
            如果 i < 字符串长度(文本):
                如果 子串(文本, i, i + 1) == "+":
                    i = i + 1
                否则如果 子串(文本, i, i + 1) == "-":
                    指符号 = -1
                    i = i + 1
            循环 i < 字符串长度(文本):
                设 e字 = 子串(文本, i, i + 1)
                如果 e字 >= "0" 且 e字 <= "9":
                    指数值 = 指数值 * 10 + (字符编码(e字) - 字符编码("0"))
                否则:
                    跳出
                i = i + 1
            设 指数 = 指符号 * 指数值
            设 基数 = 符号 * (整数部分 + 小数部分 / 幂(10, 小数位数))
            返回 基数 * 幂(10, 指数)
        否则:
            跳出
        i = i + 1
    如果 有数字:
        设 值 = 整数部分 + 小数部分 / 幂(10, 小数位数)
        返回 符号 * 值
    返回 0

函程 解析二进制(文本, 起始=0): // 公开
    // 解析二进制数，支持0b前缀和下划线分隔
    设 i = 起始
    设 结果 = 0
    设 有数字 = 假
    // 跳过0b前缀
    如果 i + 1 < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "0" 且 (子串(文本, i + 1, i + 2) == "b" 或 子串(文本, i + 1, i + 2) == "B"):
            i = i + 2
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 == "0":
            结果 = 结果 * 2
            有数字 = 真
        否则如果 字 == "1":
            结果 = 结果 * 2 + 1
            有数字 = 真
        否则如果 字 == "_":
            忽略
        否则:
            跳出
        i = i + 1
    如果 有数字:
        返回 结果
    返回 0

函程 解析八进制(文本, 起始=0): // 公开
    // 解析八进制数，支持0o前缀和下划线分隔
    设 i = 起始
    设 结果 = 0
    设 有数字 = 假
    // 跳过0o前缀
    如果 i + 1 < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "0" 且 (子串(文本, i + 1, i + 2) == "o" 或 子串(文本, i + 1, i + 2) == "O"):
            i = i + 2
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 >= "0" 且 字 <= "7":
            结果 = 结果 * 8 + (字符编码(字) - 字符编码("0"))
            有数字 = 真
        否则如果 字 == "_":
            忽略
        否则:
            跳出
        i = i + 1
    如果 有数字:
        返回 结果
    返回 0

函程 解析十六进制(文本, 起始=0): // 公开
    // 解析十六进制数，支持0x前缀、#前缀和下划线分隔
    设 i = 起始
    设 结果 = 0
    设 有数字 = 假
    // 跳过0x前缀或#前缀
    如果 i + 1 < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "0" 且 (子串(文本, i + 1, i + 2) == "x" 或 子串(文本, i + 1, i + 2) == "X"):
            i = i + 2
    否则如果 i < 字符串长度(文本) 且 子串(文本, i, i + 1) == "#":
        i = i + 1
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 >= "0" 且 字 <= "9":
            结果 = 结果 * 16 + (字符编码(字) - 字符编码("0"))
            有数字 = 真
        否则如果 字 >= "a" 且 字 <= "f":
            结果 = 结果 * 16 + (字符编码(字) - 字符编码("a") + 10)
            有数字 = 真
        否则如果 字 >= "A" 且 字 <= "F":
            结果 = 结果 * 16 + (字符编码(字) - 字符编码("A") + 10)
            有数字 = 真
        否则如果 字 == "_":
            忽略
        否则:
            跳出
        i = i + 1
    如果 有数字:
        返回 结果
    返回 0

// ===== 标识符解析 =====

函程 解析标识符(文本, 起始=0): // 公开
    // 解析ASCII标识符：以字母或下划线开头，后接字母、数字或下划线
    设 i = 起始
    设 结果 = ""
    如果 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 (字 >= "a" 且 字 <= "z") 或 (字 >= "A" 且 字 <= "Z") 或 字 == "_":
            结果 = 结果 + 字
            i = i + 1
            循环 i < 字符串长度(文本):
                设 字2 = 子串(文本, i, i + 1)
                如果 (字2 >= "a" 且 字2 <= "z") 或 (字2 >= "A" 且 字2 <= "Z") 或 (字2 >= "0" 且 字2 <= "9") 或 字2 == "_":
                    结果 = 结果 + 字2
                    i = i + 1
                否则:
                    跳出
    返回 结果

// ===== 尺寸解析 =====

函程 解析尺寸(文本, 起始=0): // 公开
    // 解析人类可读的尺寸字符串，如"10.5 MB"、"64 mib"
    // 返回字节数
    设 i = 起始
    设 数值 = 解析浮点数(文本, 起始)
    设 长度 = 解析整数长度(文本, 起始)
    i = 起始 + 长度
    // 跳过小数部分
    如果 i < 字符串长度(文本) 且 子串(文本, i, i + 1) == ".":
        i = i + 1
        循环 i < 字符串长度(文本):
            设 字 = 子串(文本, i, i + 1)
            如果 字 >= "0" 且 字 <= "9":
                i = i + 1
            否则:
                跳出
    // 跳过空白
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 == " " 或 字 == "\t":
            i = i + 1
        否则:
            跳出
    // 解析单位前缀
    设 倍数 = 1
    如果 i < 字符串长度(文本):
        设 前缀 = 转小写(子串(文本, i, i + 1))
        如果 前缀 == "k":
            倍数 = 1000
            i = i + 1
        否则如果 前缀 == "m":
            倍数 = 1000000
            i = i + 1
        否则如果 前缀 == "g":
            倍数 = 1000000000
            i = i + 1
        否则如果 前缀 == "t":
            倍数 = 1000000000000
            i = i + 1
        否则如果 前缀 == "p":
            倍数 = 1000000000000000
            i = i + 1
        否则如果 前缀 == "e":
            倍数 = 1000000000000000000
            i = i + 1
        // 检查二进制单位 (ki, mi, gi 等)
        如果 i < 字符串长度(文本):
            设 下 = 转小写(子串(文本, i, i + 1))
            如果 下 == "i":
                如果 前缀 == "k":
                    倍数 = 1024
                否则如果 前缀 == "m":
                    倍数 = 1048576
                否则如果 前缀 == "g":
                    倍数 = 1073741824
                否则如果 前缀 == "t":
                    倍数 = 1099511627776
                否则如果 前缀 == "p":
                    倍数 = 1125899906842624
                否则如果 前缀 == "e":
                    倍数 = 1152921504606846976
                i = i + 1
        // 跳过可选的 B/b
        如果 i < 字符串长度(文本):
            设 下 = 转小写(子串(文本, i, i + 1))
            如果 下 == "b":
                i = i + 1
    返回 四舍五入(数值 * 倍数)
