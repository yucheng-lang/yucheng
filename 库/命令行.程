// ===== 语程标准库：命令行 =====
// 提供命令行参数访问工具函数
// 跨平台：所有功能基于内置函数，Windows/Linux/macOS 通用
//
// 公开接口：参数个数、参数值、所有参数、
//           解析命令行、程序名、
//           标志参数、命名参数、位置参数

// ===== 基础参数访问 =====

函程 参数个数(): // 公开
    // 返回命令行参数个数（不含程序名）
    设 参数列表 = 命令行参数()
    返回 长度(参数列表) - 1

函程 参数值(序号): // 公开
    // 返回第序号个命令行参数
    // 序号0为程序名，序号1开始为实际参数
    设 参数列表 = 命令行参数()
    返回 参数列表[序号]

函程 所有参数(): // 公开
    // 返回所有命令行参数列表（不含程序名）
    设 结果 = []
    遍 i 于 范围(1, 参数个数() + 1):
        结果 = 追加(结果, 参数值(i))
    返回 结果

函程 程序名(): // 公开
    // 返回程序名称（第0个参数）
    返回 参数值(0)

// ===== 命令行解析 =====

函程 解析命令行(命令串): // 公开
    // 将命令行字符串解析为参数列表
    // 支持引号和转义
    设 结果 = []
    设 i = 0
    设 当前 = ""
    循环 i < 字符串长度(命令串):
        // 跳过空白
        循环 i < 字符串长度(命令串):
            设 字 = 子串(命令串, i, i + 1)
            如果 字 == " " 或 字 == "\t" 或 字 == "\n" 或 字 == "\r":
                i = i + 1
            否则:
                跳出
        如果 i >= 字符串长度(命令串):
            跳出
        设 字 = 子串(命令串, i, i + 1)
        如果 字 == "\"":
            // 双引号字符串
            i = i + 1
            循环 i < 字符串长度(命令串):
                设 c = 子串(命令串, i, i + 1)
                如果 c == "\\":
                    如果 i + 1 < 字符串长度(命令串):
                        设 下 = 子串(命令串, i + 1, i + 2)
                        如果 下 == "\"":
                            当前 = 当前 + "\""
                            i = i + 2
                        否则如果 下 == "\\":
                            当前 = 当前 + "\\"
                            i = i + 2
                        否则如果 下 == "n":
                            当前 = 当前 + "\n"
                            i = i + 2
                        否则如果 下 == "t":
                            当前 = 当前 + "\t"
                            i = i + 2
                        否则:
                            当前 = 当前 + c
                            i = i + 1
                    否则:
                        当前 = 当前 + c
                        i = i + 1
                否则如果 c == "\"":
                    i = i + 1
                    跳出
                否则:
                    当前 = 当前 + c
                    i = i + 1
            结果 = 追加(结果, 当前)
            当前 = ""
        否则如果 字 == "'":
            // 单引号字符串
            i = i + 1
            循环 i < 字符串长度(命令串):
                设 c = 子串(命令串, i, i + 1)
                如果 c == "'":
                    i = i + 1
                    跳出
                否则:
                    当前 = 当前 + c
                    i = i + 1
            结果 = 追加(结果, 当前)
            当前 = ""
        否则:
            // 无引号参数
            循环 i < 字符串长度(命令串):
                设 c = 子串(命令串, i, i + 1)
                如果 c == " " 或 c == "\t" 或 c == "\n" 或 c == "\r":
                    跳出
                当前 = 当前 + c
                i = i + 1
            结果 = 追加(结果, 当前)
            当前 = ""
    返回 结果

// ===== 高级参数分析 =====

函程 标志参数(标志名): // 公开
    // 检查命令行中是否存在指定标志
    // 支持 -x 和 --xxx 形式
    设 短标志 = "-" + 标志名
    设 长标志 = "--" + 标志名
    遍 i 于 范围(1, 参数个数() + 1):
        设 参数 = 参数值(i)
        如果 参数 == 短标志 或 参数 == 长标志:
            返回 真
        // 支持 -abc 形式的组合短标志
        如果 字符串长度(参数) > 1 且 子串(参数, 0, 1) == "-" 且 子串(参数, 1, 2) != "-":
            如果 查找(子串(参数, 1, 字符串长度(参数)), 标志名) >= 0:
                返回 真
    返回 假

函程 命名参数(名称, 默认值=""): // 公开
    // 获取命名参数的值
    // 支持 --name=value 和 --name value 形式
    设 长名 = "--" + 名称
    设 等号名 = 长名 + "="
    遍 i 于 范围(1, 参数个数() + 1):
        设 参数 = 参数值(i)
        // --name=value 形式
        如果 字符串长度(参数) > 字符串长度(等号名):
            如果 子串(参数, 0, 字符串长度(等号名)) == 等号名:
                返回 子串(参数, 字符串长度(等号名), 字符串长度(参数))
        // --name value 形式
        如果 参数 == 长名:
            如果 i + 1 <= 参数个数():
                设 下个 = 参数值(i + 1)
                如果 子串(下个, 0, 1) != "-":
                    返回 下个
            返回 默认值
    返回 默认值

函程 位置参数(): // 公开
    // 获取所有位置参数（非标志、非命名参数）
    设 结果 = []
    设 i = 1
    循环 i <= 参数个数():
        设 参数 = 参数值(i)
        如果 子串(参数, 0, 1) == "-":
            // 跳过标志和命名参数
            如果 查找(参数, "=") < 0 且 i + 1 <= 参数个数():
                设 下个 = 参数值(i + 1)
                如果 子串(下个, 0, 1) != "-":
                    i = i + 1
        否则:
            结果 = 追加(结果, 参数)
        i = i + 1
    返回 结果

函程 要求参数(序号, 提示=""): // 公开
    // 获取必需的参数，如果没有则报错
    如果 序号 < 1 或 序号 > 参数个数():
        如果 提示 != "":
            输出("错误: 缺少参数 - " + 提示)
        否则:
            输出("错误: 缺少第" + 转字符串(序号) + "个参数")
        返回 ""
    返回 参数值(序号)

// ===== 命令行交互 =====

函程 询问确认(提示, 默认=真): // 公开
    // 询问用户是否确认
    设 选项 = 默认 ? "[Y/n]" : "[y/N]"
    输出(提示 + " " + 选项 + " ")
    设 回答 = 读取输入()
    回答 = 去首尾空白(转小写(回答))
    如果 回答 == "y" 或 回答 == "yes" 或 回答 == "是":
        返回 真
    如果 回答 == "n" 或 回答 == "no" 或 回答 == "否":
        返回 假
    返回 默认

函程 询问选择(提示, 选项列表): // 公开
    // 询问用户从列表中选择
    输出(提示)
    遍 i 于 范围(长度(选项列表)):
        输出("  " + 转字符串(i + 1) + ") " + 选项列表[i])
    输出("请选择 (1-" + 转字符串(长度(选项列表)) + "): ")
    设 回答 = 读取输入()
    设 序号 = 转整数(去首尾空白(回答))
    如果 序号 >= 1 且 序号 <= 长度(选项列表):
        返回 选项列表[序号 - 1]
    返回 选项列表[0]

函程 询问输入(提示, 默认值=""): // 公开
    // 询问用户输入
    输出(提示 + " ")
    设 回答 = 读取输入()
    回答 = 去首尾空白(回答)
    如果 回答 == "":
        返回 默认值
    返回 回答
