// 多维数组 - 多维数组视图实现（纯列表+元数据）
// 放弃零拷贝视图语义，改用列表+形状+步长元数据模拟多维索引
// 支持行主序和列主序布局
//
// 公开接口：创建多维数组、获取维度/形状/元素总数、
//           多维取值/多维设值、切片、转为列表、
//           遍历元素、遍历索引对、数组相等判断

// === 布局常量 ===

函程 行主序(): // 公开
    返回 "行主序"

函程 列主序(): // 公开
    返回 "列主序"

// === 步长计算 ===

函程 计算步长(形状, 布局): // 内部
    // 根据形状和布局计算步长
    设 维度数 = 形状.长度()
    设 步长 = []
    设 i = 0
    循环 当 i < 维度数:
        步长.添加(0)
        i = i + 1
    步长[维度数 - 1] = 1
    设 j = 维度数 - 2
    循环 当 j >= 0:
        如果 布局 == 行主序():
            步长[j] = 步长[j + 1] * 形状[j + 1]
        否则:
            // 列主序：前面维度的步长更小
            如果 j == 维度数 - 2:
                步长[j] = 1
            否则:
                步长[j] = 步长[j + 1]
        j = j - 1
    // 列主序修正
    如果 布局 == 列主序():
        设 i2 = 0
        循环 当 i2 < 维度数 - 1:
            步长[i2] = 步长[i2 + 1] * 形状[i2 + 1]
            i2 = i2 + 1
        // 反转步长（列主序第一个维度步长最大）
        设 反转 = []
        设 k = 维度数 - 1
        循环 当 k >= 0:
            反转.添加(步长[k])
            k = k - 1
        设 正式 = []
        设 m = 反转.长度() - 1
        循环 当 m >= 0:
            正式.添加(反转[m])
            m = m - 1
        步长 = 正式
    返回 步长

// === 创建多维数组 ===

函程 创建多维数组(数据, 形状, 布局 = "行主序"): // 公开
    // 从一维列表和形状创建多维数组
    // 数据: 一维列表
    // 形状: 每个维度的大小的列表，如 [2, 3]
    // 布局: "行主序" 或 "列主序"
    如果 数据.长度() == 0:
        返回 {
            数据: [],
            形状: [],
            步长: [],
            布局: 布局
        }
    // 验证形状与数据长度匹配
    设 总数 = 1
    遍 维 于 形状:
        总数 = 总数 * 维
    如果 总数 != 数据.长度():
        返回 {
            数据: [],
            形状: [],
            步长: [],
            布局: 布局
        }
    返回 {
        数据: 数据,
        形状: 形状,
        步长: 计算步长(形状, 布局),
        布局: 布局
    }

函程 创建零数组(形状, 布局 = "行主序"): // 公开
    // 创建全零多维数组
    设 总数 = 1
    遍 维 于 形状:
        总数 = 总数 * 维
    设 数据 = []
    设 i = 0
    循环 当 i < 总数:
        数据.添加(0)
        i = i + 1
    返回 创建多维数组(数据, 形状, 布局)

函程 创建填充数组(值, 形状, 布局 = "行主序"): // 公开
    // 创建全指定值的多维数组
    设 总数 = 1
    遍 维 于 形状:
        总数 = 总数 * 维
    设 数据 = []
    设 i = 0
    循环 当 i < 总数:
        数据.添加(值)
        i = i + 1
    返回 创建多维数组(数据, 形状, 布局)

// === 查询函数 ===

函程 获取维度(数组): // 公开
    // 获取数组的维度数
    返回 数组.形状.长度()

函程 获取形状(数组): // 公开
    // 获取数组的形状
    返回 数组.形状

函程 元素总数(数组): // 公开
    // 获取数组的总元素数
    如果 数组.形状.长度() == 0:
        返回 0
    设 总数 = 1
    遍 维 于 数组.形状:
        总数 = 总数 * 维
    返回 总数

函程 数组为空(数组): // 公开
    // 检查数组是否为空
    返回 元素总数(数组) == 0

函程 获取布局(数组): // 公开
    // 获取数组的内存布局
    返回 数组.布局

// === 索引操作 ===

函程 计算偏移(数组, 索引): // 公开
    // 计算多维索引的线性偏移
    如果 索引.长度() != 数组.形状.长度():
        返回 -1
    设 偏移 = 0
    设 i = 0
    循环 当 i < 索引.长度():
        如果 索引[i] < 0 或 索引[i] >= 数组.形状[i]:
            返回 -1
        偏移 = 偏移 + 索引[i] * 数组.步长[i]
        i = i + 1
    返回 偏移

函程 多维取值(数组, 索引): // 公开
    // 通过多维索引获取元素值
    // 索引为列表，如 [1, 2]
    设 偏移 = 计算偏移(数组, 索引)
    如果 偏移 < 0 或 偏移 >= 数组.数据.长度():
        返回 空
    返回 数组.数据[偏移]

函程 多维设值(数组, 索引, 值): // 公开
    // 通过多维索引设置元素值
    设 偏移 = 计算偏移(数组, 索引)
    如果 偏移 >= 0 且 偏移 < 数组.数据.长度():
        数组.数据[偏移] = 值
    返回 数组

// === 切片操作 ===

函程 数组切片(数组, 范围列表): // 公开
    // 创建数组的切片
    // 范围列表: 每个维度的[起始, 结束]对
    // 如 [[0,1], [1,3]] 表示第0维取0-1，第1维取1-3
    如果 范围列表.长度() != 数组.形状.长度():
        返回 数组
    设 新形状 = []
    设 新数据 = []
    设 总数 = 1
    遍 范 于 范围列表:
        设 大小 = 范[1] - 范[0]
        如果 大小 < 0:
            大小 = 0
        新形状.添加(大小)
        总数 = 总数 * 大小
    // 遍历所有新索引组合，提取对应元素
    数组切片遍历(数组, 范围列表, 新形状, [], 0, 新数据)
    返回 创建多维数组(新数据, 新形状, 数组.布局)

函程 数组切片遍历(数组, 范围列表, 新形状, 当前索引, 维度, 结果列表): // 内部
    // 递归遍历切片维度
    如果 维度 == 范围列表.长度():
        设 源索引 = []
        设 i = 0
        循环 当 i < 范围列表.长度():
            源索引.添加(范围列表[i][0] + 当前索引[i])
            i = i + 1
        设 值 = 多维取值(数组, 源索引)
        如果 值 != 空:
            结果列表.添加(值)
        返回
    设 i = 0
    循环 当 i < 新形状[维度]:
        设 新索引 = []
        遍 项 于 当前索引:
            新索引.添加(项)
        新索引.添加(i)
        数组切片遍历(数组, 范围列表, 新形状, 新索引, 维度 + 1, 结果列表)
        i = i + 1

// === 转换函数 ===

函程 数组转列表(数组): // 公开
    // 将多维数组转换为一维列表
    设 结果 = []
    遍 项 于 数组.数据:
        结果.添加(项)
    返回 结果

函程 嵌套列表(数组): // 公开
    // 将多维数组转换为嵌套列表
    // 如 [1,2,3,4,5,6] + 形状[2,3] → [[1,2,3],[4,5,6]]
    返回 嵌套列表内部(数组.数据, 数组.形状, 0)

函程 嵌套列表内部(数据, 形状, 维度): // 内部
    如果 维度 >= 形状.长度():
        如果 数据.长度() > 0:
            返回 数据[0]
        返回 空
    设 结果 = []
    设 块大小 = 1
    设 i = 维度 + 1
    循环 当 i < 形状.长度():
        块大小 = 块大小 * 形状[i]
        i = i + 1
    设 j = 0
    循环 当 j < 形状[维度]:
        设 子数据 = 数据.子串(j * 块大小, (j + 1) * 块大小)
        结果.添加(嵌套列表内部(子数据, 形状, 维度 + 1))
        j = j + 1
    返回 结果

// === 遍历 ===

函程 遍历元素(数组): // 公开
    // 返回所有元素的列表（按线性顺序）
    返回 数组转列表(数组)

函程 遍历索引对(数组): // 公开
    // 返回所有{索引, 值}对的列表
    设 结果 = []
    设 总数 = 元素总数(数组)
    遍 线性索引 于 范围列表(总数):
        设 多维 = 线性转多维(数组, 线性索引)
        结果.添加({索引: 多维, 值: 数组.数据[线性索引]})
    返回 结果

函程 范围列表(上限): // 内部
    设 结果 = []
    设 i = 0
    循环 当 i < 上限:
        结果.添加(i)
        i = i + 1
    返回 结果

函程 线性转多维(数组, 线性索引): // 内部
    设 索引 = []
    设 剩余 = 线性索引
    设 i = 0
    循环 当 i < 数组.形状.长度():
        索引.添加(剩余 / 数组.步长[i])
        剩余 = 剩余 % 数组.步长[i]
        i = i + 1
    返回 索引

// === 比较 ===

函程 数组相等(数组1, 数组2): // 公开
    // 比较两个多维数组是否相等
    如果 数组1.形状.长度() != 数组2.形状.长度():
        返回 假
    设 i = 0
    循环 当 i < 数组1.形状.长度():
        如果 数组1.形状[i] != 数组2.形状[i]:
            返回 假
        i = i + 1
    如果 数组1.数据.长度() != 数组2.数据.长度():
        返回 假
    设 j = 0
    循环 当 j < 数组1.数据.长度():
        如果 数组1.数据[j] != 数组2.数据[j]:
            返回 假
        j = j + 1
    返回 真

// === 常用数组操作 ===

函程 数组映射(数组, 函数): // 公开
    // 对每个元素应用函数，返回新数组
    设 新数据 = []
    遍 项 于 数组.数据:
        新数据.添加(函数(项))
    返回 创建多维数组(新数据, 数组.形状, 数组.布局)

函程 数组过滤非零(数组): // 公开
    // 返回所有非零元素（展平为一维）
    设 结果 = []
    遍 项 于 数组.数据:
        如果 项 != 0 且 项 != "" 且 项 != 假:
            结果.添加(项)
    返回 结果

函程 数组重塑(数组, 新形状): // 公开
    // 在不改变数据的情况下改变数组形状
    设 新总数 = 1
    遍 维 于 新形状:
        新总数 = 新总数 * 维
    如果 新总数 != 数组.数据.长度():
        返回 数组  // 形状不匹配，返回原数组
    返回 创建多维数组(数组.数据, 新形状, 数组.布局)

函程 数组转置(数组): // 公开
    // 转置二维数组（行列互换）
    如果 数组.形状.长度() != 2:
        返回 数组
    设 行数 = 数组.形状[0]
    设 列数 = 数组.形状[1]
    设 新数据 = []
    设 j = 0
    循环 当 j < 列数:
        设 i = 0
        循环 当 i < 行数:
            新数据.添加(多维取值(数组, [i, j]))
            i = i + 1
        j = j + 1
    返回 创建多维数组(新数据, [列数, 行数], 数组.布局)
