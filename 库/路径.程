// ===== 语程标准库：路径 =====
// 提供文件路径操作工具函数
//
// 公开接口：合并路径、分割路径、分割文件名、
//           提取目录、提取文件名、提取扩展名、
//           修改扩展名、添加扩展名、
//           是绝对路径、父目录、路径规范化

// ===== 路径合并与分割 =====

函程 合并路径(路径1, 路径2): // 公开
    设 结果 = 路径1
    设 结果长 = 字符串长度(结果)
    如果 结果长 > 0 且 子串(结果, 结果长 - 1, 1) != "/":
        如果 子串(结果, 结果长 - 1, 1) != "\\":
            结果 = 结果 + "/"
    设 路径2长 = 字符串长度(路径2)
    如果 路径2长 > 0:
        如果 子串(路径2, 0, 1) == "/" 或 子串(路径2, 0, 1) == "\\":
            结果 = 结果 + 子串(路径2, 1, 路径2长 - 1)
        否则:
            结果 = 结果 + 路径2
    返回 结果

函程 分割路径(路径): // 公开
    设 位置 = 字符串长度(路径) - 1
    循环 位置 >= 0:
        设 字 = 子串(路径, 位置, 1)
        如果 字 == "/" 或 字 == "\\":
            返回 [子串(路径, 0, 位置), 子串(路径, 位置 + 1, 字符串长度(路径) - 位置 - 1)]
        位置 = 位置 - 1
    返回 ["", 路径]

函程 分割文件名(路径): // 公开
    设 路径部分 = 分割路径(路径)
    设 文件名 = 路径部分[1]
    设 名长 = 字符串长度(文件名)
    如果 名长 == 0:
        返回 [路径, "", ""]
    设 点位 = 名长 - 1
    循环 点位 >= 0:
        如果 子串(文件名, 点位, 1) == ".":
            返回 [路径部分[0], 子串(文件名, 0, 点位), 子串(文件名, 点位, 名长 - 点位)]
        点位 = 点位 - 1
    返回 [路径部分[0], 文件名, ""]

// ===== 路径提取 =====

函程 提取目录(路径): // 公开
    设 部分 = 分割路径(路径)
    返回 部分[0]

函程 提取文件名(路径): // 公开
    设 部分 = 分割路径(路径)
    返回 部分[1]

函程 提取扩展名(路径): // 公开
    设 部分 = 分割文件名(路径)
    返回 部分[2]

函程 提取主文件名(路径): // 公开
    设 部分 = 分割文件名(路径)
    返回 部分[1]

// ===== 路径修改 =====

函程 修改扩展名(路径, 新扩展名): // 公开
    设 部分 = 分割文件名(路径)
    设 目录 = 部分[0]
    设 主名 = 部分[1]
    设 结果 = ""
    如果 字符串长度(目录) > 0:
        结果 = 目录 + "/"
    结果 = 结果 + 主名
    如果 字符串长度(新扩展名) > 0:
        如果 子串(新扩展名, 0, 1) != ".":
            结果 = 结果 + "."
        结果 = 结果 + 新扩展名
    返回 结果

函程 添加扩展名(路径, 扩展名): // 公开
    设 当前 = 提取扩展名(路径)
    如果 字符串长度(当前) > 0:
        返回 路径
    返回 修改扩展名(路径, 扩展名)

// ===== 路径判断 =====

函程 是绝对路径(路径): // 公开
    如果 字符串长度(路径) == 0:
        返回 假
    设 首 = 子串(路径, 0, 1)
    如果 首 == "/":
        返回 真
    如果 字符串长度(路径) >= 2:
        设 次 = 子串(路径, 1, 1)
        如果 次 == ":":
            返回 真
    返回 假

函程 父目录(路径): // 公开
    设 部分 = 分割路径(路径)
    如果 字符串长度(部分[0]) == 0:
        返回 ""
    返回 部分[0]

函程 路径规范化(路径): // 公开
    设 结果 = ""
    设 i = 0
    设 长度 = 字符串长度(路径)
    循环 i < 长度:
        设 字 = 子串(路径, i, 1)
        如果 字 == "\\":
            结果 = 结果 + "/"
        否则:
            结果 = 结果 + 字
        i = i + 1
    返回 结果
