// SQL工具 - SQL解析与生成

// === 辅助判断函数 ===

函程 是空白字符(字符): // 内部
    如果 字符 == 空:
        返回 假
    返回 字符 == " " 或 字符 == "\t" 或 字符 == "\n" 或 字符 == "\r"

函程 是数字字符(字符): // 内部
    如果 字符 == 空:
        返回 假
    返回 字符 >= "0" 且 字符 <= "9"

函程 是字母字符(字符): // 内部
    如果 字符 == 空:
        返回 假
    返回 (字符 >= "a" 且 字符 <= "z") 或 (字符 >= "A" 且 字符 <= "Z")

函程 是字母数字字符(字符): // 内部
    如果 字符 == 空:
        返回 假
    返回 是字母字符(字符) 或 是数字字符(字符)

函程 是SQL操作符字符(字符): // 内部
    如果 字符 == 空:
        返回 假
    返回 字符 == "+" 或 字符 == "-" 或 字符 == "*" 或 字符 == "/" 或 字符 == "<" 或 字符 == ">" 或 字符 == "=" 或 字符 == "!" 或 字符 == "&" 或 字符 == "|" 或 字符 == "~" 或 字符 == "%" 或 字符 == "^"

// === SQL词法分析 ===

函程 SQL词法分析(输入): // 公开
    设 词元列表 = []
    设 位置 = 0
    循环 当 位置 < 长度(输入):
        设 字符 = 输入[位置]
        如果 是空白字符(字符):
            位置 = 位置 + 1
        否则 如果 字符 == "'":
            设 结果 = 读取SQL字符串(输入, 位置)
            词元列表.添加({类型: "字符串", 值: 结果["值"]})
            位置 = 结果["位置"]
        否则 如果 字符 == '"':
            设 结果 = 读取引用标识符(输入, 位置)
            词元列表.添加({类型: "引用标识符", 值: 结果["值"]})
            位置 = 结果["位置"]
        否则 如果 是数字字符(字符) 或 (字符 == "." 且 位置 + 1 < 长度(输入) 且 是数字字符(输入[位置 + 1])):
            设 结果 = 读取SQL数字(输入, 位置)
            词元列表.添加(结果["词元"])
            位置 = 结果["位置"]
        否则 如果 是字母字符(字符) 或 字符 == "_":
            设 结果 = 读取SQL标识符(输入, 位置)
            词元列表.添加(结果["词元"])
            位置 = 结果["位置"]
        否则 如果 是SQL操作符字符(字符):
            设 结果 = 读取SQLOperator(输入, 位置)
            词元列表.添加(结果["词元"])
            位置 = 结果["位置"]
        否则 如果 字符 == ";":
            词元列表.添加({类型: "分号", 值: ";"})
            位置 = 位置 + 1
        否则 如果 字符 == ",":
            词元列表.添加({类型: "逗号", 值: ","})
            位置 = 位置 + 1
        否则 如果 字符 == "(":
            词元列表.添加({类型: "左括号", 值: "("})
            位置 = 位置 + 1
        否则 如果 字符 == ")":
            词元列表.添加({类型: "右括号", 值: ")"})
            位置 = 位置 + 1
        否则:
            位置 = 位置 + 1
    返回 词元列表

函程 读取SQL字符串(输入, 起始): // 内部
    设 结果 = ""
    设 位置 = 起始 + 1
    循环 当 位置 < 长度(输入):
        如果 输入[位置] == "'":
            如果 位置 + 1 < 长度(输入) 且 输入[位置 + 1] == "'":
                结果 = 结果 + "'"
                位置 = 位置 + 2
            否则:
                位置 = 位置 + 1
                跳出
        否则 如果 输入[位置] == "\\":
            位置 = 位置 + 1
            如果 位置 < 长度(输入):
                结果 = 结果 + 输入[位置]
                位置 = 位置 + 1
        否则:
            结果 = 结果 + 输入[位置]
            位置 = 位置 + 1
    返回 {值: 结果, 位置: 位置}

函程 读取引用标识符(输入, 起始): // 内部
    设 结果 = ""
    设 位置 = 起始 + 1
    循环 当 位置 < 长度(输入):
        如果 输入[位置] == '"':
            位置 = 位置 + 1
            跳出
        否则:
            结果 = 结果 + 输入[位置]
            位置 = 位置 + 1
    返回 {值: 结果, 位置: 位置}

函程 读取SQL数字(输入, 起始): // 内部
    设 结果 = ""
    设 位置 = 起始
    设 是小数 = 假
    循环 当 位置 < 长度(输入) 且 是数字字符(输入[位置]):
        结果 = 结果 + 输入[位置]
        位置 = 位置 + 1
    如果 位置 < 长度(输入) 且 输入[位置] == ".":
        是小数 = 真
        结果 = 结果 + "."
        位置 = 位置 + 1
        循环 当 位置 < 长度(输入) 且 是数字字符(输入[位置]):
            结果 = 结果 + 输入[位置]
            位置 = 位置 + 1
    如果 位置 < 长度(输入) 且 (输入[位置] == "E" 或 输入[位置] == "e"):
        是小数 = 真
        结果 = 结果 + 输入[位置]
        位置 = 位置 + 1
        如果 位置 < 长度(输入) 且 (输入[位置] == "+" 或 输入[位置] == "-"):
            结果 = 结果 + 输入[位置]
            位置 = 位置 + 1
        循环 当 位置 < 长度(输入) 且 是数字字符(输入[位置]):
            结果 = 结果 + 输入[位置]
            位置 = 位置 + 1
    设 类型名 = "整数"
    如果 是小数:
        类型名 = "小数"
    返回 {词元: {类型: 类型名, 值: 结果}, 位置: 位置}

函程 读取SQL标识符(输入, 起始): // 内部
    设 结果 = ""
    设 位置 = 起始
    循环 当 位置 < 长度(输入) 且 (是字母数字字符(输入[位置]) 或 输入[位置] == "_"):
        结果 = 结果 + 输入[位置]
        位置 = 位置 + 1
    设 类型名 = "标识符"
    如果 是SQL关键字(结果):
        类型名 = "关键字"
    返回 {词元: {类型: 类型名, 值: 结果}, 位置: 位置}

函程 读取SQLOperator(输入, 起始): // 内部
    设 字符 = 输入[起始]
    设 位置 = 起始 + 1
    如果 位置 < 长度(输入):
        设 双字符 = 字符 + 输入[位置]
        如果 双字符 == "<>" 或 双字符 == "!=" 或 双字符 == "<=" 或 双字符 == ">=" 或 双字符 == "==":
            返回 {词元: {类型: "操作符", 值: 双字符}, 位置: 位置 + 1}
    返回 {词元: {类型: "操作符", 值: 字符}, 位置: 位置}

函程 是SQL关键字(词): // 公开
    设 大写词 = 转大写(词)
    设 关键字表 = ["SELECT", "FROM", "WHERE", "INSERT", "INTO", "VALUES", "UPDATE", "SET", "DELETE", "CREATE", "TABLE", "INDEX", "DROP", "ALTER", "ADD", "COLUMN", "PRIMARY", "KEY", "FOREIGN", "REFERENCES", "NOT", "NULL", "DEFAULT", "AND", "OR", "IN", "BETWEEN", "LIKE", "IS", "AS", "JOIN", "LEFT", "RIGHT", "INNER", "OUTER", "ON", "GROUP", "BY", "HAVING", "ORDER", "ASC", "DESC", "LIMIT", "OFFSET", "UNION", "DISTINCT", "ALL", "EXISTS", "CASE", "WHEN", "THEN", "ELSE", "END", "COUNT", "SUM", "AVG", "MIN", "MAX", "IF"]
    循环 关键字 于 关键字表:
        如果 关键字 == 大写词:
            返回 真
    返回 假

// === SQL生成 ===

函程 生成SELECT(列列表, 表名, 条件 = "", 排序 = "", 限制 = -1, 偏移 = -1): // 公开
    设 SQL = "SELECT " + 连接(列列表, ", ")
    SQL = SQL + " FROM " + 表名
    如果 长度(条件) > 0:
        SQL = SQL + " WHERE " + 条件
    如果 长度(排序) > 0:
        SQL = SQL + " ORDER BY " + 排序
    如果 限制 >= 0:
        SQL = SQL + " LIMIT " + 转字符串(限制)
    如果 偏移 >= 0:
        SQL = SQL + " OFFSET " + 转字符串(偏移)
    返回 SQL

函程 生成INSERT(表名, 列列表, 值列表): // 公开
    设 列部分 = 连接(列列表, ", ")
    设 值部分 = ""
    设 索引 = 0
    循环 值 于 值列表:
        如果 索引 > 0:
            值部分 = 值部分 + ", "
        值部分 = 值部分 + SQL转义值(值)
        索引 = 索引 + 1
    返回 "INSERT INTO " + 表名 + " (" + 列部分 + ") VALUES (" + 值部分 + ")"

函程 生成UPDATE(表名, 列值对, 条件 = ""): // 公开
    设 设置部分 = ""
    设 索引 = 0
    循环 键, 值 于 列值对:
        如果 索引 > 0:
            设置部分 = 设置部分 + ", "
        设置部分 = 设置部分 + 键 + " = " + SQL转义值(值)
        索引 = 索引 + 1
    设 SQL = "UPDATE " + 表名 + " SET " + 设置部分
    如果 长度(条件) > 0:
        SQL = SQL + " WHERE " + 条件
    返回 SQL

函程 生成DELETE(表名, 条件 = ""): // 公开
    设 SQL = "DELETE FROM " + 表名
    如果 长度(条件) > 0:
        SQL = SQL + " WHERE " + 条件
    返回 SQL

函程 生成创建表(表名, 列定义列表, 如果不存在 = 假): // 公开
    设 SQL = "CREATE TABLE "
    如果 如果不存在:
        SQL = SQL + "IF NOT EXISTS "
    SQL = SQL + 表名 + " ("
    SQL = SQL + 连接(列定义列表, ", ")
    SQL = SQL + ")"
    返回 SQL

函程 生成删除表(表名, 如果存在 = 假): // 公开
    设 SQL = "DROP TABLE "
    如果 如果存在:
        SQL = SQL + "IF EXISTS "
    返回 SQL + 表名

函程 生成列定义(列名, 类型, 约束列表 = []): // 公开
    设 定义 = 列名 + " " + 类型
    循环 约束 于 约束列表:
        定义 = 定义 + " " + 约束
    返回 定义

// === SQL值转义 ===

函程 SQL转义值(值): // 公开
    如果 值 == 空:
        返回 "NULL"
    返回 "'" + SQL转义字符串(转字符串(值)) + "'"

函程 SQL转义字符串(字符串): // 公开
    设 结果 = ""
    循环 字符 于 字符串:
        如果 字符 == "'":
            结果 = 结果 + "''"
        否则:
            结果 = 结果 + 字符
    返回 结果

函程 SQL引用标识符(标识符): // 公开
    返回 '"' + 替换(标识符, '"', '""') + '"'

// === SQL解析 ===

函程 解析SQL(SQL文本): // 公开
    设 词元列表 = SQL词法分析(SQL文本)
    返回 {类型: "语句列表", 子节点: 解析语句列表(词元列表)}

函程 解析语句列表(词元列表): // 内部
    设 语句列表 = []
    设 索引 = 0
    循环 当 索引 < 长度(词元列表):
        设 词元 = 词元列表[索引]
        如果 词元["类型"] == "关键字":
            设 语句 = 解析单个语句(词元列表, 索引)
            语句列表.添加(语句["节点"])
            索引 = 语句["位置"]
        否则:
            索引 = 索引 + 1
    返回 语句列表

函程 解析单个语句(词元列表, 索引): // 内部
    设 关键字 = 转大写(词元列表[索引]["值"])
    如果 关键字 == "SELECT":
        返回 解析SELECT语句(词元列表, 索引)
    否则 如果 关键字 == "INSERT":
        返回 解析INSERT语句(词元列表, 索引)
    否则 如果 关键字 == "UPDATE":
        返回 解析UPDATE语句(词元列表, 索引)
    否则 如果 关键字 == "DELETE":
        返回 解析DELETE语句(词元列表, 索引)
    否则 如果 关键字 == "CREATE":
        返回 解析CREATE语句(词元列表, 索引)
    否则:
        返回 {节点: {类型: "未知语句"}, 位置: 索引 + 1}

函程 解析SELECT语句(词元列表, 索引): // 内部
    返回 {节点: {类型: "SELECT", 列: [], 表: "", 条件: ""}, 位置: 索引 + 1}

函程 解析INSERT语句(词元列表, 索引): // 内部
    返回 {节点: {类型: "INSERT", 表: "", 列: [], 值: []}, 位置: 索引 + 1}

函程 解析UPDATE语句(词元列表, 索引): // 内部
    返回 {节点: {类型: "UPDATE", 表: "", 设置: [], 条件: ""}, 位置: 索引 + 1}

函程 解析DELETE语句(词元列表, 索引): // 内部
    返回 {节点: {类型: "DELETE", 表: "", 条件: ""}, 位置: 索引 + 1}

函程 解析CREATE语句(词元列表, 索引): // 内部
    返回 {节点: {类型: "CREATE", 对象类型: "", 名称: "", 定义: []}, 位置: 索引 + 1}

// === SQL格式化 ===

函程 SQL压缩(SQL文本): // 公开
    设 词元列表 = SQL词法分析(SQL文本)
    设 结果 = ""
    循环 词元 于 词元列表:
        设 类型 = 词元["类型"]
        设 值 = 词元["值"]
        如果 类型 == "逗号":
            结果 = 结果 + ", "
        否则 如果 类型 == "左括号":
            结果 = 结果 + "("
        否则 如果 类型 == "右括号":
            结果 = 结果 + ")"
        否则:
            结果 = 结果 + 值 + " "
    返回 去除空白(结果)

// === SQL验证 ===

函程 验证SQL(SQL文本): // 公开
    设 词元列表 = SQL词法分析(SQL文本)
    如果 长度(词元列表) == 0:
        返回 {有效: 假, 错误: "空SQL语句"}
    返回 {有效: 真, 错误: ""}

函程 提取表名(SQL文本): // 公开
    设 词元列表 = SQL词法分析(SQL文本)
    设 表名列表 = []
    设 索引 = 0
    循环 当 索引 < 长度(词元列表) - 1:
        设 当前值 = 转大写(词元列表[索引]["值"])
        设 下个类型 = 词元列表[索引 + 1]["类型"]
        如果 当前值 == "FROM" 且 下个类型 == "标识符":
            表名列表.添加(词元列表[索引 + 1]["值"])
        否则 如果 当前值 == "INTO" 且 下个类型 == "标识符":
            表名列表.添加(词元列表[索引 + 1]["值"])
        否则 如果 当前值 == "UPDATE" 且 下个类型 == "标识符":
            表名列表.添加(词元列表[索引 + 1]["值"])
        否则 如果 当前值 == "TABLE" 且 下个类型 == "标识符":
            表名列表.添加(词元列表[索引 + 1]["值"])
        否则 如果 当前值 == "JOIN" 且 下个类型 == "标识符":
            表名列表.添加(词元列表[索引 + 1]["值"])
        索引 = 索引 + 1
    返回 表名列表
