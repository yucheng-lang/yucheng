// ===== 语程标准库：统计 =====
// 提供统计分析函数：描述统计、分布分析、线性回归
//
// 公开接口：计数、求和、平均值、中位数、众数、最小、最大、极差、
//           方差、标准差、样本方差、样本标准差、
//           百分位数、下四分位、中四分位、上四分位、四分位距、
//           偏度、峰度、
//           协方差、回归斜率、回归截距、相关系数、回归预测、
//           Z标准化、极值归一化、统计摘要

// ===== 描述统计 =====

函程 计数(数据): // 公开
    返回 数组长度(数据)

函程 求和(数据): // 公开
    设 总 = 0
    遍 项 于 数据:
        总 = 总 + 项
    返回 总

函程 平均值(数据): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    返回 求和(数据) / 数组长度(数据)

函程 中位数(数据): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    设 排序后 = 排序(数据)
    设 n = 数组长度(排序后)
    如果 n - (n / 2) * 2 == 1:
        返回 排序后[n / 2]
    返回 (排序后[n / 2 - 1] + 排序后[n / 2]) / 2

函程 众数(数据): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    设 排序后 = 排序(数据)
    设 当前值 = 排序后[0]
    设 当前数 = 1
    设 众数值 = 当前值
    设 最高数 = 1
    设 i = 1
    循环 i < 数组长度(排序后):
        如果 排序后[i] == 当前值:
            当前数 = 当前数 + 1
        否则:
            如果 当前数 > 最高数:
                最高数 = 当前数
                众数值 = 当前值
            当前值 = 排序后[i]
            当前数 = 1
        i = i + 1
    如果 当前数 > 最高数:
        众数值 = 当前值
    返回 众数值

函程 最小(数据): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    设 m = 数据[0]
    遍 项 于 数据:
        如果 项 < m:
            m = 项
    返回 m

函程 最大(数据): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    设 m = 数据[0]
    遍 项 于 数据:
        如果 项 > m:
            m = 项
    返回 m

函程 极差(数据): // 公开
    返回 最大(数据) - 最小(数据)

// ===== 方差与标准差 =====

函程 方差(数据): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    设 均 = 平均值(数据)
    设 总 = 0
    遍 项 于 数据:
        设 差 = 项 - 均
        总 = 总 + 差 * 差
    返回 总 / 数组长度(数据)

函程 标准差(数据): // 公开
    返回 平方根(方差(数据))

函程 样本方差(数据): // 公开
    如果 数组长度(数据) <= 1:
        返回 0
    设 均 = 平均值(数据)
    设 总 = 0
    遍 项 于 数据:
        设 差 = 项 - 均
        总 = 总 + 差 * 差
    返回 总 / (数组长度(数据) - 1)

函程 样本标准差(数据): // 公开
    返回 平方根(样本方差(数据))

// ===== 分位数 =====

函程 百分位数(数据, 百分比): // 公开
    如果 数组长度(数据) == 0:
        返回 0
    设 排序后 = 排序(数据)
    设 n = 数组长度(排序后)
    设 位 = 百分比 / 100 * (n - 1)
    设 低 = 向下取整(位)
    设 高 = 向上取整(位)
    如果 低 == 高:
        返回 排序后[低]
    设 权 = 位 - 低
    返回 排序后[低] * (1 - 权) + 排序后[高] * 权

函程 下四分位(数据): // 公开
    返回 百分位数(数据, 25)

函程 中四分位(数据): // 公开
    返回 百分位数(数据, 50)

函程 上四分位(数据): // 公开
    返回 百分位数(数据, 75)

函程 四分位距(数据): // 公开
    返回 上四分位(数据) - 下四分位(数据)

// ===== 偏度与峰度 =====

函程 偏度(数据): // 公开
    如果 数组长度(数据) < 3:
        返回 0
    设 n = 数组长度(数据)
    设 均 = 平均值(数据)
    设 标 = 标准差(数据)
    如果 标 == 0:
        返回 0
    设 总 = 0
    遍 项 于 数据:
        设 标准 = (项 - 均) / 标
        总 = 总 + 标准 * 标准 * 标准
    返回 总 / n

函程 峰度(数据): // 公开
    如果 数组长度(数据) < 4:
        返回 0
    设 n = 数组长度(数据)
    设 均 = 平均值(数据)
    设 标 = 标准差(数据)
    如果 标 == 0:
        返回 0
    设 总 = 0
    遍 项 于 数据:
        设 标准 = (项 - 均) / 标
        设 平方 = 标准 * 标准
        总 = 总 + 平方 * 平方
    返回 总 / n - 3

// ===== 线性回归 =====

函程 协方差(数据x, 数据y): // 公开
    如果 数组长度(数据x) != 数组长度(数据y):
        返回 0
    设 n = 数组长度(数据x)
    如果 n == 0:
        返回 0
    设 均x = 平均值(数据x)
    设 均y = 平均值(数据y)
    设 总 = 0
    设 i = 0
    循环 i < n:
        总 = 总 + (数据x[i] - 均x) * (数据y[i] - 均y)
        i = i + 1
    返回 总 / n

函程 回归斜率(数据x, 数据y): // 公开
    设 varx = 方差(数据x)
    如果 varx == 0:
        返回 0
    返回 协方差(数据x, 数据y) / varx

函程 回归截距(数据x, 数据y): // 公开
    返回 平均值(数据y) - 回归斜率(数据x, 数据y) * 平均值(数据x)

函程 相关系数(数据x, 数据y): // 公开
    设 varx = 方差(数据x)
    设 vary = 方差(数据y)
    如果 varx == 0 或 vary == 0:
        返回 0
    返回 协方差(数据x, 数据y) / (平方根(varx) * 平方根(vary))

函程 回归预测(数据x, 数据y, 新x): // 公开
    设 斜 = 回归斜率(数据x, 数据y)
    设 截 = 回归截距(数据x, 数据y)
    返回 斜 * 新x + 截

// ===== 数据标准化 =====

函程 Z标准化(数据): // 公开
    设 均 = 平均值(数据)
    设 标 = 标准差(数据)
    如果 标 == 0:
        返回 数据
    设 结果 = []
    遍 项 于 数据:
        结果.添加((项 - 均) / 标)
    返回 结果

函程 极值归一化(数据): // 公开
    设 小 = 最小(数据)
    设 大 = 最大(数据)
    设 差 = 大 - 小
    如果 差 == 0:
        返回 数据
    设 结果 = []
    遍 项 于 数据:
        结果.添加((项 - 小) / 差)
    返回 结果

// ===== 统计摘要 =====

函程 统计摘要(数据): // 公开
    输出 "=== 统计摘要 ==="
    输出 "计数: " + 转字符串(计数(数据))
    输出 "求和: " + 转字符串(求和(数据))
    输出 "均值: " + 转字符串(平均值(数据))
    输出 "中位: " + 转字符串(中位数(数据))
    输出 "众数: " + 转字符串(众数(数据))
    输出 "最小: " + 转字符串(最小(数据))
    输出 "最大: " + 转字符串(最大(数据))
    输出 "极差: " + 转字符串(极差(数据))
    输出 "方差: " + 转字符串(方差(数据))
    输出 "标差: " + 转字符串(标准差(数据))
    输出 "Q1:   " + 转字符串(下四分位(数据))
    输出 "Q3:   " + 转字符串(上四分位(数据))
    输出 "IQR:  " + 转字符串(四分位距(数据))
