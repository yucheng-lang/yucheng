// ===== 语程标准库：单元测试 =====
// 提供简单的单元测试框架
//
// 公开接口：断言为真、断言为假、断言相等、断言不等、断言大于、断言小于、
//           断言接近、断言包含、断言为空、断言不为空、
//           测试组、运行测试、测试摘要、重置测试、全部通过

// ===== 内部状态 =====

设 通过数 = 0 // 内部
设 失败数 = 0 // 内部
设 错误数 = 0 // 内部
设 测试总数 = 0 // 内部
设 当前测试名 = "" // 内部

// ===== 断言函数 =====

函程 断言为真(条件, 消息): // 公开
    测试总数 = 测试总数 + 1
    如果 条件:
        通过数 = 通过数 + 1
    否则:
        失败数 = 失败数 + 1
        输出 "  ✗ 失败: " + 消息

函程 断言为假(条件, 消息): // 公开
    断言为真(非 条件, 消息)

函程 断言相等(实际, 期望, 消息): // 公开
    测试总数 = 测试总数 + 1
    如果 实际 == 期望:
        通过数 = 通过数 + 1
    否则:
        失败数 = 失败数 + 1
        输出 "  ✗ 失败: " + 消息
        输出 "    期望: " + 转字符串(期望)
        输出 "    实际: " + 转字符串(实际)

函程 断言不等(实际, 期望, 消息): // 公开
    断言为真(实际 != 期望, 消息)

函程 断言大于(值, 阈值, 消息): // 公开
    断言为真(值 > 阈值, 消息)

函程 断言小于(值, 阈值, 消息): // 公开
    断言为真(值 < 阈值, 消息)

函程 断言接近(实际, 期望, 精度, 消息): // 公开
    设 差 = 绝对值(实际 - 期望)
    断言为真(差 < 精度, 消息 + " (差值: " + 转字符串(差) + ")")

函程 断言包含(容器, 元素, 消息): // 公开
    测试总数 = 测试总数 + 1
    设 找到 = 假
    遍 项 于 容器:
        如果 项 == 元素:
            找到 = 真
    如果 找到:
        通过数 = 通过数 + 1
    否则:
        失败数 = 失败数 + 1
        输出 "  ✗ 失败: " + 消息
        输出 "    未找到: " + 转字符串(元素)

函程 断言为空(值, 消息): // 公开
    断言为真(数组长度(值) == 0, 消息)

函程 断言不为空(值, 消息): // 公开
    断言为真(数组长度(值) > 0, 消息)

// ===== 测试执行 =====

函程 测试组(名称): // 公开
    当前测试名 = 名称
    输出 ""
    输出 "▶ " + 名称

函程 运行测试(名称, 测试函): // 公开
    输出 "  ○ " + 名称
    尝试:
        测试函()
    捕获 错误:
        错误数 = 错误数 + 1
        输出 "  ✗ 错误: " + 转字符串(错误)

// ===== 测试结果 =====

函程 测试摘要(): // 公开
    输出 ""
    输出 "════════════════════════"
    输出 "测试结果摘要"
    输出 "════════════════════════"
    输出 "总计: " + 转字符串(测试总数)
    输出 "通过: " + 转字符串(通过数)
    输出 "失败: " + 转字符串(失败数)
    输出 "错误: " + 转字符串(错误数)
    如果 测试总数 > 0:
        设 通过率 = 通过数 * 100 / 测试总数
        输出 "通过率: " + 转字符串(四舍五入(通过率 * 10) / 10) + "%"
    如果 失败数 == 0 且 错误数 == 0:
        输出 "状态: 全部通过 ✓"
    否则:
        输出 "状态: 存在失败 ✗"

函程 重置测试(): // 公开
    通过数 = 0
    失败数 = 0
    错误数 = 0
    测试总数 = 0
    当前测试名 = ""

函程 全部通过(): // 公开
    返回 失败数 == 0 且 错误数 == 0
