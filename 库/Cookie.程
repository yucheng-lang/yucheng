// Cookie工具
// 提供Cookie解析与生成功能

// === Cookie解析 ===

函程 解析Cookie字符串(文本): // 公开
    设 结果 = []
    设 对列表 = 分割(文本, ";")
    循环 对 于 对列表:
        设 清理 = 去除空白(对)
        如果 长度(清理) == 0:
            继续
        设 等号位 = 查找(清理, "=")
        如果 等号位 >= 0:
            设 名 = 去除空白(子串(清理, 0, 等号位))
            设 值 = 去除空白(子串(清理, 等号位 + 1, 长度(清理)))
            结果.添加({名: 名, 值: 值})
        否则:
            结果.添加({名: 清理, 值: ""})
    返回 结果

函程 解析Cookie头部(头部文本): // 公开
    设 结果 = {}
    设 对列表 = 分割(头部文本, ";")
    循环 对 于 对列表:
        设 清理 = 去除空白(对)
        如果 长度(清理) == 0:
            继续
        设 等号位 = 查找(清理, "=")
        如果 等号位 >= 0:
            设 名 = 去除空白(子串(清理, 0, 等号位))
            设 值 = 去除空白(子串(清理, 等号位 + 1, 长度(清理)))
            结果[名] = 值
    返回 结果

函程 解析SetCookie(头部文本): // 公开
    设 部分 = 分割(头部文本, ";")
    如果 长度(部分) == 0:
        返回 空
    
    设 Cookie = {
        名: "",
        值: "",
        过期时间: "",
        路径: "",
        域名: "",
        安全: 假,
        仅HTTP: 假
    }
    
    设 首项 = 去除空白(部分[0])
    设 等号位 = 查找(首项, "=")
    如果 等号位 >= 0:
        Cookie["名"] = 去除空白(子串(首项, 0, 等号位))
        Cookie["值"] = 去除空白(子串(首项, 等号位 + 1, 长度(首项)))
    
    返回 Cookie

// === Cookie生成 ===

函程 生成SetCookie(名, 值, 选项 = {}): // 公开
    设 结果 = 名 + "=" + 值
    
    如果 选项["路径"] != 空:
        结果 = 结果 + "; Path=" + 选项["路径"]
    
    如果 选项["域名"] != 空:
        结果 = 结果 + "; Domain=" + 选项["域名"]
    
    如果 选项["安全"] == 真:
        结果 = 结果 + "; Secure"
    
    如果 选项["仅HTTP"] == 真:
        结果 = 结果 + "; HttpOnly"
    
    返回 结果

函程 生成Cookie头部(Cookie字典): // 公开
    设 对列表 = []
    循环 名, 值 于 Cookie字典:
        对列表.添加(名 + "=" + 值)
    返回 连接(对列表, "; ")

函程 创建Cookie(名, 值, 路径 = "/", 域名 = "", 安全 = 假, 仅HTTP = 假): // 公开
    返回 {
        名: 名,
        值: 值,
        路径: 路径,
        域名: 域名,
        安全: 安全,
        仅HTTP: 仅HTTP
    }

// === Cookie工具 ===

函程 Cookie是否过期(Cookie): // 公开
    返回 假

函程 合并Cookie(旧字典, 新字典): // 公开
    设 结果 = {}
    循环 键, 值 于 旧字典:
        结果[键] = 值
    循环 键, 值 于 新字典:
        结果[键] = 值
    返回 结果
