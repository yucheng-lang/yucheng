// 异步网络 - 基于回调模式的网络操作
// 语程对象按值传递，修改对象的函数返回修改后的对象。
// 采用「返回 {结果, 错误}」模式，去除回调参数，直接返回结果。

// === 异步HTTP客户端 ===

函程 异步HTTP获取(地址, 头部): // 公开
    如果 头部 == 空:
        头部 = ""
    尝试:
        设 结果 = HTTP请求("GET", 地址, "", 头部)
        返回 {结果: 结果, 错误: 空}
    捕获 错误:
        返回 {结果: 空, 错误: 错误}

函程 异步HTTP提交(地址, 数据, 头部): // 公开
    如果 头部 == 空 或 头部 == "":
        头部 = "Content-Type: application/x-www-form-urlencoded"
    尝试:
        设 结果 = HTTP请求("POST", 地址, 数据, 头部)
        返回 {结果: 结果, 错误: 空}
    捕获 错误:
        返回 {结果: 空, 错误: 错误}

函程 异步HTTP放置(地址, 数据, 头部): // 公开
    如果 头部 == 空:
        头部 = ""
    尝试:
        设 结果 = HTTP请求("PUT", 地址, 数据, 头部)
        返回 {结果: 结果, 错误: 空}
    捕获 错误:
        返回 {结果: 空, 错误: 错误}

函程 异步HTTP删除(地址, 头部): // 公开
    如果 头部 == 空:
        头部 = ""
    尝试:
        设 结果 = HTTP请求("DELETE", 地址, "", 头部)
        返回 {结果: 结果, 错误: 空}
    捕获 错误:
        返回 {结果: 空, 错误: 错误}

// === 异步请求构建器 ===

函程 创建异步请求(方法, 地址): // 公开
    返回 {
        方法: 方法,
        地址: 地址,
        头部: {},
        数据: "",
        重试次数: 0,
        重试间隔: 1
    }

函程 设置异步头部(请求, 键, 值): // 公开
    请求.头部[键] = 值
    返回 请求

函程 设置异步数据(请求, 数据): // 公开
    请求.数据 = 数据
    返回 请求

函程 设置异步重试(请求, 次数, 间隔): // 公开
    请求.重试次数 = 次数
    请求.重试间隔 = 间隔
    返回 请求

函程 执行异步请求(请求): // 公开
    设 头部串 = ""
    遍 键, 值 于 请求.头部:
        如果 长度(头部串) > 0:
            头部串 = 头部串 + "\r\n"
        头部串 = 头部串 + 键 + ": " + 值
    设 尝试次数 = 0
    设 最大尝试 = 1 + 请求.重试次数
    循环 尝试次数 < 最大尝试:
        尝试:
            设 结果 = HTTP请求(请求.方法, 请求.地址, 请求.数据, 头部串)
            返回 {结果: 结果, 错误: 空}
        捕获 错误:
            尝试次数 = 尝试次数 + 1
            如果 尝试次数 >= 最大尝试:
                返回 {结果: 空, 错误: 错误}
    返回 {结果: 空, 错误: "未知错误"}

// === 批量异步请求 ===

函程 批量异步获取(地址列表): // 公开
    设 结果 = []
    遍 地址 于 地址列表:
        尝试:
            设 内容 = HTTP请求("GET", 地址)
            结果 = 追加(结果, {地址: 地址, 内容: 内容, 错误: 空})
        捕获 错误:
            结果 = 追加(结果, {地址: 地址, 内容: 空, 错误: 错误})
    返回 结果

