// 选项类型 - Optional类型（可能包含或不包含值）

// === 构造函数 ===

函程 某些(值): // 公开
    // 创建包含值的选项
    返回 {有效: 真, 内容: 值}

函程 无(类型名=""): // 公开
    // 创建不包含值的空选项
    返回 {有效: 假, 内容: 空}

函程 选项(值): // 公开
    // 将值转换为选项类型
    // 如果值为空（nil），返回空选项
    如果 值 == 空:
        返回 无()
    否则:
        返回 某些(值)

// === 查询函数 ===

函程 有值(选项): // 公开
    // 检查选项是否包含值
    返回 选项.有效 == 真

函程 无值(选项): // 公开
    // 检查选项是否为空
    返回 选项.有效 != 真

// === 访问函数 ===

函程 获取(选项): // 公开
    // 获取选项的值，如果为空则抛出异常
    如果 无值(选项):
        抛出 "无法从空选项中获取值"
    返回 选项.内容

函程 获取或默认(选项, 默认值): // 公开
    // 获取选项的值，如果为空则返回默认值
    如果 有值(选项):
        返回 选项.内容
    否则:
        返回 默认值

函程 获取或计算(选项, 计算函数): // 公开
    // 获取选项的值，如果为空则调用计算函数
    如果 有值(选项):
        返回 选项.内容
    否则:
        返回 计算函数()

函程 获取或抛出(选项, 消息): // 公开
    // 获取选项的值，如果为空则抛出带消息的异常
    如果 无值(选项):
        抛出 消息
    返回 选项.内容

// === 变换函数 ===

函程 映射(选项, 变换函数): // 公开
    // 如果选项有值，对值应用变换函数，返回新选项
    如果 有值(选项):
        返回 某些(变换函数(选项.内容))
    否则:
        返回 无()

函程 平面映射(选项, 变换函数): // 公开
    // 如果选项有值，对值应用返回选项的变换函数
    如果 有值(选项):
        返回 变换函数(选项.内容)
    否则:
        返回 无()

函程 过滤(选项, 条件函数): // 公开
    // 如果选项有值且满足条件，返回原选项，否则返回空
    如果 有值(选项) 且 条件函数(选项.内容):
        返回 选项
    否则:
        返回 无()

函程 展平(选项): // 公开
    // 展平嵌套选项
    如果 有值(选项):
        返回 选项.内容
    否则:
        返回 无()

// === 组合函数 ===

函程 或选择(选项甲, 选项乙): // 公开
    // 如果甲有值返回甲，否则返回乙
    如果 有值(选项甲):
        返回 选项甲
    否则:
        返回 选项乙

函程 或计算(选项, 计算函数): // 公开
    // 如果选项有值返回自身，否则返回计算函数的结果
    如果 有值(选项):
        返回 选项
    否则:
        返回 计算函数()

函程 且满足(选项, 条件函数): // 公开
    // 如果选项有值且满足条件，返回自身，否则返回空
    返回 过滤(选项, 条件函数)

函程 链式操作(选项, 操作列表): // 公开
    // 链式执行一系列操作
    设 当前 = 选项
    循环 操作 在 操作列表:
        当前 = 平面映射(当前, 操作)
        如果 无值(当前):
            返回 无()
    返回 当前

// === 比较函数 ===

函程 选项相等(选项甲, 选项乙): // 公开
    // 比较两个选项是否相等
    如果 有值(选项甲) 且 有值(选项乙):
        返回 选项甲.内容 == 选项乙.内容
    否则如果 无值(选项甲) 且 无值(选项乙):
        返回 真
    否则:
        返回 假

// === 转换函数 ===

函程 选项到列表(选项): // 公开
    // 将选项转换为列表（有值则包含一个元素，否则为空列表）
    如果 有值(选项):
        返回 [选项.内容]
    否则:
        返回 []

函程 列表到选项(列表): // 公开
    // 将列表转换为选项（取第一个元素或空）
    如果 列表.长度() > 0:
        返回 某些(列表[0])
    否则:
        返回 无()

函程 选项到期望值(选项, 错误="值为空"): // 公开
    // 将选项转换为期望值类型
    如果 有值(选项):
        返回 期望值success(选项.内容)
    否则:
        返回 期望值error(错误)

// === 字符串表示 ===

函程 选项转文本(选项): // 公开
    // 将选项转换为字符串表示
    如果 有值(选项):
        返回 "某些(" + 转文本(选项.内容) + ")"
    否则:
        返回 "无"

// === 期望值类型引用（声明，实际实现在期望值.程） ===

函程 期望值成功(值): // 内部
    返回 {是成功: 真, 值: 值}

函程 期望值错误(错误): // 内部
    返回 {是成功: 假, 错误: 错误}

// === 实用函数 ===

函程 遍历(选项, 操作函数): // 公开
    // 如果选项有值，对值执行操作函数
    如果 有值(选项):
        操作函数(选项.内容)

函程 无论如何(选项, 操作函数): // 公开
    // 无论选项是否有值都执行操作
    操作函数()

函程 值或空(选项): // 公开
    // 返回值或空字符串
    如果 有值(选项):
        返回 选项.内容
    否则:
        返回 ""

函程 值或零(选项): // 公开
    // 返回值或0
    如果 有值(选项):
        返回 选项.内容
    否则:
        返回 0

函程 值或假(选项): // 公开
    // 返回值或假
    如果 有值(选项):
        返回 选项.内容
    否则:
        返回 假

函程 不安全获取(选项): // 公开
    // 不安全地获取值，不检查是否为空
    // 仅在确定有值时使用
    返回 选项.内容
