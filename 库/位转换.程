// 位转换 - 位与数值转换

// === 进制转换 ===

函程 转二进制(值): // 公开
    // 将整数转换为二进制字符串
    如果 值 == 0:
        返回 "0"
    设 结果 = ""
    设 临时 = 绝对值(值)
    循环 临时 > 0:
        设 位 = 临时 % 2
        如果 位 == 0:
            结果 = "0" + 结果
        否则:
            结果 = "1" + 结果
        临时 = 向下取整(临时 / 2)
    如果 值 < 0:
        结果 = "-" + 结果
    返回 结果

函程 转八进制(值): // 公开
    // 将整数转换为八进制字符串
    如果 值 == 0:
        返回 "0"
    设 结果 = ""
    设 临时 = 绝对值(值)
    循环 临时 > 0:
        设 位 = 临时 % 8
        设 字符表 = "01234567"
        结果 = 字符表[位] + 结果
        临时 = 向下取整(临时 / 8)
    如果 值 < 0:
        结果 = "-" + 结果
    返回 结果

函程 转十六进制(值): // 公开
    // 将整数转换为十六进制字符串
    如果 值 == 0:
        返回 "0"
    设 结果 = ""
    设 临时 = 绝对值(值)
    设 字符表 = "0123456789ABCDEF"
    循环 临时 > 0:
        设 位 = 临时 % 16
        结果 = 字符表[位] + 结果
        临时 = 向下取整(临时 / 16)
    如果 值 < 0:
        结果 = "-" + 结果
    返回 结果

