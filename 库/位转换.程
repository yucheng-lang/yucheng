// === 字节序交换 ===

函程 交换字节序16(值): // 公开
    // 交换16位整数的字节序
    返回 ((值 >> 8) & 0xFF) | ((值 << 8) & 0xFF00)

函程 交换字节序32(值): // 公开
    // 交换32位整数的字节序
    返回 ((值 >> 24) & 0x000000FF) |
           ((值 >>  8) & 0x0000FF00) |
           ((值 <<  8) & 0x00FF0000) |
           ((值 << 24) & 0xFF000000)

函程 交换字节序64(值): // 公开
    // 交换64位整数的字节序
    返回 ((值 >> 56) & 0x00000000000000FF) |
           ((值 >> 40) & 0x000000000000FF00) |
           ((值 >> 24) & 0x0000000000FF0000) |
           ((值 >>  8) & 0x00000000FF000000) |
           ((值 <<  8) & 0x000000FF00000000) |
           ((值 << 24) & 0x0000FF0000000000) |
           ((值 << 40) & 0x00FF000000000000) |
           ((值 << 56) & 0xFF00000000000000)

// === ZigZag编码 ===

函程 ZigZag编码(值): // 公开
    // ZigZag编码：将有符号整数编码为无符号整数
    返回 (值 << 1) ^ (值 >> 63)

函程 ZigZag解码(值): // 公开
    返回 (值 >> 1) ^ -(值 & 1)

// === 变长整数编码 ===

函程 编码变长整数(值): // 公开
    // 将64位无符号整数编码为变长字节序列
    设 结果 = []
    设 当前 = 值
    循环 真:
        设 字节 = 当前 & 0x7F
        当前 = 当前 >> 7
        如果 当前 != 0:
            字节 = 字节 | 0x80
            结果.添加(字节)
        否则:
            结果.添加(字节)
            跳出
    返回 结果

函程 解码变长整数(字节列表): // 公开
    // 从变长字节序列解码64位无符号整数
    设 结果 = 0
    设 位移 = 0
    循环 字节 在 字节列表:
        结果 = 结果 | ((字节 & 0x7F) << 位移)
        位移 = 位移 + 7
        如果 (字节 & 0x80) == 0:
            跳出
    返回 结果

// === 位操作辅助 ===

函程 提取位(值, 起始位, 位数): // 公开
    // 从值中提取指定位范围的位
    设 掩码 = (1 << 位数) - 1
    返回 (值 >> 起始位) & 掩码

函程 插入位(目标, 值, 起始位, 位数): // 公开
    // 将值的指定位插入到目标的指定位置
    设 掩码 = (1 << 位数) - 1
    设 清除目标 = 目标 & ~(掩码 << 起始位)
    返回 清除目标 | ((值 & 掩码) << 起始位)

函程 填充位(起始位, 位数): // 公开
    // 生成指定范围的全1掩码
    返回 ((1 << 位数) - 1) << 起始位

// === 位模式检测 ===

函程 是2的幂(值): // 公开
    // 检查值是否为2的幂
    返回 值 > 0 且 (值 & (值 - 1)) == 0

函程 下一个2的幂(值): // 公开
    // 返回不小于值的最小2的幂
    如果 值 <= 0:
        返回 1
    值 = 值 - 1
    值 = 值 | (值 >> 1)
    值 = 值 | (值 >> 2)
    值 = 值 | (值 >> 4)
    值 = 值 | (值 >> 8)
    值 = 值 | (值 >> 16)
    值 = 值 | (值 >> 32)
    返回 值 + 1

函程 位计数(值): // 公开
    // 计算值中1的位数（汉明权重）
    设 计数 = 0
    循环 值 != 0:
        值 = 值 & (值 - 1)
        计数 = 计数 + 1
    返回 计数

函程 前导零计数(值, 位宽=64): // 公开
    // 计算值中前导零的位数
    如果 值 == 0:
        返回 位宽
    设 计数 = 0
    循环 (值 & (1 << (位宽 - 1))) == 0:
        计数 = 计数 + 1
        值 = 值 << 1
    返回 计数

函程 后随零计数(值): // 公开
    // 计算值中后随零的位数
    如果 值 == 0:
        返回 64
    设 计数 = 0
    循环 (值 & 1) == 0:
        计数 = 计数 + 1
        值 = 值 >> 1
    返回 计数

// === 位反转 ===

函程 反转位8(值): // 公开
    // 反转8位值的位序
    值 = ((值 & 0xF0) >> 4) | ((值 & 0x0F) << 4)
    值 = ((值 & 0xCC) >> 2) | ((值 & 0x33) << 2)
    值 = ((值 & 0xAA) >> 1) | ((值 & 0x55) << 1)
    返回 值

函程 反转位32(值): // 公开
    // 反转32位值的位序
    值 = ((值 >>  1) & 0x55555555) | ((值 & 0x55555555) <<  1)
    值 = ((值 >>  2) & 0x33333333) | ((值 & 0x33333333) <<  2)
    值 = ((值 >>  4) & 0x0F0F0F0F) | ((值 & 0x0F0F0F0F) <<  4)
    值 = ((值 >>  8) & 0x00FF00FF) | ((值 & 0x00FF00FF) <<  8)
    值 = (值 >> 16) | (值 << 16)
    返回 值

函程 反转位64(值): // 公开
    // 反转64位值的位序
    值 = ((值 >>  1) & 0x5555555555555555) | ((值 & 0x5555555555555555) <<  1)
    值 = ((值 >>  2) & 0x3333333333333333) | ((值 & 0x3333333333333333) <<  2)
    值 = ((值 >>  4) & 0x0F0F0F0F0F0F0F0F) | ((值 & 0x0F0F0F0F0F0F0F0F) <<  4)
    值 = ((值 >>  8) & 0x00FF00FF00FF00FF) | ((值 & 0x00FF00FF00FF00FF) <<  8)
    值 = ((值 >> 16) & 0x0000FFFF0000FFFF) | ((值 & 0x0000FFFF0000FFFF) << 16)
    值 = (值 >> 32) | (值 << 32)
    返回 值
