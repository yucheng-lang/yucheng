// ===== 语程标准库：字典扩展 =====
// 提供高级字典操作工具
//
// 公开接口：创建计数表、计数表增量、计数表最常见、计数表最少见、
//           字典合并、字典深度合并、字典翻转、
//           字典过滤键、字典过滤值、字典映射值、
//           字典取值默认、字典取值路径、
//           字典深拷贝、字典扁平化、字典嵌套化、
//           字典键交集、字典键并集、字典键差集、
//           有序字典

// ===== 计数表 =====

函程 创建计数表(): // 公开
    返回 {}

函程 计数表增量(表, 键, 增量 = 1): // 公开
    如果 表.包含(键):
        表[键] = 表[键] + 增量
    否则:
        表[键] = 增量
    返回 表

函程 计数表批量计数(表, 列表): // 公开
    遍 项 于 列表:
        计数表增量(表, 项)
    返回 表

函程 计数表最常见(表, n = 10): // 公开
    设 对列表 = []
    循环 键, 值 于 表:
        对列表.添加({键: 键, 计数: 值})
    // 按计数降序排序
    设 结果 = _按字段降序(对列表, "计数")
    返回 数组切片(结果, 0, _最小值(n, 数组长度(结果)))

函程 计数表最少见(表, n = 10): // 公开
    设 对列表 = []
    循环 键, 值 于 表:
        对列表.添加({键: 键, 计数: 值})
    设 结果 = _按字段升序(对列表, "计数")
    返回 数组切片(结果, 0, _最小值(n, 数组长度(结果)))

函程 计数表总计数(表): // 公开
    设 总 = 0
    循环 键, 值 于 表:
        总 = 总 + 值
    返回 总

函程 计数表元素数(表): // 公开
    设 计 = 0
    循环 键, 值 于 表:
        计 = 计 + 1
    返回 计

// ===== 合并 =====

函程 字典合并(字典1, 字典2): // 公开
    // 合并两个字典（字典2的值覆盖字典1）
    设 结果 = {}
    循环 键, 值 于 字典1:
        结果[键] = 值
    循环 键, 值 于 字典2:
        结果[键] = 值
    返回 结果

函程 字典合并覆盖(目标, 来源): // 公开
    // 将来源字典的键值对合并到目标字典（就地修改）
    循环 键, 值 于 来源:
        目标[键] = 值
    返回 目标

函程 字典深度合并(字典1, 字典2): // 公开
    // 递归合并嵌套字典
    设 结果 = {}
    循环 键, 值 于 字典1:
        结果[键] = 值
    循环 键, 值 于 字典2:
        如果 结果.包含(键) 且 类型(结果[键]) == "字典" 且 类型(值) == "字典":
            结果[键] = 字典深度合并(结果[键], 值)
        否则:
            结果[键] = 值
    返回 结果

// ===== 翻转 =====

函程 字典翻转(字典): // 公开
    // 键值互换（值变为键，键变为值）
    设 结果 = {}
    循环 键, 值 于 字典:
        结果[值] = 键
    返回 结果

函程 字典翻转多值(字典): // 公开
    // 键值互换，但一个值可能对应多个键
    设 结果 = {}
    循环 键, 值 于 字典:
        如果 结果.包含(值):
            结果[值].添加(键)
        否则:
            结果[值] = [键]
    返回 结果

// ===== 过滤与映射 =====

函程 字典过滤键(字典, 函数): // 公开
    设 结果 = {}
    循环 键, 值 于 字典:
        如果 函数(键):
            结果[键] = 值
    返回 结果

函程 字典过滤值(字典, 函数): // 公开
    设 结果 = {}
    循环 键, 值 于 字典:
        如果 函数(值):
            结果[键] = 值
    返回 结果

函程 字典映射值(字典, 函数): // 公开
    设 结果 = {}
    循环 键, 值 于 字典:
        结果[键] = 函数(值)
    返回 结果

函程 字典映射键值(字典, 函数): // 公开
    设 结果 = {}
    循环 键, 值 于 字典:
        设 新键值 = 函数(键, 值)
        如果 类型(新键值) == "列表" 且 数组长度(新键值) >= 2:
            结果[新键值[0]] = 新键值[1]
    返回 结果

// ===== 安全取值 =====

函程 字典取值默认(字典, 键, 默认值): // 公开
    如果 字典.包含(键):
        返回 字典[键]
    返回 默认值

函程 字典取值路径(字典, 路径): // 公开
    // 按路径取嵌套值，路径为键列表
    设 当前 = 字典
    遍 键 于 路径:
        如果 类型(当前) == "字典" 且 当前.包含(键):
            当前 = 当前[键]
        否则:
            返回 空
    返回 当前

函程 字典设置路径(字典, 路径, 值): // 公开
    // 按路径设置嵌套值
    如果 数组长度(路径) == 0:
        返回 字典
    如果 数组长度(路径) == 1:
        字典[路径[0]] = 值
        返回 字典
    设 当前 = 字典
    设 i = 0
    循环 当 i < 数组长度(路径) - 1:
        设 键 = 路径[i]
        如果 非 当前.包含(键):
            当前[键] = {}
        当前 = 当前[键]
        i = i + 1
    当前[路径[数组长度(路径) - 1]] = 值
    返回 字典

// ===== 拷贝与转换 =====

函程 字典深拷贝(字典): // 公开
    设 结果 = {}
    循环 键, 值 于 字典:
        如果 类型(值) == "字典":
            结果[键] = 字典深拷贝(值)
        否则 如果 类型(值) == "列表":
            结果[键] = 列表深拷贝(值)
        否则:
            结果[键] = 值
    返回 结果

函程 列表深拷贝(列表): // 内部
    设 结果 = []
    遍 项 于 列表:
        如果 类型(项) == "字典":
            结果.添加(字典深拷贝(项))
        否则 如果 类型(项) == "列表":
            结果.添加(列表深拷贝(项))
        否则:
            结果.添加(项)
    返回 结果

函程 字典扁平化(字典, 分隔符 = ".", 前缀 = ""): // 公开
    // 将嵌套字典扁平化为单层字典，键用分隔符连接
    设 结果 = {}
    循环 键, 值 于 字典:
        设 新键 = 键
        如果 字符串长度(前缀) > 0:
            新键 = 前缀 + 分隔符 + 键
        如果 类型(值) == "字典":
            设 子结果 = 字典扁平化(值, 分隔符, 新键)
            循环 子键, 子值 于 子结果:
                结果[子键] = 子值
        否则:
            结果[新键] = 值
    返回 结果

函程 字典嵌套化(字典, 分隔符 = "."): // 公开
    // 将扁平字典还原为嵌套字典
    设 结果 = {}
    循环 键, 值 于 字典:
        设 部分 = 分割(键, 分隔符)
        字典设置路径(结果, 部分, 值)
    返回 结果

// ===== 集合运算 =====

函程 字典键交集(字典1, 字典2): // 公开
    // 返回两个字典共有键的子字典（取字典1的值）
    设 结果 = {}
    循环 键, 值 于 字典1:
        如果 字典2.包含(键):
            结果[键] = 值
    返回 结果

函程 字典键并集(字典1, 字典2): // 公开
    返回 字典合并(字典1, 字典2)

函程 字典键差集(字典1, 字典2): // 公开
    // 返回在字典1但不在字典2的键
    设 结果 = {}
    循环 键, 值 于 字典1:
        如果 非 字典2.包含(键):
            结果[键] = 值
    返回 结果

函程 字典键对称差(字典1, 字典2): // 公开
    设 结果 = {}
    循环 键, 值 于 字典1:
        如果 非 字典2.包含(键):
            结果[键] = 值
    循环 键, 值 于 字典2:
        如果 非 字典1.包含(键):
            结果[键] = 值
    返回 结果

// ===== 有序字典 =====

函程 创建有序字典(): // 公开
    返回 {键列表: [], 数据: {}}

函程 有序设值(有序字典, 键, 值): // 公开
    如果 非 有序字典.数据.包含(键):
        有序字典.键列表.添加(键)
    有序字典.数据[键] = 值
    返回 有序字典

函程 有序取值(有序字典, 键): // 公开
    如果 有序字典.数据.包含(键):
        返回 有序字典.数据[键]
    返回 空

函程 有序删除(有序字典, 键): // 公开
    如果 有序字典.数据.包含(键):
        有序字典.数据[键] = 空  // 标记删除
        设 新键 = []
        遍 k 于 有序字典.键列表:
            如果 k != 键:
                新键.添加(k)
        有序字典.键列表 = 新键
    返回 有序字典

函程 有序键列表(有序字典): // 公开
    返回 有序字典.键列表

函程 有序遍历(有序字典): // 公开
    // 返回 [键, 值] 对列表
    设 结果 = []
    遍 键 于 有序字典.键列表:
        如果 有序字典.数据.包含(键):
            结果.添加([键, 有序字典.数据[键]])
    返回 结果

函程 有序转字典(有序字典): // 公开
    返回 有序字典.数据

函程 字典转有序(字典): // 公开
    设 结果 = 创建有序字典()
    循环 键, 值 于 字典:
        有序设值(结果, 键, 值)
    返回 结果

// ===== 内部辅助 =====

函程 _按字段降序(列表, 字段): // 内部
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 n = 数组长度(结果)
    设 i = 0
    循环 当 i < n - 1:
        设 j = 0
        循环 当 j < n - 1 - i:
            如果 结果[j][字段] < 结果[j + 1][字段]:
                设 临时 = 结果[j]
                结果[j] = 结果[j + 1]
                结果[j + 1] = 临时
            j = j + 1
        i = i + 1
    返回 结果

函程 _按字段升序(列表, 字段): // 内部
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 n = 数组长度(结果)
    设 i = 0
    循环 当 i < n - 1:
        设 j = 0
        循环 当 j < n - 1 - i:
            如果 结果[j][字段] > 结果[j + 1][字段]:
                设 临时 = 结果[j]
                结果[j] = 结果[j + 1]
                结果[j + 1] = 临时
            j = j + 1
        i = i + 1
    返回 结果

函程 _最小值(a, b): // 内部
    如果 a < b:
        返回 a
    返回 b
