// ===== 语程标准库：JSON工具 =====
// 提供JSON解析与生成工具函数
//
// 公开接口：解析JSON、生成JSON、
//           取JSON值、设JSON值、JSON键存在、
//           JSON转字符串、字符串转JSON、
//           JSON数组长度、JSON数组项、
//           JSON是对象、JSON是数组、JSON是字符串、JSON是数字

// ===== JSON解析 =====

函程 解析JSON(文本): // 公开
    返回 JSON解析(文本)

函程 生成JSON(数据): // 公开
    设 结果 = JSON格式化(数据)
    返回 清理JSON数字(结果)

函程 紧凑JSON(数据): // 公开
    设 结果 = JSON生成(数据)
    返回 清理JSON数字(结果)

函程 清理JSON数字(json文本): // 内部
    设 结果 = 替换(json文本, ".0,", ",")
    结果 = 替换(结果, ".0]", "]")
    结果 = 替换(结果, ".0}", "}")
    结果 = 替换(结果, ".0\n", "\n")
    返回 结果

// ===== JSON值操作 =====

函程 取JSON值(对象, 键): // 公开
    如果 对象.包含(键):
        返回 对象[键]
    返回 ""

函程 设JSON值(对象, 键, 值): // 公开
    对象[键] = 值
    返回 对象

函程 JSON键存在(对象, 键): // 公开
    返回 对象.包含(键)

// ===== JSON数组操作 =====

函程 JSON数组长度(数组): // 公开
    返回 数组长度(数组)

函程 JSON数组项(数组, 索引): // 公开
    如果 索引 < 数组长度(数组):
        返回 数组[索引]
    返回 ""

函程 JSON数组追加(数组, 项): // 公开
    数组.添加(项)
    返回 数组

// ===== JSON类型判断 =====

函程 JSON是对象(值): // 公开
    返回 转字符串(值) == "[object Object]"

函程 JSON是数组(值): // 公开
    返回 数组长度(值) >= 0 且 非 值.包含

函程 JSON是字符串(值): // 公开
    返回 字符串长度(转字符串(值)) > 0 且 子串(转字符串(值), 0, 1) == "\""

函程 JSON是数字(值): // 公开
    返回 转浮点数(值) != 0 或 值 == 0

// ===== JSON文件操作 =====

函程 加载JSON(路径): // 公开
    如果 非 文件存在(路径):
        返回 {}
    设 文本 = 读取文件(路径)
    返回 JSON解析(文本)

函程 保存JSON(路径, 数据): // 公开
    设 文本 = JSON格式化(数据)
    写入文件(路径, 文本)

// ===== JSON查询工具 =====

函程 取嵌套值(对象, 键路径): // 公开
    设 当前 = 对象
    遍 键 于 键路径:
        如果 当前.包含(键):
            当前 = 当前[键]
        否则:
            返回 ""
    返回 当前

函程 合并JSON(基础, 覆盖): // 公开
    设 结果 = {}
    遍 k 于 基础.键:
        结果[k] = 基础[k]
    遍 k 于 覆盖.键:
        结果[k] = 覆盖[k]
    返回 结果
