// ===== 语程标准库：环境变量 =====
// 提供环境变量访问工具函数
// 跨平台：自动适配 Windows/Linux/macOS 环境变量差异
//
// 公开接口：获取环境变量、环境变量存在、设置环境变量、
//           删除环境变量、所有环境变量、
//           获取用户目录、获取临时目录、获取应用目录

// ===== 基础操作 =====

函程 获取环境变量(键, 默认值=""): // 公开
    // 获取环境变量的值，不存在则返回默认值
    设 值 = 环境变量(键)
    如果 值 == "":
        返回 默认值
    返回 值

函程 环境变量存在(键): // 公开
    // 检查环境变量是否存在
    设 值 = 环境变量(键)
    返回 值 != ""

函程 删除环境变量(键): // 公开
    // 删除指定的环境变量（设置为空）
    设置环境变量(键, "")

// ===== 常用目录 =====

函程 获取用户目录(): // 公开
    // 获取用户主目录
    设 主目录 = 获取环境变量("HOME")
    如果 主目录 != "":
        返回 主目录
    主目录 = 获取环境变量("USERPROFILE")
    如果 主目录 != "":
        返回 主目录
    设 盘符 = 获取环境变量("HOMEDRIVE")
    设 路径 = 获取环境变量("HOMEPATH")
    如果 盘符 != "" 且 路径 != "":
        返回 盘符 + 路径
    返回 "."

函程 获取临时目录(): // 公开
    // 获取系统临时目录
    返回 临时目录()

函程 获取应用目录(): // 公开
    // 获取当前可执行文件所在目录
    返回 当前目录()

// ===== 路径相关 =====

函程 路径分隔符(): // 内部
    // 返回当前系统的路径分隔符
    设 系统 = 获取环境变量("OS")
    如果 子串(系统, 0, 7) == "Windows":
        返回 ";"
    返回 ":"

函程 获取路径列表(变量名="PATH"): // 公开
    // 获取PATH等路径变量的列表
    设 值 = 获取环境变量(变量名)
    如果 值 == "":
        返回 []
    返回 分割(值, 路径分隔符())

函程 添加路径(新路径, 变量名="PATH"): // 公开
    // 将新路径添加到PATH变量中
    设 当前 = 获取环境变量(变量名)
    如果 当前 == "":
        设置环境变量(变量名, 新路径)
    否则:
        设置环境变量(变量名, 当前 + 路径分隔符() + 新路径)

// ===== 系统信息 =====

函程 获取系统名称(): // 公开
    // 获取操作系统名称
    设 系统 = 获取环境变量("OS")
    如果 子串(系统, 0, 7) == "Windows":
        返回 "Windows"
    设 内核 = 获取环境变量("KERNEL_NAME")
    如果 内核 != "":
        返回 内核
    返回 "未知"

函程 获取处理器架构(): // 公开
    // 获取处理器架构
    设 架构 = 获取环境变量("PROCESSOR_ARCHITECTURE")
    如果 架构 != "":
        返回 架构
    架构 = 获取环境变量("HOSTTYPE")
    如果 架构 != "":
        返回 架构
    返回 "未知"

函程 获取主机名(): // 公开
    // 获取主机名
    设 名称 = 获取环境变量("HOSTNAME")
    如果 名称 != "":
        返回 名称
    名称 = 获取环境变量("COMPUTERNAME")
    如果 名称 != "":
        返回 名称
    返回 "未知"

函程 获取用户名(): // 公开
    // 获取当前用户名
    设 名称 = 获取环境变量("USER")
    如果 名称 != "":
        返回 名称
    名称 = 获取环境变量("USERNAME")
    如果 名称 != "":
        返回 名称
    返回 "未知"

函程 获取语言设置(): // 公开
    // 获取系统语言设置
    设 语言 = 获取环境变量("LANG")
    如果 语言 != "":
        返回 语言
    语言 = 获取环境变量("LC_ALL")
    如果 语言 != "":
        返回 语言
    返回 "未知"

函程 获取终端类型(): // 公开
    // 获取终端类型
    返回 获取环境变量("TERM", "未知")

函程 获取编辑器(): // 公开
    // 获取默认编辑器
    设 编辑器 = 获取环境变量("EDITOR")
    如果 编辑器 != "":
        返回 编辑器
    编辑器 = 获取环境变量("VISUAL")
    如果 编辑器 != "":
        返回 编辑器
    返回 "vi"
