// Unicode工具
// 提供Unicode字符分类、转换、规范化等功能

// === Unicode分类 ===

函程 是字母(字符): // 公开
    // 判断是否为字母（含中文等Unicode字母）
    设 码 = 字符编码(字符)
    // 基本拉丁字母
    如果 (码 >= 65 且 码 <= 90) 或 (码 >= 97 且 码 <= 122):
        返回 真
    // 拉丁扩展
    如果 码 >= 192 且 码 <= 687:
        返回 真
    // 希腊字母
    如果 码 >= 913 且 码 <= 974:
        返回 真
    // 西里尔字母
    如果 码 >= 1040 且 码 <= 1327:
        返回 真
    // CJK统一汉字
    如果 码 >= 0x4E00 且 码 <= 0x9FFF:
        返回 真
    // CJK扩展A
    如果 码 >= 0x3400 且 码 <= 0x4DBF:
        返回 真
    // 平假名
    如果 码 >= 0x3040 且 码 <= 0x309F:
        返回 真
    // 片假名
    如果 码 >= 0x30A0 且 码 <= 0x30FF:
        返回 真
    // 韩文字母
    如果 码 >= 0xAC00 且 码 <= 0xD7AF:
        返回 真
    返回 假

函程 是数字(字符): // 公开
    // 判断是否为数字字符（含全角数字）
    设 码 = 字符编码(字符)
    // ASCII数字
    如果 码 >= 48 且 码 <= 57:
        返回 真
    // 全角数字 ０-９
    如果 码 >= 0xFF10 且 码 <= 0xFF19:
        返回 真
    // 阿拉伯-印度数字
    如果 码 >= 0x0660 且 码 <= 0x0669:
        返回 真
    返回 假

函程 是汉字(字符): // 公开
    // 判断是否为CJK汉字
    设 码 = 字符编码(字符)
    如果 码 >= 0x4E00 且 码 <= 0x9FFF:
        返回 真
    如果 码 >= 0x3400 且 码 <= 0x4DBF:
        返回 真
    如果 码 >= 0x20000 且 码 <= 0x2A6DF:
        返回 真
    如果 码 >= 0xF900 且 码 <= 0xFAFF:
        返回 真
    返回 假

函程 是日文假名(字符): // 公开
    设 码 = 字符编码(字符)
    如果 码 >= 0x3040 且 码 <= 0x309F:
        返回 真
    如果 码 >= 0x30A0 且 码 <= 0x30FF:
        返回 真
    如果 码 >= 0x31F0 且 码 <= 0x31FF:
        返回 真
    返回 假

函程 是韩文字母(字符): // 公开
    设 码 = 字符编码(字符)
    如果 码 >= 0xAC00 且 码 <= 0xD7AF:
        返回 真
    如果 码 >= 0x1100 且 码 <= 0x11FF:
        返回 真
    如果 码 >= 0x3130 且 码 <= 0x318F:
        返回 真
    返回 假

函程 是空白字符(字符): // 公开
    设 码 = 字符编码(字符)
    如果 码 == 9 或 码 == 10 或 码 == 13 或 码 == 32:
        返回 真
    // 不间断空格等
    如果 码 == 0x00A0 或 码 == 0x1680:
        返回 真
    如果 码 >= 0x2000 且 码 <= 0x200A:
        返回 真
    如果 码 == 0x2028 或 码 == 0x2029 或 码 == 0x202F:
        返回 真
    如果 码 == 0x205F 或 码 == 0x3000:
        返回 真
    返回 假

函程 是标点符号(字符): // 公开
    设 码 = 字符编码(字符)
    // ASCII标点
    如果 (码 >= 33 且 码 <= 47) 或 (码 >= 58 且 码 <= 64):
        返回 真
    如果 (码 >= 91 且 码 <= 96) 或 (码 >= 123 且 码 <= 126):
        返回 真
    // 中文标点
    如果 码 >= 0x3000 且 码 <= 0x303F:
        返回 真
    // 全角标点
    如果 码 >= 0xFF01 且 码 <= 0xFF0F:
        返回 真
    如果 码 >= 0xFF1A 且 码 <= 0xFF20:
        返回 真
    如果 码 >= 0xFF3B 且 码 <= 0xFF40:
        返回 真
    如果 码 >= 0xFF5B 且 码 <= 0xFF65:
        返回 真
    返回 假

函程 是控制字符(字符): // 公开
    设 码 = 字符编码(字符)
    如果 码 >= 0 且 码 <= 31:
        返回 真
    如果 码 == 127:
        返回 真
    返回 假

// === 字符转换 ===

函程 转大写(字符): // 公开
    设 码 = 字符编码(字符)
    如果 码 >= 97 且 码 <= 122:
        返回 字符(码 - 32)
    返回 字符

函程 转小写(字符): // 公开
    设 码 = 字符编码(字符)
    如果 码 >= 65 且 码 <= 90:
        返回 字符(码 + 32)
    返回 字符

函程 全角转半角(字符): // 公开
    设 码 = 字符编码(字符)
    // 全角数字
    如果 码 >= 0xFF10 且 码 <= 0xFF19:
        返回 字符(码 - 0xFEE0)
    // 全角大写字母
    如果 码 >= 0xFF21 且 码 <= 0xFF3A:
        返回 字符(码 - 0xFEE0)
    // 全角小写字母
    如果 码 >= 0xFF41 且 码 <= 0xFF5A:
        返回 字符(码 - 0xFEE0)
    // 全角空格
    如果 码 == 0x3000:
        返回 字符(32)
    返回 字符

函程 半角转全角(字符): // 公开
    设 码 = 字符编码(字符)
    // 半角数字
    如果 码 >= 48 且 码 <= 57:
        返回 字符(码 + 0xFEE0)
    // 半角大写字母
    如果 码 >= 65 且 码 <= 90:
        返回 字符(码 + 0xFEE0)
    // 半角小写字母
    如果 码 >= 97 且 码 <= 122:
        返回 字符(码 + 0xFEE0)
    // 半角空格
    如果 码 == 32:
        返回 字符(0x3000)
    返回 字符

// === 字符信息 ===

函程 字符名称(字符): // 公开
    // 返回字符的Unicode分类描述
    设 码 = 字符编码(字符)
    如果 是控制字符(字符):
        返回 "控制字符"
    如果 是空白字符(字符):
        返回 "空白字符"
    如果 码 >= 65 且 码 <= 90:
        返回 "大写字母"
    如果 码 >= 97 且 码 <= 122:
        返回 "小写字母"
    如果 码 >= 48 且 码 <= 57:
        返回 "数字"
    如果 是汉字(字符):
        返回 "汉字"
    如果 是日文假名(字符):
        返回 "假名"
    如果 是韩文字母(字符):
        返回 "韩文字母"
    如果 是标点符号(字符):
        返回 "标点符号"
    如果 是字母(字符):
        返回 "字母"
    返回 "其他"

函程 字符码点(字符): // 公开
    返回 字符编码(字符)

函程 码点转字符(码点): // 公开
    返回 字符(码点)

// === 字符串Unicode操作 ===

函程 字符串转码点列表(文本): // 公开
    设 列表 = []
    循环 字符 于 文本:
        列表.添加(字符编码(字符))
    返回 列表

函程 码点列表转字符串(码点列表): // 公开
    设 结果 = ""
    循环 码 于 码点列表:
        结果 = 结果 + 字符(码)
    返回 结果

函程 Unicode码(文本): // 公开
    // 返回字符串的Unicode码点表示
    设 结果 = ""
    循环 字符 于 文本:
        设 码 = 字符编码(字符)
        如果 码 > 127:
            结果 = 结果 + "U+" + 整数转十六进制(码)
        否则:
            结果 = 结果 + 字符
    返回 结果

函程 字符串全角转半角(文本): // 公开
    设 结果 = ""
    循环 字符 于 文本:
        结果 = 结果 + 全角转半角(字符)
    返回 结果

函程 字符串半角转全角(文本): // 公开
    设 结果 = ""
    循环 字符 于 文本:
        结果 = 结果 + 半角转全角(字符)
    返回 结果

// === 统计 ===

函程 字符分类统计(文本): // 公开
    // 统计文本中各类字符数量
    设 统计 = {
        字母: 0,
        数字: 0,
        汉字: 0,
        标点: 0,
        空白: 0,
        控制: 0,
        其他: 0
    }
    循环 字符 于 文本:
        如果 是汉字(字符):
            统计.汉字 = 统计.汉字 + 1
        否则 如果 是字母(字符):
            统计.字母 = 统计.字母 + 1
        否则 如果 是数字(字符):
            统计.数字 = 统计.数字 + 1
        否则 如果 是标点符号(字符):
            统计.标点 = 统计.标点 + 1
        否则 如果 是空白字符(字符):
            统计.空白 = 统计.空白 + 1
        否则 如果 是控制字符(字符):
            统计.控制 = 统计.控制 + 1
        否则:
            统计.其他 = 统计.其他 + 1
    返回 统计

函程 包含中文(文本): // 公开
    循环 字符 于 文本:
        如果 是汉字(字符):
            返回 真
    返回 假

函程 包含日文(文本): // 公开
    循环 字符 于 文本:
        如果 是日文假名(字符):
            返回 真
    返回 假

函程 包含韩文(文本): // 公开
    循环 字符 于 文本:
        如果 是韩文字母(字符):
            返回 真
    返回 假

// === 辅助 ===

函程 整数转十六进制(值): // 内部
    设 十六位 = "0123456789ABCDEF"
    设 结果 = ""
    如果 值 == 0:
        返回 "0"
    循环 当 值 > 0:
        设 余 = 值 % 16
        结果 = 十六位[余] + 结果
        值 = 值 / 16
    返回 结果
