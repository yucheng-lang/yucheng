// ===== 语程标准库：位操作 =====
// 提供位运算工具函数
//
// 公开接口：按位与、按位或、按位异或、按位取反、左移、右移、
//           测试位、设置位、清除位、翻转位、
//           计算设置位、前导零位、尾随零位、
//           二进制字符串、八进制字符串、十六进制字符串、
//           左旋位、右旋位

// ===== 基本位运算 =====

函程 按位与(a, b): // 公开
    返回 位与(a, b)

函程 按位或(a, b): // 公开
    返回 位或(a, b)

函程 按位异或(a, b): // 公开
    返回 位异或(a, b)

函程 按位取反(a): // 公开
    返回 位取反(a)

函程 左移(a, n): // 公开
    返回 位左移(a, n)

函程 右移(a, n): // 公开
    返回 位右移(a, n)

// ===== 位测试与操作 =====

函程 测试位(值, 位): // 公开
    设 掩码 = 位左移(1, 位)
    返回 位与(值, 掩码) == 掩码

函程 设置位(值, 位): // 公开
    设 掩码 = 位左移(1, 位)
    返回 位或(值, 掩码)

函程 清除位(值, 位): // 公开
    设 掩码 = 位取反(位左移(1, 位))
    返回 位与(值, 掩码)

函程 翻转位(值, 位): // 公开
    设 掩码 = 位左移(1, 位)
    返回 位异或(值, 掩码)

// ===== 位计数 =====

函程 计算设置位(值): // 公开
    设 计数 = 0
    循环 当 值 > 0:
        计数 = 计数 + 位与(值, 1)
        值 = 位右移(值, 1)
    返回 计数

函程 前导零位(值): // 公开
    如果 值 == 0:
        返回 64
    设 计数 = 0
    循环 当 位与(位右移(值, 63), 1) == 0:
        计数 = 计数 + 1
        值 = 位左移(值, 1)
    返回 计数

函程 尾随零位(值): // 公开
    如果 值 == 0:
        返回 64
    设 计数 = 0
    循环 当 位与(值, 1) == 0:
        计数 = 计数 + 1
        值 = 位右移(值, 1)
    返回 计数

函程 首个设置位(值): // 公开
    如果 值 == 0:
        返回 0
    返回 尾随零位(值) + 1

// ===== 位旋转 =====

函程 左旋位(值, 位移): // 公开
    返回 位或(位左移(值, 位移), 位右移(值, 64 - 位移))

函程 右旋位(值, 位移): // 公开
    返回 位或(位右移(值, 位移), 位左移(值, 64 - 位移))

// ===== 进制转换 =====

函程 二进制字符串(值): // 公开
    如果 值 == 0:
        返回 "0"
    设 结果 = ""
    设 剩余 = 值
    循环 当 剩余 > 0:
        如果 位与(剩余, 1) == 1:
            结果 = "1" + 结果
        否则:
            结果 = "0" + 结果
        剩余 = 位右移(剩余, 1)
    返回 结果

函程 八进制字符串(值): // 公开
    如果 值 == 0:
        返回 "0"
    设 结果 = ""
    设 剩余 = 值
    循环 当 剩余 > 0:
        设 位值 = 位与(剩余, 7)
        结果 = 转字符串(位值) + 结果
        剩余 = 位右移(剩余, 3)
    返回 结果

函程 十六进制字符串(值): // 公开
    如果 值 == 0:
        返回 "0"
    设 结果 = ""
    设 剩余 = 值
    设 字符表 = "0123456789ABCDEF"
    循环 当 剩余 > 0:
        设 位值 = 位与(剩余, 15)
        设 字符 = 子串(字符表, 位值, 1)
        结果 = 字符 + 结果
        剩余 = 位右移(剩余, 4)
    返回 结果

// ===== 位掩码工具 =====

函程 创建掩码(低位, 高位): // 公开
    设 全1 = 位取反(0)
    设 宽 = 高位 - 低位 + 1
    设 低位掩码 = 位右移(全1, 64 - 宽)
    返回 位左移(低位掩码, 低位)

函程 位提取(值, 低位, 高位): // 公开
    设 掩码 = 创建掩码(低位, 高位)
    返回 位右移(位与(值, 掩码), 低位)

函程 位设置(值, 低位, 高位, 新值): // 公开
    设 掩码 = 创建掩码(低位, 高位)
    设 清除 = 位与(值, 位取反(掩码))
    返回 位或(清除, 位左移(新值, 低位))
