// 操作系统工具
// 提供系统信息获取、命令执行、休眠等功能

// === 系统信息 ===

函程 系统名称(): // 公开
    设 系统 = 环境变量("OS")
    如果 子串(系统, 0, 7) == "Windows":
        返回 "Windows"
    返回 环境("KERNEL_NAME", "未知")

函程 环境读取(键, 默认值=""): // 内部
    设 值 = 环境变量(键)
    如果 值 == "":
        返回 默认值
    返回 值

函程 主机名(): // 公开
    设 名称 = 环境变量("COMPUTERNAME")
    如果 名称 != "":
        返回 名称
    返回 环境变量("HOSTNAME", "未知")

函程 用户名(): // 公开
    设 名称 = 环境变量("USER")
    如果 名称 != "":
        返回 名称
    返回 环境变量("USERNAME", "未知")

函程 用户主目录(): // 公开
    设 主目录 = 环境变量("HOME")
    如果 主目录 != "":
        返回 主目录
    主目录 = 环境变量("USERPROFILE")
    如果 主目录 != "":
        返回 主目录
    设 盘符 = 环境变量("HOMEDRIVE")
    设 路径 = 环境变量("HOMEPATH")
    如果 盘符 != "" 且 路径 != "":
        返回 盘符 + 路径
    返回 "."

函程 临时目录路径(): // 公开
    设 临时 = 环境变量("TEMP")
    如果 临时 != "":
        返回 临时
    临时 = 环境变量("TMP")
    如果 临时 != "":
        返回 临时
    返回 临时目录()

函程 当前目录路径(): // 公开
    返回 当前目录()

函程 系统分隔符(): // 公开
    设 路径分隔 = 环境变量("PATH")
    如果 查找(路径分隔, ";") >= 0:
        返回 "\\"
    否则:
        返回 "/"

函程 是Windows(): // 公开
    返回 系统分隔符() == "\\"

函程 是Unix(): // 公开
    返回 系统分隔符() == "/"

// === 命令执行 ===

函程 执行命令并返回(命令): // 公开
    // 执行系统命令并返回输出
    返回 执行命令(命令)

函程 执行并捕获(命令): // 公开
    // 执行命令并返回 {输出: "", 退出码: 0}
    设 结果 = 执行命令(命令)
    返回 {输出: 结果, 退出码: 0}

函程 退出程序(代码 = 0): // 公开
    // 以指定退出码结束程序
    退出(代码)

// === 休眠 ===
// 注意：内置函数 休眠(毫秒数) 可直接使用

函程 秒休眠(秒数): // 公开
    // 暂停当前线程指定秒数
    休眠(秒数 * 1000)

函程 分休眠(分钟数): // 公开
    // 暂停当前线程指定分钟数
    休眠(分钟数 * 60 * 1000)

// === 环境查询 ===

函程 命令行参数列表(): // 公开
    返回 命令行参数()

函程 工作目录(): // 公开
    返回 当前目录()

函程 设置工作目录(路径): // 公开
    设置当前目录(路径)

// === 时间相关 ===

函程 当前时间戳(): // 公开
    返回 时间戳()

// === 系统资源 ===

函程 系统架构(): // 公开
    // 获取处理器架构（跨平台）
    设 架构 = 环境变量("PROCESSOR_ARCHITECTURE")
    如果 架构 != "":
        // Windows 环境变量
        如果 包含(架构, "AMD64") 或 包含(架构, "amd64"):
            返回 "x86_64"
        如果 包含(架构, "ARM64") 或 包含(架构, "arm64"):
            返回 "aarch64"
        返回 架构
    // Unix 环境变量
    架构 = 环境变量("HOSTTYPE")
    如果 架构 != "":
        返回 架构
    架构 = 环境变量("ARCH")
    如果 架构 != "":
        返回 架构
    返回 "未知"

函程 处理器数量(): // 公开
    // 获取处理器数量（跨平台）
    设 数量 = 环境变量("NUMBER_OF_PROCESSORS")
    如果 数量 != "":
        返回 转整数(数量)
    // Unix: 尝试 nproc 命令
    设 结果 = 执行命令("nproc")
    如果 结果 != "":
        设 数 = 结果.去除空白().转整数()
        如果 数 > 0:
            返回 数
    返回 1

函程 Shell类型(): // 公开
    如果 是Windows():
        返回 "cmd"
    否则:
        设 Shell路径 = 环境变量("SHELL")
        如果 包含(Shell路径, "zsh"):
            返回 "zsh"
        如果 包含(Shell路径, "fish"):
            返回 "fish"
        返回 "bash"

函程 终端类型(): // 公开
    返回 环境变量("TERM", "未知")

// === 实用工具 ===

函程 暂停(提示 = "按回车键继续..."): // 公开
    输出(提示)
    读行()

函程 清屏(): // 公开
    如果 是Windows():
        执行命令("cls")
    否则:
        执行命令("clear")

函程 哔声(): // 公开
    输出("\a")

函程 环境报告(): // 公开
    // 返回系统环境摘要
    返回 {
        系统: 系统名称(),
        主机: 主机名(),
        用户: 用户名(),
        主目录: 用户主目录(),
        架构: 系统架构(),
        处理器数: 处理器数量(),
        分隔符: 系统分隔符(),
        Shell: Shell类型()
    }
