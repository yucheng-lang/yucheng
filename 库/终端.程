// ===== 语程标准库：终端 =====
// 提供终端输出美化工具函数
// 跨平台：使用 ANSI 转义码，Linux/macOS 原生支持，Windows 10+ 也已支持
//
// 公开接口：红色文本、绿色文本、蓝色文本、黄色文本、
//           加粗文本、下划线文本、闪烁文本、
//           重置样式、前景色、背景色、
//           进度条、表格、分隔线、
//           清行、光标上移

// ===== ANSI 转义码 =====

常量 重置码 = "\e[0m" // 公开
常量 加粗码 = "\e[1m" // 公开
常量 暗淡码 = "\e[2m" // 公开
常量 斜体码 = "\e[3m" // 公开
常量 下划线码 = "\e[4m" // 公开
常量 闪烁码 = "\e[5m" // 公开
常量 反转码 = "\e[7m" // 公开
常量 隐藏码 = "\e[8m" // 公开

// ===== 前景色 =====

函程 前景色(颜色码): // 公开
    返回 "\e[" + 转字符串(颜色码) + "m"

函程 红色文本(文本): // 公开
    返回 "\e[31m" + 文本 + 重置码

函程 绿色文本(文本): // 公开
    返回 "\e[32m" + 文本 + 重置码

函程 黄色文本(文本): // 公开
    返回 "\e[33m" + 文本 + 重置码

函程 蓝色文本(文本): // 公开
    返回 "\e[34m" + 文本 + 重置码

函程 紫色文本(文本): // 公开
    返回 "\e[35m" + 文本 + 重置码

函程 青色文本(文本): // 公开
    返回 "\e[36m" + 文本 + 重置码

函程 白色文本(文本): // 公开
    返回 "\e[37m" + 文本 + 重置码

// ===== 背景色 =====

函程 红底文本(文本): // 公开
    返回 "\e[41m" + 文本 + 重置码

函程 绿底文本(文本): // 公开
    返回 "\e[42m" + 文本 + 重置码

函程 黄底文本(文本): // 公开
    返回 "\e[43m" + 文本 + 重置码

函程 蓝底文本(文本): // 公开
    返回 "\e[44m" + 文本 + 重置码

// ===== 样式 =====

函程 加粗文本(文本): // 公开
    返回 加粗码 + 文本 + 重置码

函程 下划线文本(文本): // 公开
    返回 下划线码 + 文本 + 重置码

函程 闪烁文本(文本): // 公开
    返回 闪烁码 + 文本 + 重置码

函程 反转文本(文本): // 公开
    返回 反转码 + 文本 + 重置码

函程 样式文本(文本, 样式码): // 公开
    返回 "\e[" + 转字符串(样式码) + "m" + 文本 + 重置码

// ===== 进度条 =====

函程 进度条(当前, 总数, 宽度): // 公开
    如果 总数 == 0:
        返回 "[" + 重复(" ", 宽度) + "] 0%"
    设 比例 = 转浮点(当前) / 转浮点(总数)
    设 已完成 = 四舍五入(比例 * 转浮点(宽度))
    设 剩余 = 宽度 - 已完成
    设 百分比 = 四舍五入(比例 * 100)
    设 结果 = "["
    设 i = 0
    循环 i < 已完成:
        结果 = 结果 + "="
        i = i + 1
    如果 已完成 < 宽度:
        结果 = 结果 + ">"
    设 i = 0
    循环 i < 剩余 - 1:
        结果 = 结果 + " "
        i = i + 1
    结果 = 结果 + "] " + 转字符串(百分比) + "%"
    返回 结果

// ===== 表格 =====

函程 表格行(列, 宽度): // 公开
    设 结果 = "|"
    设 i = 0
    循环 i < 数组长度(列):
        设 内容 = 转字符串(列[i])
        设 填充 = 宽度 - 字符串长度(内容)
        如果 填充 < 0:
            填充 = 0
        结果 = 结果 + " " + 内容 + 重复(" ", 填充) + " |"
        i = i + 1
    返回 结果

函程 表格分隔线(列数, 宽度): // 公开
    设 结果 = "+"
    设 i = 0
    循环 i < 列数:
        结果 = 结果 + 重复("-", 宽度 + 2) + "+"
        i = i + 1
    返回 结果

函程 分隔线(长度 = 40, 字符 = "-"): // 公开
    // 生成一条分隔线
    返回 重复(字符, 长度)

// ===== 终端控制 =====

函程 清行(): // 公开
    输出 "\e[2K\r"

函程 光标上移(行数): // 公开
    输出 "\e[" + 转字符串(行数) + "A"

函程 光标下移(行数): // 公开
    输出 "\e[" + 转字符串(行数) + "B"

函程 隐藏光标(): // 公开
    输出 "\e[?25l"

函程 显示光标(): // 公开
    输出 "\e[?25h"

函程 清屏(): // 公开
    输出 "\e[2J\e[H"
