// ===== 语程标准库：单调时间 =====
// 提供高精度单调递增时间测量
//
// 公开接口：获取单调时间、单调时间差、
//           创建计时器、读取纳秒、读取微秒、读取毫秒、
//           格式化耗时

// === 单调时间获取 ===

函程 获取单调时间(): // 公开
    返回 系统时间() * 1000000000

函程 单调时间纳秒(起, 止): // 公开
    返回 止 - 起

函程 单调时间微秒(起, 止): // 公开
    返回 (止 - 起) / 1000

函程 单调时间毫秒(起, 止): // 公开
    返回 (止 - 起) / 1000000

函程 单调时间秒(起, 止): // 公开
    返回 (止 - 起) / 1000000000

// === 计时器 ===

函程 创建计时器(): // 公开
    返回 {起点: 获取单调时间(), 活跃: 真, 累计: 0, 断点: 0}

函程 读取纳秒(计): // 公开
    设 活 = 计.活跃
    设 累 = 计.累计
    设 起 = 计.起点
    如果 活:
        返回 获取单调时间() - 起 - 累
    设 断 = 计.断点
    返回 断 - 起 - 累

函程 读取微秒(计): // 公开
    返回 读取纳秒(计) / 1000

函程 读取毫秒(计): // 公开
    返回 读取纳秒(计) / 1000000

函程 读取秒(计): // 公开
    返回 读取纳秒(计) / 1000000000

函程 暂停计时(计): // 公开
    设 活 = 计.活跃
    如果 活:
        计.活跃 = 假
        计.断点 = 获取单调时间()
    返回 计

函程 继续计时(计): // 公开
    设 活 = 计.活跃
    如果 不是 活:
        设 旧累计 = 计.累计
        设 旧断点 = 计.断点
        计.累计 = 旧累计 + (获取单调时间() - 旧断点)
        计.活跃 = 真
    返回 计

函程 重置计时(计): // 公开
    计.起点 = 获取单调时间()
    计.活跃 = 真
    计.累计 = 0
    计.断点 = 0
    返回 计

// === 格式化 ===

函程 格式化耗时(纳秒数): // 公开
    如果 纳秒数 < 1000:
        返回 转文本(纳秒数) + " ns"
    设 微秒 = 纳秒数 / 1000
    如果 微秒 < 1000:
        返回 格式化精度(微秒) + " μs"
    设 毫秒 = 微秒 / 1000
    如果 毫秒 < 1000:
        返回 格式化精度(毫秒) + " ms"
    设 秒 = 毫秒 / 1000
    如果 秒 < 60:
        返回 格式化精度(秒) + " s"
    设 分钟 = 秒 / 60
    如果 分钟 < 60:
        返回 格式化精度(分钟) + " min"
    设 小时 = 分钟 / 60
    返回 格式化精度(小时) + " h"

函程 格式化精度(数值): // 内部
    设 文本 = 转文本(数值)
    设 点位 = 查找(文本, ".")
    如果 点位 < 0:
        返回 文本 + ".00"
    设 整数部分 = 子串(文本, 0, 点位)
    设 小数部分 = 子串(文本, 点位 + 1, 2)
    循环 当 小数部分.长度() < 2:
        小数部分 = 小数部分 + "0"
    返回 整数部分 + "." + 小数部分
