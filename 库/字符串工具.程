// ===== 语程标准库：字符串工具 =====
// 提供字符串操作常用函数
//
// 公开接口：重复、开头是、结尾是、出现次数、居中、左填充、右填充、
//           格式化金额、表格行、表格分隔

函程 重复(文本, 次数): // 公开
    设 结果 = ""
    循环 次数 > 0:
        结果 = 结果 + 文本
        次数 = 次数 - 1
    返回 结果

函程 开头是(文本, 前缀): // 公开
    如果 字符串长度(前缀) > 字符串长度(文本):
        返回 假
    设 截取 = 子串(文本, 0, 字符串长度(前缀))
    返回 截取 == 前缀

函程 结尾是(文本, 后缀): // 公开
    如果 字符串长度(后缀) > 字符串长度(文本):
        返回 假
    设 起始 = 字符串长度(文本) - 字符串长度(后缀)
    设 截取 = 子串(文本, 起始, 字符串长度(文本))
    返回 截取 == 后缀

函程 出现次数(文本, 子串文本): // 公开
    如果 字符串长度(子串文本) == 0:
        返回 0
    设 计数 = 0
    设 位置 = 查找(文本, 子串文本)
    循环 位置 >= 0:
        计数 = 计数 + 1
        文本 = 子串(文本, 位置 + 字符串长度(子串文本), 字符串长度(文本))
        位置 = 查找(文本, 子串文本)
    返回 计数

函程 居中(文本, 总长度, 填充): // 公开
    如果 字符串长度(文本) >= 总长度:
        返回 文本
    设 剩余 = 总长度 - 字符串长度(文本)
    设 左 = 剩余 / 2
    设 右 = 剩余 - 左
    返回 重复(填充, 左) + 文本 + 重复(填充, 右)

函程 左填充(文本, 总长度, 填充): // 公开
    如果 字符串长度(文本) >= 总长度:
        返回 文本
    设 剩余 = 总长度 - 字符串长度(文本)
    返回 重复(填充, 剩余) + 文本

函程 右填充(文本, 总长度, 填充): // 公开
    如果 字符串长度(文本) >= 总长度:
        返回 文本
    设 剩余 = 总长度 - 字符串长度(文本)
    返回 文本 + 重复(填充, 剩余)

函程 格式化金额(数值): // 公开
    设 文本 = 转字符串(数值)
    设 整数部分 = 文本
    设 小数部分 = ""
    设 点位 = 查找(文本, ".")
    如果 点位 >= 0:
        整数部分 = 子串(文本, 0, 点位)
        小数部分 = 子串(文本, 点位, 字符串长度(文本))
    // 从右往左每3位加逗号
    设 结果 = ""
    设 计数 = 0
    设 i = 字符串长度(整数部分) - 1
    循环 i >= 0:
        如果 计数 > 0 且 计数 - (计数 / 3) * 3 == 0:
            结果 = "," + 结果
        设 字符 = 子串(整数部分, i, i + 1)
        结果 = 字符 + 结果
        计数 = 计数 + 1
        i = i - 1
    返回 结果 + 小数部分

函程 表格行(列, 宽度): // 公开
    设 结果 = "|"
    设 i = 0
    循环 i < 长度(列):
        设 内容 = 居中(转字符串(列[i]), 宽度, " ")
        结果 = 结果 + 内容 + "|"
        i = i + 1
    返回 结果

函程 表格分隔(列数, 宽度): // 公开
    设 结果 = "|"
    设 i = 0
    循环 i < 列数:
        结果 = 结果 + 重复("-", 宽度) + "|"
        i = i + 1
    返回 结果
