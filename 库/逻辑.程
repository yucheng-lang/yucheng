// 逻辑工具
// 提供逻辑运算、条件判断等工具函数

// === 逻辑运算 ===

函程 蕴含(a, b): // 公开
    // 逻辑蕴含：a -> b，即 !a || b
    返回 非 a 或 b

函程 等价(a, b): // 公开
    // 逻辑等价：a <-> b
    返回 a == b

函程 异或(a, b): // 公开
    // 逻辑异或：a ⊕ b
    返回 (a 或 b) 且 非 (a 且 b)

函程 与非(a, b): // 公开
    // 逻辑与非：!(a && b)
    返回 非 (a 且 b)

函程 或非(a, b): // 公开
    // 逻辑或非：!(a || b)
    返回 非 (a 或 b)

// === 条件工具 ===

函程 条件(布尔值, 真值, 假值): // 公开
    // 三元条件运算
    如果 布尔值:
        返回 真值
    返回 假值

函程 合取(值列表): // 公开
    // 对列表中所有值做逻辑与
    循环 值 于 值列表:
        如果 非 值:
            返回 假
    返回 真

函程 析取(值列表): // 公开
    // 对列表中所有值做逻辑或
    循环 值 于 值列表:
        如果 值:
            返回 真
    返回 假

函程 取反(值列表): // 公开
    // 对列表中所有值取反
    设 结果 = []
    循环 值 于 值列表:
        结果.添加(非 值)
    返回 结果

// === 全称与存在 ===

函程 全部满足(列表, 条件函数): // 公开
    // 判断列表中所有元素是否都满足条件
    循环 项 于 列表:
        如果 非 条件函数(项):
            返回 假
    返回 真

函程 存在满足(列表, 条件函数): // 公开
    // 判断列表中是否存在满足条件的元素
    循环 项 于 列表:
        如果 条件函数(项):
            返回 真
    返回 假

函程 无一满足(列表, 条件函数): // 公开
    // 判断列表中是否没有元素满足条件
    返回 非 存在满足(列表, 条件函数)

函程 恰好一个(列表, 条件函数): // 公开
    // 判断是否恰好有一个元素满足条件
    设 计数 = 0
    循环 项 于 列表:
        如果 条件函数(项):
            计数 = 计数 + 1
            如果 计数 > 1:
                返回 假
    返回 计数 == 1

函程 至少N个(列表, 条件函数, n): // 公开
    // 判断是否至少有n个元素满足条件
    设 计数 = 0
    循环 项 于 列表:
        如果 条件函数(项):
            计数 = 计数 + 1
            如果 计数 >= n:
                返回 真
    返回 假

函程 至多N个(列表, 条件函数, n): // 公开
    // 判断是否至多有n个元素满足条件
    设 计数 = 0
    循环 项 于 列表:
        如果 条件函数(项):
            计数 = 计数 + 1
            如果 计数 > n:
                返回 假
    返回 真

// === 布尔计数 ===

函程 真值计数(列表): // 公开
    // 统计列表中真值的个数
    设 计数 = 0
    循环 值 于 列表:
        如果 值:
            计数 = 计数 + 1
    返回 计数

函程 假值计数(列表): // 公开
    // 统计列表中假值的个数
    返回 列表.长度() - 真值计数(列表)

函程 真值比例(列表): // 公开
    // 返回真值占比
    如果 列表.长度() == 0:
        返回 0.0
    返回 真值计数(列表) * 1.0 / 列表.长度()

// === 真值表 ===

函程 二元真值表(函数): // 公开
    // 生成二元逻辑函数的真值表
    返回 [
        {a: 假, b: 假, 结果: 函数(假, 假)},
        {a: 假, b: 真, 结果: 函数(假, 真)},
        {a: 真, b: 假, 结果: 函数(真, 假)},
        {a: 真, b: 真, 结果: 函数(真, 真)}
    ]

函程 一元真值表(函数): // 公开
    // 生成一元逻辑函数的真值表
    返回 [
        {a: 假, 结果: 函数(假)},
        {a: 真, 结果: 函数(真)}
    ]

// === 逻辑等价判断 ===

函程 二元等价(f1, f2): // 公开
    // 判断两个二元逻辑函数是否等价
    设 值列表 = [假, 真]
    循环 a 于 值列表:
        循环 b 于 值列表:
            如果 f1(a, b) != f2(a, b):
                返回 假
    返回 真

函程 一元等价(f1, f2): // 公开
    // 判断两个一元逻辑函数是否等价
    设 值列表 = [假, 真]
    循环 a 于 值列表:
        如果 f1(a) != f2(a):
            返回 假
    返回 真

函程 是重言式(函数): // 公开
    // 判断一元逻辑函数是否为重言式（永真）
    设 值列表 = [假, 真]
    循环 a 于 值列表:
        如果 非 函数(a):
            返回 假
    返回 真

函程 是矛盾式(函数): // 公开
    // 判断一元逻辑函数是否为矛盾式（永假）
    设 值列表 = [假, 真]
    循环 a 于 值列表:
        如果 函数(a):
            返回 假
    返回 真

// === 短路求值辅助 ===

函程 链式与(条件列表): // 公开
    // 链式逻辑与，遇假即停
    循环 条件 于 条件列表:
        如果 非 条件:
            返回 假
    返回 真

函程 链式或(条件列表): // 公开
    // 链式逻辑或，遇真即停
    循环 条件 于 条件列表:
        如果 条件:
            返回 真
    返回 假
