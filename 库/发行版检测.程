// ===== 语程标准库：发行版检测 =====
// 提供Linux/BSD/macOS发行版识别功能
// 借鉴空灵语言 distros 库的设计思想
//
// 公开接口：检测发行版、发行版名称、发行版版本、
//           是Ubuntu、是Debian、是Fedora、是Arch、
//           是CentOS、是Alpine、是macOS、是Windows、
//           包管理器、安装命令、系统信息

// === 发行版枚举 ===

函程 检测发行版(): // 公开
    // 检测当前操作系统的发行版
    // 返回字典：{名称, 版本, 代号, 家族, 包管理器}
    如果 是Windows():
        返回 {名称: "Windows", 版本: windows版本(), 代号: "", 家族: "windows", 包管理器: "winget"}
    否则如果 是macOS():
        返回 {名称: "macOS", 版本: mac版本(), 代号: mac代号(), 家族: "darwin", 包管理器: "brew"}
    否则:
        返回 linux发行版()

函程 发行版名称(): // 公开
    设 信息 = 检测发行版()
    返回 信息.获取默认值("名称", "未知")

函程 发行版版本(): // 公开
    设 信息 = 检测发行版()
    返回 信息.获取默认值("版本", "未知")

// === 常见发行版快捷检测 ===

函程 是Ubuntu(): // 公开
    返回 包含(发行版名称(), "Ubuntu")

函程 是Debian(): // 公开
    设 名 = 发行版名称()
    返回 包含(名, "Debian") 或 包含(名, "Ubuntu")

函程 是Fedora(): // 公开
    返回 包含(发行版名称(), "Fedora")

函程 是CentOS(): // 公开
    设 名 = 发行版名称()
    返回 包含(名, "CentOS") 或 包含(名, "RHEL") 或 包含(名, "Rocky") 或 包含(名, "Alma")

函程 是Arch(): // 公开
    设 名 = 发行版名称()
    返回 包含(名, "Arch") 或 包含(名, "Manjaro")

函程 是Alpine(): // 公开
    返回 包含(发行版名称(), "Alpine")

函程 是openSUSE(): // 公开
    设 名 = 发行版名称()
    返回 包含(名, "SUSE") 或 包含(名, "openSUSE")

函程 是Gentoo(): // 公开
    返回 包含(发行版名称(), "Gentoo")

函程 是NixOS(): // 公开
    返回 包含(发行版名称(), "NixOS")

// === 包管理器 ===

函程 包管理器(): // 公开
    // 获取当前系统的包管理器
    设 信息 = 检测发行版()
    返回 信息.获取默认值("包管理器", "unknown")

函程 安装命令(包名): // 公开
    // 生成安装指定包的命令
    设 管理 = 包管理器()
    设 命令表 = {
        "apt": "apt install " + 包名,
        "apt-get": "apt-get install " + 包名,
        "dnf": "dnf install " + 包名,
        "yum": "yum install " + 包名,
        "pacman": "pacman -S " + 包名,
        "apk": "apk add " + 包名,
        "zypper": "zypper install " + 包名,
        "emerge": "emerge " + 包名,
        "nix-env": "nix-env -i " + 包名,
        "brew": "brew install " + 包名,
        "winget": "winget install " + 包名,
        "choco": "choco install " + 包名
    }
    返回 命令表.获取默认值(管理, 包管理器() + " install " + 包名)

// === 系统信息 ===

函程 系统信息(): // 公开
    // 获取完整的系统信息
    设 发行 = 检测发行版()
    返回 {
        操作系统: 发行.获取默认值("名称", "未知"),
        版本: 发行.获取默认值("版本", "未知"),
        代号: 发行.获取默认值("代号", ""),
        家族: 发行.获取默认值("家族", "未知"),
        包管理器: 发行.获取默认值("包管理器", "未知"),
        架构: 系统架构(),
        主机名: 环境变量("COMPUTERNAME").长度() > 0 ? 环境变量("COMPUTERNAME") : 环境变量("HOSTNAME"),
        用户名: 环境变量("USERNAME").长度() > 0 ? 环境变量("USERNAME") : 环境变量("USER")
    }

函程 系统架构(): // 公开
    // 获取系统架构
    设 架构 = 环境变量("PROCESSOR_ARCHITECTURE")
    如果 架构.长度() > 0:
        返回 架构
    设 结果 = 执行命令("uname -m 2>/dev/null || echo unknown")
    返回 替换(结果, "\n", "")

// === 内部实现 ===

函程 linux发行版(): // 内部
    // 通过 /etc/os-release 检测 Linux 发行版
    设 信息 = 读取文件("/etc/os-release")
    设 名称 = 提取值(信息, "NAME")
    设 版本 = 提取值(信息, "VERSION_ID")
    设 代号 = 提取值(信息, "VERSION_CODENAME")
    设 家族 = 提取值(信息, "ID")
    设 包管理 = 推断包管理器(名称, 家族)
    返回 {名称: 名称, 版本: 版本, 代号: 代号, 家族: 家族, 包管理器: 包管理}

函程 提取值(文本, 键): // 内部
    // 从 os-release 格式文本中提取值
    设 行列表 = 文本.分割("\n")
    循环 行 于 行列表:
        如果 包含(行, 键 + "="):
            设 值 = 行.分割("=")[1]
            // 去除引号
            值 = 替换(替换(值, "\"", ""), "'", "")
            返回 去除首尾空白(值)
    返回 ""

函程 推断包管理器(名称, 家族): // 内部
    设 低名 = 转小写(名称)
    设 低族 = 转小写(家族)
    如果 包含(低名, "ubuntu") 或 包含(低族, "debian"):
        返回 "apt"
    如果 包含(低名, "fedora"):
        返回 "dnf"
    如果 包含(低名, "centos") 或 包含(低名, "rhel") 或 包含(低族, "rhel"):
        返回 "yum"
    如果 包含(低名, "arch") 或 包含(低族, "arch"):
        返回 "pacman"
    如果 包含(低名, "alpine"):
        返回 "apk"
    如果 包含(低名, "suse"):
        返回 "zypper"
    如果 包含(低名, "gentoo"):
        返回 "emerge"
    如果 包含(低名, "nix"):
        返回 "nix-env"
    如果 包含(低族, "debian"):
        返回 "apt"
    返回 "unknown"

函程 windows版本(): // 内部
    设 结果 = 执行命令("ver")
    返回 去除首尾空白(结果)

函程 mac版本(): // 内部
    设 结果 = 执行命令("sw_vers -productVersion 2>/dev/null")
    返回 去除首尾空白(结果)

函程 mac代号(): // 内部
    设 版本 = mac版本()
    设 代号表 = {
        "14": "Sonoma", "13": "Ventura", "12": "Monterey",
        "11": "Big Sur", "10.15": "Catalina", "10.14": "Mojave",
        "10.13": "High Sierra", "10.12": "Sierra"
    }
    循环 键, 值 于 代号表:
        如果 包含(版本, 键):
            返回 值
    返回 ""

函程 是Windows(): // 内部
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")

函程 是macOS(): // 内部
    设 系统 = 环境变量("OSTYPE")
    返回 包含(转小写(系统), "darwin")

函程 去除首尾空白(文本): // 内部
    返回 替换(替换(文本, "\n", ""), "\r", "")
