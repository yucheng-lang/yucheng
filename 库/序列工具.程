// ===== 语程标准库：序列工具 =====
// 提供函数式序列操作工具
//
// 公开接口：映射、过滤、折叠左、折叠右、
//           任意满足、全部满足、无一满足、
//           拉链、解拉链、连接、
//           展平、去假值、去空值、
//           重复序列、序列包含、
//           序列最大值、序列最小值、
//           分组依据、唯一依据

// ===== 映射与过滤 =====

函程 映射(列表, 函数): // 公开
    // 对列表中每个元素应用函数，返回结果列表
    设 结果 = []
    遍 项 于 列表:
        结果.添加(函数(项))
    返回 结果

函程 过滤(列表, 函数): // 公开
    // 保留满足条件的元素
    设 结果 = []
    遍 项 于 列表:
        如果 函数(项):
            结果.添加(项)
    返回 结果

函程 过滤索引(列表, 函数): // 公开
    // 保留满足条件的元素（函数接收索引和值）
    设 结果 = []
    设 i = 0
    遍 项 于 列表:
        如果 函数(i, 项):
            结果.添加(项)
        i = i + 1
    返回 结果

// ===== 折叠 =====

函程 折叠左(列表, 初始值, 函数): // 公开
    // 从左向右折叠: f(f(f(初始, a[0]), a[1]), a[2])
    设 累积 = 初始值
    遍 项 于 列表:
        累积 = 函数(累积, 项)
    返回 累积

函程 折叠右(列表, 初始值, 函数): // 公开
    // 从右向左折叠
    设 累积 = 初始值
    设 i = 数组长度(列表) - 1
    循环 当 i >= 0:
        累积 = 函数(列表[i], 累积)
        i = i - 1
    返回 累积

函程 累积左(列表, 初始值, 函数): // 公开
    // 返回每步折叠的中间结果
    设 结果 = [初始值]
    设 累积 = 初始值
    遍 项 于 列表:
        累积 = 函数(累积, 项)
        结果.添加(累积)
    返回 结果

// ===== 判断 =====

函程 任意满足(列表, 函数): // 公开
    // 是否存在满足条件的元素
    遍 项 于 列表:
        如果 函数(项):
            返回 真
    返回 假

函程 全部满足(列表, 函数): // 公开
    // 是否所有元素都满足条件
    遍 项 于 列表:
        如果 非 函数(项):
            返回 假
    返回 真

函程 无一满足(列表, 函数): // 公开
    // 是否没有元素满足条件
    遍 项 于 列表:
        如果 函数(项):
            返回 假
    返回 真

函程 计数满足(列表, 函数): // 公开
    // 统计满足条件的元素个数
    设 计 = 0
    遍 项 于 列表:
        如果 函数(项):
            计 = 计 + 1
    返回 计

// ===== 拉链 =====

函程 拉链(列表1, 列表2): // 公开
    // 将两个列表按位置配对
    设 结果 = []
    设 长度 = 最小值(数组长度(列表1), 数组长度(列表2))
    设 i = 0
    循环 当 i < 长度:
        结果.添加([列表1[i], 列表2[i]])
        i = i + 1
    返回 结果

函程 拉链长(列表1, 列表2, 默认1 = 空, 默认2 = 空): // 公开
    // 拉链，以较长列表为准，不足用默认值填充
    设 结果 = []
    设 长度 = 最大值(数组长度(列表1), 数组长度(列表2))
    设 i = 0
    循环 当 i < 长度:
        设 甲 = 默认1
        设 乙 = 默认2
        如果 i < 数组长度(列表1):
            甲 = 列表1[i]
        如果 i < 数组长度(列表2):
            乙 = 列表2[i]
        结果.添加([甲, 乙])
        i = i + 1
    返回 结果

函程 解拉链(对列表): // 公开
    // 将配对列表拆分为两个列表
    设 左 = []
    设 右 = []
    遍 对 于 对列表:
        左.添加(对[0])
        右.添加(对[1])
    返回 [左, 右]

// ===== 连接与展平 =====

函程 连接(列表们): // 公开
    // 将多个列表连接为一个
    设 结果 = []
    遍 列表 于 列表们:
        遍 项 于 列表:
            结果.添加(项)
    返回 结果

函程 展平(列表): // 公开
    // 展开一层嵌套
    设 结果 = []
    遍 项 于 列表:
        如果 类型(项) == "列表":
            遍 子项 于 项:
                结果.添加(子项)
        否则:
            结果.添加(项)
    返回 结果

函程 深度展平(列表): // 公开
    // 递归展开所有嵌套
    设 结果 = []
    遍 项 于 列表:
        如果 类型(项) == "列表":
            设 子结果 = 深度展平(项)
            遍 子项 于 子结果:
                结果.添加(子项)
        否则:
            结果.添加(项)
    返回 结果

// ===== 值过滤 =====

函程 去假值(列表): // 公开
    // 去除所有假值（假、0、空、""）
    设 结果 = []
    遍 项 于 列表:
        如果 项:
            结果.添加(项)
    返回 结果

函程 去空值(列表): // 公开
    // 去除所有空值
    设 结果 = []
    遍 项 于 列表:
        如果 项 != 空:
            结果.添加(项)
    返回 结果

函程 去重复(列表): // 公开
    // 保持顺序去重
    返回 数组去重(列表)

// ===== 序列生成 =====

函程 重复序列(值, 次数): // 公开
    // 生成重复值的列表
    设 结果 = []
    设 i = 0
    循环 当 i < 次数:
        结果.添加(值)
        i = i + 1
    返回 结果

函程 范围序列(起始, 结束, 步长 = 1): // 公开
    // 生成范围列表
    设 结果 = []
    设 i = 起始
    如果 步长 > 0:
        循环 当 i < 结束:
            结果.添加(i)
            i = i + 步长
    否则 如果 步长 < 0:
        循环 当 i > 结束:
            结果.添加(i)
            i = i + 步长
    返回 结果

函程 枚举序列(列表): // 公开
    // 返回 [索引, 值] 对的列表
    设 结果 = []
    设 i = 0
    遍 项 于 列表:
        结果.添加([i, 项])
        i = i + 1
    返回 结果

// ===== 聚合 =====

函程 序列最大值(列表): // 公开
    如果 数组长度(列表) == 0:
        返回 空
    设 结果 = 列表[0]
    遍 项 于 列表:
        如果 项 > 结果:
            结果 = 项
    返回 结果

函程 序列最小值(列表): // 公开
    如果 数组长度(列表) == 0:
        返回 空
    设 结果 = 列表[0]
    遍 项 于 列表:
        如果 项 < 结果:
            结果 = 项
    返回 结果

函程 序列求和(列表): // 公开
    返回 数组求和(列表)

函程 序列平均值(列表): // 公开
    返回 数组平均值(列表)

// ===== 分组 =====

函程 分组依据(列表, 函数): // 公开
    // 按函数返回值分组，返回字典
    设 结果 = {}
    遍 项 于 列表:
        设 键 = 函数(项)
        如果 结果.包含(键):
            结果[键].添加(项)
        否则:
            结果[键] = [项]
    返回 结果

函程 唯一依据(列表, 函数): // 公开
    // 按函数返回值去重（保留首个）
    设 已见 = {}
    设 结果 = []
    遍 项 于 列表:
        设 键 = 函数(项)
        如果 非 已见.包含(键):
            已见[键] = 真
            结果.添加(项)
    返回 结果

函程 排序依据(列表, 函数): // 公开
    // 按函数返回值排序
    设 对列表 = []
    遍 项 于 列表:
        对列表.添加({原始: 项, 键值: 函数(项)})
    // 冒泡排序
    设 n = 数组长度(对列表)
    设 i = 0
    循环 当 i < n - 1:
        设 j = 0
        循环 当 j < n - 1 - i:
            如果 对列表[j].键值 > 对列表[j + 1].键值:
                设 临时 = 对列表[j]
                对列表[j] = 对列表[j + 1]
                对列表[j + 1] = 临时
            j = j + 1
        i = i + 1
    设 结果 = []
    遍 对 于 对列表:
        结果.添加(对.原始)
    返回 结果

// ===== 查找 =====

函程 查找满足(列表, 函数): // 公开
    // 返回第一个满足条件的元素，无则返回空
    遍 项 于 列表:
        如果 函数(项):
            返回 项
    返回 空

函程 查找索引满足(列表, 函数): // 公开
    // 返回第一个满足条件的元素索引，无则返回 -1
    设 i = 0
    遍 项 于 列表:
        如果 函数(项):
            返回 i
        i = i + 1
    返回 -1

函程 分区(列表, 函数): // 公开
    // 将列表分为满足条件和不满足条件的两部分
    设 满足 = []
    设 不满足 = []
    遍 项 于 列表:
        如果 函数(项):
            满足.添加(项)
        否则:
            不满足.添加(项)
    返回 [满足, 不满足]

函程 滑动窗口(列表, 大小): // 公开
    // 返回滑动窗口切片列表
    设 结果 = []
    设 i = 0
    循环 当 i + 大小 <= 数组长度(列表):
        结果.添加(数组切片(列表, i, i + 大小))
        i = i + 1
    返回 结果

// ===== 辅助 =====

函程 最小值(a, b): // 内部
    如果 a < b:
        返回 a
    返回 b

函程 最大值(a, b): // 内部
    如果 a > b:
        返回 a
    返回 b
