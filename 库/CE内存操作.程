    返回 再次扫描(结果, 转文本(最大值), "小于等于")

函程 未知初始值扫描(进程ID, 数据类型): // 公开
    // 快捷方式：未知初始值扫描（记录所有地址）
    设 会话 = 创建扫描会话(进程ID)
    返回 首次扫描(会话, "0", 数据类型, "未知")

// ==================== 进程选择辅助 ====================

函程 列出可扫描进程(): // 公开
    // 列出所有可扫描的进程（有窗口的进程）
    设 所有进程 = 获取所有进程()
    设 结果 = []
    循环 进程 于 所有进程:
        设 进程ID = 进程.取值("进程ID")
        如果 进程ID > 4:  // 排除系统空闲进程
            结果 = 结果.添加(进程)
    返回 结果

// ==================== 十六进制编辑器视图 ====================

函程 十六进制视图(字节数据, 每行字节数): // 公开
    // 将字节数据格式化为十六进制视图
    设 结果 = ""
    设 偏移 = 0
    设 长度 = 字节数据.长度()
    如果 每行字节数 <= 0:
        每行字节数 = 16
    循环 当 偏移 < 长度:
        // 偏移地址
        结果 = 结果 + 格式化十六进制(偏移, 8) + "  "
        // 十六进制值
        设 行末尾 = 偏移 + 每行字节数
        如果 行末尾 > 长度:
            行末尾 = 长度
        设 当前偏移 = 偏移
        循环 当 当前偏移 < 行末尾:
            结果 = 结果 + 格式化十六进制(字节数据[当前偏移], 2) + " "
            当前偏移 = 当前偏移 + 1
        结果 = 结果 + "\n"
        偏移 = 偏移 + 每行字节数
    返回 结果

// ==================== 内存区域枚举 ====================

函程 枚举内存区域(进程ID): // 公开
    // 枚举进程的内存区域
    设 命令输出 = 执行命令("powershell -NoProfile -Command \"$p = Get-Process -Id " + 转文本(取整(进程ID)) + " -ErrorAction SilentlyContinue; if($p) { $p.Modules | ForEach-Object { $_.BaseAddress.ToInt64().ToString('X') + '|' + $_.ModuleMemorySize.ToString() + '|' + $_.ModuleName } } else { 'NOTFOUND' }\"")
    命令输出 = 去除空白(命令输出)
    设 输出未找到 = 包含(命令输出, "NOTFOUND")
    如果 输出未找到 或 输出.长度() == 0:
        返回 []
    设 行列表 = 分割(命令输出, "\n")
    设 结果 = []
    循环 行 于 行列表:
        设 部分 = 分割(去除空白(行), "|")
        如果 部分.长度() >= 3:
            结果 = 结果.添加({基地址: "0x" + 部分[0], 大小: 转数字(部分[1]), 模块名: 部分[2], 保护: "读写"})
    返回 结果
