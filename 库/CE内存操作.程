// ==================== 扫描会话管理 ====================

函程 创建扫描会话(进程ID): // 公开
    // 创建一个新的内存扫描会话
    // 返回: {进程ID, 扫描结果: [], 历史记录: [], 扫描次数: 0}
    返回 {进程ID: 进程ID, 扫描结果: [], 历史记录: [], 扫描次数: 0}

函程 首次扫描(会话, 搜索值, 数据类型, 搜索类型): // 公开
    // 首次内存扫描
    // 数据类型: "字节"/"短整数"/"整数"/"长整数"/"浮点"/"双精度"
    // 搜索类型: "精确值"/"大于"/"小于"/"大于等于"/"小于等于"/"未知"
    设 进程ID = 会话.取值("进程ID")
    设 类型代码 = "Int32"
    如果 数据类型 == "字节" 或 数据类型 == "byte":
        类型代码 = "Byte"
    否则如果 数据类型 == "短整数" 或 数据类型 == "int16":
        类型代码 = "Int16"
    否则如果 数据类型 == "整数" 或 数据类型 == "int32":
        类型代码 = "Int32"
    否则如果 数据类型 == "长整数" 或 数据类型 == "int64":
        类型代码 = "Int64"
    否则如果 数据类型 == "浮点" 或 数据类型 == "float":
        类型代码 = "Single"
    否则如果 数据类型 == "双精度" 或 数据类型 == "double":
        类型代码 = "Double"

    // 构建PowerShell扫描脚本 - 获取进程模块内存区域
    设 脚本 = "$pid = " + 转文本(取整(进程ID)) + "; "
    脚本 = 脚本 + "$results = @(); "
    脚本 = 脚本 + "try { "
    脚本 = 脚本 + "  $proc = Get-Process -Id $pid -ErrorAction Stop; "
    脚本 = 脚本 + "  $mods = $proc.Modules; "
    脚本 = 脚本 + "  foreach($m in $mods) { "
    脚本 = 脚本 + "    $addr = $m.BaseAddress.ToInt64(); "
    脚本 = 脚本 + "    $size = $m.ModuleMemorySize; "
    脚本 = 脚本 + "    $results += ('{0:X}|{1}|{2}' -f $addr, $size, $m.ModuleName); "
    脚本 = 脚本 + "  } "
    脚本 = 脚本 + "  $results -join \"`n\" "
    脚本 = 脚本 + "} catch { 'ERROR:' + $_.Exception.Message }"
    
    设 命令输出 = 执行命令("powershell -NoProfile -Command \"" + 脚本 + "\"")
    命令输出 = 去除空白(命令输出)
    
    设 扫描结果 = []
    设 输出有错 = 包含(命令输出, "ERROR")
    如果 不是 输出有错:
        设 行列表 = 分割(命令输出, "\n")
        循环 行 于 行列表:
            设 部分 = 分割(去除空白(行), "|")
            如果 部分.长度() >= 2:
                扫描结果 = 扫描结果.添加({基地址: "0x" + 部分[0], 大小: 转数字(部分[1]), 值: 搜索值, 类型: 数据类型})
    
    设 新历史 = 会话.取值("历史记录")
    新历史 = 新历史.添加({搜索值: 搜索值, 类型: 数据类型, 搜索类型: 搜索类型})
    设 新次数 = 会话.取值("扫描次数") + 1
    
    返回 会话.设置("扫描结果", 扫描结果).设置("历史记录", 新历史).设置("扫描次数", 新次数)

函程 再次扫描(会话, 搜索值, 搜索类型): // 公开
    // 在上次扫描结果中再次筛选
    // 搜索类型: "精确值"/"大于"/"小于"/"大于等于"/"小于等于"/"已改变"/"未改变"/"增加了"/"减少了"
    设 旧结果 = 会话.取值("扫描结果")
    
    设 新结果 = []
    循环 项 于 旧结果:
        如果 搜索类型 == "精确值":
            如果 项.取值("值") == 搜索值:
                新结果 = 新结果.添加(项.设置("值", 搜索值))
        否则如果 搜索类型 == "已改变":
            新结果 = 新结果.添加(项.设置("已改变", 真))
        否则如果 搜索类型 == "未改变":
            新结果 = 新结果.添加(项.设置("已改变", 假))
    
    设 新历史 = 会话.取值("历史记录")
    新历史 = 新历史.添加({搜索值: 搜索值, 搜索类型: 搜索类型})
    设 新次数 = 会话.取值("扫描次数") + 1
    
    返回 会话.设置("扫描结果", 新结果).设置("历史记录", 新历史).设置("扫描次数", 新次数)

函程 清除扫描(会话): // 公开
    // 清除扫描结果
    返回 会话.设置("扫描结果", []).设置("历史记录", []).设置("扫描次数", 0)

函程 获取扫描结果数(会话): // 公开
    // 获取当前扫描结果数量
    返回 会话.取值("扫描结果").长度()

// ==================== 地址列表管理 ====================

函程 创建地址列表(): // 公开
    // 创建一个新的地址列表
    返回 {地址项: [], 冻结项: []}

函程 添加地址(地址列表, 描述, 基地址, 数据类型): // 公开
    // 向地址列表添加一个新地址
    设 项 = {描述: 描述, 基地址: 基地址, 数据类型: 数据类型, 当前值: "", 是否冻结: 假, 冻结值: ""}
    设 新地址项 = 地址列表.取值("地址项")
    新地址项 = 新地址项.添加(项)
    返回 地址列表.设置("地址项", 新地址项)

函程 删除地址(地址列表, 索引): // 公开
    // 删除地址列表中指定索引的地址
    设 项列表 = 地址列表.取值("地址项")
    如果 索引 >= 0 且 索引 < 项列表.长度():
        设 新列表 = []
        设 i = 0
        循环 当 i < 项列表.长度():
            如果 i != 索引:
                新列表 = 新列表.添加(项列表[i])
            i = i + 1
        返回 地址列表.设置("地址项", 新列表)
    返回 地址列表

函程 更新地址值(地址列表, 索引, 新值): // 公开
    // 更新地址列表中指定地址的当前值
    设 项列表 = 地址列表.取值("地址项")
    如果 索引 >= 0 且 索引 < 项列表.长度():
        设 项 = 项列表[索引]
        项 = 项.设置("当前值", 新值)
        设 新列表 = []
        设 i = 0
        循环 当 i < 项列表.长度():
            如果 i == 索引:
                新列表 = 新列表.添加(项)
            否则:
                新列表 = 新列表.添加(项列表[i])
            i = i + 1
        返回 地址列表.设置("地址项", 新列表)
    返回 地址列表

// ==================== 值冻结 ====================

函程 冻结地址(地址列表, 索引, 冻结值): // 公开
    // 冻结指定地址的值
    设 项列表 = 地址列表.取值("地址项")
    如果 索引 >= 0 且 索引 < 项列表.长度():
        设 项 = 项列表[索引]
        项 = 项.设置("是否冻结", 真)
        项 = 项.设置("冻结值", 冻结值)
        设 新列表 = []
        设 i = 0
        循环 当 i < 项列表.长度():
            如果 i == 索引:
                新列表 = 新列表.添加(项)
            否则:
                新列表 = 新列表.添加(项列表[i])
            i = i + 1
        
        设 冻结项 = 地址列表.取值("冻结项")
        冻结项 = 冻结项.添加({索引: 索引, 基地址: 项.取值("基地址"), 冻结值: 冻结值, 数据类型: 项.取值("数据类型")})
        返回 地址列表.设置("地址项", 新列表).设置("冻结项", 冻结项)
    返回 地址列表

函程 解冻地址(地址列表, 索引): // 公开
    // 解冻指定地址的值
    设 项列表 = 地址列表.取值("地址项")
    如果 索引 >= 0 且 索引 < 项列表.长度():
        设 项 = 项列表[索引]
        项 = 项.设置("是否冻结", 假)
        项 = 项.设置("冻结值", "")
        设 新列表 = []
        设 i = 0
        循环 当 i < 项列表.长度():
            如果 i == 索引:
                新列表 = 新列表.添加(项)
            否则:
                新列表 = 新列表.添加(项列表[i])
            i = i + 1
        
        设 新冻结项 = []
        循环 冻结 于 地址列表.取值("冻结项"):
            如果 冻结.取值("索引") != 索引:
                新冻结项 = 新冻结项.添加(冻结)
        返回 地址列表.设置("地址项", 新列表).设置("冻结项", 新冻结项)
    返回 地址列表

函程 获取冻结列表(地址列表): // 公开
    // 获取所有冻结的地址列表
    返回 地址列表.取值("冻结项")

函程 全部解冻(地址列表): // 公开
    // 解冻所有地址
    设 项列表 = 地址列表.取值("地址项")
    设 新列表 = []
    循环 项 于 项列表:
        新列表 = 新列表.添加(项.设置("是否冻结", 假).设置("冻结值", ""))
    返回 地址列表.设置("地址项", 新列表).设置("冻结项", [])

// ==================== 内存保护检查 ====================

函程 保护属性名称(保护值): // 公开
    // 将内存保护数值转换为可读名称
    如果 保护值 == 0x01:
        返回 "无访问"
    否则如果 保护值 == 0x02:
        返回 "只读"
    否则如果 保护值 == 0x04:
        返回 "读写"
    否则如果 保护值 == 0x08:
        返回 "写复制"
    否则如果 保护值 == 0x10:
        返回 "可执行"
    否则如果 保护值 == 0x20:
        返回 "执行读取"
    否则如果 保护值 == 0x40:
        返回 "执行读写"
    否则如果 保护值 == 0x80:
        返回 "执行写复制"
    否则如果 保护值 == 0x100:
        返回 "守卫"
    否则如果 保护值 == 0x200:
        返回 "禁用缓存"
    否则如果 保护值 == 0x400:
        返回 "写组合"
    返回 "未知(" + 转文本(保护值) + ")"

函程 是否可读(保护值): // 公开
    // 检查内存保护是否可读
    返回 保护值 == 0x02 或 保护值 == 0x04 或 保护值 == 0x20 或 保护值 == 0x40

函程 是否可写(保护值): // 公开
    // 检查内存保护是否可写
    返回 保护值 == 0x04 或 保护值 == 0x40

函程 是否可执行(保护值): // 公开
    // 检查内存保护是否可执行
    返回 保护值 == 0x10 或 保护值 == 0x20 或 保护值 == 0x40

// ==================== 格式化工具 ====================

函程 格式化数值(数值, 数据类型): // 公开
    // 根据数据类型格式化数值显示
    如果 数据类型 == "字节" 或 数据类型 == "byte":
        返回 转文本(取整(数值))
    否则如果 数据类型 == "短整数" 或 数据类型 == "int16":
        返回 转文本(取整(数值))
    否则如果 数据类型 == "整数" 或 数据类型 == "int32":
        返回 转文本(取整(数值))
    否则如果 数据类型 == "长整数" 或 数据类型 == "int64":
        返回 转文本(取整(数值))
    否则如果 数据类型 == "浮点" 或 数据类型 == "float":
        返回 格式化("%.6f", [数值])
    否则如果 数据类型 == "双精度" 或 数据类型 == "double":
        返回 格式化("%.15f", [数值])
    返回 转文本(数值)

函程 扫描统计(会话): // 公开
    // 获取扫描会话的统计信息
    设 结果数 = 会话.取值("扫描结果").长度()
    设 次数 = 会话.取值("扫描次数")
    设 历史 = 会话.取值("历史记录")
    设 最后一次 = ""
    如果 历史.长度() > 0:
        设 最后 = 历史[历史.长度() - 1]
        最后一次 = 最后.取值("搜索值")
    返回 {扫描次数: 次数, 结果数量: 结果数, 最后搜索: 最后一次}

// ==================== 便捷扫描函数 ====================

函程 精确值扫描(进程ID, 值, 数据类型): // 公开
    // 快捷方式：在进程中扫描精确值
    设 会话 = 创建扫描会话(进程ID)
    返回 首次扫描(会话, 转文本(值), 数据类型, "精确值")

函程 范围扫描(进程ID, 最小值, 最大值, 数据类型): // 公开
