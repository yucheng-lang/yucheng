// ===== 语程标准库：颜色 =====
// 提供RGB颜色操作函数
//
// 公开接口：红绿蓝、提取红、提取绿、提取蓝、
//           颜色强度、颜色混合、颜色加、颜色减、
//           灰度颜色、渐变色、
//           颜色转十六进制、十六进制转颜色、
//           RGB转HSL、HSL转RGB、
//           颜色亮度、是亮色、是暗色

// ===== 颜色构造与提取 =====

函程 红绿蓝(r, g, b): // 公开
    返回 (r * 65536) + (g * 256) + b

函程 提取红(颜色): // 公开
    返回 向下取整(颜色 / 65536)

函程 提取绿(颜色): // 公开
    返回 模(向下取整(颜色 / 256), 256)

函程 提取蓝(颜色): // 公开
    返回 模(颜色, 256)

// ===== 颜色操作 =====

函程 颜色强度(颜色, 因子): // 公开
    设 r = 提取红(颜色)
    设 g = 提取绿(颜色)
    设 b = 提取蓝(颜色)
    设 新r = 四舍五入(转浮点数(r) * 因子)
    设 新g = 四舍五入(转浮点数(g) * 因子)
    设 新b = 四舍五入(转浮点数(b) * 因子)
    如果 新r > 255:
        新r = 255
    如果 新g > 255:
        新g = 255
    如果 新b > 255:
        新b = 255
    返回 红绿蓝(新r, 新g, 新b)

函程 颜色混合(颜色1, 颜色2, 比例): // 公开
    设 r1 = 提取红(颜色1)
    设 g1 = 提取绿(颜色1)
    设 b1 = 提取蓝(颜色1)
    设 r2 = 提取红(颜色2)
    设 g2 = 提取绿(颜色2)
    设 b2 = 提取蓝(颜色2)
    设 r = 四舍五入(转浮点数(r1) * (1 - 比例) + 转浮点数(r2) * 比例)
    设 g = 四舍五入(转浮点数(g1) * (1 - 比例) + 转浮点数(g2) * 比例)
    设 b = 四舍五入(转浮点数(b1) * (1 - 比例) + 转浮点数(b2) * 比例)
    返回 红绿蓝(r, g, b)

函程 颜色加(颜色1, 颜色2): // 公开
    设 r = 提取红(颜色1) + 提取红(颜色2)
    设 g = 提取绿(颜色1) + 提取绿(颜色2)
    设 b = 提取蓝(颜色1) + 提取蓝(颜色2)
    如果 r > 255:
        r = 255
    如果 g > 255:
        g = 255
    如果 b > 255:
        b = 255
    返回 红绿蓝(r, g, b)

函程 颜色减(颜色1, 颜色2): // 公开
    设 r = 提取红(颜色1) - 提取红(颜色2)
    设 g = 提取绿(颜色1) - 提取绿(颜色2)
    设 b = 提取蓝(颜色1) - 提取蓝(颜色2)
    如果 r < 0:
        r = 0
    如果 g < 0:
        g = 0
    如果 b < 0:
        b = 0
    返回 红绿蓝(r, g, b)

// ===== 特殊颜色 =====

函程 灰度颜色(级别): // 公开
    返回 红绿蓝(级别, 级别, 级别)

函程 渐变色(颜色1, 颜色2, 步数): // 公开
    设 结果 = []
    设 i = 0
    循环 i <= 步数:
        设 比例 = 转浮点数(i) / 转浮点数(步数)
        结果.添加(颜色混合(颜色1, 颜色2, 比例))
        i = i + 1
    返回 结果

// ===== 格式转换 =====

函程 颜色转十六进制(颜色): // 公开
    设 r = 提取红(颜色)
    设 g = 提取绿(颜色)
    设 b = 提取蓝(颜色)
    设 结果 = "#"
    设 字符表 = "0123456789ABCDEF"
    结果 = 结果 + 子串(字符表, 向下取整(r / 16), 1)
    结果 = 结果 + 子串(字符表, 模(r, 16), 1)
    结果 = 结果 + 子串(字符表, 向下取整(g / 16), 1)
    结果 = 结果 + 子串(字符表, 模(g, 16), 1)
    结果 = 结果 + 子串(字符表, 向下取整(b / 16), 1)
    结果 = 结果 + 子串(字符表, 模(b, 16), 1)
    返回 结果

函程 十六进制转颜色(文本): // 公开
    // 去掉 # 前缀
    设 值 = 文本
    如果 子串(文本, 0, 1) == "#":
        值 = 子串(文本, 1, 字符串长度(文本) - 1)
    设 r = 十六进制转整数(子串(值, 0, 2))
    设 g = 十六进制转整数(子串(值, 2, 2))
    设 b = 十六进制转整数(子串(值, 4, 2))
    返回 红绿蓝(r, g, b)

函程 十六进制转整数(文本): // 内部
    设 结果 = 0
    设 i = 0
    循环 当 i < 字符串长度(文本):
        设 字 = 子串(文本, i, 1)
        结果 = 结果 * 16
        如果 字 >= "0" 且 字 <= "9":
            结果 = 结果 + (字符编码(字) - 字符编码("0"))
        否则如果 字 >= "A" 且 字 <= "F":
            结果 = 结果 + (字符编码(字) - 字符编码("A") + 10)
        否则如果 字 >= "a" 且 字 <= "f":
            结果 = 结果 + (字符编码(字) - 字符编码("a") + 10)
        i = i + 1
    返回 结果

// ===== 颜色分析 =====

函程 颜色亮度(颜色): // 公开
    设 r = 提取红(颜色)
    设 g = 提取绿(颜色)
    设 b = 提取蓝(颜色)
    返回 (转浮点数(r) * 299 + 转浮点数(g) * 587 + 转浮点数(b) * 114) / 1000

函程 是亮色(颜色): // 公开
    返回 颜色亮度(颜色) > 128

函程 是暗色(颜色): // 公开
    返回 颜色亮度(颜色) <= 128

