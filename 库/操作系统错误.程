// ===== 语程标准库：操作系统错误 =====
// 提供操作系统错误的报告与处理功能
// 跨平台支持：Windows使用GetLastError+FormatMessage，POSIX使用errno+strerror
//
// 公开接口：获取最后错误、错误消息、抛出操作系统错误、
//           错误码转消息、是错误码、常见错误码

// === 错误获取 ===

函程 获取最后错误(): // 公开
    // 获取最近一次操作系统错误码
    返回 最后错误码()

函程 错误消息(错误码): // 公开
    // 将操作系统错误码转为可读的错误消息
    // Windows: 使用 net helpmsg 命令
    // POSIX: 使用 strerror 等价
    如果 是Windows平台():
        设 结果 = 执行命令("net helpmsg " + 转文本(错误码))
        返回 去除首尾空白(结果)
    否则:
        设 结果 = 执行命令("strerror " + 转文本(错误码) + " 2>/dev/null || echo \"未知错误\"")
        返回 去除首尾空白(结果)

函程 抛出操作系统错误(错误码, 附加信息=""): // 公开
    // 抛出操作系统错误异常
    设 消息 = 错误消息(错误码)
    如果 附加信息.长度() > 0:
        消息 = 附加信息 + ": " + 消息 + " (错误码: " + 转文本(错误码) + ")"
    否则:
        消息 = 消息 + " (错误码: " + 转文本(错误码) + ")"
    抛出 消息

// === 错误检查 ===

函程 检查错误(结果, 操作描述=""): // 公开
    // 检查操作结果，如果是错误码则抛出异常
    设 码 = 转整数(结果)
    如果 码 != 0:
        抛出操作系统错误(码, 操作描述)
    返回 码

函程 是错误码(码): // 公开
    // 判断是否为错误码（非零）
    返回 码 != 0

函程 是成功码(码): // 公开
    // 判断是否为成功码（零）
    返回 码 == 0

// === 常见错误码 ===

函程 常见错误码(): // 公开
    // 返回常见操作系统错误码字典
    返回 {
        // 通用错误
        "成功": 0,
        "操作不允许": 1,
        "文件不存在": 2,
        "权限不足": 13,
        "文件已存在": 17,
        "不是目录": 20,
        "是目录": 21,
        "参数无效": 22,
        "文件表溢出": 23,
        "太多打开文件": 24,
        "设备无空间": 28,
        "只读文件系统": 30,
        "链接太多": 31,
        "断开的管道": 32,
        "数学参数超出域": 33,
        "数学结果不可表示": 34,
        "资源死锁": 35,
        "文件名过长": 36,
        "无可用锁": 37,
        "功能未实现": 38,
        "目录非空": 39,
        "符号链接层级过多": 40,
        "信号中断": 4,
        "IO错误": 5,
        "地址已被使用": 98,
        "网络不可达": 101,
        "连接被拒绝": 111,
        "连接超时": 110,
        "进程不存在": 3,
        // Windows 特有
        "Windows_文件未找到": 2,
        "Windows_路径未找到": 3,
        "Windows_访问被拒绝": 5,
        "Windows_句柄无效": 6,
        "Windows_内存不足": 8,
        "Windows_环境错误": 10,
        "Windows_磁盘满": 112,
    }

// === 辅助 ===

函程 是Windows平台(): // 内部
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")

函程 去除首尾空白(文本): // 内部
    返回 替换(替换(文本, "\n", ""), "\r", "")
