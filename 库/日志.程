// ===== 语程标准库：日志 =====
// 提供日志记录框架：多级别日志、格式化输出
//
// 公开接口：级别调试、级别信息、级别警告、级别错误、级别关闭、
//           设置日志级别、调试、信息、警告、错误、
//           设置日志文件、调试文件、信息文件、警告文件、错误文件、
//           日志进入、日志退出、详细信息、
//           开始计时、结束计时、计时执行

// ===== 公开常量 =====

常量 级别调试 = 0 // 公开
常量 级别信息 = 1 // 公开
常量 级别警告 = 2 // 公开
常量 级别错误 = 3 // 公开
常量 级别关闭 = 4 // 公开

// ===== 内部状态 =====

设 当前日志级别 = 级别信息 // 内部

函程 设置日志级别(级别): // 公开
    当前日志级别 = 级别

// ===== 内部函数 =====

函程 级别名称(级别): // 内部
    如果 级别 == 级别调试:
        返回 "调试"
    如果 级别 == 级别信息:
        返回 "信息"
    如果 级别 == 级别警告:
        返回 "警告"
    如果 级别 == 级别错误:
        返回 "错误"
    返回 "未知"

函程 级别标记(级别): // 内部
    如果 级别 == 级别调试:
        返回 "[DBG]"
    如果 级别 == 级别信息:
        返回 "[INF]"
    如果 级别 == 级别警告:
        返回 "[WRN]"
    如果 级别 == 级别错误:
        返回 "[ERR]"
    返回 "[???]"

函程 格式化日志(级别, 消息): // 内部
    设 标记 = 级别标记(级别)
    设 时间 = 当前时间()
    返回 标记 + " " + 时间 + " - " + 消息

// ===== 公开日志输出 =====

函程 调试(消息): // 公开
    如果 当前日志级别 <= 级别调试:
        输出 格式化日志(级别调试, 消息)

函程 信息(消息): // 公开
    如果 当前日志级别 <= 级别信息:
        输出 格式化日志(级别信息, 消息)

函程 警告(消息): // 公开
    如果 当前日志级别 <= 级别警告:
        输出 格式化日志(级别警告, 消息)

函程 错误(消息): // 公开
    如果 当前日志级别 <= 级别错误:
        输出 格式化日志(级别错误, 消息)

// ===== 文件日志 =====

设 日志文件路径 = "" // 内部

函程 设置日志文件(路径): // 公开
    日志文件路径 = 路径

函程 写入日志(级别, 消息): // 内部
    设 行 = 格式化日志(级别, 消息)
    输出 行
    如果 日志文件路径 != "":
        追加文件(日志文件路径, 行 + "\n")

函程 调试文件(消息): // 公开
    如果 当前日志级别 <= 级别调试:
        写入日志(级别调试, 消息)

函程 信息文件(消息): // 公开
    如果 当前日志级别 <= 级别信息:
        写入日志(级别信息, 消息)

函程 警告文件(消息): // 公开
    如果 当前日志级别 <= 级别警告:
        写入日志(级别警告, 消息)

函程 错误文件(消息): // 公开
    如果 当前日志级别 <= 级别错误:
        写入日志(级别错误, 消息)

// ===== 分组日志 =====

设 日志缩进 = 0 // 内部

函程 日志进入(标题): // 公开
    信息(标题)
    日志缩进 = 日志缩进 + 1

函程 日志退出(标题): // 公开
    日志缩进 = 日志缩进 - 1
    如果 日志缩进 < 0:
        日志缩进 = 0
    信息(标题)

函程 缩进消息(消息): // 内部
    设 前缀 = ""
    设 i = 0
    循环 i < 日志缩进:
        前缀 = 前缀 + "  "
        i = i + 1
    返回 前缀 + 消息

函程 详细信息(消息): // 公开
    信息(缩进消息(消息))

// ===== 计时日志 =====

设 计时起点 = 0 // 内部

函程 开始计时(): // 公开
    计时起点 = 时间戳()

函程 结束计时(任务名): // 公开
    设 终点 = 时间戳()
    设 耗时 = 终点 - 计时起点
    信息(任务名 + " 耗时: " + 转字符串(耗时) + " 秒")
    返回 耗时

函程 计时执行(函, 名称): // 公开
    设 起 = 时间戳()
    设 结果 = 函()
    设 终 = 时间戳()
    设 耗时 = 终 - 起
    信息(名称 + " 耗时: " + 转字符串(耗时) + " 秒")
    返回 结果
