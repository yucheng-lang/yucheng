// ===== 语程标准库：算法 =====
// 提供常用算法：排序、搜索、排列组合
//
// 公开接口：冒泡排序、插入排序、选择排序、归并排序、降序排序、
//           二分查找、二分下界、二分上界、线性查找、
//           反转、右旋转、左旋转、
//           阶乘、排列数、组合数、全排列、组合、笛卡尔积、
//           有序去重、交换、计数、滑动窗口、分区

// ===== 排序算法 =====

函程 冒泡排序(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 n = 数组长度(结果)
    设 i = 0
    循环 i < n - 1:
        设 j = 0
        循环 j < n - 1 - i:
            如果 结果[j] > 结果[j + 1]:
                设 临时 = 结果[j]
                结果[j] = 结果[j + 1]
                结果[j + 1] = 临时
            j = j + 1
        i = i + 1
    返回 结果

函程 插入排序(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 n = 数组长度(结果)
    设 i = 1
    循环 i < n:
        设 关键 = 结果[i]
        设 j = i - 1
        循环 j >= 0 且 结果[j] > 关键:
            结果[j + 1] = 结果[j]
            j = j - 1
        结果[j + 1] = 关键
        i = i + 1
    返回 结果

函程 选择排序(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 n = 数组长度(结果)
    设 i = 0
    循环 i < n - 1:
        设 最小位 = i
        设 j = i + 1
        循环 j < n:
            如果 结果[j] < 结果[最小位]:
                最小位 = j
            j = j + 1
        如果 最小位 != i:
            设 临时 = 结果[i]
            结果[i] = 结果[最小位]
            结果[最小位] = 临时
        i = i + 1
    返回 结果

// 归并排序的合并操作
函程 归并合并(左, 右): // 内部
    设 结果 = []
    设 i = 0
    设 j = 0
    循环 i < 数组长度(左) 且 j < 数组长度(右):
        如果 左[i] <= 右[j]:
            结果.添加(左[i])
            i = i + 1
        否则:
            结果.添加(右[j])
            j = j + 1
    循环 i < 数组长度(左):
        结果.添加(左[i])
        i = i + 1
    循环 j < 数组长度(右):
        结果.添加(右[j])
        j = j + 1
    返回 结果

函程 归并排序(列表): // 公开
    如果 数组长度(列表) <= 1:
        返回 列表
    设 中 = 数组长度(列表) / 2
    设 左 = 数组切片(列表, 0, 中)
    设 右 = 数组切片(列表, 中, 数组长度(列表))
    设 排左 = 归并排序(左)
    设 排右 = 归并排序(右)
    返回 归并合并(排左, 排右)

函程 降序排序(列表): // 公开
    设 升序 = 排序(列表)
    设 结果 = []
    设 i = 数组长度(升序) - 1
    循环 i >= 0:
        结果.添加(升序[i])
        i = i - 1
    返回 结果

// ===== 搜索算法 =====

函程 二分查找(列表, 目标): // 公开
    设 低 = 0
    设 高 = 数组长度(列表) - 1
    循环 低 <= 高:
        设 中 = (低 + 高) / 2
        如果 列表[中] == 目标:
            返回 中
        如果 列表[中] < 目标:
            低 = 中 + 1
        否则:
            高 = 中 - 1
    返回 -1

函程 二分下界(列表, 目标): // 公开
    设 低 = 0
    设 高 = 数组长度(列表)
    循环 低 < 高:
        设 中 = (低 + 高) / 2
        如果 列表[中] < 目标:
            低 = 中 + 1
        否则:
            高 = 中
    返回 低

函程 二分上界(列表, 目标): // 公开
    设 低 = 0
    设 高 = 数组长度(列表)
    循环 低 < 高:
        设 中 = (低 + 高) / 2
        如果 列表[中] <= 目标:
            低 = 中 + 1
        否则:
            高 = 中
    返回 高

函程 线性查找(列表, 目标): // 公开
    设 i = 0
    循环 i < 数组长度(列表):
        如果 列表[i] == 目标:
            返回 i
        i = i + 1
    返回 -1

// ===== 列表变换 =====

函程 反转(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 n = 数组长度(结果)
    设 i = 0
    循环 i < n / 2:
        设 临时 = 结果[i]
        结果[i] = 结果[n - 1 - i]
        结果[n - 1 - i] = 临时
        i = i + 1
    返回 结果

函程 右旋转(列表, k): // 公开
    如果 数组长度(列表) == 0:
        返回 []
    设 n = 数组长度(列表)
    设 步 = k - (k / n) * n
    如果 步 == 0:
        返回 列表
    设 结果 = []
    设 i = n - 步
    循环 i < n:
        结果.添加(列表[i])
        i = i + 1
    设 i = 0
    循环 i < n - 步:
        结果.添加(列表[i])
        i = i + 1
    返回 结果

函程 左旋转(列表, k): // 公开
    如果 数组长度(列表) == 0:
        返回 []
    设 n = 数组长度(列表)
    设 步 = k - (k / n) * n
    如果 步 == 0:
        返回 列表
    设 结果 = []
    设 i = 步
    循环 i < n:
        结果.添加(列表[i])
        i = i + 1
    设 i = 0
    循环 i < 步:
        结果.添加(列表[i])
        i = i + 1
    返回 结果

// ===== 排列组合 =====

函程 阶乘(n): // 公开
    如果 n < 0:
        返回 0
    如果 n <= 1:
        返回 1
    设 结果 = 1
    设 i = 2
    循环 i <= n:
        结果 = 结果 * i
        i = i + 1
    返回 结果

函程 排列数(n, k): // 公开
    如果 k > n 或 k < 0:
        返回 0
    设 结果 = 1
    设 i = 0
    循环 i < k:
        结果 = 结果 * (n - i)
        i = i + 1
    返回 结果

函程 组合数(n, k): // 公开
    如果 k > n 或 k < 0:
        返回 0
    如果 k > n - k:
        k = n - k
    设 结果 = 1
    设 i = 0
    循环 i < k:
        结果 = 结果 * (n - i) / (i + 1)
        i = i + 1
    返回 结果

函程 全排列(列表): // 公开
    如果 数组长度(列表) <= 1:
        返回 [列表]
    设 结果 = []
    设 i = 0
    循环 i < 数组长度(列表):
        设 当前 = 列表[i]
        设 其余 = []
        设 j = 0
        循环 j < 数组长度(列表):
            如果 j != i:
                其余.添加(列表[j])
            j = j + 1
        设 子排列 = 全排列(其余)
        遍 排 于 子排列:
            设 新排 = [当前]
            遍 项 于 排:
                新排.添加(项)
            结果.添加(新排)
        i = i + 1
    返回 结果

函程 组合(列表, k): // 公开
    如果 k == 0:
        返回 [[]]
    如果 k > 数组长度(列表):
        返回 []
    如果 k == 数组长度(列表):
        返回 [列表]
    设 结果 = []
    // 包含第一个元素的组合
    设 子组合 = 组合(数组切片(列表, 1, 数组长度(列表)), k - 1)
    遍 组 于 子组合:
        设 新组 = [列表[0]]
        遍 项 于 组:
            新组.添加(项)
        结果.添加(新组)
    // 不包含第一个元素的组合
    设 剩余组合 = 组合(数组切片(列表, 1, 数组长度(列表)), k)
    遍 组 于 剩余组合:
        结果.添加(组)
    返回 结果

函程 笛卡尔积(列表1, 列表2): // 公开
    设 结果 = []
    遍 项1 于 列表1:
        遍 项2 于 列表2:
            结果.添加([项1, 项2])
    返回 结果

// ===== 其他算法 =====

函程 有序去重(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        设 找到 = 假
        遍 已 于 结果:
            如果 已 == 项:
                找到 = 真
        如果 非 找到:
            结果.添加(项)
    返回 结果

函程 交换(列表, i, j): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 临时 = 结果[i]
    结果[i] = 结果[j]
    结果[j] = 临时
    返回 结果

函程 计数(列表, 目标): // 公开
    设 数 = 0
    遍 项 于 列表:
        如果 项 == 目标:
            数 = 数 + 1
    返回 数

函程 滑动窗口(列表, 窗口大小): // 公开
    如果 窗口大小 > 数组长度(列表):
        返回 []
    设 结果 = []
    设 i = 0
    循环 i <= 数组长度(列表) - 窗口大小:
        结果.添加(数组切片(列表, i, i + 窗口大小))
        i = i + 1
    返回 结果

函程 分区(列表, 条件函): // 公开
    设 满足 = []
    设 不满足 = []
    遍 项 于 列表:
        如果 条件函(项):
            满足.添加(项)
        否则:
            不满足.添加(项)
    返回 [满足, 不满足]
