// 字符串杂项工具
// 提供字符串的杂项处理函数

// === 字符串截取 ===

函程 取左边(文本, 长度): // 公开
    // 取文本左边指定长度
    如果 长度 >= 文本.长度():
        返回 文本
    返回 文本.子串(0, 长度)

函程 取右边(文本, 长度): // 公开
    // 取文本右边指定长度
    如果 长度 >= 文本.长度():
        返回 文本
    返回 文本.子串(文本.长度() - 长度)

函程 取中间(文本, 开始, 长度): // 公开
    // 从指定位置取指定长度
    如果 开始 >= 文本.长度():
        返回 ""
    设 可取 = 文本.长度() - 开始
    如果 长度 > 可取:
        长度 = 可取
    返回 文本.子串(开始, 长度)

// === 字符串查找 ===

函程 出现次数(文本, 子串): // 公开
    // 统计子串出现的次数
    如果 子串.长度() == 0:
        返回 0
    设 计数 = 0
    设 位置 = 0
    循环 当 真:
        设 找到 = 文本.子串(位置).查找(子串)
        如果 找到 < 0:
            跳出
        计数 = 计数 + 1
        位置 = 位置 + 找到 + 子串.长度()
    返回 计数

函程 第N次出现(文本, 子串, 第N次 = 1): // 公开
    // 查找子串第N次出现的位置
    如果 子串.长度() == 0 或 第N次 < 1:
        返回 -1
    设 计数 = 0
    设 位置 = 0
    循环 当 真:
        设 找到 = 文本.子串(位置).查找(子串)
        如果 找到 < 0:
            返回 -1
        计数 = 计数 + 1
        如果 计数 == 第N次:
            返回 位置 + 找到
        位置 = 位置 + 找到 + 子串.长度()
    返回 -1

函程 全部位置(文本, 子串): // 公开
    // 返回子串所有出现位置的列表
    设 结果 = []
    如果 子串.长度() == 0:
        返回 结果
    设 位置 = 0
    循环 当 真:
        设 找到 = 文本.子串(位置).查找(子串)
        如果 找到 < 0:
            跳出
        结果.添加(位置 + 找到)
        位置 = 位置 + 找到 + 子串.长度()
    返回 结果

// === 字符串分割扩展 ===

函程 按长度分割(文本, 长度): // 公开
    // 按固定长度分割字符串
    设 结果 = []
    设 位置 = 0
    循环 当 位置 < 文本.长度():
        设 剩余 = 文本.长度() - 位置
        设 实际 = 长度
        如果 实际 > 剩余:
            实际 = 剩余
        结果.添加(文本.子串(位置, 实际))
        位置 = 位置 + 长度
    返回 结果

函程 按多分隔符分割(文本, 分隔符列表): // 公开
    // 按多个分隔符分割字符串
    设 结果 = [文本]
    循环 分隔符 于 分隔符列表:
        设 新结果 = []
        循环 段 于 结果:
            设 子段 = 段.分割(分隔符)
            循环 项 于 子段:
                新结果.添加(项)
        结果 = 新结果
    返回 结果

函程 按行分割(文本): // 公开
    // 按换行符分割，自动处理 \r\n 和 \n
    设 结果 = 文本.替换("\r\n", "\n").分割("\n")
    返回 结果

// === 字符串修剪 ===

函程 去除首尾(文本, 字符集合 = " \t\n\r"): // 公开
    // 去除首尾在字符集合中的字符
    设 结果 = 文本
    循环 当 结果.长度() > 0 且 字符集合.包含(结果[0]):
        结果 = 结果.子串(1)
    循环 当 结果.长度() > 0 且 字符集合.包含(结果[结果.长度()-1]):
        结果 = 结果.子串(0, 结果.长度()-1)
    返回 结果

函程 去除左边(文本, 字符集合 = " \t\n\r"): // 公开
    设 结果 = 文本
    循环 当 结果.长度() > 0 且 字符集合.包含(结果[0]):
        结果 = 结果.子串(1)
    返回 结果

函程 去除右边(文本, 字符集合 = " \t\n\r"): // 公开
    设 结果 = 文本
    循环 当 结果.长度() > 0 且 字符集合.包含(结果[结果.长度()-1]):
        结果 = 结果.子串(0, 结果.长度()-1)
    返回 结果

// === 字符串判断 ===

函程 是空白(文本): // 公开
    // 判断字符串是否只包含空白字符
    循环 字符 于 文本:
        如果 字符 != " " 且 字符 != "\t" 且 字符 != "\n" 且 字符 != "\r":
            返回 假
    返回 真

函程 是数字串(文本): // 公开
    // 判断字符串是否只包含数字
    如果 文本.长度() == 0:
        返回 假
    循环 字符 于 文本:
        如果 字符 < "0" 或 字符 > "9":
            返回 假
    返回 真

函程 是字母串(文本): // 公开
    // 判断字符串是否只包含字母
    如果 文本.长度() == 0:
        返回 假
    循环 字符 于 文本:
        如果 非 ((字符 >= "a" 且 字符 <= "z") 或 (字符 >= "A" 且 字符 <= "Z")):
            返回 假
    返回 真

函程 是字母数字串(文本): // 公开
    // 判断是否只包含字母和数字
    如果 文本.长度() == 0:
        返回 假
    循环 字符 于 文本:
        如果 非 ((字符 >= "a" 且 字符 <= "z") 或 (字符 >= "A" 且 字符 <= "Z") 或 (字符 >= "0" 且 字符 <= "9")):
            返回 假
    返回 真

函程 以任意开头(文本, 前缀列表): // 公开
    // 判断是否以列表中任一前缀开头
    循环 前缀 于 前缀列表:
        如果 文本.开始于(前缀):
            返回 真
    返回 假

函程 以任意结尾(文本, 后缀列表): // 公开
    // 判断是否以列表中任一后缀结尾
    循环 后缀 于 后缀列表:
        如果 文本.结束于(后缀):
            返回 真
    返回 假

// === 字符串变换 ===

函程 翻转(文本): // 公开
    // 翻转字符串
    设 结果 = ""
    设 计 = 文本.长度() - 1
    循环 当 计 >= 0:
        结果 = 结果 + 文本[计]
        计 = 计 - 1
    返回 结果

函程 首字母大写(文本): // 公开
    // 将每个单词的首字母大写
    设 结果 = ""
    设 需大写 = 真
    循环 当前字符 于 文本:
        如果 需大写 且 当前字符 >= "a" 且 当前字符 <= "z":
            结果 = 结果 + 字符(字符编码(当前字符) - 32)
            需大写 = 假
        否则:
            结果 = 结果 + 当前字符
            需大写 = (当前字符 == " ")
    返回 结果

函程 交替大小写(文本): // 公开
    // 交替大小写转换
    设 结果 = ""
    设 大写 = 真
    循环 字符 于 文本:
        设 码 = 字符编码(字符)
        如果 大写:
            如果 码 >= 97 且 码 <= 122:
                结果 = 结果 + 字符(码 - 32)
            否则:
                结果 = 结果 + 字符
        否则:
            如果 码 >= 65 且 码 <= 90:
                结果 = 结果 + 字符(码 + 32)
            否则:
                结果 = 结果 + 字符
        如果 (码 >= 65 且 码 <= 90) 或 (码 >= 97 且 码 <= 122):
            大写 = 非 大写
    返回 结果

函程 去除变音符号(文本): // 公开
    // 简化的去除变音符号处理
    设 结果 = 文本
    // 常见带变音符号的字符替换
    结果 = 结果.替换("à", "a").替换("á", "a").替换("â", "a").替换("ã", "a").替换("ä", "a")
    结果 = 结果.替换("è", "e").替换("é", "e").替换("ê", "e").替换("ë", "e")
    结果 = 结果.替换("ì", "i").替换("í", "i").替换("î", "i").替换("ï", "i")
    结果 = 结果.替换("ò", "o").替换("ó", "o").替换("ô", "o").替换("õ", "o").替换("ö", "o")
    结果 = 结果.替换("ù", "u").替换("ú", "u").替换("û", "u").替换("ü", "u")
    结果 = 结果.替换("À", "A").替换("Á", "A").替换("Â", "A").替换("Ã", "A").替换("Ä", "A")
    结果 = 结果.替换("È", "E").替换("É", "E").替换("Ê", "E").替换("Ë", "E")
    结果 = 结果.替换("Ì", "I").替换("Í", "I").替换("Î", "I").替换("Ï", "I")
    结果 = 结果.替换("Ò", "O").替换("Ó", "O").替换("Ô", "O").替换("Õ", "O").替换("Ö", "O")
    结果 = 结果.替换("Ù", "U").替换("Ú", "U").替换("Û", "U").替换("Ü", "U")
    结果 = 结果.替换("ñ", "n").替换("Ñ", "N")
    结果 = 结果.替换("ç", "c").替换("Ç", "C")
    结果 = 结果.替换("ß", "ss")
    结果 = 结果.替换("ø", "o").替换("Ø", "O")
    结果 = 结果.替换("æ", "ae").替换("Æ", "AE")
    返回 结果

// === 字符串生成 ===

函程 重复字符(字符, 重复次数): // 公开
    // 生成重复字符组成的字符串
    设 结果 = ""
    循环 计 于 范围(0, 重复次数):
        结果 = 结果 + 字符
    返回 结果

函程 生成数字串(长度): // 公开
    设 结果 = ""
    循环 计 于 范围(0, 长度):
        结果 = 结果 + (计 % 10).转文本()
    返回 结果

函程 生成字母串(长度, 起始 = "a"): // 公开
    设 结果 = ""
    设 起始码 = 起始.字符码()
    循环 计 于 范围(0, 长度):
        结果 = 结果 + 字符(起始码 + (计 % 26))
    返回 结果

// === 字符串脱敏 ===

函程 脱敏(文本, 保留左边=0, 保留右边=0, 掩码="*"): // 公开
    // 字符串脱敏处理，中间用掩码替代
    如果 文本.长度() <= 保留左边 + 保留右边:
        返回 重复字符(掩码, 文本.长度())
    设 左 = 取左边(文本, 保留左边)
    设 右 = 取右边(文本, 保留右边)
    设 中间长度 = 文本.长度() - 保留左边 - 保留右边
    设 遮盖 = ""
    设 计 = 0
    循环 计 < 中间长度:
        遮盖 = 遮盖 + 掩码
        计 = 计 + 1
    返回 左 + 遮盖 + 右

函程 手机号脱敏(手机号): // 公开
    // 手机号中间4位脱敏
    返回 脱敏(手机号, 3, 4, "*")

函程 身份证脱敏(身份证): // 公开
    // 身份证中间脱敏
    返回 脱敏(身份证, 3, 4, "*")

函程 邮箱脱敏(邮箱): // 公开
    // 邮箱@前脱敏
    设 位置 = 邮箱.查找("@")
    如果 位置 < 0:
        返回 脱敏(邮箱, 1, 0, "*")
    设 用户名 = 邮箱.子串(0, 位置)
    设 域名 = 邮箱.子串(位置)
    如果 用户名.长度() <= 1:
        返回 "*" + 域名
    设 遮盖 = ""
    设 计 = 0
    循环 当 计 < 用户名.长度()-1:
        遮盖 = 遮盖 + "*"
        计 = 计 + 1
    返回 用户名[0] + 遮盖 + 域名

// === 辅助 ===

函程 范围(开始, 结束): // 内部
    设 列表 = []
    设 计 = 开始
    循环 当 计 < 结束:
        列表.添加(计)
        计 = 计 + 1
    返回 列表
