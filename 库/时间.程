// 时间 - 完整时间处理与时区

// === 时间创建 ===

函程 当前时间(): // 公开
    // 获取当前本地时间
    返回 获取系统时间().转为本地时间()

函程 当前UTC时间(): // 公开
    // 获取当前UTC时间
    返回 获取系统时间()

函程 创建时间(年, 月, 日, 时=0, 分=0, 秒=0, 纳秒=0, 时区="本地"): // 公开
    // 创建指定的时间对象
    返回 {
        年: 年, 月: 月, 日: 日,
        时: 时, 分: 分, 秒: 秒, 纳秒: 纳秒,
        时区: 时区,
        星期: 计算星期(年, 月, 日),
        一年中第几天: 计算年中天数(年, 月, 日)
    }

函程 从时间戳(秒数): // 公开
    // 从Unix时间戳创建时间
    返回 时间戳转时间(秒数)

函程 从ISO格式(ISO字符串): // 公开
    // 从ISO 8601格式字符串解析时间
    // 格式: "2024-01-15T10:30:00+08:00"
    设 日期部分 = ISO字符串.分割("T")[0]
    设 时间部分 = ISO字符串.分割("T")[1].分割("+")[0].分割("-")[0].分割("Z")[0]
    设 日期段 = 日期部分.分割("-")
    设 时间段 = 时间部分.分割(":")
    设 年 = 转整数(日期段[0])
    设 月 = 转整数(日期段[1])
    设 日 = 转整数(日期段[2])
    设 时 = 时间段.长度() > 0 ? 转整数(时间段[0]) : 0
    设 分 = 时间段.长度() > 1 ? 转整数(时间段[1]) : 0
    设 秒 = 时间段.长度() > 2 ? 转整数(时间段[2].分割(".")[0]) : 0
    返回 创建时间(年, 月, 日, 时, 分, 秒)

// === 时间转换 ===

函程 转为时间戳(时间): // 公开
    // 将时间转换为Unix时间戳（秒）
    返回 时间转时间戳(时间)

函程 转为ISO格式(时间, 包含时区=真): // 公开
    // 将时间转换为ISO 8601格式字符串
    设 结果 = 格式化数字(时间.年, 4) + "-" + 格式化数字(时间.月, 2) + "-" + 格式化数字(时间.日, 2)
    结果 = 结果 + "T" + 格式化数字(时间.时, 2) + ":" + 格式化数字(时间.分, 2) + ":" + 格式化数字(时间.秒, 2)
    如果 时间.纳秒 > 0:
        结果 = 结果 + "." + 转文本(时间.纳秒).去除尾随("0")
    如果 包含时区:
        如果 时间.时区 == "UTC":
            结果 = 结果 + "Z"
        否则如果 时间.时区 != "本地":
            设 偏移 = 获取时区偏移(时间.时区)
            结果 = 结果 + 格式化时区偏移(偏移)
    返回 结果

函程 转为本地时间(时间): // 公开
    // 转换为本地时间
    设 本地偏移 = 获取本地时区偏移秒()
    返回 时间偏移(时间, 本地偏移)

函程 转为UTC时间(时间): // 公开
    // 转换为UTC时间
    设 本地偏移 = 获取本地时区偏移秒()
    返回 时间偏移(时间, -本地偏移)

函程 转为指定时区(时间, 目标时区): // 公开
    // 转换为指定时区的时间
    设 源偏移 = 获取时区偏移(时间.时区)
    设 目标偏移 = 获取时区偏移(目标时区)
    设 差值 = 目标偏移 - 源偏移
    返回 时间偏移(时间, 差值)

// === 时间格式化 ===

函程 格式化时间(时间, 格式串="%Y-%m-%d %H:%M:%S"): // 公开
    // 按格式字符串格式化时间
    设 结果 = 格式串
    结果 = 结果.替换("%Y", 格式化数字(时间.年, 4))
    结果 = 结果.替换("%m", 格式化数字(时间.月, 2))
    结果 = 结果.替换("%d", 格式化数字(时间.日, 2))
    结果 = 结果.替换("%H", 格式化数字(时间.时, 2))
    结果 = 结果.替换("%M", 格式化数字(时间.分, 2))
    结果 = 结果.替换("%S", 格式化数字(时间.秒, 2))
    结果 = 结果.替换("%w", 转文本(时间.星期))
    结果 = 结果.替换("%j", 格式化数字(时间.一年中第几天, 3))
    结果 = 结果.替换("%A", 星期名称(时间.星期))
    结果 = 结果.替换("%a", 星期简称(时间.星期))
    结果 = 结果.替换("%B", 月份名称(时间.月))
    结果 = 结果.替换("%b", 月份简称(时间.月))
    返回 结果

函程 中文格式(时间): // 公开
    // 以中文格式显示时间
    返回 转文本(时间.年) + "年" + 转文本(时间.月) + "月" + 转文本(时间.日) + "日 " +
           格式化数字(时间.时, 2) + "时" + 格式化数字(时间.分, 2) + "分" + 格式化数字(时间.秒, 2) + "秒"

函程 友好格式(时间): // 公开
    // 以友好格式显示时间（如"3分钟前"）
    设 现在 = 当前时间()
    设 差秒 = 时间差秒(时间, 现在)
    设 绝对差 = 绝对值(差秒)
    如果 绝对差 < 60:
        返回 "刚刚"
    否则如果 绝对差 < 3600:
        返回 转文本(绝对差 / 60) + "分钟" + (差秒 > 0 ? "后" : "前")
    否则如果 绝对差 < 86400:
        返回 转文本(绝对差 / 3600) + "小时" + (差秒 > 0 ? "后" : "前")
    否则如果 绝对差 < 2592000:
        返回 转文本(绝对差 / 86400) + "天" + (差秒 > 0 ? "后" : "前")
    否则如果 绝对差 < 31536000:
        返回 转文本(绝对差 / 2592000) + "个月" + (差秒 > 0 ? "后" : "前")
    否则:
        返回 转文本(绝对差 / 31536000) + "年" + (差秒 > 0 ? "后" : "前")

// === 时间运算 ===

函程 时间偏移(时间, 秒数): // 公开
    // 对时间进行秒数偏移
    设 时间戳 = 转为时间戳(时间) + 秒数
    返回 从时间戳(时间戳)

函程 增加年(时间, 年数): // 公开
    返回 创建时间(时间.年 + 年数, 时间.月, 时间.日, 时间.时, 时间.分, 时间.秒)

函程 增加月(时间, 月数): // 公开
    设 总月 = (时间.年 * 12 + 时间.月 - 1) + 月数
    设 新年 = 总月 / 12
    设 新月 = 总月 % 12 + 1
    设 最大日 = 月份天数(新年, 新月)
    设 新日 = 最小值(时间.日, 最大日)
    返回 创建时间(新年, 新月, 新日, 时间.时, 时间.分, 时间.秒)

函程 增加天(时间, 天数): // 公开
    返回 时间偏移(时间, 天数 * 86400)

函程 增加小时(时间, 小时数): // 公开
    返回 时间偏移(时间, 小时数 * 3600)

函程 增加分钟(时间, 分钟数): // 公开
    返回 时间偏移(时间, 分钟数 * 60)

函程 增加秒(时间, 秒数): // 公开
    返回 时间偏移(时间, 秒数)

// === 时间差 ===

函程 时间差(开始, 结束): // 公开
    // 计算两个时间之间的差值
    设 差秒 = 转为时间戳(结束) - 转为时间戳(开始)
    返回 {
        总秒数: 差秒,
        总分钟: 差秒 / 60,
        总小时: 差秒 / 3600,
        总天数: 差秒 / 86400,
        天: 差秒 / 86400,
        小时: (差秒 % 86400) / 3600,
        分钟: (差秒 % 3600) / 60,
        秒: 差秒 % 60
    }

函程 时间差秒(开始, 结束): // 公开
    返回 转为时间戳(结束) - 转为时间戳(开始)

函程 时间差毫秒(开始, 结束): // 公开
    返回 时间差秒(开始, 结束) * 1000

// === 时间比较 ===

函程 时间相等(甲, 乙): // 公开
    返回 转为时间戳(甲) == 转为时间戳(乙)

函程 时间早于(甲, 乙): // 公开
    返回 转为时间戳(甲) < 转为时间戳(乙)

函程 时间晚于(甲, 乙): // 公开
    返回 转为时间戳(甲) > 转为时间戳(乙)

函程 时间在范围内(时间, 开始, 结束): // 公开
    返回 转为时间戳(时间) >= 转为时间戳(开始) 且 转为时间戳(时间) <= 转为时间戳(结束)

// === 日期查询 ===

函程 是闰年(年): // 公开
    返回 (年 % 4 == 0 且 年 % 100 != 0) 或 年 % 400 == 0

函程 月份天数(年, 月): // 公开
    设 天数表 = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    如果 月 == 2 且 是闰年(年):
        返回 29
    返回 天数表[月 - 1]

函程 年天数(年): // 公开
    返回 是闰年(年) ? 366 : 365

函程 计算星期(年, 月, 日): // 公开
    // 计算星期几（0=周一，6=周日）
    设 调整月 = 月
    设 调整年 = 年
    如果 调整月 < 3:
        调整月 = 调整月 + 12
        调整年 = 调整年 - 1
    设 K = 调整年 % 100
    设 J = 调整年 / 100
    设 日序 = (日 + (13 * (调整月 + 1)) / 5 + K + K/4 + J/4 + 5*J) % 7
    返回 (日序 + 5) % 7

函程 计算年中天数(年, 月, 日): // 公开
    设 天数 = 0
    循环 M 从 1 到 月 - 1:
        天数 = 天数 + 月份天数(年, M)
    返回 天数 + 日

// === 时区 ===

函程 获取时区偏移(时区名): // 公开
    // 获取时区偏移（秒）
    设 时区表 = {
        "UTC": 0, "GMT": 0,
        "Asia/Shanghai": 28800, "CST": 28800,
        "Asia/Tokyo": 32400, "JST": 32400,
        "Asia/Kolkata": 19800, "IST": 19800,
        "Europe/London": 0,
        "Europe/Paris": 3600, "CET": 3600,
        "Europe/Moscow": 10800, "MSK": 10800,
        "America/New_York": -18000, "EST": -18000,
        "America/Chicago": -21600, "CST": -21600,
        "America/Denver": -25200, "MST": -25200,
        "America/Los_Angeles": -28800, "PST": -28800,
        "Australia/Sydney": 36000, "AEST": 36000
    }
    返回 时区表.获取默认值(时区名, 0)

函程 格式化时区偏移(偏移秒): // 公开
    // 格式化时区偏移为字符串
    设 正号 = 偏移秒 >= 0
    设 绝对值 = 绝对值(偏移秒)
    设 小时 = 绝对值 / 3600
    设 分钟 = (绝对值 % 3600) / 60
    返回 (正号 ? "+" : "-") + 格式化数字(小时, 2) + ":" + 格式化数字(分钟, 2)

函程 获取本地时区偏移秒(): // 公开
    // 获取本地时区偏移（秒）
    // 跨平台：使用内置函数 时区偏移秒() 自动检测系统时区
    // 返回值示例：UTC+8 返回 28800，UTC-5 返回 -18000
    返回 时区偏移秒()

// === 辅助函数 ===

函程 星期名称(日序): // 公开
    设 名称 = ["周一", "周二", "周三", "周四", "周五", "周六", "周日"]
    返回 名称[日序]

函程 星期简称(日序): // 公开
    设 名称 = ["一", "二", "三", "四", "五", "六", "日"]
    返回 名称[日序]

函程 月份名称(月): // 公开
    设 名称 = ["一月", "二月", "三月", "四月", "五月", "六月", "七月", "八月", "九月", "十月", "十一月", "十二月"]
    返回 名称[月 - 1]

函程 月份简称(月): // 公开
    设 名称 = ["1月", "2月", "3月", "4月", "5月", "6月", "7月", "8月", "9月", "10月", "11月", "12月"]
    返回 名称[月 - 1]

函程 格式化数字(数, 位数): // 内部
    设 文本 = 转文本(数)
    如果 文本.长度() < 位数:
        返回 "0".重复(位数 - 文本.长度()) + 文本
    返回 文本

// === 系统时间函数声明 ===
// 获取系统时间() - 返回系统时间对象
// 时间戳转时间(秒数) - 时间戳转时间对象
// 时间转时间戳(时间) - 时间对象转时间戳
