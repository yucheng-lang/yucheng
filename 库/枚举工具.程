// 枚举工具
// 提供枚举类型创建、枚举操作等功能

// === 枚举创建 ===

函程 创建枚举(名称, 成员列表): // 公开
    // 从列表创建枚举
    // 例如: 创建枚举("颜色", ["红", "绿", "蓝"])
    设 枚举 = {__名称: 名称, __成员: [], __值表: {}}
    设 计 = 0
    遍 成员 于 成员列表:
        枚举[成员] = 计
        枚举.__成员.添加(成员)
        枚举.__值表[成员] = 计
        计 = 计 + 1
    返回 枚举

函程 创建值枚举(名称, 成员值表): // 公开
    // 从字典创建枚举（指定值）
    // 例如: 创建值枚举("状态", {正常: 0, 警告: 1, 错误: 2})
    设 枚举 = {__名称: 名称, __成员: [], __值表: {}}
    遍 成员, 值 于 成员值表:
        枚举[成员] = 值
        枚举.__成员.添加(成员)
        枚举.__值表[成员] = 值
    返回 枚举

函程 创建标志枚举(名称, 成员列表): // 公开
    // 创建标志枚举（位标志，值为2的幂）
    // 例如: 创建标志枚举("权限", ["读", "写", "执行"])
    // 读=1, 写=2, 执行=4
    设 枚举 = {__名称: 名称, __成员: [], __值表: {}, __标志: 真}
    设 计 = 0
    遍 成员 于 成员列表:
        设 值 = 位左移(1, 计)
        枚举[成员] = 值
        枚举.__成员.添加(成员)
        枚举.__值表[成员] = 值
        计 = 计 + 1
    返回 枚举

// === 枚举查询 ===

函程 枚举名称(枚举): // 公开
    返回 枚举.__名称

函程 枚举成员(枚举): // 公开
    返回 枚举.__成员

函程 枚举值表(枚举): // 公开
    返回 枚举.__值表

函程 枚举成员数(枚举): // 公开
    返回 枚举.__成员.长度()

函程 是否枚举成员(枚举, 名称): // 公开
    返回 枚举.__成员.包含(名称)

函程 是否枚举值(枚举, 值): // 公开
    遍 成员 于 枚举.__成员:
        如果 枚举[成员] == 值:
            返回 真
    返回 假

函程 根据名称取值(枚举, 名称): // 公开
    如果 枚举.__成员.包含(名称):
        返回 枚举[名称]
    返回 空

函程 根据值取名称(枚举, 值): // 公开
    遍 成员 于 枚举.__成员:
        如果 枚举[成员] == 值:
            返回 成员
    返回 空

函程 枚举最小值(枚举): // 公开
    设 最小 = 枚举[枚举.__成员[0]]
    遍 成员 于 枚举.__成员:
        如果 枚举[成员] < 最小:
            最小 = 枚举[成员]
    返回 最小

函程 枚举最大值(枚举): // 公开
    设 最大 = 枚举[枚举.__成员[0]]
    遍 成员 于 枚举.__成员:
        如果 枚举[成员] > 最大:
            最大 = 枚举[成员]
    返回 最大

// === 枚举迭代 ===

函程 枚举遍历(枚举): // 公开
    // 返回所有 [名称, 值] 对
    设 结果 = []
    遍 成员 于 枚举.__成员:
        结果.添加([成员, 枚举[成员]])
    返回 结果

函程 枚举名称列表(枚举): // 公开
    返回 枚举.__成员

函程 枚举值列表(枚举): // 公开
    设 结果 = []
    遍 成员 于 枚举.__成员:
        结果.添加(枚举[成员])
    返回 结果

// === 标志枚举操作 ===

函程 标志包含(标志值, 标志位): // 公开
    返回 位与(标志值, 标志位) == 标志位

函程 标志添加(标志值, 标志位): // 公开
    返回 位或(标志值, 标志位)

函程 标志移除(标志值, 标志位): // 公开
    返回 位与(标志值, 位取反(标志位))

函程 标志切换(标志值, 标志位): // 公开
    返回 位异或(标志值, 标志位)

函程 解析标志(枚举, 标志值): // 公开
    设 结果 = []
    遍 成员 于 枚举.__成员:
        如果 标志包含(标志值, 枚举[成员]):
            结果.添加(成员)
    返回 结果

// === 枚举转换 ===

函程 枚举转字典(枚举): // 公开
    设 结果 = {}
    遍 成员 于 枚举.__成员:
        结果[成员] = 枚举[成员]
    返回 结果

函程 枚举转列表(枚举): // 公开
    设 结果 = []
    遍 成员 于 枚举.__成员:
        结果.添加({名称: 成员, 值: 枚举[成员]})
    返回 结果

函程 枚举描述(枚举): // 公开
    设 结果 = "枚举 " + 枚举.__名称 + " {"
    设 项列表 = []
    遍 成员 于 枚举.__成员:
        项列表.添加(成员 + " = " + 转文本(枚举[成员]))
    结果 = 结果 + 项列表.连接(", ") + "}"
    返回 结果
