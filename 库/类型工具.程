// 类型工具库 - 类型检查与转换
// 提供类型判断和类型转换的工具函数

// 公开接口：类型名、是整数、是浮点数、是字符串、是列表、是字典、是逻辑值、转换为整数、转换为浮点数、转换为字符串

函程 类型名(值): // 公开
    // 返回值的类型名称
    设 名 = 类型(值)
    返回 名

函程 是整数(值): // 公开
    // 判断值是否为整数
    设 名 = 类型(值)
    返回 名 == "整数" 或 名 == "int"

函程 是浮点数(值): // 公开
    // 判断值是否为浮点数
    设 名 = 类型(值)
    返回 名 == "浮点数" 或 名 == "float"

函程 是字符串(值): // 公开
    // 判断值是否为字符串
    设 名 = 类型(值)
    返回 名 == "字符串" 或 名 == "string"

函程 是列表(值): // 公开
    // 判断值是否为列表
    设 名 = 类型(值)
    返回 名 == "列表" 或 名 == "list"

函程 是字典(值): // 公开
    // 判断值是否为字典
    设 名 = 类型(值)
    返回 名 == "字典" 或 名 == "dict"

函程 是逻辑值(值): // 公开
    // 判断值是否为逻辑值
    设 名 = 类型(值)
    返回 名 == "逻辑值" 或 名 == "bool"

函程 是数值(值): // 公开
    // 判断值是否为数值（整数或浮点数）
    返回 是整数(值) 或 是浮点数(值)

函程 是空值(值): // 公开
    // 判断值是否为空值
    返回 值 == 空

函程 是可迭代(值): // 公开
    // 判断值是否可迭代（列表或字符串或字典）
    返回 是列表(值) 或 是字符串(值) 或 是字典(值)

函程 转换为整数(值, 默认值 = 0): // 公开
    // 将值转换为整数
    // 转换失败时返回默认值
    如果 是整数(值):
        返回 值
    如果 是浮点数(值):
        返回 整数部分(值)
    如果 是字符串(值):
        设 结果 = 解析整数(值)
        如果 结果 == 空:
            返回 默认值
        返回 结果
    如果 是逻辑值(值):
        如果 值:
            返回 1
        否则:
            返回 0
    返回 默认值

函程 转换为浮点数(值, 默认值 = 0.0): // 公开
    // 将值转换为浮点数
    // 转换失败时返回默认值
    如果 是浮点数(值):
        返回 值
    如果 是整数(值):
        返回 值 * 1.0
    如果 是字符串(值):
        设 结果 = 解析浮点数(值)
        如果 结果 == 空:
            返回 默认值
        返回 结果
    如果 是逻辑值(值):
        如果 值:
            返回 1.0
        否则:
            返回 0.0
    返回 默认值

函程 转换为字符串(值): // 公开
    // 将值转换为字符串
    返回 转文本(值)

函程 转换为逻辑值(值): // 公开
    // 将值转换为逻辑值
    // 空值、0、空字符串、空列表返回假，其余返回真
    如果 值 == 空:
        返回 假
    如果 是整数(值):
        返回 值 != 0
    如果 是浮点数(值):
        返回 值 != 0.0
    如果 是字符串(值):
        返回 长度(值) > 0
    如果 是列表(值):
        返回 长度(值) > 0
    如果 是字典(值):
        返回 值.长度 > 0
    返回 真

函程 解析整数(文本): // 公开
    // 尝试从字符串解析整数，失败返回空
    设 结果 = 0
    设 符号 = 1
    设 起始 = 0
    设 文本长度 = 长度(文本)
    
    如果 文本长度 == 0:
        返回 空
    
    // 跳过空白
    循环 起始 < 文本长度 且 文本[起始] == ' ':
        起始 = 起始 + 1
    
    如果 起始 >= 文本长度:
        返回 空
    
    // 处理符号
    如果 文本[起始] == '-':
        符号 = -1
        起始 = 起始 + 1
    否则如果 文本[起始] == '+':
        起始 = 起始 + 1
    
    设 找到数字 = 假
    循环 起始 < 文本长度:
        设 字符 = 文本[起始]
        设 编码 = 字符编码(字符)
        如果 编码 >= 48 且 编码 <= 57:  // '0'-'9'
            结果 = 结果 * 10 + (编码 - 48)
            找到数字 = 真
        否则:
            跳出
        起始 = 起始 + 1
    
    如果 找到数字:
        返回 结果 * 符号
    返回 空

函程 解析浮点数(文本): // 公开
    // 尝试从字符串解析浮点数，失败返回空
    设 整数部分 = 0
    设 小数部分 = 0
    设 小数位数 = 0
    设 符号 = 1
    设 起始 = 0
    设 文本长度 = 长度(文本)
    设 在小数 = 假
    
    如果 文本长度 == 0:
        返回 空
    
    // 跳过空白
    循环 起始 < 文本长度 且 文本[起始] == ' ':
        起始 = 起始 + 1
    
    如果 起始 >= 文本长度:
        返回 空
    
    // 处理符号
    如果 文本[起始] == '-':
        符号 = -1
        起始 = 起始 + 1
    否则如果 文本[起始] == '+':
        起始 = 起始 + 1
    
    设 找到数字 = 假
    循环 起始 < 文本长度:
        设 字符 = 文本[起始]
        如果 字符 == '.' 且 非 在小数:
            在小数 = 真
        否则:
            设 编码 = 字符编码(字符)
            如果 编码 >= 48 且 编码 <= 57:
                如果 在小数:
                    小数部分 = 小数部分 * 10 + (编码 - 48)
                    小数位数 = 小数位数 + 1
                否则:
                    整数部分 = 整数部分 * 10 + (编码 - 48)
                找到数字 = 真
            否则:
                跳出
        起始 = 起始 + 1
    
    如果 找到数字:
        设 结果 = (整数部分 + 小数部分 / 幂(10, 小数位数)) * 符号
        返回 结果
    返回 空
