// 字符串表 - 高效字符串键值表

// === 辅助函数 ===

函程 是字母(字符): // 内部
    设 编码 = 字符编码(字符)
    返回 (编码 >= 65 且 编码 <= 90) 或 (编码 >= 97 且 编码 <= 122)

函程 是字母数字(字符): // 内部
    设 编码 = 字符编码(字符)
    返回 是字母(字符) 或 (编码 >= 48 且 编码 <= 57)

// === 创建字符串表 ===

函程 新建字符串表(模式="区分大小写"): // 公开
    // 创建新的空字符串表
    返回 {数据: {}, 计数: 0, 模式: 模式}

函程 从键值对创建(键值对列表, 模式="区分大小写"): // 公开
    // 从键值对列表创建字符串表
    设 表 = 新建字符串表(模式)
    循环 键, 值 在 键值对列表:
        表.数据[规范化键(表, 键)] = {键: 键, 值: 值}
        表.计数 = 表.计数 + 1
    返回 表

函程 从字典创建(字典, 模式="区分大小写"): // 公开
    // 从字典创建字符串表
    设 表 = 新建字符串表(模式)
    循环 键, 值 在 字典:
        表.数据[规范化键(表, 键)] = {键: 键, 值: 值}
        表.计数 = 表.计数 + 1
    返回 表

// === 键规范化 ===

函程 规范化键(表, 键): // 内部
    // 根据表的模式规范化键
    如果 表.模式 == "区分大小写":
        返回 键
    否则如果 表.模式 == "不区分大小写":
        返回 键.转小写()
    否则如果 表.模式 == "不区分样式":
        返回 键.转小写().替换("_", "")
    返回 键

// === 访问操作 ===

函程 获取值(表, 键): // 公开
    // 获取键对应的值，如果键不存在则抛出异常
    设 规范键 = 规范化键(表, 键)
    如果 数组包含(键集合(表.数据), 规范键):
        返回 表.数据[规范键].值
    抛出 "键不存在: " + 键

函程 获取默认值(表, 键, 默认=""): // 公开
    // 获取键对应的值，如果键不存在则返回默认值
    设 规范键 = 规范化键(表, 键)
    如果 数组包含(键集合(表.数据), 规范键):
        返回 表.数据[规范键].值
    返回 默认

函程 设置值(表, 键, 值): // 公开
    // 设置键值对
    设 规范键 = 规范化键(表, 键)
    如果 非 数组包含(键集合(表.数据), 规范键):
        表.计数 = 表.计数 + 1
    表.数据[规范键] = {键: 键, 值: 值}
    返回 表

函程 删除键(表, 键): // 公开
    // 删除键值对
    设 规范键 = 规范化键(表, 键)
    如果 数组包含(键集合(表.数据), 规范键):
        表.数据.删除(规范键)
        表.计数 = 表.计数 - 1

函程 有键(表, 键): // 公开
    // 检查键是否存在
    返回 数组包含(键集合(表.数据), 规范化键(表, 键))

函程 含有(表, 键): // 公开
    // 有键的别名，用于 "在" 操作符
    返回 有键(表, 键)

// === 查询操作 ===

函程 长度(表): // 公开
    // 返回键值对数量
    返回 表.计数

函程 是空表(表): // 公开
    // 检查表是否为空
    返回 表.计数 == 0

函程 获取模式(表): // 公开
    // 获取表的模式
    返回 表.模式

函程 键列表(表): // 公开
    // 返回所有键的列表
    设 结果 = []
    循环 规范键, 条目 在 表.数据:
        结果.添加(条目.键)
    返回 结果

函程 值列表(表): // 公开
    // 返回所有值的列表
    设 结果 = []
    循环 规范键, 条目 在 表.数据:
        结果.添加(条目.值)
    返回 结果

函程 键值对列表(表): // 公开
    // 返回所有键值对的列表
    设 结果 = []
    循环 规范键, 条目 在 表.数据:
        结果.添加({键: 条目.键, 值: 条目.值})
    返回 结果

// === 批量操作 ===

函程 合并(表甲, 表乙): // 公开
    // 合并两个字符串表，乙的值覆盖甲的同名键
    设 结果 = 新建字符串表(表甲.模式)
    循环 条目 在 键值对列表(表甲):
        设置值(结果, 条目.键, 条目.值)
    循环 条目 在 键值对列表(表乙):
        设置值(结果, 条目.键, 条目.值)
    返回 结果

函程 清空(表, 模式=""): // 公开
    // 清空字符串表，可选更改模式
    表.数据 = {}
    表.计数 = 0
    如果 模式.长度() > 0:
        表.模式 = 模式

函程 过滤键(表, 条件函数): // 公开
    // 按条件筛选键，返回新表
    设 结果 = 新建字符串表(表.模式)
    循环 条目 在 键值对列表(表):
        如果 条件函数(条目.键):
            设置值(结果, 条目.键, 条目.值)
    返回 结果

函程 映射值(表, 变换函数): // 公开
    // 对所有值应用变换函数，返回新表
    设 结果 = 新建字符串表(表.模式)
    循环 条目 在 键值对列表(表):
        设置值(结果, 条目.键, 变换函数(条目.值))
    返回 结果

// === 字符串替换 ===

函程 格式替换(格式串, 表, 标志列表=[]): // 公开
    // 使用字符串表进行格式替换
    // 支持 ${key} 和 $key 格式
    设 结果 = ""
    设 位置 = 0
    循环 位置 < 格式串.长度():
        如果 格式串[位置] == '$':
            如果 位置 + 1 < 格式串.长度():
                如果 格式串[位置+1] == '$':
                    结果 = 结果 + '$'
                    位置 = 位置 + 2
                否则如果 格式串[位置+1] == '{':
                    设 结束位置 = 格式串.查找("}", 位置+2)
                    如果 结束位置 >= 0:
                        设 键名 = 格式串.子串(位置+2, 结束位置 - 位置 - 2)
                        结果 = 结果 + 获取替换值(表, 键名, 标志列表)
                        位置 = 结束位置 + 1
                    否则:
                        结果 = 结果 + '$'
                        位置 = 位置 + 1
                否则如果 是字母(格式串[位置+1]) 或 格式串[位置+1] == '_':
                    设 键名 = ""
                    设 键位置 = 位置 + 1
                    循环 键位置 < 格式串.长度() 且 (是字母数字(格式串[键位置]) 或 格式串[键位置] == '_'):
                        键名 = 键名 + 格式串[键位置]
                        键位置 = 键位置 + 1
                    结果 = 结果 + 获取替换值(表, 键名, 标志列表)
                    位置 = 键位置
                否则:
                    结果 = 结果 + '$'
                    位置 = 位置 + 1
            否则:
                结果 = 结果 + '$'
                位置 = 位置 + 1
        否则:
            结果 = 结果 + 格式串[位置]
            位置 = 位置 + 1
    返回 结果

函程 获取替换值(表, 键名, 标志列表): // 内部
    // 获取格式替换的值
    如果 有键(表, 键名):
        返回 获取值(表, 键名)
    如果 数组包含(标志列表, "使用环境变量"):
        设 环境值 = 获取环境变量(键名)
        如果 环境值.长度() > 0:
            返回 环境值
    如果 数组包含(标志列表, "使用键"):
        返回 '$' + 键名
    如果 数组包含(标志列表, "使用空字符串"):
        返回 ""
    抛出 "格式字符串中键未找到: " + 键名

// === 转换 ===

函程 字符串表转字典(表): // 公开
    // 将字符串表转换为普通字典
    设 结果 = {}
    循环 条目 在 键值对列表(表):
        结果[条目.键] = 条目.值
    返回 结果

函程 字符串表转文本(表): // 公开
    // 将字符串表转换为文本表示
    如果 表.计数 == 0:
        返回 "{:}"
    设 结果 = "{"
    设 索引 = 0
    循环 条目 在 键值对列表(表):
        如果 索引 > 0:
            结果 = 结果 + ", "
        结果 = 结果 + 条目.键 + ": " + 条目.值
        索引 = 索引 + 1
    返回 结果 + "}"

