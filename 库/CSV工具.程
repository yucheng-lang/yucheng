// CSV工具 - CSV解析与生成
// 简化版：使用基本字符串操作实现

// === CSV解析 ===

函程 解析CSV(文本, 分隔符=",", 引号="\""): // 公开
    // 解析CSV文本为二维列表
    设 行列表 = []
    设 当前行 = []
    设 当前字段 = ""
    设 位置 = 0
    设 在引号内 = 假
    设 文本长度 = 字符串长度(文本)

    循环 当 位置 < 文本长度:
        设 字符 = 子串(文本, 位置, 1)

        如果 在引号内:
            如果 字符 == 引号:
                // 检查是否为双引号转义
                如果 位置 + 1 < 文本长度 且 子串(文本, 位置 + 1, 1) == 引号:
                    当前字段 = 当前字段 + 引号
                    位置 = 位置 + 2
                否则:
                    在引号内 = 假
                    位置 = 位置 + 1
            否则:
                当前字段 = 当前字段 + 字符
                位置 = 位置 + 1
        否则:
            如果 字符 == 引号 且 字符串长度(当前字段) == 0:
                在引号内 = 真
                位置 = 位置 + 1
            否则如果 字符 == 分隔符:
                当前行.添加(当前字段)
                当前字段 = ""
                位置 = 位置 + 1
            否则如果 字符 == "\r":
                如果 位置 + 1 < 文本长度 且 子串(文本, 位置 + 1, 1) == "\n":
                    位置 = 位置 + 1
                当前行.添加(当前字段)
                当前字段 = ""
                如果 当前行.长度() > 0:
                    行列表.添加(当前行)
                当前行 = []
                位置 = 位置 + 1
            否则如果 字符 == "\n":
                当前行.添加(当前字段)
                当前字段 = ""
                如果 当前行.长度() > 0:
                    行列表.添加(当前行)
                当前行 = []
                位置 = 位置 + 1
            否则:
                当前字段 = 当前字段 + 字符
                位置 = 位置 + 1

    // 处理最后一个字段和行
    当前行.添加(当前字段)
    如果 当前行.长度() > 0:
        行列表.添加(当前行)

    返回 行列表

函程 解析CSV带表头(文本, 分隔符=",", 引号="\""): // 公开
    设 行列表 = 解析CSV(文本, 分隔符, 引号)
    如果 行列表.长度() == 0:
        返回 []
    设 表头 = 行列表[0]
    设 结果 = []
    设 索引 = 1
    循环 当 索引 < 行列表.长度():
        设 行 = 行列表[索引]
        设 记录 = {}
        设 列索引 = 0
        循环 当 列索引 < 表头.长度() 且 列索引 < 行.长度():
            记录[表头[列索引]] = 行[列索引]
            列索引 = 列索引 + 1
        结果.添加(记录)
        索引 = 索引 + 1
    返回 结果

// === CSV生成 ===

函程 生成CSV行(字段列表, 分隔符=",", 引号="\""): // 公开
    设 转义字段 = []
    遍 字段 于 字段列表:
        转义字段.添加(CSV转义字段(转文本(字段), 分隔符, 引号))
    返回 转义字段.连接(分隔符)

函程 生成CSV(行列表, 分隔符=",", 引号="\"", 换行="\n"): // 公开
    设 行文本列表 = []
    遍 行 于 行列表:
        行文本列表.添加(生成CSV行(行, 分隔符, 引号))
    返回 行文本列表.连接(换行)

// === CSV字段转义 ===

函程 CSV转义字段(字段, 分隔符=",", 引号="\""): // 公开
    设 需要引号 = 假
    如果 包含(字段, 分隔符):
        需要引号 = 真
    否则如果 包含(字段, 引号):
        需要引号 = 真
    否则如果 包含(字段, "\n") 或 包含(字段, "\r"):
        需要引号 = 真

    如果 需要引号:
        // 替换引号为双引号
        设 转义内容 = 替换(字段, 引号, 引号 + 引号)
        返回 引号 + 转义内容 + 引号
    否则:
        返回 字段

// === CSV查询 ===

函程 CSV按列查找(数据, 表头列名, 查找值, 返回列名=""): // 公开
    遍 行 于 数据:
        设 列值 = 行.获取默认值(表头列名, "")
        如果 列值 == 查找值:
            如果 字符串长度(返回列名) > 0:
                返回 行.获取默认值(返回列名, "")
            否则:
                返回 行
    返回 空

函程 CSV筛选(数据, 列名, 条件函数): // 公开
    设 结果 = []
    遍 行 于 数据:
        设 值 = 行.获取默认值(列名, "")
        如果 条件函数(值):
            结果.添加(行)
    返回 结果

函程 CSV去重(数据, 列名列表=[]): // 公开
    设 已见 = {}
    设 结果 = []
    遍 行 于 数据:
        设 键 = ""
        如果 列名列表.长度() > 0:
            遍 列名 于 列名列表:
                键 = 键 + 行.获取默认值(列名, "") + "|"
        否则:
            键 = 转文本(行)
        如果 非 已见.含有(键):
            已见[键] = 真
            结果.添加(行)
    返回 结果
