// ===== 语程标准库：HTML工具 =====
// 提供HTML生成工具函数
//
// 公开接口：标签、自闭合标签、转义HTML、反转义HTML、
//           属性字符串、链接、图片、标题、段落、列表、
//           表格、表单、样式标签、脚本标签、
//           页面框架、粗体、斜体、删除线

// ===== 基础标签生成 =====

函程 转义HTML(文本): // 公开
    // 将特殊字符转义为HTML实体
    设 结果 = ""
    遍 字 于 文本:
        如果 字 == "&":
            结果 = 结果 + "&amp;"
        否则如果 字 == "<":
            结果 = 结果 + "&lt;"
        否则如果 字 == ">":
            结果 = 结果 + "&gt;"
        否则如果 字 == "\"":
            结果 = 结果 + "&quot;"
        否则如果 字 == "'":
            结果 = 结果 + "&#39;"
        否则:
            结果 = 结果 + 字
    返回 结果

函程 反转义HTML(文本): // 公开
    // 将HTML实体还原为字符
    设 结果 = 文本
    结果 = 替换(结果, "&amp;", "&")
    结果 = 替换(结果, "&lt;", "<")
    结果 = 替换(结果, "&gt;", ">")
    结果 = 替换(结果, "&quot;", "\"")
    结果 = 替换(结果, "&#39;", "'")
    结果 = 替换(结果, "&nbsp;", " ")
    返回 结果

函程 属性字符串(属性表): // 公开
    // 将属性字典转换为HTML属性字符串
    // 属性表为字典，如 {"href": "url", "class": "btn"}
    设 结果 = ""
    遍 键 于 键集合(属性表):
        设 值 = 属性表[键]
        结果 = 结果 + " " + 键 + "=\"" + 转义HTML(转字符串(值)) + "\""
    返回 结果

函程 标签(标签名, 内容="", 属性表={}): // 公开
    // 生成HTML标签
    设 属性 = 属性字符串(属性表)
    返回 "<" + 标签名 + 属性 + ">" + 内容 + "</" + 标签名 + ">"

函程 自闭合标签(标签名, 属性表={}): // 公开
    // 生成自闭合HTML标签，如 <br/>, <hr/>, <img/>
    设 属性 = 属性字符串(属性表)
    返回 "<" + 标签名 + 属性 + " />"

// ===== 常用HTML元素 =====

函程 标题(文本, 级别=1): // 公开
    如果 级别 < 1:
        返回 标签("h1", 转义HTML(文本))
    如果 级别 > 6:
        返回 标签("h6", 转义HTML(文本))
    返回 标签("h" + 转字符串(级别), 转义HTML(文本))

函程 段落(文本, 属性表={}): // 公开
    返回 标签("p", 转义HTML(文本), 属性表)

函程 链接(地址, 文本="", 属性表={}): // 公开
    设 完整属性 = {"href": 地址}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    设 显示文本 = 文本
    如果 显示文本 == "":
        显示文本 = 地址
    返回 标签("a", 转义HTML(显示文本), 完整属性)

函程 图片(源, 替换文本="", 属性表={}): // 公开
    设 完整属性 = {"src": 源, "alt": 替换文本}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    返回 自闭合标签("img", 完整属性)

函程 粗体(文本, 属性表={}): // 公开
    返回 标签("strong", 转义HTML(文本), 属性表)

函程 斜体(文本, 属性表={}): // 公开
    返回 标签("em", 转义HTML(文本), 属性表)

函程 删除线(文本, 属性表={}): // 公开
    返回 标签("del", 转义HTML(文本), 属性表)

函程 下划线(文本, 属性表={}): // 公开
    返回 标签("u", 转义HTML(文本), 属性表)

函程 代码(文本, 属性表={}): // 公开
    返回 标签("code", 转义HTML(文本), 属性表)

函程 预格式(文本, 属性表={}): // 公开
    返回 标签("pre", 转义HTML(文本), 属性表)

函程 换行(): // 公开
    返回 "<br />"

函程 水平线(): // 公开
    返回 "<hr />"

函程 分割(文本, 属性表={}): // 公开
    返回 标签("div", 文本, 属性表)

函程 行内(文本, 属性表={}): // 公开
    返回 标签("span", 转义HTML(文本), 属性表)

// ===== 列表 =====

函程 列表(项目列表, 类型="无序", 属性表={}): // 公开
    设 内容 = ""
    遍 项 于 项目列表:
        内容 = 内容 + 标签("li", 转义HTML(项))
    如果 类型 == "有序":
        返回 标签("ol", 内容, 属性表)
    否则:
        返回 标签("ul", 内容, 属性表)

函程 无序列表(项目列表, 属性表={}): // 公开
    设 内容 = ""
    遍 项 于 项目列表:
        内容 = 内容 + 标签("li", 转义HTML(项))
    返回 标签("ul", 内容, 属性表)

函程 有序列表(项目列表, 属性表={}): // 公开
    设 内容 = ""
    遍 项 于 项目列表:
        内容 = 内容 + 标签("li", 转义HTML(项))
    返回 标签("ol", 内容, 属性表)

函程 定义列表(定义列表数据, 属性表={}): // 公开
    设 内容 = ""
    遍 项 于 定义列表数据:
        内容 = 内容 + 标签("dt", 转义HTML(项[0]))
        内容 = 内容 + 标签("dd", 转义HTML(项[1]))
    返回 标签("dl", 内容, 属性表)

// ===== 表格 =====

函程 表格(行数据, 表头行=[], 属性表={}): // 公开
    设 内容 = ""
    如果 长度(表头行) > 0:
        设 头内容 = ""
        遍 单元 于 表头行:
            头内容 = 头内容 + 标签("th", 转义HTML(单元))
        内容 = 内容 + 标签("thead", 标签("tr", 头内容))
    设 体内容 = ""
    遍 行 于 行数据:
        设 行内容 = ""
        遍 单元 于 行:
            行内容 = 行内容 + 标签("td", 转义HTML(单元))
        体内容 = 体内容 + 标签("tr", 行内容)
    如果 长度(体内容) > 0:
        内容 = 内容 + 标签("tbody", 体内容)
    返回 标签("table", 内容, 属性表)

// ===== 表单 =====

函程 表单(内容, 动作="", 方法="post", 属性表={}): // 公开
    设 完整属性 = {"action": 动作, "method": 方法}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    返回 标签("form", 内容, 完整属性)

函程 输入框(类型="text", 名称="", 值="", 属性表={}): // 公开
    设 完整属性 = {"type": 类型, "name": 名称, "value": 值}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    返回 自闭合标签("input", 完整属性)

函程 文本域(名称="", 内容="", 属性表={}): // 公开
    设 完整属性 = {"name": 名称}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    返回 标签("textarea", 转义HTML(内容), 完整属性)

函程 选择框(名称, 选项列表, 默认值="", 属性表={}): // 公开
    设 完整属性 = {"name": 名称}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    设 内容 = ""
    遍 项 于 选项列表:
        设 显示 = 项[0]
        设 值 = 项[1]
        如果 值 == 默认值:
            内容 = 内容 + 标签("option", 转义HTML(显示), {"value": 值, "selected": "selected"})
        否则:
            内容 = 内容 + 标签("option", 转义HTML(显示), {"value": 值})
    返回 标签("select", 内容, 完整属性)

函程 按钮(文本, 类型="submit", 属性表={}): // 公开
    设 完整属性 = {"type": 类型}
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    返回 标签("button", 转义HTML(文本), 完整属性)

函程 标签标签(文本, 关联="", 属性表={}): // 公开
    设 完整属性 = {}
    如果 关联 != "":
        完整属性["for"] = 关联
    遍 键 于 键集合(属性表):
        完整属性[键] = 属性表[键]
    返回 标签("label", 转义HTML(文本), 完整属性)

// ===== 页面结构 =====

函程 样式标签(样式代码): // 公开
    返回 标签("style", 样式代码)

函程 脚本标签(代码, 来源=""): // 公开
    如果 来源 != "":
        返回 标签("script", "", {"src": 来源})
    返回 标签("script", 代码)

函程 页面框架(标题, 正文, 样式="", 脚本="", 语言="zh"): // 公开
    设 头内容 = 标签("title", 转义HTML(标题))
    设 字符集 = 自闭合标签("meta", {"charset": "utf-8"})
    设 视口 = 自闭合标签("meta", {"name": "viewport", "content": "width=device-width, initial-scale=1"})
    如果 样式 != "":
        头内容 = 头内容 + 样式标签(样式)
    设 头 = 标签("head", 字符集 + 视口 + 头内容)
    设 体内容 = 正文
    如果 脚本 != "":
        体内容 = 体内容 + 脚本标签(脚本)
    设 体 = 标签("body", 体内容)
    返回 标签("html", 头 + 体, {"lang": 语言})

函程 导入样式(地址): // 公开
    返回 自闭合标签("link", {"rel": "stylesheet", "href": 地址})
