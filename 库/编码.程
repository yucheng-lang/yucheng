// ===== 语程标准库：编码 =====
// 提供编码解码工具函数
//
// 公开接口：数字转十六进制、十六进制字符转数字、
//           转义显示、反转义显示、
//           格式化字节、格式化工程值、
//           是数字字符、是字母、是中文字符、是空白、
//           提取数字、提取字母、提取中文

// ===== 十六进制编码 =====

函程 数字转十六进制(n): // 公开
    如果 n < 0:
        返回 "-" + 数字转十六进制(-n)
    如果 n < 10:
        返回 转字符串(n)
    如果 n < 16:
        如果 n == 10:
            返回 "A"
        如果 n == 11:
            返回 "B"
        如果 n == 12:
            返回 "C"
        如果 n == 13:
            返回 "D"
        如果 n == 14:
            返回 "E"
        返回 "F"
    返回 数字转十六进制(n / 16) + 数字转十六进制(n - (n / 16) * 16)

函程 十六进制字符转数字(字符): // 公开
    如果 字符 == "0":
        返回 0
    如果 字符 == "1":
        返回 1
    如果 字符 == "2":
        返回 2
    如果 字符 == "3":
        返回 3
    如果 字符 == "4":
        返回 4
    如果 字符 == "5":
        返回 5
    如果 字符 == "6":
        返回 6
    如果 字符 == "7":
        返回 7
    如果 字符 == "8":
        返回 8
    如果 字符 == "9":
        返回 9
    如果 字符 == "A" 或 字符 == "a":
        返回 10
    如果 字符 == "B" 或 字符 == "b":
        返回 11
    如果 字符 == "C" 或 字符 == "c":
        返回 12
    如果 字符 == "D" 或 字符 == "d":
        返回 13
    如果 字符 == "E" 或 字符 == "e":
        返回 14
    如果 字符 == "F" 或 字符 == "f":
        返回 15
    返回 -1

// ===== 转义处理 =====

函程 转义显示(文本): // 公开
    设 结果 = ""
    遍 字 于 文本:
        如果 字 == "\n":
            结果 = 结果 + "\\n"
        否则如果 字 == "\t":
            结果 = 结果 + "\\t"
        否则如果 字 == "\r":
            结果 = 结果 + "\\r"
        否则:
            结果 = 结果 + 字
    返回 结果

函程 反转义显示(文本): // 公开
    设 结果 = ""
    设 i = 0
    循环 i < 字符串长度(文本):
        如果 子串(文本, i, i + 1) == "\\":
            如果 i + 1 < 字符串长度(文本):
                设 下 = 子串(文本, i + 1, i + 2)
                如果 下 == "n":
                    结果 = 结果 + "\n"
                    i = i + 2
                否则如果 下 == "t":
                    结果 = 结果 + "\t"
                    i = i + 2
                否则如果 下 == "r":
                    结果 = 结果 + "\r"
                    i = i + 2
                否则如果 下 == "\\":
                    结果 = 结果 + "\\"
                    i = i + 2
                否则:
                    结果 = 结果 + "\\"
                    i = i + 1
            否则:
                结果 = 结果 + "\\"
                i = i + 1
        否则:
            结果 = 结果 + 子串(文本, i, i + 1)
            i = i + 1
    返回 结果

// ===== 格式化工具 =====

函程 格式化字节(字节数): // 公开
    如果 字节数 < 1024:
        返回 转字符串(字节数) + " B"
    设 千字节 = 字节数 / 1024
    如果 千字节 < 1024:
        返回 转字符串(四舍五入(千字节 * 100) / 100) + " KB"
    设 兆字节 = 千字节 / 1024
    如果 兆字节 < 1024:
        返回 转字符串(四舍五入(兆字节 * 100) / 100) + " MB"
    设 吉字节 = 兆字节 / 1024
    返回 转字符串(四舍五入(吉字节 * 100) / 100) + " GB"

函程 格式化工程值(数值): // 公开
    如果 数值 == 0:
        返回 "0"
    设 绝对 = 绝对值(数值)
    设 符号 = ""
    如果 数值 < 0:
        符号 = "-"
    如果 绝对 >= 1e9:
        返回 符号 + 转字符串(四舍五入(绝对 / 1e9 * 100) / 100) + "G"
    如果 绝对 >= 1e6:
        返回 符号 + 转字符串(四舍五入(绝对 / 1e6 * 100) / 100) + "M"
    如果 绝对 >= 1e3:
        返回 符号 + 转字符串(四舍五入(绝对 / 1e3 * 100) / 100) + "K"
    如果 绝对 < 1e-3:
        返回 符号 + 转字符串(四舍五入(绝对 * 1e6 * 100) / 100) + "u"
    如果 绝对 < 1:
        返回 符号 + 转字符串(四舍五入(绝对 * 1e3 * 100) / 100) + "m"
    返回 符号 + 转字符串(四舍五入(绝对 * 100) / 100)

// ===== 字符分类 =====

函程 是数字字符(字符): // 公开
    返回 字符 >= "0" 且 字符 <= "9"

函程 是字母(字符): // 公开
    返回 (字符 >= "A" 且 字符 <= "Z") 或 (字符 >= "a" 且 字符 <= "z")

函程 是中文字符(字符): // 公开
    返回 字符 >= "\u4e00" 且 字符 <= "\u9fff"

函程 是空白(字符): // 公开
    返回 字符 == " " 或 字符 == "\t" 或 字符 == "\n" 或 字符 == "\r"

// ===== 字符串分析 =====

函程 提取数字(文本): // 公开
    设 结果 = ""
    遍 字 于 文本:
        如果 是数字字符(字):
            结果 = 结果 + 字
    返回 结果

函程 提取字母(文本): // 公开
    设 结果 = ""
    遍 字 于 文本:
        如果 是字母(字):
            结果 = 结果 + 字
    返回 结果

函程 提取中文(文本): // 公开
    设 结果 = ""
    遍 字 于 文本:
        如果 是中文字符(字):
            结果 = 结果 + 字
    返回 结果
