// ===== 语程标准库：应用目录 =====
// 提供跨平台获取应用程序特殊目录路径
// 遵循 XDG 规范（Linux/BSD）、Windows API、macOS 标准路径
//
// 公开接口：用户主目录、数据目录、配置目录、缓存目录、
//           临时目录、桌面目录、文档目录、下载目录、
//           音乐目录、图片目录、视频目录、
//           应用数据目录、应用配置目录、应用缓存目录、
//           是Windows、是macOS、是Linux

导入 "路径"

// === 基础目录 ===

函程 用户主目录(): // 公开
    // 获取用户主目录（~）
    设 值 = 环境变量("HOME")
    如果 值.长度() > 0:
        返回 值
    值 = 环境变量("USERPROFILE")
    如果 值.长度() > 0:
        返回 值
    值 = 环境变量("HOMEDRIVE") + 环境变量("HOMEPATH")
    如果 值.长度() > 0:
        返回 值
    返回 "."

函程 数据目录(): // 公开
    // 获取应用数据目录
    // Windows: %APPDATA%  Linux: ~/.local/share  macOS: ~/Library/Application Support
    如果 是Windows():
        设 值 = 环境变量("APPDATA")
        如果 值.长度() > 0:
            返回 值
        返回 合并路径(用户主目录(), "AppData/Roaming")
    否则如果 是macOS():
        返回 合并路径(用户主目录(), "Library/Application Support")
    否则:
        设 值 = 环境变量("XDG_DATA_HOME")
        如果 值.长度() > 0:
            返回 值
        返回 合并路径(用户主目录(), ".local/share")

函程 配置目录(): // 公开
    // 获取配置目录
    // Windows: %APPDATA%  Linux: ~/.config  macOS: ~/Library/Preferences
    如果 是Windows():
        设 值 = 环境变量("APPDATA")
        如果 值.长度() > 0:
            返回 值
        返回 合并路径(用户主目录(), "AppData/Roaming")
    否则如果 是macOS():
        返回 合并路径(用户主目录(), "Library/Preferences")
    否则:
        设 值 = 环境变量("XDG_CONFIG_HOME")
        如果 值.长度() > 0:
            返回 值
        返回 合并路径(用户主目录(), ".config")

函程 缓存目录(): // 公开
    // 获取缓存目录
    // Windows: %LOCALAPPDATA%  Linux: ~/.cache  macOS: ~/Library/Caches
    如果 是Windows():
        设 值 = 环境变量("LOCALAPPDATA")
        如果 值.长度() > 0:
            返回 值
        返回 合并路径(用户主目录(), "AppData/Local")
    否则如果 是macOS():
        返回 合并路径(用户主目录(), "Library/Caches")
    否则:
        设 值 = 环境变量("XDG_CACHE_HOME")
        如果 值.长度() > 0:
            返回 值
        返回 合并路径(用户主目录(), ".cache")

函程 临时目录(): // 公开
    // 获取临时文件目录
    // Windows: %TEMP% 或 %TMP%  Unix: /tmp
    设 值 = 环境变量("TEMP")
    如果 值.长度() > 0:
        返回 值
    值 = 环境变量("TMP")
    如果 值.长度() > 0:
        返回 值
    值 = 环境变量("TMPDIR")
    如果 值.长度() > 0:
        返回 值
    返回 "/tmp"

