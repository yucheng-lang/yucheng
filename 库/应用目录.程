        返回 合并路径(缓存目录(), 应用名)

// === 平台检测 ===

函程 是Windows(): // 公开
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")

函程 是macOS(): // 公开
    设 系统 = 环境变量("OSTYPE")
    如果 包含(转小写(系统), "darwin"):
        返回 真
    // macOS 通常没有 OSTYPE，通过其他方式检测
    设 主目录 = 环境变量("HOME")
    返回 主目录.长度() > 0 且 不是Windows() 且 文件存在("/Users")

函程 是Linux(): // 公开
    返回 不是Windows() 且 不是macOS()

函程 不是Windows(): // 内部
    设 是Win = 是Windows()
    返回 不是 是Win
