// === 内部实现 ===

函程 检测引擎(): // 内部
    // 检测可用的HTTP服务器引擎
    设 Python结果 = 执行命令("python --version 2>&1 || python3 --version 2>&1")
    设 Py可用 = 不是 包含(Python结果, "not found")
    设 Py正常 = 不是 包含(Python结果, "不是")
    如果 Py可用 且 Py正常 且 Python结果.长度() > 0:
        返回 "python"
    设 Node结果 = 执行命令("node --version 2>&1")
    设 Nd可用 = 不是 包含(Node结果, "not found")
    设 Nd正常 = 不是 包含(Node结果, "不是")
    如果 Nd可用 且 Nd正常 且 Node结果.长度() > 0:
        返回 "node"
    返回 "simple"

函程 启动Python服务器(服务器): // 内部
    设 命令 = "python -m http.server " + 转文本(服务器.端口) + " --bind " + 服务器.主机
    如果 服务器.静态目录.长度() > 0:
        命令 = 命令 + " --directory \"" + 服务器.静态目录 + "\""
    服务器.运行中 = 真
    输出("HTTP服务器启动: http://" + 服务器.主机 + ":" + 转文本(服务器.端口))
    执行命令(命令)

函程 启动Node服务器(服务器): // 内部
    // 生成简单的 Node.js HTTP 服务器脚本
    设 脚本 = "const http = require('http'); const server = http.createServer((req, res) => { res.writeHead(200, {'Content-Type':'text/html;charset=utf-8'}); res.end('语程HTTP服务器运行中'); }); server.listen(" + 转文本(服务器.端口) + ", '" + 服务器.主机 + "');"
    设 脚本路径 = 临时目录() + "/yucheng_http_server.js"
    写入文件(脚本路径, 脚本)
    服务器.运行中 = 真
    输出("HTTP服务器启动: http://" + 服务器.主机 + ":" + 转文本(服务器.端口))
    执行命令("node \"" + 脚本路径 + "\"")

函程 启动内置服务器(服务器): // 内部
    // 使用 Python 一行命令或 npx serve
    设 命令 = "python3 -m http.server " + 转文本(服务器.端口) + " 2>/dev/null || npx serve -l " + 转文本(服务器.端口) + " 2>/dev/null || echo '无可用HTTP服务器引擎'"
    服务器.运行中 = 真
    输出("HTTP服务器启动: http://" + 服务器.主机 + ":" + 转文本(服务器.端口))
    执行命令(命令)

函程 错误页面(状态码, 描述): // 内部
    返回 "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>错误 " + 转文本(状态码) + "</title><style>body{font-family:sans-serif;text-align:center;padding:50px}h1{font-size:48px;color:#e74c3c}p{color:#666}</style></head><body><h1>" + 转文本(状态码) + "</h1><p>" + 转文本(描述) + "</p></body></html>"

函程 连接(列表, 分隔符): // 内部
    如果 列表.长度() == 0:
        返回 ""
    设 结果 = 转文本(列表[0])
    设 i = 1
    循环 i < 列表.长度():
        结果 = 结果 + 分隔符 + 转文本(列表[i])
        i = i + 1
    返回 结果

函程 是Windows平台(): // 内部
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")
