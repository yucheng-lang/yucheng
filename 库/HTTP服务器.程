// ===== 语程标准库：HTTP服务器 =====
// 提供HTTP服务器功能，支持路由、中间件、静态文件
// 跨平台支持：使用系统命令启动Python/Node.js内置HTTP服务器
//
// 公开接口：创建服务器、监听、路由、中间件、
//           静态文件服务、JSON响应、HTML响应、
//           获取请求、发送响应、URL参数、
//           HTTP方法、HTTP状态码

导入 "JSON工具"

// === HTTP方法常量 ===

函程 HTTP方法(): // 公开
    返回 {GET: "GET", POST: "POST", PUT: "PUT", DELETE: "DELETE", PATCH: "PATCH", HEAD: "HEAD", OPTIONS: "OPTIONS"}

// === HTTP状态码 ===

函程 HTTP状态码(): // 公开
    返回 {
        // 成功
        OK: 200,
        已创建: 201,
        已接受: 202,
        无内容: 204,
        // 重定向
        永久移动: 301,
        临时移动: 302,
        未修改: 304,
        // 客户端错误
        错误请求: 400,
        未授权: 401,
        禁止访问: 403,
        未找到: 404,
        方法不允许: 405,
        请求超时: 408,
        冲突: 409,
        请求实体过大: 413,
        请求URI过长: 414,
        不支持的媒体类型: 415,
        请求过于频繁: 429,
        // 服务器错误
        内部错误: 500,
        未实现: 501,
        网关错误: 502,
        服务不可用: 503,
        网关超时: 504
    }

// === 服务器创建 ===

函程 创建服务器(主机="0.0.0.0", 端口=8080): // 公开
    // 创建一个HTTP服务器配置
    返回 {
        主机: 主机,
        端口: 端口,
        路由表: [],
        中间件列表: [],
        静态目录: "",
        服务器类型: "auto",
        运行中: 假
    }

函程 添加路由(服务器, 方法, 路径, 处理器): // 公开
    // 添加路由规则
    // 方法: "GET", "POST" 等
    // 路径: "/api/hello" 等
    // 处理器: 处理请求的函数
    设 路由 = {方法: 方法, 路径: 路径, 处理器: 处理器}
    服务器.路由表.添加(路由)
    返回 服务器

函程 添加中间件(服务器, 中间件函数): // 公开
    // 添加中间件
    服务器.中间件列表.添加(中间件函数)
    返回 服务器

函程 设置静态目录(服务器, 目录路径): // 公开
    // 设置静态文件服务目录
    服务器.静态目录 = 目录路径
    返回 服务器

// === 启动服务器 ===

函程 启动服务器(服务器): // 公开
    // 启动HTTP服务器
    // 自动检测可用的HTTP服务器引擎
    设 引擎 = 检测引擎()
    如果 引擎 == "python":
        启动Python服务器(服务器)
    否则如果 引擎 == "node":
        启动Node服务器(服务器)
    否则:
        启动内置服务器(服务器)

函程 停止服务器(服务器): // 公开
    // 停止HTTP服务器
    服务器.运行中 = 假
    如果 是Windows平台():
        执行命令("taskkill /F /IM python.exe /FI \"WINDOWTITLE eq yucheng_http_server\" 2>nul")
        执行命令("taskkill /F /IM node.exe /FI \"WINDOWTITLE eq yucheng_http_server\" 2>nul")
    否则:
        执行命令("pkill -f yucheng_http_server 2>/dev/null")

// === 响应构建 ===

函程 文本响应(内容, 状态码=200): // 公开
    返回 {状态码: 状态码, 头部: {"Content-Type": "text/plain; charset=utf-8"}, 主体: 内容}

函程 HTML响应(内容, 状态码=200): // 公开
    返回 {状态码: 状态码, 头部: {"Content-Type": "text/html; charset=utf-8"}, 主体: 内容}

函程 JSON响应(内容, 状态码=200): // 公开
    返回 {状态码: 状态码, 头部: {"Content-Type": "application/json; charset=utf-8"}, 主体: 生成JSON(内容)}

函程 重定向(地址, 状态码=302): // 公开
    返回 {状态码: 状态码, 头部: {"Location": 地址}, 主体: ""}

函程 文件响应(文件路径, 内容类型="application/octet-stream"): // 公开
    设 内容 = 读取文件(文件路径)
    返回 {状态码: 200, 头部: {"Content-Type": 内容类型}, 主体: 内容}

函程 错误响应(状态码, 消息=""): // 公开
    设 码表 = HTTP状态码()
    设 描述 = 消息.长度() > 0 ? 消息 : 转文本(状态码)
    返回 {状态码: 状态码, 头部: {"Content-Type": "text/html; charset=utf-8"}, 主体: 错误页面(状态码, 描述)}

// === URL参数解析 ===

函程 解析URL参数(查询字符串): // 公开
    // 解析URL查询参数 ?key=value&key2=value2
    设 结果 = {}
    如果 查询字符串.长度() == 0:
        返回 结果
    // 去除开头的 ?
    如果 子串(查询字符串, 0, 1) == "?":
        查询字符串 = 子串(查询字符串, 1, 查询字符串.长度() - 1)
    设 对列表 = 查询字符串.分割("&")
    循环 对 于 对列表:
        设 部分 = 对.分割("=")
        如果 部分.长度() >= 2:
            结果 = 结果.设置(部分[0], URL解码(部分[1]))
        否则如果 部分.长度() == 1 且 部分[0].长度() > 0:
            结果 = 结果.设置(部分[0], "")
    返回 结果

函程 构建URL参数(参数字典): // 公开
    // 从字典构建URL查询参数字符串
    设 对列表 = []
    循环 键, 值 于 参数字典:
        对列表.添加(URL编码(键) + "=" + URL编码(转文本(值)))
    设 结果 = 连接(对列表, "&")
    如果 结果.长度() > 0:
        返回 "?" + 结果
    返回 ""

