// 压缩集合 - 稀疏位集合（Sparse Bit Set）实现
// 高效存储整数集合，适合大范围稀疏整数
//
// 公开接口：创建压缩集合、集合包含、集合添加、集合移除、
//           集合大小、集合清空、集合并集/交集/差集/对称差集、
//           集合相等、子集判断、集合转列表、列表转压缩集合

// === 常量 ===

函程 桶位数(): // 内部
    // 每个桶存储的位数（512位）
    返回 512

函程 整数位数(): // 内部
    // 每个整数存储的位数（64位）
    返回 64

函程 每桶整数数(): // 内部
    // 每个桶中的整数个数
    返回 桶位数() / 整数位数()

// === 创建 ===

函程 创建压缩集合(): // 公开
    // 创建空的压缩集合
    返回 {
        元素列表: [],     // 小规模时直接存储元素
        桶: {},           // 大规模时用字典存储桶
        计数: 0           // 元素数量
    }

// === 内部：获取桶键和桶内偏移 ===

函程 桶键(值): // 内部
    返回 值 / 桶位数()

函程 桶内偏移(值): // 内部
    返回 值 % 桶位数()

// === 内部：位操作 ===

函程 置位(整数列表, 位偏移): // 内部
    // 在整数列表中设置指定位
    设 字索引 = 位偏移 / 整数位数()
    设 位索引 = 位偏移 % 整数位数()
    // 确保列表足够长
    循环 当 整数列表.长度() <= 字索引:
        整数列表.添加(0)
    整数列表[字索引] = 位或(整数列表[字索引], 位左移(1, 位索引))

函程 清位(整数列表, 位偏移): // 内部
    // 在整数列表中清除指定位
    设 字索引 = 位偏移 / 整数位数()
    设 位索引 = 位偏移 % 整数位数()
    如果 字索引 < 整数列表.长度():
        整数列表[字索引] = 位与(整数列表[字索引], 位取反(位左移(1, 位索引)))

函程 测试位(整数列表, 位偏移): // 内部
    // 测试整数列表中指定位是否设置
    设 字索引 = 位偏移 / 整数位数()
    设 位索引 = 位偏移 % 整数位数()
    如果 字索引 >= 整数列表.长度():
        返回 假
    返回 位与(整数列表[字索引], 位左移(1, 位索引)) != 0

// === 内部：从元素列表迁移到桶模式 ===

函程 迁移到桶模式(集合): // 内部
    // 当元素超过34个时，从简单列表模式迁移到桶模式
    设 旧元素 = 集合.元素列表
    集合.桶 = {}
    集合.元素列表 = []
    遍 值 于 旧元素:
        集合添加(集合, 值)

// === 基本操作 ===

函程 集合包含(集合, 值): // 公开
    // 检查值是否在集合中
    如果 集合.计数 <= 34:
        遍 项 于 集合.元素列表:
            如果 项 == 值:
                返回 真
        返回 假
    设 键 = 桶键(值)
    如果 非 集合.桶.包含(键):
        返回 假
    返回 测试位(集合.桶[键], 桶内偏移(值))

函程 集合添加(集合, 值): // 公开
    // 向集合中添加值（如果已存在则无操作）
    如果 集合包含(集合, 值):
        返回 集合
    如果 集合.计数 < 34:
        集合.元素列表.添加(值)
        集合.计数 = 集合.计数 + 1
        返回 集合
    // 需要桶模式
    如果 集合.计数 == 34 且 集合.桶.长度() == 0:
        迁移到桶模式(集合)
    设 键 = 桶键(值)
    如果 非 集合.桶.包含(键):
        集合.桶[键] = []
    置位(集合.桶[键], 桶内偏移(值))
    集合.计数 = 集合.计数 + 1
    返回 集合

函程 集合移除(集合, 值): // 公开
    // 从集合中移除值
    如果 集合.计数 <= 34:
        设 i = 0
        循环 当 i < 集合.元素列表.长度():
            如果 集合.元素列表[i] == 值:
                集合.元素列表[i] = 集合.元素列表[集合.元素列表.长度() - 1]
                集合.元素列表 = 集合.元素列表.子串(0, 集合.元素列表.长度() - 1)
                集合.计数 = 集合.计数 - 1
                返回 集合
            i = i + 1
        返回 集合
    设 键 = 桶键(值)
    如果 集合.桶.包含(键):
        清位(集合.桶[键], 桶内偏移(值))
        集合.计数 = 集合.计数 - 1
    返回 集合

函程 集合大小(集合): // 公开
    // 返回集合中元素的数量
    返回 集合.计数

函程 集合为空(集合): // 公开
    // 检查集合是否为空
    返回 集合.计数 == 0

函程 集合清空(集合): // 公开
    // 清空集合
    集合.元素列表 = []
    集合.桶 = {}
    集合.计数 = 0
    返回 集合

// === 包含或添加 ===

函程 包含或添加(集合, 值): // 公开
    // 如果值已存在返回真，否则添加并返回假
    如果 集合包含(集合, 值):
        返回 真
    集合添加(集合, 值)
    返回 假

函程 缺失或移除(集合, 值): // 公开
    // 如果值不存在返回真，否则移除并返回假
    如果 非 集合包含(集合, 值):
        返回 真
    集合移除(集合, 值)
    返回 假

// === 集合遍历 ===

函程 集合转列表(集合): // 公开
    // 将集合中的所有元素转为列表
    如果 集合.计数 <= 34:
        返回 集合.元素列表
    设 结果 = []
    遍 键, 整数列表 于 集合.桶:
        设 基值 = 键 * 桶位数()
        遍 整数值 于 整数列表:
            设 位偏移 = 0
            设 剩余 = 整数值
            循环 当 剩余 != 0:
                如果 位与(剩余, 1) != 0:
                    结果.添加(基值 + 位偏移)
                剩余 = 位右移(剩余, 1)
                位偏移 = 位偏移 + 1
    返回 结果

// === 集合运算 ===

函程 集合并集(集合1, 集合2): // 公开
    // 返回两个集合的并集
    设 结果 = 创建压缩集合()
    遍 值 于 集合转列表(集合1):
        集合添加(结果, 值)
    遍 值 于 集合转列表(集合2):
        集合添加(结果, 值)
    返回 结果

函程 集合交集(集合1, 集合2): // 公开
    // 返回两个集合的交集
    设 结果 = 创建压缩集合()
    遍 值 于 集合转列表(集合1):
        如果 集合包含(集合2, 值):
            集合添加(结果, 值)
    返回 结果

函程 集合差集(集合1, 集合2): // 公开
    // 返回集合1中不在集合2中的元素
    设 结果 = 创建压缩集合()
    遍 值 于 集合转列表(集合1):
        如果 非 集合包含(集合2, 值):
            集合添加(结果, 值)
    返回 结果

函程 集合对称差集(集合1, 集合2): // 公开
    // 返回只在其中一个集合中出现的元素
    设 结果 = 创建压缩集合()
    遍 值 于 集合转列表(集合1):
        如果 非 集合包含(集合2, 值):
            集合添加(结果, 值)
    遍 值 于 集合转列表(集合2):
        如果 非 集合包含(集合1, 值):
            集合添加(结果, 值)
    返回 结果

函程 集合不相交(集合1, 集合2): // 公开
    // 检查两个集合是否没有公共元素
    遍 值 于 集合转列表(集合1):
        如果 集合包含(集合2, 值):
            返回 假
    返回 真

// === 子集判断 ===

函程 是子集(集合1, 集合2): // 公开
    // 集合1是否是集合2的子集
    遍 值 于 集合转列表(集合1):
        如果 非 集合包含(集合2, 值):
            返回 假
    返回 真

函程 是真子集(集合1, 集合2): // 公开
    // 集合1是否是集合2的真子集
    返回 是子集(集合1, 集合2) 且 非 是子集(集合2, 集合1)

函程 集合相等(集合1, 集合2): // 公开
    // 两个集合是否相等
    返回 是子集(集合1, 集合2) 且 是子集(集合2, 集合1)

// === 转换工具 ===

函程 列表转压缩集合(列表): // 公开
    // 从列表创建压缩集合（自动去重）
    设 结果 = 创建压缩集合()
    遍 值 于 列表:
        集合添加(结果, 值)
    返回 结果

函程 集合转字符串(集合): // 公开
    // 将集合转为字符串表示
    设 元素 = 集合转列表(集合)
    设 结果 = "{"
    设 i = 0
    遍 值 于 元素:
        如果 i > 0:
            结果 = 结果 + ", "
        结果 = 结果 + 转文本(值)
        i = i + 1
    返回 结果 + "}"
