// ===== 语程标准库：文件操作 =====
// 提供文件读写和操作工具函数
//
// 公开接口：文件存在、读文件、写文件、追加文件、
//           删除文件、复制文件、移动文件、
//           文件大小、读行、写行、
//           临时文件名

// ===== 文件检查 =====

函程 文件存在检查(路径): // 公开
    // 检查文件是否存在
    返回 文件存在(路径)

// ===== 文件读写 =====

函程 读文件(路径): // 公开
    // 读取整个文件内容为字符串
    返回 读取文件(路径)

函程 写文件(路径, 内容): // 公开
    // 将字符串内容写入文件（覆盖已有内容）
    写入文件(路径, 内容)

函程 追加到文件(路径, 内容): // 公开
    // 将内容追加到文件末尾
    追加文件(路径, 内容)

// ===== 行操作 =====

函程 读行(路径): // 公开
    // 按行读取文件，返回行列表
    设 内容 = 读文件(路径)
    返回 内容.分割("\n")

函程 写行(路径, 行列表): // 公开
    // 将行列表写入文件，每行末尾加换行符
    设 内容 = ""
    设 首行 = 真
    遍 行 于 行列表:
        如果 首行:
            内容 = 行
            首行 = 假
        否则:
            内容 = 内容 + "\n" + 行
    写文件(路径, 内容)

函程 追加行(路径, 行): // 公开
    // 追加一行到文件末尾
    追加到文件(路径, 行 + "\n")

// ===== 文件操作 =====

函程 删除指定文件(路径): // 公开
    // 删除指定文件
    删除文件(路径)

函程 尝试删除(路径): // 公开
    // 尝试删除文件，如果不存在或删除失败返回假
    如果 非 文件存在(路径):
        返回 假
    删除文件(路径)
    返回 真

函程 复制文件(源路径, 目标路径): // 公开
    // 复制文件到目标路径
    设 内容 = 读文件(源路径)
    写文件(目标路径, 内容)

函程 移动文件(源路径, 目标路径): // 公开
    // 移动（重命名）文件
    复制文件(源路径, 目标路径)
    删除文件(源路径)

// ===== 文件信息 =====

函程 获取文件大小(路径): // 公开
    // 返回文件大小（字节数）
    返回 文件大小(路径)

// ===== 临时文件 =====

函程 临时文件名(): // 公开
    // 生成临时文件名
    返回 "temp_" + 转文本(时间戳()) + "_" + 转文本(随机整数(10000, 99999))

函程 创建临时文件(内容=""): // 公开
    // 创建临时文件并返回路径
    设 路径 = 临时文件名()
    写文件(路径, 内容)
    返回 路径
