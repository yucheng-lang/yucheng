// 浮点环境 - 浮点精度与舍入控制

// === 浮点常量 ===

设 浮点基数 = 2
设 单精度尾数位数 = 24
设 单精度精度位数 = 6
设 单精度最小指数 = -125
设 单精度最大指数 = 128
设 单精度最小值 = 1.17549435e-38
设 单精度最大值 = 3.40282347e+38
设 单精度机器精度 = 1.19209290e-07

设 双精度尾数位数 = 53
设 双精度精度位数 = 15
设 双精度最小指数 = -1021
设 双精度最大指数 = 1024
设 双精度最小值 = 2.2250738585072014e-308
设 双精度最大值 = 1.7976931348623157e+308
设 双精度机器精度 = 2.2204460492503131e-16

// === 舍入模式 ===

函程 获取舍入模式(): // 公开
    // 获取当前浮点舍入模式
    返回 当前舍入模式

函程 设置舍入模式(模式): // 公开
    // 设置浮点舍入模式
    // 模式: "最近", "向下", "向上", "向零"
    当前舍入模式 = 模式

设 当前舍入模式 = "最近"

// === 浮点异常 ===

函程 清除异常(): // 公开
    // 清除所有浮点异常标志
    浮点异常标志 = {}

函程 获取异常标志(): // 公开
    // 获取当前浮点异常标志
    返回 浮点异常标志

函程 触发异常(异常类型): // 公开
    // 手动触发浮点异常
    浮点异常标志[异常类型] = 真

函程 测试异常(异常类型): // 公开
    // 测试指定异常是否被设置
    返回 浮点异常标志.获取默认值(异常类型, 假)

设 浮点异常标志 = {}

// === 安全浮点运算 ===

函程 安全除法(甲, 乙): // 公开
    // 安全的除法运算，处理除零情况
    如果 乙 == 0:
        触发异常("除零")
        如果 甲 > 0: 返回 正无穷()
        否则如果 甲 < 0: 返回 负无穷()
        否则: 返回 非数值()
    返回 甲 / 乙

函程 安全开方(值): // 公开
    // 安全的开方运算，处理负数情况
    如果 值 < 0:
        触发异常("无效操作")
        返回 非数值()
    返回 开方(值)

函程 安全对数(值): // 公开
    // 安全的对数运算
    如果 值 <= 0:
        触发异常("无效操作")
        返回 非数值()
    返回 自然对数(值)

// === 浮点分类 ===

函程 是非数值(值): // 公开
    // 检查是否为NaN
    返回 值 != 值

函程 是正无穷(值): // 公开
    // 检查是否为正无穷
    返回 值 == 正无穷()

函程 是负无穷(值): // 公开
    // 检查是否为负无穷
    返回 值 == 负无穷()

函程 是无穷(值): // 公开
    // 检查是否为无穷大
    返回 是正无穷(值) 或 是负无穷(值)

函程 是有限数(值): // 公开
    // 检查是否为有限数（非NaN、非无穷）
    返回 非 是非数值(值) 且 非 是无穷(值)

函程 是正规数(值): // 公开
    // 检查是否为正规浮点数
    返回 是有限数(值) 且 绝对值(值) >= 双精度最小值

函程 是次正规数(值): // 公开
    // 检查是否为次正规浮点数
    返回 是有限数(值) 且 绝对值(值) > 0 且 绝对值(值) < 双精度最小值

函程 是零(值): // 公开
    // 检查是否为零（正零或负零）
    返回 值 == 0

// === 浮点比较 ===

函程 近似相等(甲, 乙, 容差=1e-9): // 公开
    // 检查两个浮点数是否近似相等
    如果 是非数值(甲) 或 是非数值(乙):
        返回 假
    返回 绝对值(甲 - 乙) <= 容差

函程 相对相等(甲, 乙, 相对容差=1e-9): // 公开
    // 检查两个浮点数是否相对近似相等
    如果 是非数值(甲) 或 是非数值(乙):
        返回 假
    如果 甲 == 乙:
        返回 真
    设 差 = 绝对值(甲 - 乙)
    设 较大 = 最大值(绝对值(甲), 绝对值(乙))
    返回 差 <= 较大 * 相对容差

函程 逐位相等(甲, 乙): // 公开
    // 检查两个浮点数是否逐位相等（包括-0和+0的区分）
    返回 甲 == 乙 且 是零(甲) == 是零(乙)

// === 舍入函数 ===

函程 舍入到最近(值): // 公开
    // 向最近的整数舍入
    返回 四舍五入(值)

函程 舍入向下(值): // 公开
    // 向负无穷方向舍入
    返回 向下取整(值)

函程 舍入向上(值): // 公开
    // 向正无穷方向舍入
    返回 向上取整(值)

函程 舍入向零(值): // 公开
    // 向零方向舍入（截断）
    如果 值 >= 0:
        返回 向下取整(值)
    否则:
        返回 向上取整(值)

函程 舍入到小数位(值, 位数): // 公开
    // 舍入到指定小数位数
    设 系数 = 幂10(位数)
    返回 四舍五入(值 * 系数) / 系数

函程 舍入到有效数字(值, 位数): // 公开
    // 舍入到指定有效数字
    如果 值 == 0:
        返回 0
    设 阶 = 向下取整(以10为底的对数(绝对值(值))) + 1
    设 系数 = 幂10(位数 - 阶)
    返回 四舍五入(值 * 系数) / 系数

// === 精度信息 ===

函程 获取机器精度(类型="双精度"): // 公开
    // 获取指定浮点类型的机器精度
    如果 类型 == "单精度":
        返回 单精度机器精度
    否则:
        返回 双精度机器精度

函程 获取最大值(类型="双精度"): // 公开
    // 获取指定浮点类型的最大值
    如果 类型 == "单精度":
        返回 单精度最大值
    否则:
        返回 双精度最大值

函程 获取最小正值(类型="双精度"): // 公开
    // 获取指定浮点类型的最小正值
    如果 类型 == "单精度":
        返回 单精度最小值
    否则:
        返回 双精度最小值

函程 获取精度位数(类型="双精度"): // 公开
    // 获取指定浮点类型的十进制精度位数
    如果 类型 == "单精度":
        返回 单精度精度位数
    否则:
        返回 双精度精度位数

// === 辅助函数 ===

函程 正无穷(): // 公开
    // 返回正无穷大
    返回 1.7976931348623157e+308 * 10

函程 负无穷(): // 公开
    // 返回负无穷大
    返回 -1.7976931348623157e+308 * 10

函程 非数值(): // 公开
    // 返回NaN
    返回 0.0 * 1.7976931348623157e+308

函程 幂10(指数): // 内部
    设 结果 = 1.0
    设 计 = 0
    循环 当 计 < 绝对值(指数):
        结果 = 结果 * 10
        计 = 计 + 1
    如果 指数 < 0:
        返回 1.0 / 结果
    返回 结果

函程 以10为底的对数(值): // 内部
    返回 自然对数(值) / 自然对数(10)
