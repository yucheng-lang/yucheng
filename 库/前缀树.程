// ===== 语程标准库：前缀树 =====
// 提供 CritBit 树（前缀树/Patricia Trie）实现
// 适用于字符串集合和映射的高效前缀查找
//
// 公开接口：创建前缀树、前缀树包含、前缀树插入、前缀树删除、
//           前缀树大小、前缀树前缀搜索、前缀树最长前缀、
//           前缀树键列表、前缀树值列表、前缀树转字典、字典转前缀树

// ===== 前缀树节点 =====
// 内部节点: {类型: "内部", 前缀长度: n, 左: 节点, 右: 节点}
// 叶子节点: {类型: "叶子", 键: 字符串, 值: 任意}

函程 创建前缀树(): // 公开
    返回 {根: 空, 数量: 0}

函程 前缀树包含(树, 键): // 公开
    如果 树.根 == 空:
        返回 假
    设 节点 = _前缀树查找(树.根, 键)
    如果 节点 == 空:
        返回 假
    返回 节点.键 == 键

函程 前缀树取值(树, 键): // 公开
    如果 树.根 == 空:
        返回 空
    设 节点 = _前缀树查找(树.根, 键)
    如果 节点 == 空 或 节点.键 != 键:
        返回 空
    返回 节点.值

函程 前缀树插入(树, 键, 值 = 真): // 公开
    如果 树.根 == 空:
        树.根 = {类型: "叶子", 键: 键, 值: 值}
        树.数量 = 树.数量 + 1
        返回 树
    设 节点 = _前缀树查找(树.根, 键)
    如果 节点 != 空 且 节点.键 == 键:
        节点.值 = 值
        返回 树
    // 插入新叶子
    树.根 = _前缀树插入内部(树.根, 键, 值)
    树.数量 = 树.数量 + 1
    返回 树

函程 前缀树删除(树, 键): // 公开
    如果 树.根 == 空:
        返回 假
    设 找到 = {值: 假}
    树.根 = _前缀树删除内部(树.根, 键, 找到)
    如果 找到.值:
        树.数量 = 树.数量 - 1
        返回 真
    返回 假

函程 前缀树大小(树): // 公开
    返回 树.数量

函程 前缀树是否为空(树): // 公开
    返回 树.数量 == 0

// ===== 前缀搜索 =====

函程 前缀树前缀搜索(树, 前缀): // 公开
    // 返回所有以指定前缀开头的键
    如果 树.根 == 空:
        返回 []
    设 结果 = []
    _前缀树收集前缀(树.根, 前缀, 结果)
    返回 结果

函程 前缀树最长前缀(树, 键): // 公开
    // 找到树中最长的匹配前缀
    如果 树.根 == 空:
        返回 ""
    设 结果 = {键: ""}
    _前缀树最长前缀搜索(树.根, 键, 0, 结果)
    返回 结果.键

函程 前缀树键列表(树): // 公开
    如果 树.根 == 空:
        返回 []
    设 结果 = []
    _前缀树收集键(树.根, 结果)
    返回 结果

函程 前缀树值列表(树): // 公开
    如果 树.根 == 空:
        返回 []
    设 结果 = []
    _前缀树收集值(树.根, 结果)
    返回 结果

函程 前缀树转字典(树): // 公开
    设 结果 = {}
    如果 树.根 == 空:
        返回 结果
    _前缀树收集对(树.根, 结果)
    返回 结果

函程 字典转前缀树(字典): // 公开
    设 树 = 创建前缀树()
    循环 键, 值 于 字典:
        前缀树插入(树, 键, 值)
    返回 树

// ===== 内部实现 =====

函程 _前缀树查找(节点, 键): // 内部
    如果 节点 == 空:
        返回 空
    如果 节点.类型 == "叶子":
        返回 节点
    // 内部节点：检查关键位
    设 位索引 = 节点.前缀长度
    如果 位索引 < 字符串长度(键) * 8:
        设 字节索引 = 位索引 / 8
        设 位偏移 = 7 - (位索引 - 字节索引 * 8)
        如果 字节索引 < 字符串长度(键):
            设 字节值 = 字符编码(子串(键, 字节索引, 字节索引 + 1))[0]
            设 位 = (字节值 / 幂(2, 位偏移)) - ((字节值 / 幂(2, 位偏移)) / 2) * 2
            如果 位 == 0:
                返回 _前缀树查找(节点.左, 键)
            否则:
                返回 _前缀树查找(节点.右, 键)
    // 键比节点短
    返回 _前缀树查找(节点.左, 键)

函程 _获取关键位(字符串, 位索引): // 内部
    设 字节索引 = 位索引 / 8
    设 位偏移 = 7 - (位索引 - 字节索引 * 8)
    如果 字节索引 >= 字符串长度(字符串):
        返回 0
    设 字节值 = 字符编码(子串(字符串, 字节索引, 字节索引 + 1))[0]
    返回 (字节值 / 幂(2, 位偏移)) - ((字节值 / 幂(2, 位偏移)) / 2) * 2

函程 _找差异位(键1, 键2): // 内部
    // 找到两个字符串第一个不同的位
    设 i = 0
    循环 当 真:
        设 甲 = _获取关键位(键1, i)
        设 乙 = _获取关键位(键2, i)
        如果 甲 != 乙:
            返回 i
        i = i + 1

函程 _前缀树插入内部(节点, 键, 值): // 内部
    设 新叶子 = {类型: "叶子", 键: 键, 值: 值}
    如果 节点.类型 == "叶子":
        设 差异 = _找差异位(键, 节点.键)
        设 新位 = _获取关键位(键, 差异)
        如果 新位 == 0:
            返回 {类型: "内部", 前缀长度: 差异, 左: 新叶子, 右: 节点}
        否则:
            返回 {类型: "内部", 前缀长度: 差异, 左: 节点, 右: 新叶子}
    // 内部节点
    设 位索引 = 节点.前缀长度
    设 新位 = _获取关键位(键, 位索引)
    设 差异 = _找差异位(键, _前缀树任意叶子键(节点))
    如果 差异 < 位索引:
        设 插入位 = _获取关键位(键, 差异)
        如果 插入位 == 0:
            返回 {类型: "内部", 前缀长度: 差异, 左: 新叶子, 右: 节点}
        否则:
            返回 {类型: "内部", 前缀长度: 差异, 左: 节点, 右: 新叶子}
    如果 新位 == 0:
        节点.左 = _前缀树插入内部(节点.左, 键, 值)
    否则:
        节点.右 = _前缀树插入内部(节点.右, 键, 值)
    返回 节点

函程 _前缀树任意叶子键(节点): // 内部
    如果 节点.类型 == "叶子":
        返回 节点.键
    如果 节点.左 != 空:
        返回 _前缀树任意叶子键(节点.左)
    返回 _前缀树任意叶子键(节点.右)

函程 _前缀树删除内部(节点, 键, 找到标记): // 内部
    如果 节点 == 空:
        返回 空
    如果 节点.类型 == "叶子":
        如果 节点.键 == 键:
            找到标记.值 = 真
            返回 空
        返回 节点
    // 内部节点
    设 位索引 = 节点.前缀长度
    设 新位 = _获取关键位(键, 位索引)
    如果 新位 == 0:
        节点.左 = _前缀树删除内部(节点.左, 键, 找到标记)
    否则:
        节点.右 = _前缀树删除内部(节点.右, 键, 找到标记)
    // 如果只剩一个子节点，提升它
    如果 节点.左 == 空 且 节点.右 != 空:
        返回 节点.右
    如果 节点.右 == 空 且 节点.左 != 空:
        返回 节点.左
    返回 节点

函程 _前缀树收集前缀(节点, 前缀, 结果): // 内部
    如果 节点 == 空:
        返回
    如果 节点.类型 == "叶子":
        如果 开头是(节点.键, 前缀):
            结果.添加(节点.键)
        返回
    _前缀树收集前缀(节点.左, 前缀, 结果)
    _前缀树收集前缀(节点.右, 前缀, 结果)

函程 _前缀树最长前缀搜索(节点, 键, 深度, 结果): // 内部
    如果 节点 == 空:
        返回
    如果 节点.类型 == "叶子":
        如果 开头是(键, 节点.键):
            结果.键 = 节点.键
        返回
    _前缀树最长前缀搜索(节点.左, 键, 深度 + 1, 结果)
    _前缀树最长前缀搜索(节点.右, 键, 深度 + 1, 结果)

函程 _前缀树收集键(节点, 结果): // 内部
    如果 节点 == 空:
        返回
    如果 节点.类型 == "叶子":
        结果.添加(节点.键)
        返回
    _前缀树收集键(节点.左, 结果)
    _前缀树收集键(节点.右, 结果)

函程 _前缀树收集值(节点, 结果): // 内部
    如果 节点 == 空:
        返回
    如果 节点.类型 == "叶子":
        结果.添加(节点.值)
        返回
    _前缀树收集值(节点.左, 结果)
    _前缀树收集值(节点.右, 结果)

函程 _前缀树收集对(节点, 结果): // 内部
    如果 节点 == 空:
        返回
    如果 节点.类型 == "叶子":
        结果[节点.键] = 节点.值
        返回
    _前缀树收集对(节点.左, 结果)
    _前缀树收集对(节点.右, 结果)
