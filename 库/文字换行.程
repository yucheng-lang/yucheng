// ===== 语程标准库：文字换行 =====
// 提供文字排版与换行工具函数
//
// 公开接口：换行、左对齐、右对齐、两端对齐、
//           缩进、去缩进、段落格式化、
//           截断文本、省略文本

// ===== 基本换行 =====

函程 换行(文本, 最大宽度): // 公开
    返回 换行选项(文本, 最大宽度, 真)

函程 换行选项(文本, 最大宽度, 切长词): // 内部
    如果 字符串长度(文本) <= 最大宽度:
        返回 文本
    设 结果 = ""
    设 当前行 = ""
    设 i = 0
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 == "\n":
            结果 = 结果 + 当前行 + "\n"
            当前行 = ""
            i = i + 1
            继续
        如果 字符串长度(当前行) >= 最大宽度:
            如果 字 == " " 或 字 == "\t":
                结果 = 结果 + 当前行 + "\n"
                当前行 = ""
                i = i + 1
                继续
            // 尝试在最后一个空格处断行
            设 断点 = 字符串长度(当前行) - 1
            设 找到 = 假
            循环 断点 > 0:
                设 断字 = 子串(当前行, 断点, 断点 + 1)
                如果 断字 == " " 或 断字 == "\t":
                    找到 = 真
                    断点 = 断点 + 1
                    跳出
                断点 = 断点 - 1
            如果 找到:
                结果 = 结果 + 子串(当前行, 0, 断点) + "\n"
                当前行 = 子串(当前行, 断点, 字符串长度(当前行))
            否则如果 切长词:
                结果 = 结果 + 当前行 + "\n"
                当前行 = ""
            否则:
                当前行 = 当前行 + 字
                i = i + 1
                继续
        当前行 = 当前行 + 字
        i = i + 1
    如果 字符串长度(当前行) > 0:
        如果 字符串长度(结果) > 0:
            结果 = 结果 + "\n"
        结果 = 结果 + 当前行
    返回 结果

// ===== 对齐 =====

函程 左对齐(文本, 宽度): // 公开
    如果 字符串长度(文本) >= 宽度:
        返回 文本
    返回 文本 + 重复(" ", 宽度 - 字符串长度(文本))

函程 右对齐(文本, 宽度): // 公开
    如果 字符串长度(文本) >= 宽度:
        返回 文本
    返回 重复(" ", 宽度 - 字符串长度(文本)) + 文本

函程 两端对齐(文本, 宽度): // 公开
    如果 字符串长度(文本) >= 宽度:
        返回 文本
    设 空格数 = 宽度 - 字符串长度(文本)
    设 词列表 = 分割(文本, " ")
    如果 数组长度(词列表) <= 1:
        返回 左对齐(文本, 宽度)
    设 间隔数 = 数组长度(词列表) - 1
    设 基础空格 = 空格数 / 间隔数
    设 额外空格 = 空格数 - 基础空格 * 间隔数
    设 结果 = 词列表[0]
    设 i = 1
    循环 i < 数组长度(词列表):
        设 空格 = 基础空格
        如果 i <= 额外空格:
            空格 = 空格 + 1
        结果 = 结果 + 重复(" ", 空格 + 1) + 词列表[i]
        i = i + 1
    返回 结果

// ===== 缩进 =====

函程 缩进(文本, 前缀): // 公开
    设 结果 = ""
    设 当前行 = ""
    设 i = 0
    循环 i < 字符串长度(文本):
        设 字 = 子串(文本, i, i + 1)
        如果 字 == "\n":
            结果 = 结果 + 当前行 + "\n" + 前缀
            当前行 = ""
        否则:
            当前行 = 当前行 + 字
        i = i + 1
    返回 前缀 + 结果 + 当前行

函程 去缩进(文本, 缩进宽度): // 公开
    设 结果 = ""
    设 行列表 = 分割行(文本)
    遍 行 于 行列表:
        设 去空 = 行
        设 去 = 0
        循环 去 < 缩进宽度 且 去 < 字符串长度(行):
            设 字 = 子串(行, 去, 去 + 1)
            如果 字 == " " 或 字 == "\t":
                去 = 去 + 1
            否则:
                跳出
        如果 去 > 0:
            去空 = 子串(行, 去, 字符串长度(行))
        如果 字符串长度(结果) > 0:
            结果 = 结果 + "\n"
        结果 = 结果 + 去空
    返回 结果

// ===== 段落格式化 =====

函程 段落格式化(文本, 宽度): // 公开
    设 行列表 = 分割行(文本)
    设 结果 = ""
    遍 行 于 行列表:
        设 换行后 = 换行(行, 宽度)
        如果 字符串长度(结果) > 0:
            结果 = 结果 + "\n"
        结果 = 结果 + 换行后
    返回 结果

// ===== 截断 =====

函程 截断文本(文本, 最大长度): // 公开
    如果 字符串长度(文本) <= 最大长度:
        返回 文本
    返回 子串(文本, 0, 最大长度)

函程 省略文本(文本, 最大长度): // 公开
    如果 字符串长度(文本) <= 最大长度:
        返回 文本
    如果 最大长度 <= 3:
        返回 重复(".", 最大长度)
    返回 子串(文本, 0, 最大长度 - 3) + "..."
