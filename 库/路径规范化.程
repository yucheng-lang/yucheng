// ===== 语程标准库：路径规范化 =====
// 提供路径清理与规范化工具
// 跨平台：统一将反斜杠转为正斜杠处理，支持 Windows 盘符路径和 Unix 路径
//
// 公开接口：规范化路径、清理路径、连接路径、
//           是绝对路径、拆分路径、拆分扩展名、
//           路径父目录、路径文件名、路径基名、
//           相对路径、公共前缀路径

// ===== 路径清理 =====

函程 清理路径(路径): // 公开
    // 清理路径中的冗余分隔符和点号
    设 结果 = 替换(路径, "\\", "/")
    // 去除末尾斜杠（根路径除外）
    循环 当 字符串长度(结果) > 1 且 子串(结果, 字符串长度(结果) - 1, 字符串长度(结果)) == "/":
        结果 = 子串(结果, 0, 字符串长度(结果) - 1)
    // 分割为组件
    设 组件 = 分割(结果, "/")
    设 清理后 = []
    遍 部分 于 组件:
        如果 字符串长度(部分) == 0:
            继续  // 跳过空组件（由连续斜杠产生）
        如果 部分 == ".":
            继续  // 跳过当前目录标记
        清理后.添加(部分)
    // 处理 ..
    设 栈 = []
    遍 部分 于 清理后:
        如果 部分 == "..":
            如果 数组长度(栈) > 0 且 栈[数组长度(栈) - 1] != "..":
                // 弹出栈顶（回退一级）
                栈 = 数组切片(栈, 0, 数组长度(栈) - 1)
            否则:
                栈.添加("..")
        否则:
            栈.添加(部分)
    // 重新组装
    设 重建 = 字符串连接(栈, "/")
    // 如果原路径以 / 开头，恢复
    如果 子串(结果, 0, 1) == "/":
        重建 = "/" + 重建
    如果 字符串长度(重建) == 0:
        重建 = "."
    返回 重建

函程 规范化路径(路径): // 公开
    // 规范化路径（清理 + 处理相对路径引用）
    返回 清理路径(路径)

// ===== 路径拼接 =====

函程 连接路径(基础, 相对): // 公开
    // 安全地连接两个路径
    设 基础清理 = 替换(基础, "\\", "/")
    设 相对清理 = 替换(相对, "\\", "/")
    // 去除基础路径末尾斜杠
    循环 当 字符串长度(基础清理) > 1 且 子串(基础清理, 字符串长度(基础清理) - 1, 字符串长度(基础清理)) == "/":
        基础清理 = 子串(基础清理, 0, 字符串长度(基础清理) - 1)
    // 去除相对路径开头斜杠
    循环 当 字符串长度(相对清理) > 0 且 子串(相对清理, 0, 1) == "/":
        相对清理 = 子串(相对清理, 1, 字符串长度(相对清理))
    返回 基础清理 + "/" + 相对清理

函程 连接多路径(部分列表): // 公开
    // 连接多个路径部分
    设 结果 = 部分列表[0]
    设 i = 1
    循环 当 i < 数组长度(部分列表):
        结果 = 连接路径(结果, 部分列表[i])
        i = i + 1
    返回 结果

// ===== 路径拆分 =====

函程 拆分路径(路径): // 公开
    // 返回 [目录, 文件名]
    设 清理 = 替换(路径, "\\", "/")
    设 位置 = 字符串长度(清理) - 1
    循环 当 位置 >= 0:
        如果 子串(清理, 位置, 位置 + 1) == "/":
            跳出
        位置 = 位置 - 1
    如果 位置 < 0:
        返回 ["", 清理]
    设 目录 = 子串(清理, 0, 位置)
    设 文件名 = 子串(清理, 位置 + 1, 字符串长度(清理))
    如果 字符串长度(目录) == 0:
        目录 = "/"
    返回 [目录, 文件名]

函程 拆分扩展名(路径): // 公开
    // 返回 [主干, 扩展名]
    设 清理 = 替换(路径, "\\", "/")
    设 部分 = 拆分路径(清理)
    设 文件名 = 部分[1]
    设 位置 = 字符串长度(文件名) - 1
    循环 当 位置 >= 0:
        如果 子串(文件名, 位置, 位置 + 1) == ".":
            跳出
        位置 = 位置 - 1
    如果 位置 <= 0:
        返回 [路径, ""]
    设 主干 = 子串(路径, 0, 字符串长度(路径) - (字符串长度(文件名) - 位置))
    设 扩展名 = 子串(文件名, 位置, 字符串长度(文件名))
    返回 [主干, 扩展名]

// ===== 路径组件 =====

函程 路径父目录(路径): // 公开
    设 部分 = 拆分路径(路径)
    返回 部分[0]

函程 路径文件名(路径): // 公开
    设 部分 = 拆分路径(路径)
    返回 部分[1]

函程 路径基名(路径): // 公开
    // 文件名去掉扩展名
    设 部分 = 拆分扩展名(路径)
    返回 部分[0]

函程 路径扩展名(路径): // 公开
    设 部分 = 拆分扩展名(路径)
    返回 部分[1]

// ===== 路径判断 =====

函程 是绝对路径(路径): // 公开
    如果 字符串长度(路径) == 0:
        返回 假
    设 首 = 子串(路径, 0, 1)
    如果 首 == "/":
        返回 真
    // Windows 绝对路径: C:\ 或 C:/
    如果 字符串长度(路径) >= 2:
        设 次 = 子串(路径, 1, 2)
        如果 次 == ":":
            返回 真
    返回 假

函程 是相对路径(路径): // 公开
    返回 非 是绝对路径(路径)

// ===== 路径比较 =====

函程 公共前缀路径(路径1, 路径2): // 公开
    // 找到两个路径的最长公共前缀
    设 清理1 = 替换(路径1, "\\", "/")
    设 清理2 = 替换(路径2, "\\", "/")
    设 部分1 = 分割(清理1, "/")
    设 部分2 = 分割(清理2, "/")
    设 公共 = []
    设 i = 0
    循环 当 i < 数组长度(部分1) 且 i < 数组长度(部分2):
        如果 部分1[i] == 部分2[i]:
            公共.添加(部分1[i])
        否则:
            跳出
        i = i + 1
    如果 数组长度(公共) == 0:
        返回 ""
    返回 字符串连接(公共, "/")

函程 相对路径计算(起始, 目标): // 公开
    // 计算从起始到目标的相对路径
    设 起 = 清理路径(起始)
    设 目 = 清理路径(目标)
    如果 起 == 目:
        返回 "."
    设 起部分 = 分割(起, "/")
    设 目部分 = 分割(目, "/")
    // 找到公共前缀长度
    设 公共长 = 0
    设 i = 0
    循环 当 i < 数组长度(起部分) 且 i < 数组长度(目部分):
        如果 起部分[i] == 目部分[i]:
            公共长 = 公共长 + 1
        否则:
            跳出
        i = i + 1
    // 从起始回到公共前缀
    设 上溯 = 数组长度(起部分) - 公共长
    设 结果部分 = []
    设 j = 0
    循环 当 j < 上溯:
        结果部分.添加("..")
        j = j + 1
    // 从公共前缀进入目标
    设 k = 公共长
    循环 当 k < 数组长度(目部分):
        结果部分.添加(目部分[k])
        k = k + 1
    如果 数组长度(结果部分) == 0:
        返回 "."
    返回 字符串连接(结果部分, "/")

函程 相对路径(起始, 目标): // 公开
    // 计算从起始到目标的相对路径（别名）
    返回 相对路径计算(起始, 目标)

// ===== 路径遍历 =====

函程 路径组件列表(路径): // 公开
    // 将路径拆分为组件列表
    设 清理 = 替换(路径, "\\", "/")
    返回 分割(清理, "/")

函程 路径深度(路径): // 公开
    // 返回路径的深度（组件数）
    设 组件 = 路径组件列表(路径)
    设 深度 = 0
    遍 部分 于 组件:
        如果 字符串长度(部分) > 0 且 部分 != ".":
            如果 部分 == "..":
                深度 = 深度 - 1
            否则:
                深度 = 深度 + 1
    返回 深度
