// ===== 语程标准库：时间扩展 =====
// 提供时间操作扩展函数
//
// 公开接口：完整时间、中文日期、中文时间、中文日期时间、
//           星期名、是工作日、当前季节、
//           毫秒时间戳、格式化耗时、
//           创建计时器、暂停计时器、恢复计时器、计时器耗时、显示计时器、
//           月天数、年内天数、年底剩余、格式化日期、
//           天数差、倒计时

// ===== 时间格式化 =====

函程 完整时间(): // 公开
    返回 当前日期时间()

函程 中文日期(): // 公开
    设 年文本 = 转字符串(年())
    设 月文本 = 转字符串(月())
    设 日文本 = 转字符串(日())
    如果 字符串长度(月文本) == 1:
        月文本 = "0" + 月文本
    如果 字符串长度(日文本) == 1:
        日文本 = "0" + 日文本
    返回 年文本 + "年" + 月文本 + "月" + 日文本 + "日"

函程 中文时间(): // 公开
    设 时文本 = 转字符串(时())
    设 分文本 = 转字符串(分())
    设 秒文本 = 转字符串(秒())
    如果 字符串长度(时文本) == 1:
        时文本 = "0" + 时文本
    如果 字符串长度(分文本) == 1:
        分文本 = "0" + 分文本
    如果 字符串长度(秒文本) == 1:
        秒文本 = "0" + 秒文本
    返回 时文本 + "时" + 分文本 + "分" + 秒文本 + "秒"

函程 中文日期时间(): // 公开
    返回 中文日期() + " " + 中文时间()

// ===== 星期 =====

函程 星期名(): // 公开
    设 日序 = 星期()
    如果 日序 == 0:
        返回 "星期一"
    如果 日序 == 1:
        返回 "星期二"
    如果 日序 == 2:
        返回 "星期三"
    如果 日序 == 3:
        返回 "星期四"
    如果 日序 == 4:
        返回 "星期五"
    如果 日序 == 5:
        返回 "星期六"
    返回 "星期日"

函程 是工作日(): // 公开
    设 日序 = 星期()
    返回 日序 >= 0 且 日序 <= 4

// ===== 季节 =====

函程 当前季节(): // 公开
    设 当前月 = 月()
    如果 当前月 >= 3 且 当前月 <= 5:
        返回 "春季"
    如果 当前月 >= 6 且 当前月 <= 8:
        返回 "夏季"
    如果 当前月 >= 9 且 当前月 <= 11:
        返回 "秋季"
    返回 "冬季"

// ===== 时间戳工具 =====

函程 毫秒时间戳(): // 公开
    返回 时间戳() * 1000

函程 格式化耗时(秒数): // 公开
    如果 秒数 < 60:
        返回 转字符串(四舍五入(秒数 * 100) / 100) + " 秒"
    如果 秒数 < 3600:
        设 分 = 秒数 / 60
        设 秒 = 秒数 - 分 * 60
        返回 转字符串(分) + " 分 " + 转字符串(四舍五入(秒)) + " 秒"
    设 时 = 秒数 / 3600
    设 余 = 秒数 - 时 * 3600
    设 分 = 余 / 60
    设 秒 = 余 - 分 * 60
    返回 转字符串(时) + " 时 " + 转字符串(分) + " 分 " + 转字符串(四舍五入(秒)) + " 秒"

// ===== 计时器 =====

设 计时器列表 = {} // 内部

函程 创建计时器(名称): // 公开
    设 计时器 = {}
    计时器["名称"] = 名称
    计时器["起点"] = 时间戳()
    计时器["累计"] = 0
    计时器["运行"] = 真
    计时器列表[名称] = 计时器
    返回 计时器

函程 暂停计时器(名称): // 公开
    如果 计时器列表.包含(名称):
        设 计时器 = 计时器列表[名称]
        如果 计时器["运行"]:
            设 当前 = 时间戳()
            计时器["累计"] = 计时器["累计"] + (当前 - 计时器["起点"])
            计时器["运行"] = 假
            计时器列表[名称] = 计时器

函程 恢复计时器(名称): // 公开
    如果 计时器列表.包含(名称):
        设 计时器 = 计时器列表[名称]
        如果 非 计时器["运行"]:
            计时器["起点"] = 时间戳()
            计时器["运行"] = 真
            计时器列表[名称] = 计时器

函程 计时器耗时(名称): // 公开
    如果 计时器列表.包含(名称):
        设 计时器 = 计时器列表[名称]
        设 累计 = 计时器["累计"]
        如果 计时器["运行"]:
            累计 = 累计 + (时间戳() - 计时器["起点"])
        返回 累计
    返回 0

函程 显示计时器(名称): // 公开
    设 耗时 = 计时器耗时(名称)
    输出 名称 + ": " + 格式化耗时(耗时)

// ===== 日期工具 =====

函程 月天数(年值, 月值): // 公开
    如果 月值 == 1 或 月值 == 3 或 月值 == 5 或 月值 == 7:
        返回 31
    如果 月值 == 8 或 月值 == 10 或 月值 == 12:
        返回 31
    如果 月值 == 4 或 月值 == 6 或 月值 == 9 或 月值 == 11:
        返回 30
    // 二月
    如果 闰年(年值):
        返回 29
    返回 28

函程 年内天数(年值, 月值, 日值): // 公开
    设 总 = 日值
    设 m = 1
    循环 m < 月值:
        总 = 总 + 月天数(年值, m)
        m = m + 1
    返回 总

函程 年底剩余(年值, 月值, 日值): // 公开
    设 总天数 = 365
    如果 闰年(年值):
        总天数 = 366
    返回 总天数 - 年内天数(年值, 月值, 日值)

函程 格式化日期(格式): // 公开
    返回 时间格式化(格式)

// ===== 倒计时 =====

函程 天数差(早时间戳, 晚时间戳): // 公开
    设 差 = 晚时间戳 - 早时间戳
    返回 差 / 86400

函程 倒计时(目标时间戳): // 公开
    设 当前 = 时间戳()
    设 差 = 目标时间戳 - 当前
    如果 差 <= 0:
        输出 "已到期"
        返回 0
    设 天 = 差 / 86400
    设 余 = 差 - 天 * 86400
    设 时 = 余 / 3600
    余 = 余 - 时 * 3600
    设 分 = 余 / 60
    设 秒 = 余 - 分 * 60
    输出 转字符串(天) + "天 " + 转字符串(时) + "时 " + 转字符串(分) + "分 " + 转字符串(秒) + "秒"
    返回 差
