// ===== 语程标准库：选项解析 =====
// 提供命令行选项解析工具函数
//
// 公开接口：解析参数、获取选项、获取参数、
//           选项存在、选项值、参数值、
//           解析短选项、解析长选项

// ===== 参数解析 =====
// 选项格式：-k 值、--key 值、--key=值、-k=值
// 参数：不以 - 开头的值

函程 解析参数(参数列表): // 公开
    设 选项 = {}
    设 参数 = []
    设 i = 0
    循环 i < 数组长度(参数列表):
        设 项 = 参数列表[i]
        如果 字符串长度(项) >= 2 且 子串(项, 0, 2) == "--":
            // 长选项
            设 键值 = 子串(项, 2, 字符串长度(项))
            设 等号位 = 查找(键值, "=")
            如果 等号位 > 0:
                设 键 = 子串(键值, 0, 等号位)
                设 值 = 子串(键值, 等号位 + 1, 字符串长度(键值))
                选项[键] = 值
            否则:
                如果 i + 1 < 数组长度(参数列表):
                    设 下项 = 参数列表[i + 1]
                    如果 字符串长度(下项) > 0 且 子串(下项, 0, 1) != "-":
                        选项[键值] = 下项
                        i = i + 1
                    否则:
                        选项[键值] = ""
                否则:
                    选项[键值] = ""
        否则如果 字符串长度(项) >= 1 且 子串(项, 0, 1) == "-":
            // 短选项
            设 键值 = 子串(项, 1, 字符串长度(项))
            设 等号位 = 查找(键值, "=")
            如果 等号位 > 0:
                设 键 = 子串(键值, 0, 等号位)
                设 值 = 子串(键值, 等号位 + 1, 字符串长度(键值))
                选项[键] = 值
            否则:
                如果 i + 1 < 数组长度(参数列表):
                    设 下项 = 参数列表[i + 1]
                    如果 字符串长度(下项) > 0 且 子串(下项, 0, 1) != "-":
                        选项[键值] = 下项
                        i = i + 1
                    否则:
                        选项[键值] = ""
                否则:
                    选项[键值] = ""
        否则:
            参数.添加(项)
        i = i + 1
    返回 [选项, 参数]

// ===== 选项查询 =====

函程 获取选项(解析结果, 键): // 公开
    设 选项 = 解析结果[0]
    如果 选项.包含(键):
        返回 选项[键]
    返回 ""

函程 选项存在(解析结果, 键): // 公开
    设 选项 = 解析结果[0]
    返回 选项.包含(键)

函程 选项值(解析结果, 键, 默认值): // 公开
    设 选项 = 解析结果[0]
    如果 选项.包含(键):
        返回 选项[键]
    返回 默认值

函程 获取参数(解析结果): // 公开
    返回 解析结果[1]

函程 参数值(解析结果, 索引, 默认值): // 公开
    设 参数 = 解析结果[1]
    如果 索引 < 数组长度(参数):
        返回 参数[索引]
    返回 默认值

函程 参数数量(解析结果): // 公开
    返回 数组长度(解析结果[1])

// ===== 便捷函数 =====

函程 是标志启用(解析结果, 短键, 长键): // 公开
    设 选项 = 解析结果[0]
    返回 选项.包含(短键) 或 选项.包含(长键)

函程 获取选项值(解析结果, 短键, 长键, 默认值): // 公开
    设 选项 = 解析结果[0]
    如果 选项.包含(长键):
        返回 选项[长键]
    如果 选项.包含(短键):
        返回 选项[短键]
    返回 默认值
