// 期望值 - Result类型（表示成功值或错误）

// === 构造函数 ===

函程 成功(值): // 公开
    // 创建包含成功值的期望值
    返回 {是成功: 真, 值: 值, 错误: 空}

函程 失败(错误): // 公开
    // 创建包含错误的期望值
    返回 {是成功: 假, 值: 空, 错误: 错误}

函程 期望值(值, 错误=空): // 公开
    // 根据值是否为空创建期望值
    如果 值 != 空:
        返回 成功(值)
    否则:
        返回 失败(错误 或 "值为空")

// === 查询函数 ===

函程 是成功(期望): // 公开
    // 检查期望值是否包含成功值
    返回 期望["是成功"] == 真

函程 是失败(期望): // 公开
    // 检查期望值是否包含错误
    返回 期望["是成功"] != 真

// === 访问函数 ===

函程 取期望值(期望): // 公开
    // 获取成功值，如果包含错误则抛出异常
    如果 是失败(期望):
        抛出 "尝试访问失败期望值的值: " + 转文本(期望["错误"])
    返回 期望["值"]

函程 取错误(期望): // 公开
    // 获取错误值，如果包含成功值则抛出异常
    如果 是成功(期望):
        抛出 "尝试访问成功期望值的错误"
    返回 期望["错误"]

函程 取值或默认(期望, 默认值): // 公开
    // 获取成功值，如果失败则返回默认值
    如果 是成功(期望):
        返回 期望["值"]
    否则:
        返回 默认值

函程 取错误或默认(期望, 默认错误): // 公开
    // 获取错误值，如果成功则返回默认错误
    如果 是失败(期望):
        返回 期望["错误"]
    否则:
        返回 默认错误

函程 取值或计算(期望, 计算函数): // 公开
    // 获取成功值，如果失败则调用计算函数
    如果 是成功(期望):
        返回 期望["值"]
    否则:
        返回 计算函数(期望["错误"])

// === 组合子函数 ===

函程 映射(期望, 变换函数): // 公开
    // 对成功值应用变换函数，保持错误不变
    如果 是成功(期望):
        返回 成功(变换函数(期望["值"]))
    否则:
        返回 失败(期望["错误"])

函程 映射错误(期望, 变换函数): // 公开
    // 对错误值应用变换函数，保持成功值不变
    如果 是失败(期望):
        返回 失败(变换函数(期望["错误"]))
    否则:
        返回 成功(期望["值"])

函程 然后调用(期望, 变换函数): // 公开
    // 链式调用：如果成功则应用函数，否则传播错误
    如果 是成功(期望):
        返回 变换函数(期望["值"])
    否则:
        返回 失败(期望["错误"])

函程 或者调用(期望, 恢复函数): // 公开
    // 如果失败则应用恢复函数，否则保持成功值
    如果 是失败(期望):
        返回 恢复函数(期望["错误"])
    否则:
        返回 期望

函程 链式操作(期望, 操作列表): // 公开
    // 链式执行一系列操作
    设 当前 = 期望
    循环 操作 在 操作列表:
        当前 = 然后调用(当前, 操作)
        如果 是失败(当前):
            返回 当前
    返回 当前

// === 匹配函数 ===

函程 匹配(期望, 成功函数, 失败函数): // 公开
    // 模式匹配期望值
    如果 是成功(期望):
        返回 成功函数(期望["值"])
    否则:
        返回 失败函数(期望["错误"])

函程 成功时(期望, 操作函数): // 公开
    // 如果成功则执行操作
    如果 是成功(期望):
        操作函数(期望["值"])
    返回 期望

函程 失败时(期望, 操作函数): // 公开
    // 如果失败则执行操作
    如果 是失败(期望):
        操作函数(期望["错误"])
    返回 期望

// === 转换函数 ===

函程 转为选项(期望): // 公开
    // 将期望值转换为选项类型（丢弃错误信息）
    如果 是成功(期望):
        返回 {有值: 真, 值: 期望["值"]}
    否则:
        返回 {有值: 假, 值: 空}

函程 转为列表(期望): // 公开
    // 将期望值转换为列表
    如果 是成功(期望):
        返回 [期望["值"]]
    否则:
        返回 []

// === 比较函数 ===

函程 期望值相等(甲, 乙): // 公开
    // 比较两个期望值是否相等
    如果 是成功(甲) 且 是成功(乙):
        返回 甲["值"] == 乙["值"]
    否则如果 是失败(甲) 且 是失败(乙):
        返回 甲["错误"] == 乙["错误"]
    否则:
        返回 假

// === 解包函数 ===

函程 解包(期望): // 公开
    // 获取成功值，如果失败则抛出异常（取期望值的别名）
    返回 取期望值(期望)

函程 解包或默认(期望, 默认值): // 公开
    // 获取成功值，如果失败则返回默认值
    返回 取值或默认(期望, 默认值)

函程 期望(期望, 消息): // 公开
    // 获取成功值，如果失败则抛出带自定义消息的异常
    如果 是失败(期望):
        抛出 消息 + ": " + 转文本(期望["错误"])
    返回 期望["值"]

// === 字符串表示 ===

函程 期望值转文本(期望): // 公开
    // 将期望值转换为字符串表示
    如果 是成功(期望):
        返回 "成功(" + 转文本(期望["值"]) + ")"
    否则:
        返回 "失败(" + 转文本(期望["错误"]) + ")"

// === 批量操作 ===

函程 全部成功(期望列表): // 公开
    // 如果所有期望值都成功，返回包含所有值的成功期望
    设 值列表 = []
    循环 期望 在 期望列表:
        如果 是失败(期望):
            返回 失败(期望["错误"])
        值列表.添加(期望["值"])
    返回 成功(值列表)

函程 任一成功(期望列表): // 公开
    // 返回第一个成功的期望值，如果全部失败则返回最后一个错误
    设 最后错误 = 空
    循环 期望 在 期望列表:
        如果 是成功(期望):
            返回 期望
        最后错误 = 期望["错误"]
    返回 失败(最后错误 或 "所有操作均失败")

函程 分离结果(期望列表): // 公开
    // 将期望列表分离为成功值列表和错误列表
    设 成功列表 = []
    设 错误列表 = []
    循环 期望 在 期望列表:
        如果 是成功(期望):
            成功列表.添加(期望["值"])
        否则:
            错误列表.添加(期望["错误"])
    返回 {成功: 成功列表, 失败: 错误列表}
