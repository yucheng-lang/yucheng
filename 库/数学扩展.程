// ===== 语程标准库：数学扩展 =====
// 提供数学常量与扩展数学函数
//
// 公开接口：圆周率、自然常数、黄金比例、欧拉常数、根号二、根号三、无穷、精度下限、
//           角度转弧度、弧度转角度、符号、夹值、线性插值、中点、范围映射、
//           向零取整、银行家舍入、二的幂、十的幂、对数二、对数十、是二的幂、上取二幂、
//           正割、余割、余切、
//           等差求和、等比求和、自然数求和、平方求和、立方求和、
//           扩展最大公约数、模逆元、互质、欧拉函数

// ===== 公开常量 =====

常量 圆周率 = 3.141592653589793 // 公开
常量 自然常数 = 2.718281828459045 // 公开
常量 黄金比例 = 1.618033988749895 // 公开
常量 欧拉常数 = 0.5772156649015329 // 公开
常量 根号二 = 1.4142135623730951 // 公开
常量 根号三 = 1.7320508075688772 // 公开
常量 无穷 = 1.7976931348623157e+308 // 公开
常量 精度下限 = 2.2250738585072014e-308 // 公开

// ===== 角度与弧度 =====

函程 角度转弧度(角度): // 公开
    返回 角度 * 圆周率 / 180

函程 弧度转角度(弧度): // 公开
    返回 弧度 * 180 / 圆周率

// ===== 符号与取值 =====

函程 符号(x): // 公开
    如果 x > 0:
        返回 1
    如果 x < 0:
        返回 -1
    返回 0

函程 夹值(值, 低, 高): // 公开
    如果 值 < 低:
        返回 低
    如果 值 > 高:
        返回 高
    返回 值

函程 线性插值(a, b, t): // 公开
    返回 a + (b - a) * t

函程 中点(a, b): // 公开
    返回 (a + b) / 2

函程 范围映射(值, 旧低, 旧高, 新低, 新高): // 公开
    设 旧范围 = 旧高 - 旧低
    如果 旧范围 == 0:
        返回 新低
    返回 新低 + (值 - 旧低) * (新高 - 新低) / 旧范围

// ===== 取整函数 =====

函程 向零取整(x): // 公开
    如果 x >= 0:
        返回 向下取整(x)
    返回 向上取整(x)

函程 银行家舍入(x): // 公开
    设 整 = 向下取整(x)
    设 小 = x - 整
    如果 小 < 0.5:
        返回 整
    如果 小 > 0.5:
        返回 整 + 1
    // 小数部分恰好为 0.5 时，向偶数取整
    设 偶数判断 = 整 - (整 / 2) * 2
    如果 偶数判断 == 0:
        返回 整
    返回 整 + 1

// ===== 幂与对数 =====

函程 二的幂(n): // 公开
    返回 幂(2, n)

函程 十的幂(n): // 公开
    返回 幂(10, n)

函程 对数二(n): // 公开
    如果 n <= 0:
        返回 0
    设 结果 = 0
    循环 n >= 2:
        n = n / 2
        结果 = 结果 + 1
    返回 结果

函程 对数十(n): // 公开
    如果 n <= 0:
        返回 0
    返回 自然对数(n) / 自然对数(10)

函程 是二的幂(n): // 公开
    如果 n <= 0:
        返回 假
    循环 n > 1:
        如果 n - (n / 2) * 2 != 0:
            返回 假
        n = n / 2
    返回 真

函程 上取二幂(n): // 公开
    如果 n <= 1:
        返回 1
    设 结果 = 1
    循环 结果 < n:
        结果 = 结果 * 2
    返回 结果

// ===== 三角函数扩展 =====

函程 正割(x): // 公开
    设 c = 余弦(x)
    如果 c == 0:
        返回 无穷
    返回 1 / c

函程 余割(x): // 公开
    设 s = 正弦(x)
    如果 s == 0:
        返回 无穷
    返回 1 / s

函程 余切(x): // 公开
    设 s = 正弦(x)
    如果 s == 0:
        返回 无穷
    返回 余弦(x) / s

// ===== 数列求和 =====

函程 等差求和(首项, 末项, 项数): // 公开
    返回 (首项 + 末项) * 项数 / 2

函程 等比求和(首项, 公比, 项数): // 公开
    如果 公比 == 1:
        返回 首项 * 项数
    返回 首项 * (1 - 幂(公比, 项数)) / (1 - 公比)

函程 自然数求和(n): // 公开
    返回 n * (n + 1) / 2

函程 平方求和(n): // 公开
    返回 n * (n + 1) * (2 * n + 1) / 6

函程 立方求和(n): // 公开
    设 s = n * (n + 1) / 2
    返回 s * s

// ===== 数论 =====

函程 扩展最大公约数(a, b): // 公开
    如果 b == 0:
        返回 [a, 1, 0]
    设 结果 = 扩展最大公约数(b, a - (a / b) * b)
    设 g = 结果[0]
    设 x = 结果[1]
    设 y = 结果[2]
    返回 [g, y, x - (a / b) * y]

函程 模逆元(a, m): // 公开
    设 结果 = 扩展最大公约数(a, m)
    设 g = 结果[0]
    设 x = 结果[1]
    如果 g != 1:
        返回 -1
    返回 x - (x / m) * m

函程 互质(a, b): // 公开
    返回 最大公约数(a, b) == 1

函程 欧拉函数(n): // 公开
    设 结果 = n
    设 p = 2
    循环 p * p <= n:
        如果 n - (n / p) * p == 0:
            循环 n - (n / p) * p == 0:
                n = n / p
            结果 = 结果 - 结果 / p
        p = p + 1
    如果 n > 1:
        结果 = 结果 - 结果 / n
    返回 结果
