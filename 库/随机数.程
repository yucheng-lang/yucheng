// ===== 语程标准库：随机数 =====
// 提供随机数生成工具函数
//
// 公开接口：随机整数、随机浮点、随机范围、
//           随机抽样、随机洗牌、随机布尔、
//           随机字符串、随机颜色、随机种子

// ===== 随机数生成 =====

函程 随机整数(上限): // 公开
    返回 随机数() - (随机数() / 上限) * 上限

函程 随机浮点(): // 公开
    返回 转浮点数(随机数()) / 转浮点数(随机数() + 1)

函程 随机范围(最小, 最大): // 公开
    设 范围 = 最大 - 最小 + 1
    返回 最小 + 随机整数(范围)

函程 随机布尔(): // 公开
    返回 随机整数(2) == 0

// ===== 随机抽样 =====

函程 随机抽样(列表): // 公开
    如果 数组长度(列表) == 0:
        返回 ""
    设 索引 = 随机整数(数组长度(列表))
    返回 列表[索引]

函程 随机抽样n(列表, 数量): // 公开
    设 结果 = []
    设 i = 0
    循环 i < 数量 且 i < 数组长度(列表):
        设 索引 = 随机范围(0, 数组长度(列表) - 1)
        结果.添加(列表[索引])
        i = i + 1
    返回 结果

// ===== 随机洗牌 =====

函程 随机洗牌(列表): // 公开
    设 结果 = []
    遍 项 于 列表:
        结果.添加(项)
    设 i = 数组长度(结果) - 1
    循环 i > 0:
        设 j = 随机范围(0, i)
        设 临时 = 结果[i]
        结果[i] = 结果[j]
        结果[j] = 临时
        i = i - 1
    返回 结果

// ===== 随机字符串 =====

函程 随机字符串(长度): // 公开
    设 字符集 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    设 结果 = ""
    设 i = 0
    循环 i < 长度:
        设 索引 = 随机范围(0, 字符串长度(字符集) - 1)
        结果 = 结果 + 子串(字符集, 索引, 索引 + 1)
        i = i + 1
    返回 结果

函程 随机数字字符串(长度): // 公开
    设 结果 = ""
    设 i = 0
    循环 i < 长度:
        设 数 = 随机范围(0, 9)
        结果 = 结果 + 转字符串(数)
        i = i + 1
    返回 结果

// ===== 随机颜色 =====

函程 随机颜色(): // 公开
    设 r = 随机范围(0, 255)
    设 g = 随机范围(0, 255)
    设 b = 随机范围(0, 255)
    返回 (r * 65536) + (g * 256) + b

// ===== 加权随机 =====

函程 加权随机(选项列表, 权重列表): // 公开
    设 总权重 = 0
    遍 权 于 权重列表:
        总权重 = 总权重 + 权
    设 随机值 = 随机浮点() * 转浮点数(总权重)
    设 累积 = 0
    设 i = 0
    循环 i < 数组长度(选项列表):
        累积 = 累积 + 权重列表[i]
        如果 转浮点数(累积) >= 随机值:
            返回 选项列表[i]
        i = i + 1
    返回 选项列表[数组长度(选项列表) - 1]
