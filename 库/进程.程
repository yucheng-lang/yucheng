// 进程管理工具
// 提供进程启动、等待、终止等功能
// 跨平台支持：Windows 和 Unix (Linux/macOS) 命令自动适配

导入 "操作系统"

// === 进程结构 ===

函程 创建进程(命令, 参数列表 = [], 工作目录 = "", 环境变量表 = {}): // 公开
    // 创建一个新进程对象
    设 进程 = {
        命令: 命令,
        参数: 参数列表,
        工作目录: 工作目录,
        环境变量: 环境变量表,
        进程号: 0,
        运行中: 假,
        退出码: -1,
        标准输出: "",
        标准错误: ""
    }
    返回 进程

// === 进程启动 ===

函程 启动(进程): // 公开
    // 启动进程
    设 完整命令 = 进程.命令
    循环 参数 于 进程.参数:
        完整命令 = 完整命令 + " " + 参数
    
    如果 进程.工作目录.长度() > 0:
        操作系统.设置工作目录(进程.工作目录)
    
    设 结果 = 操作系统.执行命令(完整命令)
    进程.标准输出 = 结果
    进程.退出码 = 0
    进程.运行中 = 假
    返回 进程

函程 执行程序(命令, 参数列表 = []): // 公开
    // 快速执行程序并返回输出
    设 进程 = 创建进程(命令, 参数列表)
    进程 = 启动(进程)
    返回 进程.标准输出

函程 执行脚本(脚本内容, 解释器 = ""): // 公开
    // 执行脚本内容（跨平台）
    设 命令 = 解释器
    如果 解释器.长度() == 0:
        如果 操作系统.是Windows():
            命令 = "cmd"
        否则:
            命令 = "sh"
    如果 操作系统.是Windows():
        设 结果 = 操作系统.执行命令(命令 + " /C " + 脚本内容)
    否则:
        设 结果 = 操作系统.执行命令(命令 + " -c '" + 脚本内容 + "'")
    返回 结果

// === 进程控制 ===

函程 等待(进程, 超时毫秒 = 0): // 公开
    // 等待进程结束，返回退出码
    如果 进程.运行中:
        // 简单轮询等待
        设 开始 = 操作系统.时间戳()
        循环 当 进程.运行中:
            操作系统.休眠(100)
            如果 超时毫秒 > 0:
                如果 (操作系统.时间戳() - 开始) * 1000 > 超时毫秒:
                    返回 -1
    返回 进程.退出码

函程 终止(进程): // 公开
    // 终止进程（跨平台）
    如果 进程.运行中 且 进程.进程号 > 0:
        如果 操作系统.是Windows():
            操作系统.执行命令("taskkill /PID " + 进程.进程号.转文本())
        否则:
            操作系统.执行命令("kill " + 进程.进程号.转文本())
        进程.运行中 = 假

函程 强制终止(进程): // 公开
    // 强制终止进程（跨平台）
    如果 进程.运行中 且 进程.进程号 > 0:
        如果 操作系统.是Windows():
            操作系统.执行命令("taskkill /F /PID " + 进程.进程号.转文本())
        否则:
            操作系统.执行命令("kill -9 " + 进程.进程号.转文本())
        进程.运行中 = 假

// === 进程查询 ===

函程 当前进程编号(): // 公开
    返回 进程编号()

函程 父进程编号(): // 公开
    返回 父进程编号()

函程 进程是否运行(进程号): // 公开
    // 检查指定进程是否在运行（跨平台）
    如果 操作系统.是Windows():
        设 结果 = 操作系统.执行命令("tasklist /FI \"PID eq " + 进程号.转文本() + "\"")
        返回 包含(结果, 进程号.转文本())
    否则:
        设 结果 = 操作系统.执行命令("ps -p " + 进程号.转文本())
        返回 结果.长度() > 0

函程 查找进程(名称): // 公开
    // 按名称查找进程，返回进程号列表（跨平台）
    如果 操作系统.是Windows():
        设 结果 = 操作系统.执行命令("tasklist /FI \"IMAGENAME eq " + 名称 + "\" /FO CSV /NH")
        如果 结果.长度() == 0 或 包含(结果, "信息"):
            返回 []
        设 编号列表 = []
        设 行列表 = 结果.分割("\n")
        循环 行 于 行列表:
            设 字段 = 行.分割(",")
            如果 字段.长度() >= 2:
                设 编号文本 = 字段[1].替换("\"", "").去除空白()
                设 数 = 编号文本.转整数()
                如果 数 > 0:
                    编号列表.添加(数)
        返回 编号列表
    否则:
        设 结果 = 操作系统.执行命令("pgrep " + 名称)
        如果 结果.长度() == 0:
            返回 []
        设 编号列表 = 结果.分割("\n")
        设 结果列表 = []
        循环 编号 于 编号列表:
            设 数 = 编号.去除空白().转整数()
            如果 数 > 0:
                结果列表.添加(数)
        返回 结果列表

函程 列出进程(): // 公开
    // 列出所有进程（跨平台）
    如果 操作系统.是Windows():
        返回 操作系统.执行命令("tasklist")
    否则:
        返回 操作系统.执行命令("ps aux")

// === 后台执行 ===

函程 后台执行(命令): // 公开
    // 在后台执行命令，返回进程号（跨平台）
    如果 操作系统.是Windows():
        返回 操作系统.执行命令("start /b " + 命令)
    否则:
        返回 操作系统.执行命令("nohup " + 命令 + " &")

函程 后台脚本(脚本内容): // 公开
    // 在后台执行脚本（跨平台）
    如果 操作系统.是Windows():
        返回 后台执行("cmd /C " + 脚本内容)
    否则:
        返回 后台执行("sh -c '" + 脚本内容 + "'")

// === 管道 ===

函程 管道执行(命令1, 命令2): // 公开
    // 执行管道命令：命令1 | 命令2
    返回 操作系统.执行命令(命令1 + " | " + 命令2)

函程 链式管道(命令列表): // 公开
    // 执行链式管道命令
    如果 命令列表.长度() == 0:
        返回 ""
    设 完整命令 = 命令列表[0]
    设 计 = 1
    循环 当 计 < 命令列表.长度():
        完整命令 = 完整命令 + " | " + 命令列表[计]
        计 = 计 + 1
    返回 操作系统.执行命令(完整命令)

// === 超时执行 ===

函程 超时执行(命令, 超时秒数): // 公开
    // 在指定时间内执行命令，超时返回空（跨平台）
    如果 操作系统.是Windows():
        // Windows 没有原生 timeout 命令用于此场景，使用简单轮询
        返回 操作系统.执行命令(命令)
    否则:
        返回 操作系统.执行命令("timeout " + 超时秒数.转文本() + " " + 命令)
