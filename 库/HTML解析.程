// HTML解析工具
// 提供HTML标签解析、属性提取、文本提取等功能

// === HTML实体 ===

常量 HTML实体表 = { // 内部
    "&amp;": "&",
    "&lt;": "<",
    "&gt;": ">",
    "&quot;": "\"",
    "&apos;": "'",
    "&nbsp;": " ",
    "&copy;": "©",
    "&reg;": "®",
    "&mdash;": "—",
    "&ndash;": "–",
    "&laquo;": "«",
    "&raquo;": "»",
    "&bull;": "•",
    "&hellip;": "…",
    "&trade;": "™",
    "&euro;": "€",
    "&pound;": "£",
    "&yen;": "¥",
    "&cent;": "¢",
    "&times;": "×",
    "&divide;": "÷"
}

常量 反向实体表 = { // 内部
    "&": "&amp;",
    "<": "&lt;",
    ">": "&gt;",
    "\"": "&quot;",
    "'": "&apos;"
}

函程 HTML转义(文本): // 公开
    设 结果 = 文本
    结果 = 替换(结果, "&", "&amp;")
    结果 = 替换(结果, "<", "&lt;")
    结果 = 替换(结果, ">", "&gt;")
    结果 = 替换(结果, "\"", "&quot;")
    结果 = 替换(结果, "'", "&apos;")
    返回 结果

函程 HTML反转义(文本): // 公开
    设 结果 = 文本
    循环 实体, 字符 于 HTML实体表:
        结果 = 替换(结果, 实体, 字符)
    设 位置 = 0
    循环 位置 < 长度(结果):
        设 找到 = 查找(子串(结果, 位置), "&#")
        如果 找到 < 0:
            跳出
        设 实体开始 = 位置 + 找到
        设 分号 = 查找(子串(结果, 实体开始), ";")
        如果 分号 < 0:
            位置 = 实体开始 + 2
            继续
        设 编码部分 = 子串(结果, 实体开始 + 2, 分号 - 2)
        设 码值 = 0
        如果 长度(编码部分) > 0 且 编码部分[0] == "x":
            码值 = 十六进制转整数(子串(编码部分, 1))
        否则:
            码值 = 转整数(编码部分)
        如果 码值 > 0:
            设 字符值 = 整数转字符(码值)
            结果 = 子串(结果, 0, 实体开始) + 字符值 + 子串(结果, 实体开始 + 分号 + 1)
            位置 = 实体开始 + 1
        否则:
            位置 = 实体开始 + 2
    返回 结果

// === 标签解析 ===

函程 解析标签属性(属性文本): // 公开
    设 属性 = {}
    设 位置 = 0
    设 文本 = 去除空白(属性文本)
    
    循环 位置 < 长度(文本):
        循环 位置 < 长度(文本) 且 文本[位置] == " ":
            位置 = 位置 + 1
        如果 位置 >= 长度(文本):
            跳出
        
        设 名开始 = 位置
        循环 位置 < 长度(文本) 且 文本[位置] != "=" 且 文本[位置] != " " 且 文本[位置] != ">":
            位置 = 位置 + 1
        设 属性名 = 子串(文本, 名开始, 位置 - 名开始)
        
        如果 长度(属性名) == 0:
            位置 = 位置 + 1
            继续
        
        循环 位置 < 长度(文本) 且 文本[位置] == " ":
            位置 = 位置 + 1
        
        如果 位置 < 长度(文本) 且 文本[位置] == "=":
            位置 = 位置 + 1
            循环 位置 < 长度(文本) 且 文本[位置] == " ":
                位置 = 位置 + 1
            设 属性值 = ""
            如果 位置 < 长度(文本) 且 (文本[位置] == "\"" 或 文本[位置] == "'"):
                设 引号 = 文本[位置]
                位置 = 位置 + 1
                设 值开始 = 位置
                循环 位置 < 长度(文本) 且 文本[位置] != 引号:
                    位置 = 位置 + 1
                属性值 = 子串(文本, 值开始, 位置 - 值开始)
                如果 位置 < 长度(文本):
                    位置 = 位置 + 1
            否则:
                设 值开始 = 位置
                循环 位置 < 长度(文本) 且 文本[位置] != " " 且 文本[位置] != ">":
                    位置 = 位置 + 1
                属性值 = 子串(文本, 值开始, 位置 - 值开始)
            属性[属性名] = 属性值
        否则:
            属性[属性名] = 真
    
    返回 属性

常量 自闭合标签列表 = ["area", "base", "br", "col", "embed", "hr", "img", "input", "link", "meta", "param", "source", "track", "wbr"]

函程 是自闭合标签(标签名): // 内部
    循环 名 于 自闭合标签列表:
        如果 名 == 标签名:
            返回 真
    返回 假

函程 提取标签(HTML, 标签名): // 公开
    设 结果 = []
    设 搜索 = "<" + 标签名
    设 位置 = 0
    
    循环 位置 < 长度(HTML):
        设 找到 = 查找(子串(HTML, 位置), 搜索)
        如果 找到 < 0:
            跳出
        设 标签开始 = 位置 + 找到
        
        设 标签头结束 = 查找(子串(HTML, 标签开始), ">")
        如果 标签头结束 < 0:
            跳出
        标签头结束 = 标签开始 + 标签头结束
        
        设 标签头 = 子串(HTML, 标签开始, 标签头结束 + 1 - 标签开始)
        设 自闭合 = (长度(标签头) >= 2 且 标签头[长度(标签头)-2] == "/") 或 是自闭合标签(标签名)
        
        设 属性文本 = 去除空白(子串(标签头, 长度(标签名) + 1))
        如果 长度(属性文本) > 0 且 属性文本[长度(属性文本)-1] == ">":
            属性文本 = 子串(属性文本, 0, 长度(属性文本)-1)
        如果 长度(属性文本) > 0 且 属性文本[长度(属性文本)-1] == "/":
            属性文本 = 子串(属性文本, 0, 长度(属性文本)-1)
        
        设 属性 = 解析标签属性(属性文本)
        
        如果 自闭合:
            结果.添加({标签: 标签名, 属性: 属性, 内容: "", 自闭合: 真})
            位置 = 标签头结束 + 1
        否则:
            设 闭合标签 = "</" + 标签名 + ">"
            设 闭合位置 = 查找(子串(HTML, 标签头结束 + 1), 闭合标签)
            如果 闭合位置 < 0:
                位置 = 标签头结束 + 1
                继续
            设 内容 = 子串(HTML, 标签头结束 + 1, 闭合位置)
            结果.添加({标签: 标签名, 属性: 属性, 内容: 内容, 自闭合: 假})
            位置 = 标签头结束 + 1 + 闭合位置 + 长度(闭合标签)
    
    返回 结果

函程 提取文本(HTML): // 公开
    设 结果 = HTML
    循环 真:
        设 开始 = 查找(结果, "<script")
        如果 开始 < 0:
            跳出
        设 结束 = 查找(子串(结果, 开始), "</script>")
        如果 结束 < 0:
            跳出
        结果 = 子串(结果, 0, 开始) + 子串(结果, 开始 + 结束 + 9)
    
    循环 真:
        设 开始 = 查找(结果, "<style")
        如果 开始 < 0:
            跳出
        设 结束 = 查找(子串(结果, 开始), "</style>")
        如果 结束 < 0:
            跳出
        结果 = 子串(结果, 0, 开始) + 子串(结果, 开始 + 结束 + 8)
    
    设 清理 = ""
    设 在标签内 = 假
    循环 字符 于 结果:
        如果 字符 == "<":
            在标签内 = 真
        否则 如果 字符 == ">":
            在标签内 = 假
            继续
        如果 非 在标签内:
            清理 = 清理 + 字符
    
    清理 = HTML反转义(清理)
    清理 = 替换(清理, "\t", " ")
    循环 查找(清理, "  ") >= 0:
        清理 = 替换(清理, "  ", " ")
    
    返回 去除空白(清理)

函程 提取链接(HTML): // 公开
    设 标签列表 = 提取标签(HTML, "a")
    设 链接列表 = []
    循环 标签 于 标签列表:
        如果 包含(标签["属性"], "href"):
            链接列表.添加({
                地址: 标签["属性"]["href"],
                文本: 提取文本(标签["内容"])
            })
    返回 链接列表

函程 提取图片(HTML): // 公开
    设 标签列表 = 提取标签(HTML, "img")
    设 图片列表 = []
    循环 标签 于 标签列表:
        设 信息 = {地址: 取值(标签["属性"], "src", "")}
        如果 包含(标签["属性"], "alt"):
            信息["描述"] = 标签["属性"]["alt"]
        如果 包含(标签["属性"], "width"):
            信息["宽度"] = 标签["属性"]["width"]
        如果 包含(标签["属性"], "height"):
            信息["高度"] = 标签["属性"]["height"]
        图片列表.添加(信息)
    返回 图片列表

函程 提取标题(HTML): // 公开
    设 标签列表 = 提取标签(HTML, "title")
    如果 长度(标签列表) > 0:
        返回 提取文本(标签列表[0]["内容"])
    返回 ""

函程 提取元信息(HTML): // 公开
    设 标签列表 = 提取标签(HTML, "meta")
    设 元信息 = {}
    循环 标签 于 标签列表:
        如果 包含(标签["属性"], "name") 且 包含(标签["属性"], "content"):
            元信息[标签["属性"]["name"]] = 标签["属性"]["content"]
    返回 元信息

// === 辅助函数 ===

函程 十六进制转整数(文本): // 内部
    设 结果 = 0
    循环 字符 于 文本:
        设 值 = 0
        如果 字符 >= "0" 且 字符 <= "9":
            值 = 转整数(字符)
        否则 如果 字符 >= "a" 且 字符 <= "f":
            值 = 转整数(字符) - 转整数("a") + 10
        否则 如果 字符 >= "A" 且 字符 <= "F":
            值 = 转整数(字符) - 转整数("A") + 10
        结果 = 结果 * 16 + 值
    返回 结果

函程 整数转字符(码值): // 内部
    返回 字符(码值)
