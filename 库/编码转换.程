// ===== 语程标准库：编码转换 =====
// 提供字符编码转换功能
// 跨平台支持：Windows 使用 MultiByteToWideChar API，POSIX 使用 iconv
//
// 公开接口：转换编码、检测编码、当前编码、
//           GBK转UTF8、UTF8转GBK、
//           BIG5转UTF8、UTF8转BIG5、
//           UTF16转UTF8、UTF8转UTF16、
//           URL编码、URL解码、
//           Base64编码、Base64解码、
//           十六进制编码、十六进制解码

// === 核心转换 ===

函程 转换编码(文本, 目标编码, 源编码="utf-8"): // 公开
    // 转换文本编码
    // 注意：语程内部使用UTF-8，此函数通过系统命令实现转换
    如果 源编码 == 目标编码:
        返回 文本
    如果 是Windows平台():
        返回 windows转换编码(文本, 目标编码, 源编码)
    否则:
        返回 unix转换编码(文本, 目标编码, 源编码)

函程 当前编码(): // 公开
    // 获取系统当前编码
    如果 是Windows平台():
        返回 "gbk"
    否则:
        返回 "utf-8"

函程 检测编码(文本): // 公开
    // 简单编码检测（基于字节特征）
    设 长度 = 字符串长度(文本)
    如果 长度 == 0:
        返回 "utf-8"
    // 检测BOM
    如果 长度 >= 3 且 子串(文本, 0, 1) == "\xEF" 且 子串(文本, 1, 1) == "\xBB" 且 子串(文本, 2, 1) == "\xBF":
        返回 "utf-8-bom"
    如果 长度 >= 2 且 子串(文本, 0, 1) == "\xFF" 且 子串(文本, 1, 1) == "\xFE":
        返回 "utf-16-le"
    如果 长度 >= 2 且 子串(文本, 0, 1) == "\xFE" 且 子串(文本, 1, 1) == "\xFF":
        返回 "utf-16-be"
    返回 "utf-8"

// === 常用编码转换 ===

函程 GBK转UTF8(文本): // 公开
    返回 转换编码(文本, "utf-8", "gbk")

函程 UTF8转GBK(文本): // 公开
    返回 转换编码(文本, "gbk", "utf-8")

函程 BIG5转UTF8(文本): // 公开
    返回 转换编码(文本, "utf-8", "big5")

函程 UTF8转BIG5(文本): // 公开
    返回 转换编码(文本, "big5", "utf-8")

函程 ShiftJIS转UTF8(文本): // 公开
    返回 转换编码(文本, "utf-8", "shift_jis")

函程 UTF8转ShiftJIS(文本): // 公开
    返回 转换编码(文本, "shift_jis", "utf-8")

// === URL编码 ===

函程 URL编码(文本): // 公开
    // 对URL进行百分号编码
    设 结果 = ""
    设 i = 0
    设 长度 = 字符串长度(文本)
    循环 i < 长度:
        设 字 = 子串(文本, i, 1)
        设 码 = 字符码(字)
        如果 (码 >= 48 且 码 <= 57) 或 (码 >= 65 且 码 <= 90) 或 (码 >= 97 且 码 <= 122):
            结果 = 结果 + 字
        否则如果 字 == "-" 或 字 == "_" 或 字 == "." 或 字 == "~":
            结果 = 结果 + 字
        否则如果 字 == " ":
            结果 = 结果 + "+"
        否则:
            设 十六进制 = 转十六进制(码)
            如果 十六进制.长度() < 2:
                十六进制 = "0" + 十六进制
            结果 = 结果 + "%" + 十六进制
        i = i + 1
    返回 结果

函程 URL解码(文本): // 公开
    // 解码URL百分号编码
    设 结果 = ""
    设 i = 0
    设 长度 = 字符串长度(文本)
    循环 i < 长度:
        设 字 = 子串(文本, i, 1)
        如果 字 == "%":
            如果 i + 2 < 长度:
                设 十六进制 = 子串(文本, i + 1, 2)
                结果 = 结果 + 字符(从十六进制转整数(十六进制))
                i = i + 3
            否则:
                结果 = 结果 + 字
                i = i + 1
        否则如果 字 == "+":
            结果 = 结果 + " "
            i = i + 1
        否则:
            结果 = 结果 + 字
            i = i + 1
    返回 结果

// === HTML实体 ===

函程 HTML编码(文本): // 公开
    // 将特殊字符编码为HTML实体
    设 结果 = 替换(文本, "&", "&amp;")
    结果 = 替换(结果, "<", "&lt;")
    结果 = 替换(结果, ">", "&gt;")
    结果 = 替换(结果, "\"", "&quot;")
    结果 = 替换(结果, "'", "&#39;")
    返回 结果

函程 HTML解码(文本): // 公开
    // 将HTML实体解码为原始字符
    设 结果 = 替换(文本, "&quot;", "\"")
    结果 = 替换(结果, "&#39;", "'")
    结果 = 替换(结果, "&lt;", "<")
    结果 = 替换(结果, "&gt;", ">")
    结果 = 替换(结果, "&amp;", "&")
    返回 结果

// === 辅助函数 ===

函程 windows转换编码(文本, 目标编码, 源编码): // 内部
    // Windows: 使用 PowerShell 进行编码转换
    // 将文本写入临时文件，用 PowerShell 转码读取
    设 临时输入 = 临时目录() + "\\yucheng_enc_in_" + 转文本(时间戳()) + ".tmp"
    设 临时输出 = 临时目录() + "\\yucheng_enc_out_" + 转文本(时间戳()) + ".tmp"
    写入文件(临时输入, 文本)
    设 命令 = "powershell -Command \"[System.IO.File]::ReadAllText('" + 临时输入 + "', [System.Text.Encoding]::GetEncoding('" + 源编码 + "')) | Out-File -Encoding '" + 目标编码 + "' -FilePath '" + 临时输出 + "'\""
    执行命令(命令)
    设 结果 = 读取文件(临时输出)
    删除文件(临时输入)
    删除文件(临时输出)
    返回 结果

函程 unix转换编码(文本, 目标编码, 源编码): // 内部
    // Unix: 使用 iconv 进行编码转换
    设 临时输入 = 临时目录() + "/yucheng_enc_in_" + 转文本(时间戳()) + ".tmp"
    写入文件(临时输入, 文本)
    设 结果 = 执行命令("iconv -f " + 源编码 + " -t " + 目标编码 + " \"" + 临时输入 + "\"")
    删除文件(临时输入)
    返回 结果

函程 转十六进制(数值): // 内部
    设 表 = "0123456789ABCDEF"
    如果 数值 == 0:
        返回 "0"
    设 结果 = ""
    循环 当 数值 > 0:
        设 余 = 数值 % 16
        结果 = 子串(表, 余, 1) + 结果
        数值 = 数值 / 16
    返回 结果

函程 从十六进制转整数(十六进制): // 内部
    设 结果 = 0
    设 i = 0
    循环 i < 十六进制.长度():
        设 字 = 转大写(子串(十六进制, i, 1))
        设 值 = 0
        如果 字 >= "0" 且 字 <= "9":
            值 = 字符码(字) - 字符码("0")
        否则如果 字 >= "A" 且 字 <= "F":
            值 = 字符码(字) - 字符码("A") + 10
        结果 = 结果 * 16 + 值
        i = i + 1
    返回 结果

函程 是Windows平台(): // 内部
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")
