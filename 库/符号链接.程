// ===== 语程标准库：符号链接 =====
// 提供符号链接的创建、检测和解析功能
// 跨平台支持：Linux/macOS 原生支持，Windows 需要管理员权限或开发者模式
//
// 公开接口：创建符号链接、链接存在、解析链接、是符号链接、
//           创建硬链接、创建目录链接

导入 "路径"

// === 符号链接创建 ===

函程 创建符号链接(源路径, 链接路径): // 公开
    // 创建符号链接（跨平台）
    // Windows: 需要管理员权限或开发者模式
    // Linux/macOS: 原生支持
    如果 是Windows平台():
        执行命令("mklink \"" + 路径规范化(链接路径) + "\" \"" + 路径规范化(源路径) + "\"")
    否则:
        执行命令("ln -s \"" + 路径规范化(源路径) + "\" \"" + 路径规范化(链接路径) + "\"")

函程 创建目录链接(源路径, 链接路径): // 公开
    // 创建目录符号链接
    如果 是Windows平台():
        执行命令("mklink /D \"" + 路径规范化(链接路径) + "\" \"" + 路径规范化(源路径) + "\"")
    否则:
        执行命令("ln -s \"" + 路径规范化(源路径) + "\" \"" + 路径规范化(链接路径) + "\"")

函程 创建硬链接(源路径, 链接路径): // 公开
    // 创建硬链接（仅文件，不支持目录）
    如果 是Windows平台():
        执行命令("mklink /H \"" + 路径规范化(链接路径) + "\" \"" + 路径规范化(源路径) + "\"")
    否则:
        执行命令("ln \"" + 路径规范化(源路径) + "\" \"" + 路径规范化(链接路径) + "\"")

// === 符号链接检测 ===

函程 是符号链接(路径): // 公开
    // 检查路径是否为符号链接
    如果 是Windows平台():
        设 结果 = 执行命令("dir /AL \"" + 路径规范化(路径) + "\" 2>nul")
        返回 包含(结果, "<SYMLINK>") 或 包含(结果, "<SYMLINKD>")
    否则:
        设 结果 = 执行命令("test -L \"" + 路径 + "\" && echo YES || echo NO")
        返回 包含(去除空白(结果), "YES")

函程 链接存在(路径): // 公开
    // 检查符号链接是否存在（即使目标不存在也返回真）
    如果 是Windows平台():
        设 结果 = 执行命令("dir /AL \"" + 路径规范化(路径) + "\" 2>nul")
        返回 包含(结果, "<SYMLINK>") 或 包含(结果, "<SYMLINKD>")
    否则:
        设 结果 = 执行命令("test -L \"" + 路径 + "\" && echo YES || echo NO")
        返回 包含(去除空白(结果), "YES")

// === 符号链接解析 ===

函程 解析链接(链接路径): // 公开
    // 解析符号链接指向的实际路径
    // Windows: 使用 dir 命令解析
    // Linux/macOS: 使用 readlink
    如果 是Windows平台():
        设 结果 = 执行命令("dir /AL \"" + 路径规范化(链接路径) + "\"")
        // 从 dir 输出中提取目标路径
        设 位置 = 查找(结果, "]")
        如果 位置 >= 0:
            设 子 = 子串(结果, 位置 + 1, 结果.长度() - 位置 - 1)
            返回 去除空白(子)
        返回 链接路径
    否则:
        设 结果 = 执行命令("readlink -f \"" + 链接路径 + "\"")
        返回 去除空白(结果)

函程 解析链接原始(链接路径): // 公开
    // 解析符号链接的原始目标（不递归解析）
    如果 是Windows平台():
        返回 解析链接(链接路径)
    否则:
        设 结果 = 执行命令("readlink \"" + 链接路径 + "\"")
        返回 去除空白(结果)

// === 链接复制 ===

函程 复制链接(源路径, 目标路径): // 公开
    // 复制符号链接（创建指向相同目标的新链接）
    设 目标 = 解析链接原始(源路径)
    创建符号链接(目标, 目标路径)

// === 辅助 ===

函程 是Windows平台(): // 内部
    设 系统 = 环境变量("OS")
    设 路径分隔 = 环境变量("PATH")
    返回 包含(转小写(系统), "windows") 或 包含(路径分隔, ";")

函程 去除空白(文本): // 内部
    返回 替换(替换(文本, " ", ""), "\n", "")
