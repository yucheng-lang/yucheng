// ===== 路径工具 =====

函程 目录树(路径, 缩进=0): // 公开
    // 以树形结构显示目录内容，返回字符串
    设 结果 = ""
    设 前缀 = ""
    遍 i 于 范围(缩进):
        前缀 = 前缀 + "  "
    遍 项目 于 目录列表(路径):
        设 名称 = 项目[0]
        设 类型 = 项目[1]
        如果 类型 == "目录":
            结果 = 结果 + 前缀 + "📁 " + 名称 + "/\n"
            设 子路径 = 路径合并(路径, 名称)
            结果 = 结果 + 目录树(子路径, 缩进 + 1)
        否则:
            结果 = 结果 + 前缀 + "📄 " + 名称 + "\n"
    返回 结果

// 辅助函数
函程 范围(开始, 结束): // 内部
    设 列表 = []
    设 计 = 开始
    循环 当 计 < 结束:
        列表.添加(计)
        计 = 计 + 1
    返回 列表
