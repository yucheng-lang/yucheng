函程 删除空目录(路径): // 公开
    // 仅当目录为空时删除
    设 内容 = 目录列表(路径)
    如果 长度(内容) == 0:
        删除目录(路径)
        返回 真
    返回 假

// ===== 目录移动与复制 =====

函程 移动目录(源路径, 目标路径): // 公开
    // 移动（重命名）目录
    重命名文件(源路径, 目标路径)

函程 复制目录(源路径, 目标路径): // 公开
    // 递归复制目录
    创建目录(目标路径)
    遍 项目 于 目录列表(源路径):
        设 名称 = 项目[0]
        设 类型 = 项目[1]
        设 源项 = 路径合并(源路径, 名称)
        设 目标项 = 路径合并(目标路径, 名称)
        如果 类型 == "目录":
            复制目录(源项, 目标项)
        否则:
            复制文件(源项, 目标项)

// ===== 目录遍历 =====

函程 遍历目录(路径): // 公开
    // 遍历目录，返回[[名称, 类型], ...]列表
    // 类型为 "文件" 或 "目录"
    返回 目录列表(路径)

函程 递归遍历(路径): // 公开
    // 递归遍历目录，返回所有文件的完整路径列表
    设 结果 = []
    遍 项目 于 目录列表(路径):
        设 名称 = 项目[0]
        设 类型 = 项目[1]
        设 完整路径 = 路径合并(路径, 名称)
        如果 类型 == "文件":
            结果.添加(完整路径)
        否则如果 类型 == "目录":
            设 子结果 = 递归遍历(完整路径)
            遍 子 于 子结果:
                结果.添加(子)
    返回 结果

函程 递归遍历目录(路径): // 公开
    // 递归遍历目录，返回所有子目录的完整路径列表
    设 结果 = []
    遍 项目 于 目录列表(路径):
        设 名称 = 项目[0]
        设 类型 = 项目[1]
        设 完整路径 = 路径合并(路径, 名称)
        如果 类型 == "目录":
            结果.添加(完整路径)
            设 子结果 = 递归遍历目录(完整路径)
            遍 子 于 子结果:
                结果.添加(子)
    返回 结果

// ===== 列表操作 =====

函程 列出文件(路径): // 公开
    // 列出目录中的所有文件名
    设 结果 = []
    遍 项目 于 目录列表(路径):
        如果 项目[1] == "文件":
            结果.添加(项目[0])
    返回 结果

函程 列出目录(路径): // 公开
    // 列出目录中的所有子目录名
    设 结果 = []
    遍 项目 于 目录列表(路径):
        如果 项目[1] == "目录":
            结果.添加(项目[0])
    返回 结果

函程 列出项目(路径): // 公开
    // 列出目录中的所有项目名（文件和目录）
    设 结果 = []
    遍 项目 于 目录列表(路径):
        结果.添加(项目[0])
    返回 结果

