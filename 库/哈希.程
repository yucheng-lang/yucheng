// ===== 语程标准库：哈希 =====
// 提供哈希计算与校验工具函数
//
// 公开接口：计算MD5、计算SHA1、计算SHA256、计算SHA512、计算CRC32、
//           哈希异或、组合哈希、文件MD5、文件SHA256、
//           验证MD5、验证SHA256、验证文件MD5、
//           加盐哈希、双重哈希、简短哈希、标识哈希

// ===== 哈希计算 =====

函程 计算MD5(文本): // 公开
    返回 MD5(文本)

函程 计算SHA1(文本): // 公开
    返回 SHA1(文本)

函程 计算SHA256(文本): // 公开
    返回 SHA256(文本)

函程 计算SHA512(文本): // 公开
    返回 SHA512(文本)

函程 计算CRC32(文本): // 公开
    返回 CRC32(文本)

// ===== 哈希组合 =====

函程 哈希异或(哈希1, 哈希2): // 公开
    返回 哈希(哈希1 + "|" + 哈希2)

函程 组合哈希(值列表): // 公开
    如果 数组长度(值列表) == 0:
        返回 ""
    设 结果 = 转字符串(值列表[0])
    设 i = 1
    循环 i < 数组长度(值列表):
        结果 = 结果 + "|" + 转字符串(值列表[i])
        i = i + 1
    返回 MD5(结果)

// ===== 文件哈希 =====

函程 文件MD5(路径): // 公开
    设 内容 = 读取文件(路径)
    返回 MD5(内容)

函程 文件SHA256(路径): // 公开
    设 内容 = 读取文件(路径)
    返回 SHA256(内容)

// ===== 哈希校验 =====

函程 验证MD5(文本, 期望哈希): // 公开
    返回 MD5(文本) == 期望哈希

函程 验证SHA256(文本, 期望哈希): // 公开
    返回 SHA256(文本) == 期望哈希

函程 验证文件MD5(路径, 期望哈希): // 公开
    返回 文件MD5(路径) == 期望哈希

// ===== 密码哈希 =====

函程 加盐哈希(文本, 盐): // 公开
    返回 SHA256(盐 + 文本 + 盐)

函程 双重哈希(文本): // 公开
    设 第一 = SHA256(文本)
    返回 SHA256(第一)

// ===== 哈希摘要 =====

函程 简短哈希(文本): // 公开
    设 完整 = MD5(文本)
    返回 子串(完整, 0, 8)

函程 标识哈希(内容): // 公开
    设 时间 = 转字符串(时间戳())
    设 源 = 时间 + "|" + 内容 + "|" + 转字符串(随机数())
    返回 SHA256(源)
