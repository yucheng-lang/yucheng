// ===== 语程标准库：复数 =====
// 提供复数运算工具函数
//
// 公开接口：创建复数、复数实部、复数虚部、
//           复数加、复数减、复数乘、复数除、
//           复数模、复数共轭、复数平方、
//           复数转字符串、复数相等

// ===== 复数构造与提取 =====
// 复数用列表 [实部, 虚部] 表示

函程 创建复数(实部, 虚部): // 公开
    返回 [实部, 虚部]

函程 复数实部(复数): // 公开
    返回 复数[0]

函程 复数虚部(复数): // 公开
    返回 复数[1]

// ===== 复数运算 =====

函程 复数加(a, b): // 公开
    返回 [复数实部(a) + 复数实部(b), 复数虚部(a) + 复数虚部(b)]

函程 复数减(a, b): // 公开
    返回 [复数实部(a) - 复数实部(b), 复数虚部(a) - 复数虚部(b)]

函程 复数乘(a, b): // 公开
    设 ar = 复数实部(a)
    设 ai = 复数虚部(a)
    设 br = 复数实部(b)
    设 bi = 复数虚部(b)
    返回 [ar * br - ai * bi, ai * br + ar * bi]

函程 复数除(a, b): // 公开
    设 ar = 复数实部(a)
    设 ai = 复数虚部(a)
    设 br = 复数实部(b)
    设 bi = 复数虚部(b)
    设 分母 = br * br + bi * bi
    如果 分母 == 0:
        返回 [0, 0]
    设 实 = (ar * br + ai * bi) / 分母
    设 虚 = (ai * br - ar * bi) / 分母
    返回 [实, 虚]

// ===== 复数属性 =====

函程 复数模(复数): // 公开
    设 r = 复数实部(复数)
    设 i = 复数虚部(复数)
    返回 平方根(r * r + i * i)

函程 复数模平方(复数): // 公开
    设 r = 复数实部(复数)
    设 i = 复数虚部(复数)
    返回 r * r + i * i

函程 复数共轭(复数): // 公开
    返回 [复数实部(复数), -复数虚部(复数)]

函程 复数平方(复数): // 公开
    返回 复数乘(复数, 复数)

函程 复数倒数(复数): // 公开
    返回 复数除([1, 0], 复数)

// ===== 复数判断 =====

函程 复数相等(a, b): // 公开
    返回 复数实部(a) == 复数实部(b) 且 复数虚部(a) == 复数虚部(b)

函程 复数为零(复数): // 公开
    返回 复数实部(复数) == 0 且 复数虚部(复数) == 0

// ===== 格式化 =====

函程 复数转字符串(复数): // 公开
    设 r = 复数实部(复数)
    设 i = 复数虚部(复数)
    设 结果 = "(" + 转字符串(r) + ", " + 转字符串(i) + ")"
    返回 结果
