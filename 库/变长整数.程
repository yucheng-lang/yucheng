// 变长整数 - VarInt编码实现（灵感来自SQLite）
// 提供可变长度整数编码/解码和ZigZag编码
//
// 公开接口：写入变长整数、读取变长整数、
//           ZigZag编码、ZigZag解码、
//           整数转字节列表、字节列表转整数

// === 常量 ===

函程 最大变长长度(): // 公开
    // 变长整数最多占用的字节数
    返回 9

// === 字节操作辅助 ===

函程 取低八位(值): // 内部
    // 取值的低8位（等效于 cast[uint8]）
    返回 位与(值, 255)

函程 无符号右移(值, 位数): // 内部
    // 模拟无符号右移（将值视为正整数后右移）
    如果 值 >= 0:
        返回 位右移(值, 位数)
    // 负数：先转为等价的无符号表示再右移
    设 掩码 = 位左移(1, 32 - 位数) - 1
    返回 位或(位右移(位与(值, 掩码), 位数), 位左移(掩码 + 1, 32 - 位数))

// === VarInt 写入 ===

函程 写入变长整数(值): // 公开
    // 将整数编码为VarInt字节列表
    // 返回字节数组
    如果 值 <= 240:
        返回 [值]
    如果 值 <= 2287:
        设 y = 值 - 240
        返回 [位或(位右移(y, 8) + 241, 0), 取低八位(y)]
    如果 值 <= 67823:
        设 y = 值 - 2288
        返回 [249, 取低八位(位右移(y, 8)), 取低八位(y)]
    // 更大值：按4字节分组处理
    设 结果 = []
    如果 值 <= 16777215:
        结果.添加(250)
        结果.添加(取低八位(位右移(值, 16)))
        结果.添加(取低八位(位右移(值, 8)))
        结果.添加(取低八位(值))
        返回 结果
    如果 值 <= 4294967295:
        结果.添加(251)
        结果.添加(取低八位(位右移(值, 24)))
        结果.添加(取低八位(位右移(值, 16)))
        结果.添加(取低八位(位右移(值, 8)))
        结果.添加(取低八位(值))
        返回 结果
    如果 值 <= 1099511627775:
        结果.添加(252)
        设 高 = 位右移(值, 32)
        结果.添加(取低八位(高))
        结果.添加(取低八位(位右移(值, 24)))
        结果.添加(取低八位(位右移(值, 16)))
        结果.添加(取低八位(位右移(值, 8)))
        结果.添加(取低八位(值))
        返回 结果
    如果 值 <= 281474976710655:
        结果.添加(253)
        设 高 = 位右移(值, 32)
        结果.添加(取低八位(位右移(高, 8)))
        结果.添加(取低八位(高))
        结果.添加(取低八位(位右移(值, 24)))
        结果.添加(取低八位(位右移(值, 16)))
        结果.添加(取低八位(位右移(值, 8)))
        结果.添加(取低八位(值))
        返回 结果
    如果 值 <= 72057594037927935:
        结果.添加(254)
        设 高 = 位右移(值, 32)
        结果.添加(取低八位(位右移(高, 16)))
        结果.添加(取低八位(位右移(高, 8)))
        结果.添加(取低八位(高))
        结果.添加(取低八位(位右移(值, 24)))
        结果.添加(取低八位(位右移(值, 16)))
        结果.添加(取低八位(位右移(值, 8)))
        结果.添加(取低八位(值))
        返回 结果
    // 最大值：9字节
    结果.添加(255)
    设 高 = 位右移(值, 32)
    结果.添加(取低八位(位右移(高, 24)))
    结果.添加(取低八位(位右移(高, 16)))
    结果.添加(取低八位(位右移(高, 8)))
    结果.添加(取低八位(高))
    结果.添加(取低八位(位右移(值, 24)))
    结果.添加(取低八位(位右移(值, 16)))
    结果.添加(取低八位(位右移(值, 8)))
    结果.添加(取低八位(值))
    返回 结果

// === VarInt 读取 ===

函程 读取变长整数(字节列表): // 公开
    // 从字节列表读取VarInt编码的整数
    // 返回 {值: 整数值, 长度: 消耗的字节数}
    设 z = 字节列表
    如果 z.长度() == 0:
        返回 {值: 0, 长度: 0}
    如果 z[0] <= 240:
        返回 {值: z[0], 长度: 1}
    如果 z[0] <= 248:
        如果 z.长度() < 2:
            返回 {值: 0, 长度: 0}
        设 值 = (z[0] - 241) * 256 + z[1] + 240
        返回 {值: 值, 长度: 2}
    如果 z.长度() < z[0] - 246:
        返回 {值: 0, 长度: 0}
    如果 z[0] == 249:
        设 值 = 2288 + 256 * z[1] + z[2]
        返回 {值: 值, 长度: 3}
    如果 z[0] == 250:
        设 值 = 位或(位左移(z[1], 16), 位或(位左移(z[2], 8), z[3]))
        返回 {值: 值, 长度: 4}
    设 x = 位或(位左移(z[1], 24), 位或(位左移(z[2], 16), 位或(位左移(z[3], 8), z[4])))
    如果 z[0] == 251:
        返回 {值: x, 长度: 5}
    如果 z[0] == 252:
        设 值 = 位或(位左移(x, 8), z[5])
        返回 {值: 值, 长度: 6}
    如果 z[0] == 253:
        设 值 = 位或(位左移(x, 16), 位或(位左移(z[5], 8), z[6]))
        返回 {值: 值, 长度: 7}
    如果 z[0] == 254:
        设 值 = 位或(位左移(x, 24), 位或(位左移(z[5], 16), 位或(位左移(z[6], 8), z[7])))
        返回 {值: 值, 长度: 8}
    // z[0] == 255
    设 低 = 位或(位左移(z[5], 24), 位或(位左移(z[6], 16), 位或(位左移(z[7], 8), z[8])))
    设 值 = 位或(位左移(x, 32), 位与(低, 4294967295))
    返回 {值: 值, 长度: 9}

// === ZigZag 编码 ===
// 将有符号整数映射为无符号整数，使绝对值小的数编码后也小

函程 ZigZag编码(值): // 公开
    // 有符号整数 → 无符号整数
    // 0→0, -1→1, 1→2, -2→3, 2→4, ...
    如果 值 >= 0:
        返回 位左移(值, 1)
    返回 位异或(位左移(0 - 值, 1), 1)

函程 ZigZag解码(值): // 公开
    // 无符号整数 → 有符号整数
    // ZigZag编码的逆操作
    如果 位与(值, 1) == 0:
        返回 位右移(值, 1)
    返回 0 - 位右移(值 + 1, 1)

// === 整数与字节列表互转 ===

函程 整数转字节列表(值, 字节数 = 4): // 公开
    // 将整数拆分为字节列表（大端序）
    设 结果 = []
    设 i = 字节数 - 1
    循环 当 i >= 0:
        结果.添加(取低八位(位右移(值, i * 8)))
        i = i - 1
    设 翻转 = []
    设 j = 0
    循环 当 j < 结果.长度():
        翻转.添加(结果[结果.长度() - 1 - j])
        j = j + 1
    返回 翻转

函程 字节列表转整数(字节列表): // 公开
    // 将字节列表（大端序）合并为整数
    设 结果 = 0
    遍 字节 于 字节列表:
        结果 = 位或(位左移(结果, 8), 位与(字节, 255))
    返回 结果

// === 编解码组合工具 ===

函程 编码有符号整数(值): // 公开
    // 先ZigZag编码再VarInt编码，适合有符号整数的紧凑存储
    返回 写入变长整数(ZigZag编码(值))

函程 解码有符号整数(字节列表): // 公开
    // VarInt解码再ZigZag解码
    设 读取结果 = 读取变长整数(字节列表)
    返回 {值: ZigZag解码(读取结果.值), 长度: 读取结果.长度}
