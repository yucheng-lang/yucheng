// 流操作工具
// 提供字符串流、文件流等流式读写功能
// 注意：由于语程字典值传递特性，修改流状态的函数需要返回流对象

导入 "文件操作"
导入 "路径"

// === 字符串流 ===

函程 创建字符串流(内容 = ""): // 公开
    // 创建基于字符串的流
    返回 {
        内容: 内容,
        位置: 0,
        类型: "字符串流"
    }

函程 流读取(流, 长度): // 公开
    // 从流中读取指定长度的数据，返回 [数据, 新流]
    如果 流.类型 == "字符串流":
        如果 流.位置 >= 流.内容.长度():
            返回 ["", 流]
        设 可读 = 流.内容.长度() - 流.位置
        设 实际长度 = 最小值(长度, 可读)
        设 数据 = 流.内容.子串(流.位置, 实际长度)
        设 新流 = 流
        新流.位置 = 流.位置 + 实际长度
        返回 [数据, 新流]
    返回 ["", 流]

函程 流读取全部(流): // 公开
    // 读取流中剩余所有数据，返回 [数据, 新流]
    如果 流.类型 == "字符串流":
        设 数据 = 流.内容.子串(流.位置)
        设 新流 = 流
        新流.位置 = 流.内容.长度()
        返回 [数据, 新流]
    返回 ["", 流]

函程 流读取行(流): // 公开
    // 从流中读取一行，返回 [行, 新流]
    如果 流.类型 == "字符串流":
        如果 流.位置 >= 流.内容.长度():
            返回 ["", 流]
        设 剩余 = 流.内容.子串(流.位置)
        设 换行位 = 剩余.查找("\n")
        设 新流 = 流
        如果 换行位 < 0:
            设 行 = 剩余
            新流.位置 = 流.内容.长度()
        否则:
            设 行 = 剩余.子串(0, 换行位)
            新流.位置 = 流.位置 + 换行位 + 1
        // 去除可能的 \r
        如果 行.长度() > 0 且 行[行.长度()-1] == "\r":
            行 = 行.子串(0, 行.长度()-1)
        返回 [行, 新流]
    返回 ["", 流]

函程 流写入(流, 数据): // 公开
    // 向流写入数据，返回新流
    如果 流.类型 == "字符串流":
        设 新流 = 流
        如果 流.位置 >= 流.内容.长度():
            新流.内容 = 流.内容 + 数据
        否则:
            新流.内容 = 流.内容.子串(0, 流.位置) + 数据 + 流.内容.子串(流.位置 + 数据.长度())
        新流.位置 = 流.位置 + 数据.长度()
        返回 新流
    返回 流

函程 流写入行(流, 行): // 公开
    // 向流写入一行（自动追加换行），返回新流
    返回 流写入(流, 行 + "\n")

函程 流位置(流): // 公开
    // 获取当前读写位置
    返回 流.位置

函程 流定位(流, 位置): // 公开
    // 设置读写位置，返回新流
    设 新流 = 流
    如果 位置 < 0:
        位置 = 0
    如果 位置 > 流.内容.长度():
        位置 = 流.内容.长度()
    新流.位置 = 位置
    返回 新流

函程 流跳过(流, 偏移): // 公开
    // 相对移动读写位置，返回新流
    返回 流定位(流, 流.位置 + 偏移)

函程 流回到开头(流): // 公开
    返回 流定位(流, 0)

函程 流到末尾(流): // 公开
    返回 流定位(流, 流.内容.长度())

函程 流大小(流): // 公开
    返回 流.内容.长度()

函程 非流结束(流): // 公开
    // 是否还有数据可读
    返回 流.位置 < 流.内容.长度()

函程 流清空(流): // 公开
    设 新流 = 流
    新流.内容 = ""
    新流.位置 = 0
    返回 新流

// === 文件流 ===

函程 创建文件流(文件路径, 模式 = "读"): // 公开
    // 创建文件流，模式为"读"/"写"/"追加"
    返回 {
        路径: 文件路径,
        模式: 模式,
        类型: "文件流",
        缓冲: "",
        位置: 0,
        已修改: 假
    }

函程 文件流打开(流): // 公开
    // 打开文件流，加载内容到缓冲，返回新流
    设 新流 = 流
    如果 流.模式 == "读" 或 流.模式 == "写":
        如果 文件操作.文件存在(流.路径):
            新流.缓冲 = 文件操作.读取文件(流.路径)
        否则:
            新流.缓冲 = ""
    否则 如果 流.模式 == "追加":
        如果 文件操作.文件存在(流.路径):
            新流.缓冲 = 文件操作.读取文件(流.路径)
        否则:
            新流.缓冲 = ""
        新流.位置 = 新流.缓冲.长度()
    返回 新流

函程 文件流读取(流, 长度): // 公开
    // 从文件流读取，返回 [数据, 新流]
    设 可读 = 流.缓冲.长度() - 流.位置
    设 实际 = 最小值(长度, 可读)
    如果 实际 <= 0:
        返回 ["", 流]
    设 数据 = 流.缓冲.子串(流.位置, 实际)
    设 新流 = 流
    新流.位置 = 流.位置 + 实际
    返回 [数据, 新流]

函程 文件流读取行(流): // 公开
    // 从文件流读取一行，返回 [行, 新流]
    如果 流.位置 >= 流.缓冲.长度():
        返回 ["", 流]
    设 剩余 = 流.缓冲.子串(流.位置)
    设 换行位 = 剩余.查找("\n")
    设 新流 = 流
    如果 换行位 < 0:
        设 行 = 剩余
        新流.位置 = 流.缓冲.长度()
    否则:
        设 行 = 剩余.子串(0, 换行位)
        新流.位置 = 流.位置 + 换行位 + 1
    如果 行.长度() > 0 且 行[行.长度()-1] == "\r":
        行 = 行.子串(0, 行.长度()-1)
    返回 [行, 新流]

函程 文件流写入(流, 数据): // 公开
    // 向文件流写入，返回新流
    设 新流 = 流
    如果 流.位置 >= 流.缓冲.长度():
        新流.缓冲 = 流.缓冲 + 数据
    否则:
        新流.缓冲 = 流.缓冲.子串(0, 流.位置) + 数据 + 流.缓冲.子串(流.位置 + 数据.长度())
    新流.位置 = 流.位置 + 数据.长度()
    新流.已修改 = 真
    返回 新流

函程 文件流写入行(流, 行): // 公开
    返回 文件流写入(流, 行 + "\n")

函程 文件流刷新(流): // 公开
    // 将缓冲写入文件，返回新流
    设 新流 = 流
    如果 流.已修改:
        文件操作.写入文件(流.路径, 流.缓冲)
        新流.已修改 = 假
    返回 新流

函程 文件流关闭(流): // 公开
    // 关闭文件流，自动刷新
    设 新流 = 文件流刷新(流)
    新流.缓冲 = ""
    新流.位置 = 0
    返回 新流

函程 文件流位置(流): // 公开
    返回 流.位置

函程 文件流定位(流, 位置): // 公开
    设 新流 = 流
    新流.位置 = 位置
    返回 新流

函程 非文件流结束(流): // 公开
    返回 流.位置 < 流.缓冲.长度()

// === 辅助函数 ===

函程 最小值(a, b): // 内部
    如果 a < b:
        返回 a
    返回 b

// === 内存流 ===

函程 创建内存流(): // 公开
    // 创建内存流（等同于空字符串流）
    返回 创建字符串流("")

函程 流复制(源流, 目标流, 块大小 = 4096): // 公开
    // 将源流数据复制到目标流，返回 [源流, 目标流]
    设 当前源 = 源流
    设 当前目标 = 目标流
    循环 当 非流结束(当前源):
        设 结果 = 流读取(当前源, 块大小)
        设 数据 = 结果[0]
        当前源 = 结果[1]
        当前目标 = 流写入(当前目标, 数据)
    返回 [当前源, 当前目标]

函程 流转字符串(流): // 公开
    // 将流内容转为字符串
    返回 流.内容

函程 字符串转流(文本): // 公开
    // 将字符串转为流
    返回 创建字符串流(文本)
