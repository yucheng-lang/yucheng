// SSL工具 - HTTPS安全连接工具
// 语程已有 HTTP请求() 内置函数支持 HTTPS，
// 此库在此基础上提供更高级的 SSL/TLS 工具函数。
// 语程对象按值传递，修改对象的函数返回修改后的对象。

// === HTTPS请求 ===

函程 HTTPS获取(地址, 头部): // 公开
    如果 头部 == 空:
        头部 = ""
    返回 HTTP请求("GET", 地址, "", 头部)

函程 HTTPS提交(地址, 数据, 头部): // 公开
    如果 头部 == 空 或 头部 == "":
        头部 = "Content-Type: application/x-www-form-urlencoded"
    返回 HTTP请求("POST", 地址, 数据, 头部)

函程 HTTPS提交JSON(地址, 数据, 头部): // 公开
    如果 头部 == 空 或 头部 == "":
        头部 = "Content-Type: application/json"
    返回 HTTP请求("POST", 地址, 数据, 头部)

函程 HTTPS放置(地址, 数据, 头部): // 公开
    如果 头部 == 空:
        头部 = ""
    返回 HTTP请求("PUT", 地址, 数据, 头部)

函程 HTTPS删除(地址, 头部): // 公开
    如果 头部 == 空:
        头部 = ""
    返回 HTTP请求("DELETE", 地址, "", 头部)

// === URL安全检查 ===

函程 是HTTPS(地址): // 公开
    返回 开头是(地址, "https://")

函程 是HTTP(地址): // 公开
    返回 开头是(地址, "http://")

函程 升级HTTPS(地址): // 公开
    如果 开头是(地址, "http://"):
        返回 "https://" + 子串(地址, 7)
    返回 地址

函程 强制HTTPS(地址): // 公开
    如果 是HTTPS(地址):
        返回 地址
    返回 升级HTTPS(地址)

// === SSL/TLS配置 ===

函程 安全配置(级别): // 公开
    如果 级别 == "现代":
        返回 {
            最低版本: "TLS1.3",
            推荐版本: "TLS1.3",
            密码套件: "TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384",
            最低客户端: "Firefox 63, Chrome 70, Safari 12.1"
        }
    否则 如果 级别 == "旧版":
        返回 {
            最低版本: "TLS1.0",
            推荐版本: "TLS1.2",
            密码套件: "全部套件（包括3DES）",
            最低客户端: "几乎所有浏览器"
        }
    否则:
        返回 {
            最低版本: "TLS1.2",
            推荐版本: "TLS1.2",
            密码套件: "ECDHE-ECDSA-AES128-GCM-SHA256",
            最低客户端: "Firefox 27, Chrome 31, Safari 9"
        }

// === 安全请求构建器 ===

函程 创建安全请求(地址): // 公开
    返回 {
        地址: 地址,
        方法: "GET",
        头部: {},
        数据: "",
        超时: 30
    }

函程 设置方法(请求, 方法): // 公开
    请求.方法 = 方法
    返回 请求

函程 设置头部(请求, 键, 值): // 公开
    请求.头部[键] = 值
    返回 请求

函程 设置数据(请求, 数据): // 公开
    请求.数据 = 数据
    返回 请求

函程 执行安全请求(请求): // 公开
    设 头部串 = ""
    遍 键, 值 于 请求.头部:
        如果 长度(头部串) > 0:
            头部串 = 头部串 + "\r\n"
        头部串 = 头部串 + 键 + ": " + 值
    返回 HTTP请求(请求.方法, 请求.地址, 请求.数据, 头部串)
