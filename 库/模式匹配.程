// ===== 语程标准库：模式匹配 =====
// 提供 Rust 风格的 Option 和 Result 类型
// 借鉴空灵语言 match 库的设计思想
//
// 公开接口：有值、无值、有结果、错误结果、
//           是有值、是无值、获取值、获取默认值、
//           映射、过滤、存在判断、全满足、
//           是成功、是失败、获取结果、获取错误、
//           结果映射、错误映射、
//           期望值、选项工具

// === Option 类型 ===
// Option 使用字典表示：{类型: "some", 值: v} 或 {类型: "none"}

函程 有值(值): // 公开
    // 创建一个有值的 Option（Some）
    返回 {类型: "some", 值: 值}

函程 无值(): // 公开
    // 创建一个无值的 Option（None）
    返回 {类型: "none"}

函程 是有值(选项): // 公开
    // 检查 Option 是否有值
    返回 选项.获取默认值("类型", "") == "some"

函程 是无值(选项): // 公开
    // 检查 Option 是否无值
    返回 选项.获取默认值("类型", "") != "some"

函程 获取值(选项): // 公开
    // 获取 Option 的值，无值则抛出异常
    如果 是无值(选项):
        抛出 "Option 无值异常: 尝试对 None 调用获取值()"
    返回 选项.值

函程 获取默认值(选项, 默认): // 公开
    // 获取 Option 的值，无值则返回默认值
    如果 是有值(选项):
        返回 选项.值
    返回 默认

函程 获取或计算(选项, 计算函数): // 公开
    // 获取 Option 的值，无值则调用计算函数
    如果 是有值(选项):
        返回 选项.值
    返回 计算函数()

函程 或备选(选项, 备选): // 公开
    // 如果有值返回自身，无值返回备选 Option
    如果 是有值(选项):
        返回 选项
    返回 备选

函程 或计算备选(选项, 计算函数): // 公开
    // 如果有值返回自身，无值则调用计算函数获取备选
    如果 是有值(选项):
        返回 选项
    返回 计算函数()

函程 映射(选项, 转换函数): // 公开
    // 如果有值，对值应用转换函数
    如果 是有值(选项):
        返回 有值(转换函数(选项.值))
    返回 无值()

函程 绑定(选项, 转换函数): // 公开
    // 如果有值，对值应用转换函数（返回 Option），类似 flatMap
    如果 是有值(选项):
        返回 转换函数(选项.值)
    返回 无值()

函程 过滤(选项, 条件函数): // 公开
    // 如果有值且满足条件，返回自身；否则返回无值
    如果 是有值(选项):
        如果 条件函数(选项.值):
            返回 选项
        返回 无值()
    返回 无值()

函程 存在判断(选项, 条件函数): // 公开
    // 检查是否有值且满足条件
    如果 是有值(选项):
        返回 条件函数(选项.值)
    返回 假

函程 全满足(选项, 条件函数): // 公开
    // 检查无值或有值且满足条件（None 视为真）
    如果 是无值(选项):
        返回 真
    返回 条件函数(选项.值)

函程 合并(选项甲, 选项乙): // 公开
    // 将两个 Option 合并为元组 Option
    如果 是有值(选项甲) 且 是有值(选项乙):
        返回 有值([选项甲.值, 选项乙.值])
    返回 无值()

函程 拆分(选项元组): // 公开
    // 将元组 Option 拆分为两个 Option
    如果 是有值(选项元组):
        设 元组 = 选项元组.值
        返回 [有值(元组[0]), 有值(元组[1])]
    返回 [无值(), 无值()]

// === Result 类型 ===
// Result 使用字典表示：{类型: "ok", 值: v} 或 {类型: "err", 错误: e}

函程 成功结果(值): // 公开
    // 创建一个成功的 Result（Ok）
    返回 {类型: "ok", 值: 值}

函程 失败结果(错误): // 公开
    // 创建一个失败的 Result（Err）
    返回 {类型: "err", 错误: 错误}

函程 是成功(结果): // 公开
    // 检查 Result 是否成功
    返回 结果.获取默认值("类型", "") == "ok"

函程 是失败(结果): // 公开
    // 检查 Result 是否失败
    返回 结果.获取默认值("类型", "") != "ok"

函程 获取结果(结果): // 公开
    // 获取 Result 的成功值，失败则抛出异常
    如果 是失败(结果):
        抛出 "Result 异常: " + 转文本(结果.获取默认值("错误", "未知错误"))
    返回 结果.值

函程 获取错误(结果): // 公开
    // 获取 Result 的错误值
    如果 是成功(结果):
        抛出 "Result 成功时无错误"
    返回 结果.错误

函程 结果默认值(结果, 默认): // 公开
    // 获取 Result 的值，失败则返回默认值
    如果 是成功(结果):
        返回 结果.值
    返回 默认

函程 结果或计算(结果, 计算函数): // 公开
    // 获取 Result 的值，失败则调用计算函数
    如果 是成功(结果):
        返回 结果.值
    返回 计算函数()

函程 结果映射(结果, 转换函数): // 公开
    // 如果成功，对值应用转换函数
    如果 是成功(结果):
        返回 成功结果(转换函数(结果.值))
    返回 结果

函程 错误映射(结果, 转换函数): // 公开
    // 如果失败，对错误应用转换函数
    如果 是失败(结果):
        返回 失败结果(转换函数(结果.错误))
    返回 结果

函程 结果绑定(结果, 转换函数): // 公开
    // 如果成功，对值应用转换函数（返回 Result）
    如果 是成功(结果):
        返回 转换函数(结果.值)
    返回 结果

函程 结果过滤(结果, 条件函数, 错误消息="值不满足条件"): // 公开
    // 如果成功且满足条件，返回自身；否则返回失败
    如果 是成功(结果):
        如果 条件函数(结果.值):
            返回 结果
        返回 失败结果(错误消息)
    返回 结果

函程 合并结果(结果甲, 结果乙): // 公开
    // 合并两个 Result，任一失败则返回第一个失败
    如果 是失败(结果甲):
        返回 结果甲
    如果 是失败(结果乙):
        返回 结果乙
    返回 成功结果([结果甲.值, 结果乙.值])

// === 期望值类型 ===
// 期望值 = Option + 错误消息，类似 Result 但更轻量

函程 期望值(值, 错误消息="值不存在"): // 公开
    // 创建期望值：有值返回成功，空值返回失败
    如果 值 == 空 或 值 == "":
        返回 失败结果(错误消息)
    返回 成功结果(值)

函程 期望非空(值, 错误消息="值不能为空"): // 公开
    // 期望值不为空
    如果 值 == 空 或 (转文本(值) == "0" 且 类型(值) == "number"):
        返回 成功结果(值)
    如果 值 == 空:
        返回 失败结果(错误消息)
    返回 成功结果(值)

// === 便捷转换 ===

函程 结果转选项(结果): // 公开
    // 将 Result 转换为 Option
    如果 是成功(结果):
        返回 有值(结果.值)
    返回 无值()

函程 选项转结果(选项, 错误消息="值不存在"): // 公开
    // 将 Option 转换为 Result
    如果 是有值(选项):
        返回 成功结果(选项.值)
    返回 失败结果(错误消息)

函程 安全执行(函数): // 公开
    // 安全执行函数，捕获异常并返回 Result
    尝试:
        设 结果 = 函数()
        返回 成功结果(结果)
    捕获 错误:
        返回 失败结果(转文本(错误))
