// XML工具
// 提供XML解析、生成、查询功能

// === XML节点 ===

函程 创建节点(标签名, 属性 = {}, 子节点 = [], 文本 = ""): // 公开
    // 创建XML节点
    返回 {
        标签: 标签名,
        属性: 属性,
        子节点: 子节点,
        文本: 文本
    }

函程 节点添加子节点(父节点, 子节点): // 公开
    父节点.子节点.添加(子节点)
    返回 父节点

函程 节点设置属性(节点, 属性名, 属性值): // 公开
    节点.属性[属性名] = 属性值
    返回 节点

函程 节点获取属性(节点, 属性名, 默认值 = ""): // 公开
    如果 节点.属性.包含(属性名):
        返回 节点.属性[属性名]
    返回 默认值

函程 节点文本内容(节点): // 公开
    // 获取节点及其子节点的全部文本
    设 结果 = 节点.文本
    循环 子 于 节点.子节点:
        结果 = 结果 + 节点文本内容(子)
    返回 结果

函程 查找子节点(节点, 标签名): // 公开
    // 查找指定标签名的直接子节点
    设 结果 = []
    循环 子 于 节点.子节点:
        如果 子.标签 == 标签名:
            结果.添加(子)
    返回 结果

函程 查找第一个(节点, 标签名): // 公开
    // 查找第一个指定标签名的子节点
    循环 子 于 节点.子节点:
        如果 子.标签 == 标签名:
            返回 子
    返回 空

函程 递归查找(节点, 标签名): // 公开
    // 递归查找所有匹配的节点
    设 结果 = []
    如果 节点.标签 == 标签名:
        结果.添加(节点)
    循环 子 于 节点.子节点:
        设 子结果 = 递归查找(子, 标签名)
        循环 项 于 子结果:
            结果.添加(项)
    返回 结果

// === XML解析 ===

函程 解析XML(文本): // 公开
    // 解析XML文本为节点树
    设 状态 = {
        文本: 文本,
        位置: 0
    }
    跳过空白(状态)
    返回 解析节点(状态)

函程 解析节点(状态): // 内部
    跳过空白(状态)
    如果 状态.位置 >= 状态.文本.长度():
        返回 空
    
    如果 状态.文本[状态.位置] != "<":
        // 文本节点
        设 文本开始 = 状态.位置
        循环 当 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] != "<":
            状态.位置 = 状态.位置 + 1
        设 内容 = 状态.文本.子串(文本开始, 状态.位置 - 文本开始).去除空白()
        如果 内容.长度() == 0:
            返回 空
        返回 创建节点("#text", {}, [], 内容)
    
    // 跳过 <
    状态.位置 = 状态.位置 + 1
    
    // 处理注释 <!-- -->
    如果 状态.位置 + 2 < 状态.文本.长度() 且 状态.文本.子串(状态.位置, 3) == "!--":
        设 注释结束 = 状态.文本.子串(状态.位置).查找("-->")
        如果 注释结束 >= 0:
            状态.位置 = 状态.位置 + 注释结束 + 3
            跳过空白(状态)
            返回 解析节点(状态)
        返回 空
    
    // 处理声明 <?xml ... ?>
    如果 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] == "?":
        设 声明结束 = 状态.文本.子串(状态.位置).查找("?>")
        如果 声明结束 >= 0:
            状态.位置 = 状态.位置 + 声明结束 + 2
            跳过空白(状态)
            返回 解析节点(状态)
        返回 空
    
    // 处理CDATA <![CDATA[ ... ]]>
    如果 状态.位置 + 7 < 状态.文本.长度() 且 状态.文本.子串(状态.位置, 8) == "![CDATA[":
        设 数据结束 = 状态.文本.子串(状态.位置).查找("]]>")
        如果 数据结束 >= 0:
            设 内容 = 状态.文本.子串(状态.位置 + 8, 数据结束 - 8)
            状态.位置 = 状态.位置 + 数据结束 + 3
            返回 创建节点("#cdata", {}, [], 内容)
        返回 空
    
    // 读取标签名
    设 名开始 = 状态.位置
    循环 当 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] != " " 且 状态.文本[状态.位置] != ">" 且 状态.文本[状态.位置] != "/":
        状态.位置 = 状态.位置 + 1
    设 标签名 = 状态.文本.子串(名开始, 状态.位置 - 名开始)
    
    如果 标签名.长度() == 0:
        返回 空
    
    // 读取属性
    设 属性 = {}
    循环 当 真:
        跳过空白(状态)
        如果 状态.位置 >= 状态.文本.长度():
            跳出
        如果 状态.文本[状态.位置] == ">" 或 状态.文本[状态.位置] == "/":
            跳出
        // 读取属性名
        设 属名开始 = 状态.位置
        循环 当 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] != "=" 且 状态.文本[状态.位置] != " " 且 状态.文本[状态.位置] != ">":
            状态.位置 = 状态.位置 + 1
        设 属性名 = 状态.文本.子串(属名开始, 状态.位置 - 属名开始)
        如果 属性名.长度() == 0:
            跳出
        跳过空白(状态)
        如果 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] == "=":
            状态.位置 = 状态.位置 + 1
            跳过空白(状态)
            // 读取属性值
            设 属性值 = ""
            如果 状态.位置 < 状态.文本.长度() 且 (状态.文本[状态.位置] == "\"" 或 状态.文本[状态.位置] == "'"):
                设 引号 = 状态.文本[状态.位置]
                状态.位置 = 状态.位置 + 1
                设 值开始 = 状态.位置
                循环 当 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] != 引号:
                    状态.位置 = 状态.位置 + 1
                属性值 = 状态.文本.子串(值开始, 状态.位置 - 值开始)
                如果 状态.位置 < 状态.文本.长度():
                    状态.位置 = 状态.位置 + 1
            否则:
                设 值开始 = 状态.位置
                循环 当 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] != " " 且 状态.文本[状态.位置] != ">":
                    状态.位置 = 状态.位置 + 1
                属性值 = 状态.文本.子串(值开始, 状态.位置 - 值开始)
            属性[属性名] = XML反转义(属性值)
    
    跳过空白(状态)
    
    // 检查自闭合
    如果 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] == "/":
        状态.位置 = 状态.位置 + 1
        如果 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] == ">":
            状态.位置 = 状态.位置 + 1
        返回 创建节点(标签名, 属性, [], "")
    
    // 跳过 >
    如果 状态.位置 < 状态.文本.长度() 且 状态.文本[状态.位置] == ">":
        状态.位置 = 状态.位置 + 1
    
    // 读取子节点
    设 子节点列表 = []
    循环 当 真:
        跳过空白(状态)
        // 检查闭合标签
        如果 状态.位置 + 1 < 状态.文本.长度() 且 状态.文本[状态.位置] == "<" 且 状态.文本[状态.位置 + 1] == "/":
            // 找到闭合标签
            设 闭合结束 = 状态.文本.子串(状态.位置).查找(">")
            如果 闭合结束 >= 0:
                状态.位置 = 状态.位置 + 闭合结束 + 1
            跳出
        设 子 = 解析节点(状态)
        如果 子 == 空:
            跳出
        子节点列表.添加(子)
    
    返回 创建节点(标签名, 属性, 子节点列表, "")

函程 跳过空白(状态): // 内部
    循环 当 状态.位置 < 状态.文本.长度() 且 (状态.文本[状态.位置] == " " 或 状态.文本[状态.位置] == "\n" 或 状态.文本[状态.位置] == "\r" 或 状态.文本[状态.位置] == "\t"):
        状态.位置 = 状态.位置 + 1

// === XML生成 ===

函程 生成XML(节点, 缩进 = 0, 缩进符 = "  "): // 公开
    // 将节点树生成XML字符串
    设 前缀 = ""
    循环 计 于 范围(0, 缩进):
        前缀 = 前缀 + 缩进符
    
    如果 节点.标签 == "#text":
        返回 前缀 + 节点.文本
    如果 节点.标签 == "#cdata":
        返回 前缀 + "<![CDATA[" + 节点.文本 + "]]>"
    
    设 属性串 = ""
    循环 键, 值 于 节点.属性:
        属性串 = 属性串 + " " + 键 + "=\"" + XML转义(值.转文本()) + "\""
    
    如果 节点.子节点.长度() == 0 且 节点.文本.长度() == 0:
        返回 前缀 + "<" + 节点.标签 + 属性串 + " />"
    
    如果 节点.子节点.长度() == 0 且 节点.文本.长度() > 0:
        返回 前缀 + "<" + 节点.标签 + 属性串 + ">" + XML转义(节点.文本) + "</" + 节点.标签 + ">"
    
    设 结果 = 前缀 + "<" + 节点.标签 + 属性串 + ">\n"
    循环 子 于 节点.子节点:
        结果 = 结果 + 生成XML(子, 缩进 + 1, 缩进符) + "\n"
    结果 = 结果 + 前缀 + "</" + 节点.标签 + ">"
    返回 结果

函程 生成XML文档(根节点, 编码 = "UTF-8"): // 公开
    // 生成完整XML文档（含声明）
    设 声明 = "<?xml version=\"1.0\" encoding=\"" + 编码 + "\"?>\n"
    返回 声明 + 生成XML(根节点)

// === XML实体 ===

函程 XML转义(文本): // 公开
    设 结果 = 文本
    结果 = 结果.替换("&", "&amp;")
    结果 = 结果.替换("<", "&lt;")
    结果 = 结果.替换(">", "&gt;")
    结果 = 结果.替换("\"", "&quot;")
    结果 = 结果.替换("'", "&apos;")
    返回 结果

函程 XML反转义(文本): // 公开
    设 结果 = 文本
    结果 = 结果.替换("&apos;", "'")
    结果 = 结果.替换("&quot;", "\"")
    结果 = 结果.替换("&gt;", ">")
    结果 = 结果.替换("&lt;", "<")
    结果 = 结果.替换("&amp;", "&")
    返回 结果

函程 范围(开始, 结束): // 内部
    设 列表 = []
    设 计 = 开始
    循环 当 计 < 结束:
        列表.添加(计)
        计 = 计 + 1
    返回 列表

函程 节点转字符串(节点): // 公开
    // 将节点树转为XML字符串
    返回 生成XML(节点)
