// ===== 语程标准库：安全访问 =====
// 提供安全的链式访问机制，防止空指针/空值引用错误
// 借鉴空灵语言 wrapnils 库的设计思想（安全访问运算符 ?.）
//
// 公开接口：安全获取、安全调用、安全链式获取、
//           空值默认、空值计算、
//           安全字典访问、安全列表访问、
//           空值检查、非空检查、
//           非空过滤、空值映射

// === 安全获取 ===

函程 安全获取(对象, 键, 默认值=空): // 公开
    如果 对象 == 空:
        返回 默认值
    如果 类型(对象) != "dict":
        返回 默认值
    返回 对象.获取默认值(键, 默认值)

函程 安全调用(对象, 方法名, 参数列表=[], 默认值=空): // 公开
    如果 对象 == 空:
        返回 默认值
    尝试:
        设 函数 = 安全获取(对象, 方法名)
        如果 函数 == 空:
            返回 默认值
        返回 函数(参数列表)
    捕获 错误:
        返回 默认值

函程 安全链式获取(对象, 键列表, 默认值=空): // 公开
    设 当前 = 对象
    循环 键 于 键列表:
        如果 当前 == 空:
            返回 默认值
        如果 类型(当前) != "dict":
            返回 默认值
        当前 = 当前.获取默认值(键, 空)
        如果 当前 == 空:
            返回 默认值
    返回 当前

// === 空值处理 ===

函程 空值默认(值, 默认): // 公开
    如果 值 == 空 或 值 == "":
        返回 默认
    返回 值

函程 空值计算(值, 计算函数): // 公开
    如果 值 == 空 或 值 == "":
        返回 计算函数()
    返回 值

函程 空值检查(值): // 公开
    如果 值 == 空:
        返回 真
    设 值类型 = 类型(值)
    如果 值类型 == "string" 且 值 == "":
        返回 真
    如果 值类型 == "list" 且 值.长度() == 0:
        返回 真
    如果 值类型 == "dict" 且 值.长度() == 0:
        返回 真
    返回 假

函程 非空检查(值): // 公开
    返回 不是 空值检查(值)

// === 安全容器操作 ===

函程 安全字典访问(字典, 键, 默认值=空): // 公开
    如果 字典 == 空 或 类型(字典) != "dict":
        返回 默认值
    返回 字典.获取默认值(键, 默认值)

函程 安全列表访问(列表, 索引, 默认值=空): // 公开
    如果 列表 == 空 或 类型(列表) != "list":
        返回 默认值
    设 整索引 = 转整数(索引)
    如果 整索引 < 0 或 整索引 >= 列表.长度():
        返回 默认值
    返回 列表[整索引]

函程 安全列表切片(列表, 起始, 结束, 默认值=[]): // 公开
    如果 列表 == 空 或 类型(列表) != "list":
        返回 默认值
    设 结果 = []
    设 i = 起始
    设 限 = 最小值(结束, 列表.长度())
    循环 当 i < 限:
        如果 i >= 0:
            结果.添加(列表[i])
        i = i + 1
    返回 结果

// === 安全遍历 ===

函程 安全遍历(列表, 处理函数): // 公开
    如果 列表 == 空:
        返回
    循环 项 于 列表:
        设 非空 = 不是 空值检查(项)
        如果 非空:
            处理函数(项)

函程 安全遍历字典(字典, 处理函数): // 公开
    如果 字典 == 空:
        返回
    循环 键, 值 于 字典:
        设 非空 = 不是 空值检查(值)
        如果 非空:
            处理函数(键, 值)

// === 非空过滤 ===

函程 非空过滤(列表): // 公开
    设 结果 = []
    循环 项 于 列表:
        如果 非空检查(项):
            结果.添加(项)
    返回 结果

函程 空值映射(列表, 映射函数): // 公开
    设 结果 = []
    循环 项 于 列表:
        如果 空值检查(项):
            结果.添加(映射函数())
        否则:
            结果.添加(项)
    返回 结果

// === 安全转换 ===

函程 安全转整数(值, 默认=0): // 公开
    尝试:
        返回 转整数(值)
    捕获 错误:
        返回 默认

函程 安全转小数(值, 默认=0.0): // 公开
    尝试:
        返回 转小数(值)
    捕获 错误:
        返回 默认

函程 安全转文本(值, 默认=""): // 公开
    尝试:
        返回 转文本(值)
    捕获 错误:
        返回 默认

// === 安全执行 ===

函程 安全执行(函数, 默认值=空): // 公开
    尝试:
        返回 函数()
    捕获 错误:
        返回 默认值

函程 安全执行带日志(函数, 默认值=空): // 公开
    尝试:
        返回 函数()
    捕获 错误:
        输出("安全执行异常: " + 转文本(错误))
        返回 默认值
