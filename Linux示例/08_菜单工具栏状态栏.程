// ============================================================
// Linux GTK4 示例 - 08 菜单工具栏状态栏
// 测试：菜单栏、工具栏、状态栏、颜色选择对话框
// ============================================================

导入 "窗口组件"
导入 "标签"
导入 "按钮"
导入 "编辑框"
导入 "菜单"
导入 "工具栏"
导入 "状态栏"
导入 "颜色选择器"
导入 "文件选择对话框"

设 窗口句柄 = 空
设 状态栏句柄 = 空
设 内容标签 = 空

函程 显示消息(消息):
    设置状态栏文本(状态栏句柄, 0, 消息)
结束

函程 新建文件():
    设置标签文本(内容标签, "新建文件 - 未命名")
    显示消息("已新建文件")
结束

函程 打开文件():
    设 文件 = 打开文件对话框("选择文件")
    如果 字符串长度(文件) > 0:
        设置标签文本(内容标签, "打开文件: " + 文件)
        显示消息("已打开: " + 文件)
    否则:
        显示消息("取消选择文件")
    结束
结束

函程 选择颜色():
    设 颜色 = 打开颜色对话框("选择颜色")
    如果 字符串长度(颜色) > 0:
        设置标签文字颜色(内容标签, 颜色)
        显示消息("已选择颜色: " + 颜色)
    否则:
        显示消息("取消选择颜色")
    结束
结束

函程 退出程序():
    显示消息("正在退出...")
    关闭窗口(窗口句柄)
结束

函程 关于对话框():
    设置标签文本(内容标签, "语程语言 v0.4.1\nGTK4 跨平台 GUI 测试\n菜单/工具栏/状态栏")
    显示消息("关于 - 语程语言 GTK4 测试")
结束

函程 创建界面():
    设 配置 = 窗口("GTK4 菜单工具栏状态栏测试", 700, 500)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)

    // ==== 菜单栏 ====
    设 菜单 = 创建菜单栏(窗口句柄)

    设 文件菜单 = 添加子菜单(菜单, "文件")
    向子菜单添加项(文件菜单, "新建", 1001)
    向子菜单添加项(文件菜单, "打开", 1002)
    向子菜单添加分隔线(文件菜单)
    向子菜单添加项(文件菜单, "退出", 1003)

    设 编辑菜单 = 添加子菜单(菜单, "编辑")
    向子菜单添加项(编辑菜单, "颜色", 2001)

    设 帮助菜单 = 添加子菜单(菜单, "帮助")
    向子菜单添加项(帮助菜单, "关于", 3001)

    // ==== 工具栏 ====
    设 工具 = 创建工具栏(窗口句柄, 32)
    添加工具栏按钮(工具, "新建", 1001)
    添加工具栏按钮(工具, "打开", 1002)
    添加工具栏分隔线(工具)
    添加工具栏按钮(工具, "颜色", 2001)

    // ==== 状态栏 ====
    状态栏句柄 = 创建状态栏(窗口句柄)
    添加状态栏面板(状态栏句柄, 400)
    添加状态栏面板(状态栏句柄, 250)
    设置状态栏文本(状态栏句柄, 0, "就绪 - GTK4 后端")
    设置状态栏文本(状态栏句柄, 1, "语程 v0.4.1")

    // ==== 中央内容区 ====
    设 内容配置 = 标签("菜单工具栏状态栏测试\n\n请通过菜单和工具栏操作", 0, 0, 700, 400)
    内容配置.文字对齐 = 居中对齐
    内容配置.字体大小 = 16
    内容配置.文字颜色 = "#2D3748"
    内容配置.父窗口 = 窗口句柄
    内容标签 = 创建标签(内容配置)

    // ==== 菜单事件绑定 ====
    // 菜单项通过标识符传递事件，需在事件命令中处理
    // 这里用按钮模拟菜单操作
    设 按钮区 = 标签("快捷操作:", 20, 350, 80, 25, 窗口句柄)
    创建标签(按钮区)

    设 新建按钮 = 按钮("新建", 100, 348, 80, 28, 窗口句柄)
    设 打开按钮 = 按钮("打开", 190, 348, 80, 28, 窗口句柄)
    设 颜色按钮 = 按钮("颜色", 280, 348, 80, 28, 窗口句柄)
    设 关于按钮 = 按钮("关于", 370, 348, 80, 28, 窗口句柄)
    设 退出按钮 = 按钮("退出", 460, 348, 80, 28, 窗口句柄)

    _绑定控件事件(新建按钮, 通知点击, 函数(): 返回 新建文件())
    _绑定控件事件(打开按钮, 通知点击, 函数(): 返回 打开文件())
    _绑定控件事件(颜色按钮, 通知点击, 函数(): 返回 选择颜色())
    _绑定控件事件(关于按钮, 通知点击, 函数(): 返回 关于对话框())
    _绑定控件事件(退出按钮, 通知点击, 函数(): 返回 退出程序())

    输出("GTK4 菜单/工具栏/状态栏测试已创建")
    运行界面(窗口句柄)
结束

创建界面()
