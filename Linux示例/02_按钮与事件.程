// ============================================================
// Linux GTK4 示例 - 02 按钮与事件
// 测试：按钮创建、点击事件、标签更新、启用/禁用控件
// ============================================================

导入 "窗口组件"
导入 "标签"
导入 "按钮"

设 窗口句柄 = 空
设 计数标签 = 空
设 点击按钮 = 空
设 计数 = 0

函程 按钮点击():
    计数 = 计数 + 1
    设置标签文本(计数标签, "点击次数: " + 转文本(计数))
    
    如果 计数 >= 10:
        设置按钮文本(点击按钮, "已达标!")
        禁用按钮(点击按钮)
    否则:
        设置按钮文本(点击按钮, "点击我 (" + 转文本(计数) + "/10)")
    结束
结束

函程 重置点击():
    计数 = 0
    设置标签文本(计数标签, "点击次数: 0")
    设置按钮文本(点击按钮, "点击我 (0/10)")
    启用按钮(点击按钮)
结束

函程 创建界面():
    设 配置 = 窗口("GTK4 按钮与事件测试", 400, 300)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)

    // 标题标签
    设 标题 = 标签("按钮与事件测试", 0, 30, 400, 35)
    标题.文字对齐 = 居中对齐
    标题.字体大小 = 20
    标题.字体粗细 = 700
    标题.父窗口 = 窗口句柄
    创建标签(标题)

    // 计数标签
    设 计数配置 = 标签("点击次数: 0", 0, 90, 400, 30)
    计数配置.文字对齐 = 居中对齐
    计数配置.字体大小 = 16
    计数配置.父窗口 = 窗口句柄
    计数标签 = 创建标签(计数配置)

    // 点击按钮
    设 按钮配置 = 按钮("点击我 (0/10)", 100, 150, 200, 40, 窗口句柄)
    点击按钮 = 创建按钮(按钮配置)

    // 重置按钮
    设 重置配置 = 按钮("重置", 100, 210, 200, 35, 窗口句柄)
    设 重置按钮 = 创建按钮(重置配置)

    // 绑定事件
    _绑定控件事件(点击按钮, 通知点击, 函数(): 返回 按钮点击())
    _绑定控件事件(重置按钮, 通知点击, 函数(): 返回 重置点击())

    运行界面(窗口句柄)
结束

创建界面()
