// ============================================================
// Linux GTK4 示例 - 01 基础窗口
// 测试：窗口创建、标题设置、屏幕信息、窗口居中、关闭窗口
// ============================================================

导入 "窗口组件"

函程 主程序():
    // 获取屏幕尺寸
    设 屏宽 = 获取屏幕宽度()
    设 屏高 = 获取屏幕高度()
    输出("屏幕尺寸: " + 转文本(屏宽) + " x " + 转文本(屏高))

    // 创建窗口
    设 配置 = 窗口("GTK4 基础窗口测试", 640, 480)
    配置.居中 = 真
    配置.背景色 = "#F5F5F5"
    设 句柄 = 创建窗口(配置)

    输出("窗口创建成功，句柄: " + 转文本(句柄))

    // 获取窗口属性
    设 标题 = 获取窗口标题(句柄)
    输出("窗口标题: " + 转文本(标题))

    // 设置新标题
    设置窗口标题(句柄, "GTK4 窗口 - 测试通过!")
    输出("标题已更新")

    // 运行消息循环
    输出("进入消息循环...")
    运行界面(句柄)
结束

主程序()
