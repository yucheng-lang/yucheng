// ============================================================
// Linux GTK4 示例 - 03 输入控件测试
// 测试：编辑框、复选框、标签、分组框的综合使用
// ============================================================

导入 "窗口组件"
导入 "标签"
导入 "按钮"
导入 "编辑框"
导入 "复选框"
导入 "分组框"
导入 "进度条"
导入 "滑块条"

设 窗口句柄 = 空
设 姓名框 = 空
设 邮箱框 = 空
设 同意框 = 空
设 滑块句柄 = 空
设 进度条句柄 = 空
设 结果标签 = 空

函程 提交点击():
    设 姓名 = 获取编辑框文本(姓名框)
    设 邮箱 = 获取编辑框文本(邮箱框)
    设 已同意 = 获取按钮选中状态(同意框)
    设 滑块值 = 获取滑块条值(滑块句柄)
    
    设 结果 = "姓名: " + 姓名 + " | 邮箱: " + 邮箱 + " | 同意: " + 转文本(已同意) + " | 评分: " + 转文本(滑块值)
    设置标签文本(结果标签, 结果)
    
    // 更新进度条
    如果 字符串长度(姓名) > 0 且 字符串长度(邮箱) > 0 且 已同意:
        设置进度条值(进度条句柄, 100)
        设置标签文本(结果标签, "提交成功! " + 结果)
    否则:
        设置进度条值(进度条句柄, 50)
        设置标签文本(结果标签, "请完整填写信息并同意条款")
    结束
结束

函程 创建界面():
    设 配置 = 窗口("GTK4 输入控件测试", 500, 500)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)

    // 标题
    设 标题 = 标签("用户信息表单", 0, 15, 500, 30)
    标题.文字对齐 = 居中对齐
    标题.字体大小 = 18
    标题.字体粗细 = 700
    标题.父窗口 = 窗口句柄
    创建标签(标题)

    // 分组框 - 基本信息
    设 分组 = 分组框("基本信息", 30, 55, 440, 160, 窗口句柄)
    创建分组框(分组)

    // 姓名输入
    设 姓名标签 = 标签("姓名:", 50, 80, 60, 25, 窗口句柄)
    创建标签(姓名标签)

    设 姓名配置 = 编辑框("", 120, 80, 330, 28, 窗口句柄)
    姓名配置.占位符文本 = "请输入姓名"
    姓名框 = 创建编辑框(姓名配置)

    // 邮箱输入
    设 邮箱标签 = 标签("邮箱:", 50, 120, 60, 25, 窗口句柄)
    创建标签(邮箱标签)

    设 邮箱配置 = 编辑框("", 120, 120, 330, 28, 窗口句柄)
    邮箱配置.占位符文本 = "请输入邮箱地址"
    邮箱框 = 创建编辑框(邮箱配置)

    // 同意条款
    设 同意配置 = 复选框("我同意用户条款和隐私政策", 120, 165, 300, 25, 窗口句柄)
    同意框 = 创建复选框(同意配置)

    // 分组框 - 评分
    设 评分组 = 分组框("满意度评分", 30, 230, 440, 80, 窗口句柄)
    创建分组框(评分组)

    设 滑块配置 = 滑块条(50, 255, 400, 30, 窗口句柄)
    滑块句柄 = 创建滑块条(滑块配置)
    设置滑块条范围(滑块句柄, 0, 100)
    设置滑块条值(滑块句柄, 50)

    // 进度条
    设 进度配置 = 进度条(30, 330, 440, 22, 窗口句柄)
    进度条句柄 = 创建进度条(进度配置)
    设置进度条范围(进度条句柄, 0, 100)
    设置进度条值(进度条句柄, 0)

    // 提交按钮
    设 提交配置 = 按钮("提交信息", 150, 370, 200, 40, 窗口句柄)
    设 提交按钮 = 创建按钮(提交配置)

    // 结果标签
    设 结果配置 = 标签("填写表单后点击提交", 30, 430, 440, 40)
    结果配置.文字对齐 = 居中对齐
    结果配置.字体大小 = 13
    结果配置.父窗口 = 窗口句柄
    结果标签 = 创建标签(结果配置)

    // 绑定事件
    _绑定控件事件(提交按钮, 通知点击, 函数(): 返回 提交点击())

    运行界面(窗口句柄)
结束

创建界面()
