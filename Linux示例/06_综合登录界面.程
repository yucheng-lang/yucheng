// ============================================================
// Linux GTK4 示例 - 06 综合登录界面
// 测试：完整登录界面 - 标签、编辑框、按钮、复选框、分组框
// ============================================================

导入 "窗口组件"
导入 "标签"
导入 "编辑框"
导入 "按钮"
导入 "复选框"
导入 "分组框"

设 窗口句柄 = 空
设 用户名框 = 空
设 密码框 = 空
设 记住密码框 = 空
设 状态标签 = 空
设 登录按钮句柄 = 空

函程 验证登录(用户名, 密码):
    如果 用户名 == "":
        返回 "请输入用户名"
    结束
    如果 密码 == "":
        返回 "请输入密码"
    结束
    如果 字符串长度(用户名) < 3:
        返回 "用户名至少3个字符"
    结束
    如果 字符串长度(密码) < 6:
        返回 "密码至少6个字符"
    结束
    如果 用户名 == "admin" 且 密码 == "123456":
        返回 "登录成功"
    结束
    返回 "用户名或密码错误"
结束

函程 登录点击():
    设 用户名 = 获取编辑框文本(用户名框)
    设 密码 = 获取编辑框文本(密码框)
    设 结果 = 验证登录(用户名, 密码)

    如果 结果 == "登录成功":
        设置标签文本(状态标签, "登录成功! 欢迎使用语程语言")
        设置标签文字颜色(状态标签, "#38A169")
        禁用编辑框(用户名框)
        禁用编辑框(密码框)
        禁用按钮(登录按钮句柄)
    否则:
        设置标签文本(状态标签, 结果)
        设置标签文字颜色(状态标签, "#E53E3E")
    结束
结束

函程 注册点击():
    设置标签文本(状态标签, "注册功能开发中... (GTK4)")
    设置标签文字颜色(状态标签, "#DD6B20")
结束

函程 创建登录界面():
    设 配置 = 窗口("语程 - Linux登录界面", 420, 460)
    配置.居中 = 真
    配置.可调整大小 = 假
    配置.背景色 = "#F7FAFC"
    窗口句柄 = 创建窗口(配置)

    // ---- 标题区域 ----
    设 标题 = 标签("欢迎登录", 0, 25, 420, 40, 窗口句柄)
    标题.文字对齐 = 居中对齐
    标题.字体大小 = 24
    标题.字体粗细 = 700
    标题.文字颜色 = "#1A365D"
    创建标签(标题)

    设 副标题 = 标签("语程语言 - GTK4 跨平台测试", 0, 65, 420, 25, 窗口句柄)
    副标题.文字对齐 = 居中对齐
    副标题.字体大小 = 13
    副标题.文字颜色 = "#718096"
    创建标签(副标题)

    // ---- 登录分组框 ----
    设 分组 = 分组框("账号信息", 40, 105, 340, 200, 窗口句柄)
    创建分组框(分组)

    // ---- 用户名 ----
    设 用户名标签 = 标签("用户名:", 60, 135, 80, 25, 窗口句柄)
    用户名标签.文字对齐 = 右对齐
    创建标签(用户名标签)

    设 用户名配置 = 编辑框("", 150, 135, 210, 28, 窗口句柄)
    用户名配置.占位符文本 = "请输入用户名"
    用户名框 = 创建编辑框(用户名配置)

    // ---- 密码 ----
    设 密码标签 = 标签("密  码:", 60, 180, 80, 25, 窗口句柄)
    密码标签.文字对齐 = 右对齐
    创建标签(密码标签)

    设 密码配置 = 编辑框("", 150, 180, 210, 28, 窗口句柄)
    密码配置.占位符文本 = "请输入密码"
    密码配置.密码框 = 真
    密码框 = 创建编辑框(密码配置)

    // ---- 记住密码 ----
    设 记住配置 = 复选框("记住密码", 150, 225, 120, 22, 窗口句柄)
    记住密码框 = 创建复选框(记住配置)

    // ---- 登录按钮 ----
    设 登录配置 = 按钮("登  录", 60, 320, 300, 42, 窗口句柄)
    登录配置.字体大小 = 16
    登录按钮句柄 = 创建按钮(登录配置)

    // ---- 注册按钮 ----
    设 注册配置 = 按钮("注册新账号", 60, 375, 300, 36, 窗口句柄)
    设 注册按钮句柄 = 创建按钮(注册配置)

    // ---- 状态提示 ----
    设 状态配置 = 标签("", 40, 425, 340, 25, 窗口句柄)
    状态配置.文字对齐 = 居中对齐
    状态配置.字体大小 = 13
    状态标签 = 创建标签(状态配置)

    // 绑定事件
    _绑定控件事件(登录按钮句柄, 通知点击, 函数(): 返回 登录点击())
    _绑定控件事件(注册按钮句柄, 通知点击, 函数(): 返回 注册点击())

    输出("GTK4 登录界面已创建")
    运行界面(窗口句柄)
结束

创建登录界面()
