// ============================================================
// Linux GTK4 示例 - 05 定时器动画
// 测试：定时器、绘图刷新、动画效果
// ============================================================

导入 "窗口组件"
导入 "绘图"

设 窗口句柄 = 空
设 角度 = 0
设 运行中 = 真
设 计数 = 0

函程 绘制动画帧():
    设 上下文 = 获取绘图上下文(窗口句柄)
    
    如果 上下文 != 空:
        // 清除画布
        清除区域(上下文, 0, 0, 600, 450, "#1A202C")
        
        // 绘制标题
        绘制居中文本(上下文, "定时器动画测试", 0, 15, 600, 35, "#E2E8F0", 20)
        
        // 旋转方块动画 (4个方块围绕中心旋转)
        设 中心X = 300
        设 中心Y = 240
        设 半径 = 80
        设 序号 = 0
        
        循环 序号 从 0 到 3:
            设 当前角度 = 角度 + 序号 * 90
            设 弧度 = 当前角度 * 3.14159 / 180
            设 方块X = 中心X + 半径 * 余弦(弧度) - 15
            设 方块Y = 中心Y + 半径 * 正弦(弧度) - 15
            
            设 颜色列表 = ["#4299E1", "#48BB78", "#ED8936", "#9F7AEA"]
            设 当前颜色 = 颜色列表[序号]
            
            填充圆角矩形(上下文, 方块X, 方块Y, 方块X + 30, 方块Y + 30, 5, 5, 当前颜色)
        结束
        
        // 中心圆
        填充圆形(上下文, 中心X, 中心Y, 20, "#E53E3E")
        
        // 进度弧 (模拟进度条)
        设 进度 = (计数 % 100) / 100
        设 进度宽度 = 进度 * 500
        填充矩形(上下文, 50, 380, 50 + 进度宽度, 395, "#4299E1")
        绘制矩形边框(上下文, 50, 380, 550, 395, "#4A5568")
        绘制文本(上下文, 转文本(取整(进度 * 100)) + "%", 555, 380, "#E2E8F0", 13)
        
        // 帧计数
        绘制居中文本(上下文, "帧: " + 转文本(计数), 0, 410, 600, 25, "#718096", 12)
        
        释放绘图上下文(窗口句柄, 上下文)
    结束
结束

函程 定时器回调():
    如果 运行中:
        角度 = 角度 + 3
        计数 = 计数 + 1
        如果 角度 >= 360:
            角度 = 角度 - 360
        结束
        重绘窗口(窗口句柄)
    结束
结束

函程 创建界面():
    设 配置 = 窗口("GTK4 定时器动画测试", 600, 450)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)
    
    // 创建画板
    设 画板配置 = {
        "类型": "画板",
        "X": 0,
        "Y": 0,
        "宽度": 600,
        "高度": 450,
        "父窗口": 窗口句柄
    }
    _创建原生控件("画板", 画板配置)
    
    // 绑定绘制事件
    _绑定控件事件(窗口句柄, 事件绘制, 函数(): 返回 绘制动画帧())
    
    // 设置定时器（30ms间隔 ≈ 33FPS）
    设置定时器(窗口句柄, 1, 30, 函数(): 返回 定时器回调())
    
    输出("定时器动画已启动")
    运行界面(窗口句柄)
结束

创建界面()
