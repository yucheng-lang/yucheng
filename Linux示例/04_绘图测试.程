// ============================================================
// Linux GTK4 示例 - 04 绘图测试
// 测试：Cairo绘图 - 矩形、圆形、线条、文本、颜色
// ============================================================

导入 "窗口组件"
导入 "绘图"

设 窗口句柄 = 空
设 画板句柄 = 空
设 绘图上下文 = 空

函程 绘制图形():
    绘图上下文 = 获取绘图上下文(窗口句柄)
    
    如果 绘图上下文 != 空:
        // 清除画布 - 浅灰色背景
        清除区域(绘图上下文, 0, 0, 800, 500, "#F0F0F0")
        
        // 绘制标题
        绘制居中文本(绘图上下文, "GTK4 Cairo 绘图测试", 0, 10, 800, 40, "#1A365D", 22)
        
        // ---- 第一行：矩形 ----
        // 填充矩形
        填充矩形(绘图上下文, 30, 60, 170, 160, "#4299E1")
        绘制文本(绘图上下文, "填充矩形", 60, 200, "#FFFFFF", 14)
        
        // 边框矩形
        绘制矩形边框(绘图上下文, 200, 60, 340, 160, "#E53E3E")
        绘制文本(绘图上下文, "边框矩形", 230, 200, "#E53E3E", 14)
        
        // 圆角矩形
        填充圆角矩形(绘图上下文, 370, 60, 540, 160, 15, 15, "#48BB78")
        绘制文本(绘图上下文, "圆角矩形", 400, 200, "#FFFFFF", 14)
        
        // ---- 第二行：圆形和椭圆 ----
        // 填充圆形
        填充圆形(绘图上下文, 100, 280, 50, "#9F7AEA")
        绘制文本(绘图上下文, "圆形", 75, 350, "#9F7AEA", 14)
        
        // 边框圆形
        绘制圆形边框(绘图上下文, 270, 280, 50, "#ED8936")
        绘制文本(绘图上下文, "边框圆", 245, 350, "#ED8936", 14)
        
        // 填充椭圆
        填充椭圆(绘图上下文, 380, 240, 540, 320, "#38B2AC")
        绘制文本(绘图上下文, "椭圆", 420, 350, "#38B2AC", 14)
        
        // ---- 第三行：线条 ----
        绘制线条(绘图上下文, 30, 380, 770, 380, "#A0AEC0", 2)
        
        // 彩色线条
        绘制线条(绘图上下文, 30, 410, 200, 410, "#E53E3E", 3)
        绘制线条(绘图上下文, 220, 410, 390, 410, "#48BB78", 3)
        绘制线条(绘图上下文, 410, 410, 580, 410, "#4299E1", 3)
        绘制线条(绘图上下文, 600, 410, 770, 410, "#9F7AEA", 3)
        
        // 文本标注
        绘制文本(绘图上下文, "红线", 80, 440, "#E53E3E", 12)
        绘制文本(绘图上下文, "绿线", 270, 440, "#48BB78", 12)
        绘制文本(绘图上下文, "蓝线", 460, 440, "#4299E1", 12)
        绘制文本(绘图上下文, "紫线", 650, 440, "#9F7AEA", 12)
        
        // 底部信息
        绘制居中文本(绘图上下文, "语程语言 GTK4 Cairo 绘图", 0, 460, 800, 30, "#718096", 12)
        
        释放绘图上下文(窗口句柄, 绘图上下文)
    结束
结束

函程 创建界面():
    设 配置 = 窗口("GTK4 绘图测试", 800, 500)
    配置.居中 = 真
    配置.背景色 = "#F0F0F0"
    窗口句柄 = 创建窗口(配置)
    
    // 创建画板控件 (用于绘图的DrawingArea)
    设 画板配置 = {
        "类型": "画板",
        "X": 0,
        "Y": 0,
        "宽度": 800,
        "高度": 500,
        "父窗口": 窗口句柄
    }
    画板句柄 = _创建原生控件("画板", 画板配置)
    
    // 绑定绘制事件
    _绑定控件事件(窗口句柄, 事件绘制, 函数(): 返回 绘制图形())
    
    运行界面(窗口句柄)
结束

创建界面()
