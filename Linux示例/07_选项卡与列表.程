// ============================================================
// Linux GTK4 示例 - 07 选项卡与列表控件
// 测试：选项卡(Notebook)、列表框(ListBox)、下拉框(DropDown)
// ============================================================

导入 "窗口组件"
导入 "标签"
导入 "按钮"
导入 "编辑框"
导入 "选项卡"
导入 "列表框"
导入 "下拉框"

设 窗口句柄 = 空
设 列表框句柄 = 空
设 下拉框句柄 = 空
设 信息标签 = 空

函程 添加项目():
    设 当前文本 = 获取编辑框文本(输入框句柄)
    如果 字符串长度(当前文本) > 0:
        添加列表项(列表框句柄, 当前文本)
        添加下拉项(下拉框句柄, 当前文本)
        设置编辑框文本(输入框句柄, "")
        设置标签文本(信息标签, "已添加: " + 当前文本)
    否则:
        设置标签文本(信息标签, "请输入项目名称")
    结束
结束

设 输入框句柄 = 空

函程 清空项目():
    清空列表(列表框句柄)
    设置标签文本(信息标签, "列表已清空")
结束

函程 创建界面():
    设 配置 = 窗口("GTK4 选项卡与列表测试", 550, 500)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)

    // 标题
    设 标题 = 标签("选项卡与列表控件测试", 0, 10, 550, 30)
    标题.文字对齐 = 居中对齐
    标题.字体大小 = 18
    标题.字体粗细 = 700
    标题.父窗口 = 窗口句柄
    创建标签(标题)

    // 选项卡
    设 选项卡配置 = 选项卡(20, 50, 510, 390, 窗口句柄)
    设 选项卡句柄 = 创建选项卡(选项卡配置)

    // ---- 第一页：列表框 ----
    添加标签页(选项卡句柄, "列表框")

    设 列表 = 列表框(40, 90, 250, 200, 窗口句柄)
    列表框句柄 = 创建列表框(列表)
    添加列表项(列表框句柄, "苹果")
    添加列表项(列表框句柄, "香蕉")
    添加列表项(列表框句柄, "橘子")
    添加列表项(列表框句柄, "葡萄")
    添加列表项(列表框句柄, "西瓜")

    // ---- 第二页：下拉框 ----
    添加标签页(选项卡句柄, "下拉框")

    设 下拉标签 = 标签("选择一个选项:", 40, 90, 150, 25, 窗口句柄)
    创建标签(下拉标签)

    设 下拉 = 下拉框(40, 120, 250, 30, 窗口句柄)
    下拉框句柄 = 创建下拉框(下拉)
    添加下拉项(下拉框句柄, "选项A")
    添加下拉项(下拉框句柄, "选项B")
    添加下拉项(下拉框句柄, "选项C")
    设置下拉选中索引(下拉框句柄, 0)

    // ---- 第三页：添加项目 ----
    添加标签页(选项卡句柄, "添加项目")

    设 输入标签 = 标签("输入新项目名称:", 40, 90, 200, 25, 窗口句柄)
    创建标签(输入标签)

    设 输入配置 = 编辑框("", 40, 120, 250, 28, 窗口句柄)
    输入配置.占位符文本 = "请输入项目名称"
    输入框句柄 = 创建编辑框(输入配置)

    设 添加按钮 = 按钮("添加到列表", 40, 165, 120, 32, 窗口句柄)
    设 清空按钮 = 按钮("清空列表", 170, 165, 120, 32, 窗口句柄)

    _绑定控件事件(添加按钮, 通知点击, 函数(): 返回 添加项目())
    _绑定控件事件(清空按钮, 通知点击, 函数(): 返回 清空项目())

    // 信息标签
    设 信息配置 = 标签("提示: 切换选项卡查看不同控件", 20, 460, 510, 25)
    信息配置.文字对齐 = 居中对齐
    信息配置.字体大小 = 12
    信息配置.文字颜色 = "#718096"
    信息配置.父窗口 = 窗口句柄
    信息标签 = 创建标签(信息配置)

    运行界面(窗口句柄)
结束

创建界面()
