// 目录操作库示例
// 演示目录操作功能

导入 "目录操作"

输出 "=== 目录操作库示例 ==="
输出 ""

// 检查目录是否存在
输出 "--- 检查目录 ---"
设 存在 = 目录操作.目录存在检查("test_dir")
输出 "目录'test_dir'存在: " + 转文本(存在)
输出 ""

// 创建目录
输出 "--- 创建目录 ---"
目录操作.存在或创建目录("test_dir")
输出 "创建目录: test_dir"

目录操作.存在或创建目录("test_dir/sub1")
输出 "创建嵌套目录: test_dir/sub1"
输出 ""

// 当前目录
输出 "--- 当前目录 ---"
设 当前 = 目录操作.获取当前目录路径()
输出 "当前目录: " + 当前
输出 ""

// 遍历目录
输出 "--- 遍历目录 ---"
设 项目列表 = 目录操作.遍历目录(".")
输出 "当前目录内容:"
遍 项目 于 项目列表:
    输出 "  " + 项目[0] + " (" + 项目[1] + ")"
输出 ""

// 列出文件和目录
输出 "--- 列出文件和目录 ---"
设 文件列表 = 目录操作.列出文件(".")
输出 "文件数量: " + 转文本(文件列表.长度())

设 目录列表 = 目录操作.列出目录(".")
输出 "子目录数量: " + 转文本(目录列表.长度())
输出 ""

// 清理
输出 "--- 清理 ---"
删除目录("test_dir")
输出 "清理测试目录完成"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
