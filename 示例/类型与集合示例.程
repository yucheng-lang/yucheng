// 集合工具示例 - 基于列表的集合运算
导入 "库/集合工具.程"

// === 集合运算 ===
输出 "=== 集合运算 ==="
设 集A = [1, 2, 3]
设 集B = [2, 3, 4]

输出 "集合包含(集A,2): " + 转字符串(集合包含(集A, 2))
输出 "集合大小(集A): " + 转字符串(集合大小(集A))

设 并 = 集合并(集A, 集B)
输出 "集合并: " + 转字符串(并)

设 交 = 集合交(集A, 集B)
输出 "集合交: " + 转字符串(交)

设 差 = 集合差(集A, 集B)
输出 "集合差(A-B): " + 转字符串(差)

设 去重 = 列表去重集([1, 1, 2, 2, 3, 3])
输出 "列表去重集: " + 转字符串(去重)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
