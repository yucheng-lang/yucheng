// 异步示例 - Promise/Future 异步编程模式
导入 "库/异步.程"

// 示例1: 创建和兑现期约
设 期约 = 创建期约()
输出 "期约状态: " + 期约.状态
期约 = 兑现期约(期约, 42)
输出 "兑现后状态: " + 期约.状态
输出 "期约值: " + 转字符串(期约.值)

// 示例2: 拒绝期约
设 被拒绝 = 创建期约()
被拒绝 = 拒绝期约(被拒绝, "出错了")
输出 "拒绝状态: " + 被拒绝.状态
输出 "拒绝错误: " + 转字符串(被拒绝.错误)

// 示例3: 静态方法
设 已完成 = 期约已兑现(100)
输出 "静态兑现状态: " + 已完成.状态
输出 "静态兑现值: " + 转字符串(已完成.值)

设 静态拒绝 = 期约已拒绝("失败")
输出 "静态拒绝状态: " + 静态拒绝.状态

// 示例4: 期值
设 期值 = 创建期值("测试")
输出 "期值状态: " + 期值.状态
期值 = 完成期值(期值, "结果数据")
输出 "完成后期值状态: " + 期值.状态
输出 "期值结果: " + 读取期值(期值)

// 示例5: 异步执行
设 执行结果 = 异步执行(函数(): 返回 "异步计算完成")
输出 "异步执行状态: " + 执行结果.状态
输出 "异步执行结果: " + 读取期值(执行结果)

// 示例6: 管道
设 管道 = 创建管道()
管道 = 管道添加(管道, 函数(值): 返回 值 + 1)
管道 = 管道添加(管道, 函数(值): 返回 值 * 2)
管道 = 管道执行(管道, 5)
输出 "管道结果: " + 转字符串(管道.当前值)
输出 "管道状态: " + 管道.状态

// 示例7: 全部兑现
设 期约1 = 期约已兑现(1)
设 期约2 = 期约已兑现(2)
设 期约3 = 期约已兑现(3)
设 全部 = 全部兑现([期约1, 期约2, 期约3])
输出 "全部兑现状态: " + 全部.状态
输出 "全部兑现值: " + 转字符串(全部.值)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
