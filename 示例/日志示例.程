// 日志库示例
// 演示日志记录功能

导入 "库/日志"

输出 "=== 日志库示例 ==="
输出 ""

// 设置日志级别
输出 "--- 设置日志级别 ---"
设置日志级别(级别调试)
输出 "日志级别设置为：调试"
输出 ""

// 各级别日志输出
输出 "--- 各级别日志输出 ---"
调试("这是一条调试信息")
信息("这是一条普通信息")
警告("这是一条警告信息")
错误("这是一条错误信息")
输出 ""

// 修改日志级别
输出 "--- 修改日志级别 ---"
设置日志级别(级别警告)
输出 "日志级别设置为：警告"
输出 "（只显示警告和错误）"
输出 ""

调试("这条调试信息不会显示")
信息("这条普通信息不会显示")
警告("警告信息会显示")
错误("错误信息会显示")
输出 ""

// 恢复日志级别
设置日志级别(级别信息)
输出 "日志已恢复"
信息("日志功能正常")
输出 ""

输出 "=== 示例完成 ==="
输出 ""
