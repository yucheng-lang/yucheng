// ============================================================
// 语程 GUI 全组件测试
// 将所有 35 个组件库的功能添加到同一窗口中测试
// ============================================================

导入 "窗口组件"
导入 "标签"
导入 "按钮"
导入 "编辑框"
导入 "富文本框"
导入 "复选框"
导入 "单选按钮"
导入 "下拉框"
导入 "列表框"
导入 "列表视图"
导入 "树形控件"
导入 "选项卡"
导入 "进度条"
导入 "滑块条"
导入 "滚动条"
导入 "数值框"
导入 "搜索框"
导入 "IP地址框"
导入 "热键框"
导入 "日期框"
导入 "月历控件"
导入 "动画控件"
导入 "分组框"
导入 "颜色选择器"
导入 "绘图"
导入 "工具栏"
导入 "状态栏"
导入 "菜单"
导入 "右键菜单"
导入 "工具提示"
导入 "皮肤"
导入 "文件选择对话框"
导入 "文件夹选择对话框"
导入 "字体选择对话框"
// 游戏引擎库为独立游戏循环模式，不适合嵌入普通窗口

设 窗口句柄 = 空
设 状态栏句柄 = 空

函程 按钮被点击():
    设置状态栏文本(状态栏句柄, 0, "按钮被点击了！")
结束

函程 创建测试界面():
    // ==== 创建主窗口 ====
    设 配置 = 窗口("语程 GUI 全组件测试 - 34个组件库", 1100, 750)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)

    // ==== 1. 菜单栏 ====
    设 菜单 = 创建菜单栏(窗口句柄)
    设 文件菜单 = 添加子菜单(菜单, "文件")
    向子菜单添加项(文件菜单, "新建", 1001)
    向子菜单添加项(文件菜单, "打开", 1002)
    向子菜单添加分隔线(文件菜单)
    向子菜单添加项(文件菜单, "退出", 1003)
    设 编辑菜单 = 添加子菜单(菜单, "编辑")
    向子菜单添加项(编辑菜单, "复制", 2001)
    向子菜单添加项(编辑菜单, "粘贴", 2002)
    设 帮助菜单 = 添加子菜单(菜单, "帮助")
    向子菜单添加项(帮助菜单, "关于", 3001)

    // ==== 2. 工具栏 ====
    设 工具 = 创建工具栏(窗口句柄, 30)
    添加工具栏按钮(工具, "新建", 1001)
    添加工具栏按钮(工具, "打开", 1002)
    添加工具栏分隔线(工具)
    添加工具栏按钮(工具, "复制", 2001)
    添加工具栏按钮(工具, "粘贴", 2002)

    // ==== 3. 状态栏 ====
    状态栏句柄 = 创建状态栏(窗口句柄)
    添加状态栏面板(状态栏句柄, 600)
    添加状态栏面板(状态栏句柄, 300)
    设置状态栏文本(状态栏句柄, 0, "就绪 - 所有 34 个组件库已加载")
    设置状态栏文本(状态栏句柄, 1, "语程 v0.4.1 | Win32 原生 API")

    // ==== 第一行：标签、按钮、编辑框、搜索框、数值框 ====
    设 标题标签 = 标签("【语程 GUI 全组件测试】", 10, 10, 300, 25, 窗口句柄)
    标题标签.字体大小 = 16
    标题标签.字体粗细 = 700
    创建标签(标题标签)

    设 提示标签 = 标签("标签:", 10, 45, 40, 20, 窗口句柄)
    创建标签(提示标签)

    设 测试按钮 = 按钮("点击测试", 55, 42, 100, 28, 窗口句柄)
    设 按钮句柄 = 创建按钮(测试按钮)

    设 输入框 = 编辑框("编辑框内容", 165, 42, 140, 26, 窗口句柄)
    创建编辑框(输入框)

    设 搜索 = 搜索框(315, 42, 150, 28, 窗口句柄)
    创建搜索框(搜索)

    设 数值 = 数值框(475, 42, 80, 26, 窗口句柄)
    创建数值框(数值)

    // ==== 第二行：复选框、单选按钮、IP地址框、热键框 ====
    设 勾选 = 复选框("复选框", 10, 78, 90, 22, 窗口句柄)
    创建复选框(勾选)

    设 单选1 = 单选按钮("选项A", 110, 78, 80, 22, 窗口句柄, 1, 1)
    创建单选按钮(单选1)
    设 单选2 = 单选按钮("选项B", 195, 78, 80, 22, 窗口句柄, 2, 1)
    创建单选按钮(单选2)

    设 ip框 = IP地址框(290, 78, 140, 24, 窗口句柄)
    创建IP地址框(ip框)

    设 热键 = 热键框(440, 78, 120, 24, 窗口句柄)
    创建热键框(热键)

    // ==== 第三行：下拉框、日期框、进度条、滑块条、滚动条 ====
    设 下拉 = 下拉框(10, 112, 130, 26, 窗口句柄)
    设 下拉框句柄 = 创建下拉框(下拉)
    添加下拉项(下拉框句柄, "项目1")
    添加下拉项(下拉框句柄, "项目2")
    添加下拉项(下拉框句柄, "项目3")
    设置下拉选中索引(下拉框句柄, 0)

    设 日期 = 日期框(150, 112, 140, 26, 窗口句柄)
    创建日期框(日期)

    设 进度 = 进度条(300, 116, 140, 18, 窗口句柄)
    设 进度条句柄 = 创建进度条(进度)
    设置进度条范围(进度条句柄, 0, 100)
    设置进度条值(进度条句柄, 65)

    设 滑块 = 滑块条(450, 112, 110, 28, 窗口句柄)
    设 滑块句柄 = 创建滑块条(滑块)
    设置滑块条范围(滑块句柄, 0, 100)
    设置滑块条值(滑块句柄, 50)

    设 滚动 = 滚动条(570, 116, 100, 20, 窗口句柄)
    创建滚动条(滚动)

    // ==== 左侧：分组框 + 列表框 ====
    设 分组 = 分组框("水果列表", 10, 148, 200, 180, 窗口句柄)
    创建分组框(分组)

    设 列表 = 列表框(20, 170, 180, 148, 窗口句柄)
    设 列表框句柄 = 创建列表框(列表)
    添加列表项(列表框句柄, "苹果")
    添加列表项(列表框句柄, "香蕉")
    添加列表项(列表框句柄, "橘子")
    添加列表项(列表框句柄, "葡萄")
    添加列表项(列表框句柄, "西瓜")

    // ==== 中间：树形控件 ====
    设 树形 = 树形控件(220, 148, 200, 180, 窗口句柄)
    设 树形句柄 = 创建树形控件(树形)
    设 根1 = 添加根节点(树形句柄, "项目1")
    添加子节点(树形句柄, 根1, "子项1-1")
    添加子节点(树形句柄, 根1, "子项1-2")
    设 根2 = 添加根节点(树形句柄, "项目2")
    添加子节点(树形句柄, 根2, "子项2-1")
    添加子节点(树形句柄, 根2, "子项2-2")
    设 根3 = 添加根节点(树形句柄, "项目3")
    展开全部(树形句柄)

    // ==== 右侧：列表视图 ====
    设 视图 = 列表视图(430, 148, 280, 180, 窗口句柄)
    设 视图句柄 = 创建列表视图(视图)
    添加列(视图句柄, "姓名", 80)
    添加列(视图句柄, "年龄", 60)
    添加列(视图句柄, "城市", 100)
    添加行(视图句柄, ["张三", "25", "北京"])
    添加行(视图句柄, ["李四", "30", "上海"])
    添加行(视图句柄, ["王五", "28", "广州"])

    // ==== 选项卡区域 ====
    设 选项卡配置 = 选项卡(10, 340, 540, 280, 窗口句柄)
    设 选项卡句柄 = 创建选项卡(选项卡配置)
    添加标签页(选项卡句柄, "月历")
    添加标签页(选项卡句柄, "动画")
    添加标签页(选项卡句柄, "富文本")

    // 月历控件
    设 月历 = 月历控件(20, 370, 230, 180, 窗口句柄)
    创建月历控件(月历)

    // 动画控件
    设 动画 = 动画控件(260, 370, 140, 100, 窗口句柄)
    创建动画控件(动画)

    // 富文本框
    设 富文本 = 富文本框(20, 370, 520, 235, 窗口句柄)
    设 富文本句柄 = 创建富文本框(富文本)
    设置富文本内容(富文本句柄, "富文本框测试\n支持多行文本输入\n可设置加粗、斜体、颜色等格式")

    // ==== 颜色选择器 ====
    设 颜色器 = 颜色选择器(560, 340, 150, 150, 窗口句柄)
    创建颜色选择器(颜色器)

    // ==== 对话框提示 ====
    设 对话框标签 = 标签("对话框: 文件选择、文件夹选择、字体选择、颜色选择（请通过菜单或代码触发）", 560, 500, 500, 20, 窗口句柄)
    创建标签(对话框标签)

    // ==== 绘图区域提示 ====
    设 绘图标签 = 标签("绘图 API: 绘制矩形、圆形、线条、文本、图像（需通过代码调用绘图函数）", 560, 530, 500, 20, 窗口句柄)
    创建标签(绘图标签)

    // ==== 工具提示 ====
    设置工具提示(按钮句柄, "这是一个测试按钮")
    设置工具提示(输入框, "在这里输入文本")

    // ==== 右键菜单 ====
    设 右键 = 创建右键菜单()
    添加右键菜单项(右键, "菜单项1", 5001)
    添加右键菜单项(右键, "菜单项2", 5002)
    添加右键菜单分隔线(右键)
    添加右键菜单项(右键, "菜单项3", 5003)
    注册右键菜单(窗口句柄, 右键)

    // ==== 皮肤 ====
    应用主题(窗口句柄, 浅色主题())

    // ==== 绑定事件 ====
    _绑定控件事件(按钮句柄, 通知点击, 函数(): 返回 按钮被点击())

    // ==== 运行 ====
    运行界面(窗口句柄)
结束

创建测试界面()
