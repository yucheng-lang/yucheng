// 语程 - 结构体示例

// 用字典模拟结构体
设 小明 = {名字: "小明", 年龄: 25, 城市: "北京"}
设 小红 = {名字: "小红", 年龄: 23, 城市: "上海"}

输出 "=== 结构体示例 ==="
输出 小明.名字 + "，" + 转字符串(小明.年龄) + "岁，来自" + 小明.城市
输出 小红.名字 + "，" + 转字符串(小红.年龄) + "岁，来自" + 小红.城市

// 结构体字段修改（通过索引赋值）
小明["年龄"] = 26
输出 "小明过生日了，现在" + 转字符串(小明.年龄) + "岁"

// 字典结构
设 书籍 = {标题: "语程入门", 作者: "语程社区", 价格: 49.9, 库存: 100}
输出 "\n=== 字典结构 ==="
输出 "书名：" + 书籍["标题"]
输出 "作者：" + 书籍["作者"]
输出 "价格：¥" + 转字符串(书籍["价格"])

// 嵌套结构
设 学生 = {
    名字: "张三",
    成绩: {语文: 90, 数学: 95, 英语: 88},
    爱好: ["编程", "阅读", "游泳"]
}
输出 "\n=== 嵌套结构 ==="
输出 学生.名字 + "的数学成绩：" + 转字符串(学生.成绩.数学)
输出 "爱好：" + 字符串连接("、", 学生.爱好[0], 学生.爱好[1], 学生.爱好[2])
输出 ""
输出 "=== 示例完成 ==="
输出 ""
