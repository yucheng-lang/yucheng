// 测试 Win32 原生 GUI
导入 "窗口组件"
导入 "标签"
导入 "按钮"
导入 "编辑框"

设 窗口句柄 = 空
设 文本框 = 空
设 计数 = 0

函程 按钮点击():
    计数 = 计数 + 1
    设 文本 = 获取编辑框文本(文本框)
    设置标签文本(状态标签, "点击次数: " + 转文本(计数) + " | 输入: " + 文本)
结束

设 状态标签 = 空

函程 创建测试界面():
    设 配置 = 窗口("语程 Win32 原生GUI测试", 500, 350)
    配置.居中 = 真
    窗口句柄 = 创建窗口(配置)

    设 标题 = 标签("欢迎使用语程语言 Win32 原生GUI!", 50, 30, 400, 30, 窗口句柄)
    标题.字体大小 = 18
    标题.字体粗细 = 700
    创建标签(标题)

    设 提示 = 标签("这是一个真正的 Win32 原生窗口，不再有硬编码登录界面!", 50, 70, 400, 25, 窗口句柄)
    创建标签(提示)

    设 输入标签 = 标签("输入文本:", 50, 120, 80, 25, 窗口句柄)
    创建标签(输入标签)

    设 编辑配置 = 编辑框("Hello 语程!", 140, 118, 250, 28, 窗口句柄)
    文本框 = 创建编辑框(编辑配置)

    设 按钮配置 = 按钮("点击测试", 150, 180, 200, 40, 窗口句柄)
    按钮配置.字体大小 = 16
    设 点击按钮 = 创建按钮(按钮配置)

    状态标签 = 标签("等待点击...", 50, 260, 400, 30, 窗口句柄)
    状态标签.字体大小 = 14
    创建标签(状态标签)

    _绑定控件事件(点击按钮, 通知点击, 函数(): 返回 按钮点击())

    运行界面(窗口句柄)
结束

创建测试界面()
