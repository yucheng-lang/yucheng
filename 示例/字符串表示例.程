// 字符串表库示例
// 演示高效字符串键值表

导入 "库/字符串表"

输出 "=== 字符串表库示例 ==="
输出 ""

// 创建字符串表
输出 "--- 创建字符串表 ---"
设 表 = 新建字符串表("不区分大小写")
输出 "创建不区分大小写的字符串表"
输出 ""

// 设置值
输出 "--- 设置值 ---"
表 = 设置值(表, "Name", "语程")
表 = 设置值(表, "Version", "0.4")
表 = 设置值(表, "name", "覆盖")  // 不区分大小写，会覆盖Name
输出 "设置键值对完成"
输出 ""

// 获取值
输出 "--- 获取值 ---"
设 名称 = 获取值(表, "Name")
输出 "Name的值: " + 名称
设 版本 = 获取默认值(表, "Version", "未知")
输出 "Version的值: " + 版本
输出 ""

// 检查键
输出 "--- 检查键 ---"
设 有Name = 有键(表, "NAME")
输出 "是否有NAME键: " + 转文本(有Name)
输出 ""

// 键列表
输出 "--- 键值列表 ---"
设 键列表 = 键列表(表)
输出 "所有键: " + 转文本(键列表)
设 值列表 = 值列表(表)
输出 "所有值: " + 转文本(值列表)
输出 ""

// 格式替换
输出 "--- 格式替换 ---"
设 表2 = 新建字符串表()
表2 = 设置值(表2, "名称", "语程")
表2 = 设置值(表2, "版本", "0.4")
设 结果 = 格式替换("语言: $名称, 版本: ${版本}", 表2)
输出 "格式替换: " + 结果
输出 ""

输出 "=== 示例完成 ==="
输出 ""
