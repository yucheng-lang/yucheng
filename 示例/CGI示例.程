// CGI库示例
// 演示CGI（通用网关接口）辅助函数

导入 "库/CGI"

输出 "=== CGI库示例 ==="
输出 ""

// CGI环境信息
输出 "--- CGI环境信息 ---"
输出 "请求方法: " + 请求方法()
输出 "请求网址: " + 请求网址()
输出 "查询字符串: " + 查询字符串()
输出 "服务器名称: " + 服务器名称()
输出 "服务器端口: " + 服务器端口()
输出 "协议类型: " + 协议类型()
输出 ""

// 客户端信息
输出 "--- 客户端信息 ---"
输出 "用户代理: " + 用户代理()
输出 "来源页面: " + 来源页面()
输出 "客户端地址: " + 客户端地址()
输出 "是否HTTPS: " + 转字符串(是否HTTPS())
输出 ""

// 内容信息
输出 "--- 内容信息 ---"
输出 "内容类型: " + 内容类型()
输出 "内容长度: " + 转字符串(内容长度())
输出 ""

// 输出CGI响应头
输出 "--- CGI响应 ---"
输出 "Content-Type: text/html; charset=utf-8"
输出 ""
输出 "<html><head><title>语程CGI示例</title></head>"
输出 "<body><h1>语程CGI测试成功</h1></body></html>"

输出 ""
输出 "=== 示例完成 ==="
输出 ""
