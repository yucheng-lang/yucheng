// 字符串工具库示例
// 演示字符串操作常用函数

导入 "库/字符串工具"

输出 "=== 字符串工具库示例 ==="
输出 ""

// 重复字符串
输出 "--- 重复字符串 ---"
设 重复结果 = 重复("语", 5)
输出 "重复'语'5次: " + 重复结果

设 分隔线 = 重复("-", 30)
输出 "分隔线: " + 分隔线
输出 ""

// 开头和结尾判断
输出 "--- 开头和结尾判断 ---"
设 文本 = "语程编程语言"

设 是语程开头 = 开头是(文本, "语程")
输出 "'" + 文本 + "' 以'语程'开头: " + 转字符串(是语程开头)

设 是语言结尾 = 结尾是(文本, "语言")
输出 "'" + 文本 + "' 以'语言'结尾: " + 转字符串(是语言结尾)
输出 ""

// 出现次数
输出 "--- 出现次数 ---"
设 句子 = "语程是一门中文编程语言，语程由Rust实现"
设 次数 = 出现次数(句子, "语程")
输出 "句子: " + 句子
输出 "'语程'出现次数: " + 转字符串(次数)
输出 ""

// 填充对齐
输出 "--- 填充对齐 ---"
设 短文本 = "语程"
设 居中结果 = 居中(短文本, 20, "-")
输出 "居中: " + 居中结果

设 左填充结果 = 左填充(短文本, 10, " ")
输出 "左填充: '" + 左填充结果 + "'"

设 右填充结果 = 右填充(短文本, 10, ".")
输出 "右填充: '" + 右填充结果 + "'"
输出 ""

// 格式化金额
输出 "--- 格式化金额 ---"
设 金额1 = 格式化金额(1234567)
输出 "金额1: " + 金额1

设 金额2 = 格式化金额(9876543.21)
输出 "金额2: " + 金额2

设 金额3 = 格式化金额(100)
输出 "金额3: " + 金额3
输出 ""

输出 "=== 示例完成 ==="
输出 ""
