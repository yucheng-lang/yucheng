// 浏览器库示例
// 演示打开默认浏览器功能

导入 "库/浏览器"

输出 "=== 浏览器库示例 ==="
输出 ""

// 打开浏览器
输出 "--- 打开浏览器 ---"
输出 "可以使用打开浏览器()函数打开URL"
输出 "例如: 打开浏览器(\"https://www.baidu.com\")"
输出 ""

// 打开搜索
输出 "--- 打开搜索 ---"
输出 "可以使用打开搜索()函数搜索"
输出 "例如: 打开搜索(\"语程编程语言\", \"百度\")"
输出 ""

// 打开HTML预览
输出 "--- 打开HTML预览 ---"
设 HTML内容 = """
<!DOCTYPE html>
<html>
<head>
    <title>语程预览</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        h1 { color: #333; }
    </style>
</head>
<body>
    <h1>语程HTML预览</h1>
    <p>这是由语程生成的HTML内容</p>
</body>
</html>
"""
输出 "HTML内容已准备"
输出 "可以使用打开HTML(HTML内容)在浏览器中预览"
输出 ""

// URL准备
输出 "--- URL准备 ---"
设 本地路径 = "C:/Users/Document/file.html"
设 准备后URL = 准备URL(本地路径)
输出 "本地路径: " + 本地路径
输出 "准备后URL: " + 准备后URL
输出 ""

// 搜索引擎URL
输出 "--- 搜索引擎URL ---"
设 查询词 = "语程编程语言"
设 百度URL = 获取搜索URL(查询词, "百度")
设 谷歌URL = 获取搜索URL(查询词, "谷歌")
输出 "百度搜索URL: " + 百度URL
输出 "谷歌搜索URL: " + 谷歌URL
输出 ""

// 系统命令
输出 "--- 系统命令 ---"
设 打开命令 = 获取打开命令()
输出 "当前系统打开命令: " + 打开命令
输出 ""

输出 "=== 示例完成 ==="
输出 ""
