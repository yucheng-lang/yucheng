// Base64编码库示例
// 演示Base64编码和解码功能

导入 "库/Base64编码"

输出 "=== Base64编码库示例 ==="
输出 ""

// 基本编码
设 原文 = "你好，语程！"
输出 "原文: " + 原文

设 编码结果 = 编码(原文)
输出 "编码后: " + 编码结果

设 解码结果 = 解码(编码结果)
输出 "解码后: " + 解码结果
输出 ""

// URL安全编码
设 URL数据 = "用户名/密码+测试"
输出 "URL数据: " + URL数据

设 安全编码结果 = 编码(URL数据, 真)
输出 "URL安全编码: " + 安全编码结果

设 普通编码结果 = 编码(URL数据, 假)
输出 "普通编码: " + 普通编码结果
输出 ""

// 编码数字
设 数字文本 = "12345"
输出 "数字文本: " + 数字文本
设 数字编码结果 = 编码(数字文本)
输出 "编码后: " + 数字编码结果
设 数字解码结果 = 解码(数字编码结果)
输出 "解码后: " + 数字解码结果
输出 ""

// 编码JSON字符串
设 JSON字符串 = "{\"name\":\"语程\",\"version\":0.4}"
输出 "JSON: " + JSON字符串
设 JSON编码结果 = 编码(JSON字符串)
输出 "编码后: " + JSON编码结果
输出 ""

输出 "=== 示例完成 ==="
输出 ""
