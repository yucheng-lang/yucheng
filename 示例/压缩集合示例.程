// ===== 压缩集合示例 =====
// 演示 压缩集合 库的稀疏位集合功能

导入 "库/压缩集合"

// --- 创建与添加 ---
输出 "=== 创建与添加 ==="
设 集合 = 创建压缩集合()
集合 = 集合添加(集合, 100)
集合 = 集合添加(集合, 200)
集合 = 集合添加(集合, 300)
输出 "添加100,200,300"
输出 "包含100: " + 转字符串(集合包含(集合, 100))
输出 "包含50: " + 转字符串(集合包含(集合, 50))
输出 "大小: " + 转字符串(集合大小(集合))

// --- 集合运算 ---
输出 ""
输出 "=== 集合运算 ==="
设 A = 创建压缩集合()
A = 集合添加(A, 1)
A = 集合添加(A, 2)
A = 集合添加(A, 3)

设 B = 创建压缩集合()
B = 集合添加(B, 2)
B = 集合添加(B, 3)
B = 集合添加(B, 4)

设 并集 = 集合并集(A, B)
设 交集 = 集合交集(A, B)
输出 "并集大小: " + 转字符串(集合大小(并集))
输出 "交集大小: " + 转字符串(集合大小(交集))

// --- 列表转换 ---
输出 ""
输出 "=== 列表转换 ==="
设 列表 = 集合转列表(A)
设 结果 = "["
设 i = 0
循环 i < 数组长度(列表):
    如果 i > 0:
        结果 = 结果 + ", "
    结果 = 结果 + 转字符串(列表[i])
    i = i + 1
输出 "A转列表: " + 结果 + "]"

// --- 从列表创建 ---
设 C = 列表转压缩集合([10, 20, 30, 40, 50])
输出 "从列表创建大小: " + 转字符串(集合大小(C))
输出 ""
输出 "=== 示例完成 ==="
输出 ""