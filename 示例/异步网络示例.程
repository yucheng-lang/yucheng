// 异步网络示例 - 异步HTTP客户端与套接字模拟
导入 "库/异步网络.程"

// 示例1: 创建请求构建器
设 请求 = 创建异步请求("GET", "https://httpbin.org/get")
请求 = 设置异步头部(请求, "Accept", "application/json")
请求 = 设置异步重试(请求, 2, 1)
输出 "请求方法: " + 请求.方法
输出 "重试次数: " + 转字符串(请求.重试次数)

// 示例2: 异步套接字
设 套接字 = 创建异步套接字("127.0.0.1", 8080)
输出 "套接字地址: " + 套接字.地址
输出 "已连接: " + 转字符串(套接字.已连接)

设 连接结果 = 异步连接(套接字)
套接字 = 连接结果.套接字
输出 "连接后: " + 转字符串(套接字.已连接)

设 发送结果 = 异步发送(套接字, "Hello")
套接字 = 发送结果.套接字
输出 "发送字节数: " + 转字符串(发送结果.发送数)

设 接收结果 = 异步接收(套接字, 100)
套接字 = 接收结果.套接字
输出 "接收数据: " + 接收结果.数据

设 关闭结果 = 异步关闭套接字(套接字)
套接字 = 关闭结果.套接字
输出 "关闭后连接: " + 转字符串(套接字.已连接)

// 示例3: 网络调度器
设 调度器 = 创建网络调度器()
设 请求2 = 创建异步请求("GET", "https://example.com")
调度器 = 添加网络任务(调度器, 请求2)
输出 "任务数: " + 转字符串(长度(调度器.任务列表))
输出 ""
输出 "=== 示例完成 ==="
