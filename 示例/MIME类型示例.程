// MIME类型库示例
// 演示文件扩展名与MIME类型的映射查询

导入 "库/MIME类型"

输出 "=== MIME类型库示例 ==="
输出 ""

// 根据扩展名获取MIME类型
输出 "--- 根据扩展名获取MIME类型 ---"
设 类型1 = 根据扩展名查询(".html")
输出 ".html -> " + 类型1

设 类型2 = 根据扩展名查询(".css")
输出 ".css -> " + 类型2

设 类型3 = 根据扩展名查询(".js")
输出 ".js -> " + 类型3

设 类型4 = 根据扩展名查询(".json")
输出 ".json -> " + 类型4
输出 ""

// 图片类型
输出 "--- 图片MIME类型 ---"
设 图片类型 = [".png", ".jpg", ".gif", ".svg", ".webp"]
循环 扩展名 于 图片类型:
    设 类型 = 根据扩展名查询(扩展名)
    输出 扩展名 + " -> " + 类型
输出 ""

// 音视频类型
输出 "--- 音视频MIME类型 ---"
输出 ".mp3 -> " + 根据扩展名查询(".mp3")
输出 ".mp4 -> " + 根据扩展名查询(".mp4")
输出 ".wav -> " + 根据扩展名查询(".wav")
输出 ""

// 文档类型
输出 "--- 文档MIME类型 ---"
输出 ".pdf -> " + 根据扩展名查询(".pdf")
输出 ".doc -> " + 根据扩展名查询(".doc")
输出 ".txt -> " + 根据扩展名查询(".txt")
输出 ""

// 根据文件名获取MIME类型
输出 "--- 根据文件名获取MIME类型 ---"
设 文件名 = "文档.pdf"
设 文件类型 = 根据文件名查询(文件名)
输出 文件名 + " -> " + 文件类型
输出 ""

// 未知扩展名
输出 "--- 未知扩展名 ---"
设 未知类型 = 根据扩展名查询(".xyz")
输出 ".xyz -> " + 未知类型
输出 ""

// 类型判断
输出 "--- 类型判断 ---"
输出 "是文本类型('text/html'): " + 转字符串(是文本类型("text/html"))
输出 "是图片类型('image/png'): " + 转字符串(是图片类型("image/png"))
输出 "是音频类型('audio/mpeg'): " + 转字符串(是音频类型("audio/mpeg"))
输出 "是视频类型('video/mp4'): " + 转字符串(是视频类型("video/mp4"))
输出 ""

// 反向查询
输出 "--- 反向查询 ---"
输出 "text/html -> " + 根据类型查扩展名("text/html")
输出 "image/png -> " + 根据类型查扩展名("image/png")
输出 "application/json -> " + 根据类型查扩展名("application/json")
输出 ""

输出 "=== 示例完成 ==="
输出 ""
