// 最简游戏引擎测试 - 只画文字确认定时器回调执行
导入 "游戏引擎库"

设 配置 = 游戏窗口("定时器绘图测试", 400, 300)
设 句柄 = 创建窗口(配置)
设 上下文 = 获取绘图上下文(句柄)
设 帧数 = 0

函程 游戏帧(定时器ID):
    帧数 = 帧数 + 1
    清除区域(上下文, 0, 0, 400, 300, "#1a1a2e")
    绘制文本(上下文, "帧: " + 转文本(帧数), 10, 10, "#00ff00", 24)
    绘制文本(上下文, "游戏引擎运行中!", 10, 50, "#00d2ff", 18)
    _填充矩形(上下文, 50, 100, 200, 150, "#e94560")
    _绘制矩形边框(上下文, 50, 100, 200, 150, "#ff6b6b")
    _填充圆形(上下文, 300, 150, 30, "#00d2ff")
结束

启动游戏循环(句柄, 游戏帧, 30)
运行界面(句柄)

