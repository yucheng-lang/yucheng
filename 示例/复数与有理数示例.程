// ===== 复数与有理数示例 =====
// 演示 复数 和 有理数 库的功能

导入 "库/复数"
导入 "库/有理数"
导入 "库/数学工具"

// ===== 复数 =====
输出 "=== 复数运算 ==="

// 创建复数: [实部, 虚部]
设 z1 = 创建复数(3, 4)
设 z2 = 创建复数(1, 2)

输出 "z1 = " + 复数转字符串(z1) + " (3+4i)"
输出 "z2 = " + 复数转字符串(z2) + " (1+2i)"

// 四则运算
设 和 = 复数加(z1, z2)
输出 "z1 + z2 = " + 复数转字符串(和)

设 差 = 复数减(z1, z2)
输出 "z1 - z2 = " + 复数转字符串(差)

设 积 = 复数乘(z1, z2)
输出 "z1 * z2 = " + 复数转字符串(积)

设 商 = 复数除(z1, z2)
输出 "z1 / z2 = " + 复数转字符串(商)

// 模和共轭
输出 "z1的模: " + 转字符串(复数模(z1))
输出 "z1的模平方: " + 转字符串(复数模平方(z1))
输出 "z1的共轭: " + 复数转字符串(复数共轭(z1))

// ===== 有理数 =====
输出 ""
输出 "=== 有理数运算 ==="

// 创建有理数: [分子, 分母]（自动约分）
设 r1 = 创建有理数(3, 4)
设 r2 = 创建有理数(2, 3)

输出 "r1 = " + 有理数转字符串(r1)
输出 "r2 = " + 有理数转字符串(r2)

// 四则运算
输出 "r1 + r2 = " + 有理数转字符串(有理数加(r1, r2))
输出 "r1 - r2 = " + 有理数转字符串(有理数减(r1, r2))
输出 "r1 * r2 = " + 有理数转字符串(有理数乘(r1, r2))
输出 "r1 / r2 = " + 有理数转字符串(有理数除(r1, r2))

// 转换
输出 "r1的浮点值: " + 转字符串(有理数转浮点(r1))
输出 "r1的绝对值: " + 有理数转字符串(有理数绝对值(r1))

// 自动约分
设 r3 = 创建有理数(12, 8)
输出 "12/8 约分后 = " + 有理数转字符串(r3)

// 幂运算
设 r4 = 有理数幂(r1, 2)
输出 "(3/4)^2 = " + 有理数转字符串(r4)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
