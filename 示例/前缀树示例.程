// 前缀树库示例
// 演示前缀树（Trie）数据结构

导入 "库/前缀树"

输出 "=== 前缀树库示例 ==="
输出 ""

// 创建前缀树
输出 "--- 创建前缀树 ---"
设 树 = 创建前缀树()
输出 "前缀树已创建"
输出 ""

// 插入键值
输出 "--- 插入键值 ---"
前缀树插入(树, "apple", 1)
前缀树插入(树, "app", 2)
前缀树插入(树, "application", 3)
前缀树插入(树, "banana", 4)
前缀树插入(树, "band", 5)
输出 "已插入5个键"
输出 ""

// 检查包含
输出 "--- 检查包含 ---"
输出 "包含'apple': " + 转字符串(前缀树包含(树, "apple"))
输出 "包含'app': " + 转字符串(前缀树包含(树, "app"))
输出 "包含'orange': " + 转字符串(前缀树包含(树, "orange"))
输出 ""

// 获取值
输出 "--- 获取值 ---"
输出 "'apple'的值: " + 转字符串(前缀树取值(树, "apple"))
输出 "'app'的值: " + 转字符串(前缀树取值(树, "app"))
输出 ""

// 前缀搜索
输出 "--- 前缀搜索 ---"
设 前缀结果 = 前缀树前缀搜索(树, "app")
输出 "以'app'开头的键: " + 转字符串(前缀结果)

设 前缀结果2 = 前缀树前缀搜索(树, "ban")
输出 "以'ban'开头的键: " + 转字符串(前缀结果2)
输出 ""

// 最长前缀
输出 "--- 最长前缀 ---"
设 最长 = 前缀树最长前缀(树, "application_test")
输出 "'application_test'的最长匹配前缀: " + 最长
输出 ""

// 树大小
输出 "--- 树大小 ---"
输出 "前缀树大小: " + 转字符串(前缀树大小(树))
输出 ""

// 删除键
输出 "--- 删除键 ---"
设 删除结果 = 前缀树删除(树, "app")
输出 "删除'app': " + 转字符串(删除结果)
输出 "删除后包含'app': " + 转字符串(前缀树包含(树, "app"))
输出 "删除后包含'apple': " + 转字符串(前缀树包含(树, "apple"))
输出 ""

输出 "=== 示例完成 ==="
输出 ""
