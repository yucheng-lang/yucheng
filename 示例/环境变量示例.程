// ===== 环境变量示例 =====
// 演示 环境变量 库的系统环境访问功能

导入 "库/环境变量"

// --- 基本操作 ---
输出 "=== 环境变量基本操作 ==="
设 路径 = 获取环境变量("PATH", "未设置")
输出 "PATH: " + 子串(路径, 0, 50) + "..."
输出 "PATH存在: " + 转字符串(环境变量存在("PATH"))
输出 "不存在变量: " + 转字符串(环境变量存在("NOT_EXIST_VAR"))

// --- 系统信息 ---
输出 ""
输出 "=== 系统信息 ==="
输出 "系统名称: " + 获取系统名称()
输出 "处理器架构: " + 获取处理器架构()
输出 "主机名: " + 获取主机名()
输出 "用户名: " + 获取用户名()
输出 "语言设置: " + 获取语言设置()
输出 "终端类型: " + 获取终端类型()
输出 "默认编辑器: " + 获取编辑器()

// --- 常用目录 ---
输出 ""
输出 "=== 常用目录 ==="
输出 "用户目录: " + 获取用户目录()
输出 "临时目录: " + 获取临时目录()
输出 "应用目录: " + 获取应用目录()
