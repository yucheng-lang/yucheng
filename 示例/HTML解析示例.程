// HTML解析库示例
// 演示HTML标签解析、属性提取功能

导入 "库/HTML解析"

输出 "=== HTML解析库示例 ==="
输出 ""

// HTML转义
输出 "--- HTML转义 ---"
设 原始文本 = "<script>alert('XSS')</script>"
设 转义后 = HTML转义(原始文本)
输出 "原始: " + 原始文本
输出 "转义后: " + 转义后
输出 ""

// HTML反转义
输出 "--- HTML反转义 ---"
设 实体文本 = "&lt;div&gt;内容&lt;/div&gt;"
设 反转义后 = HTML反转义(实体文本)
输出 "实体: " + 实体文本
输出 "反转义: " + 反转义后
输出 ""

// 提取文本内容
输出 "--- 提取文本内容 ---"
设 HTML内容 = "<p>这是<b>语程</b>的<i>HTML解析</i>示例</p>"
设 纯文本 = 提取文本(HTML内容)
输出 "纯文本: " + 纯文本
输出 ""

// 提取标题
输出 "--- 提取标题 ---"
设 标题HTML = "<html><head><title>语程语言</title></head><body>内容</body></html>"
设 标题 = 提取标题(标题HTML)
输出 "标题: " + 标题
输出 ""

// 提取元信息
输出 "--- 提取元信息 ---"
设 元HTML = "<meta name=\"description\" content=\"语程语言示例\"><meta name=\"author\" content=\"语程\">"
设 元信息 = 提取元信息(元HTML)
输出 "元信息: " + 转字符串(元信息)
输出 ""

// 提取链接
输出 "--- 提取链接 ---"
设 链接HTML = "<a href=\"https://example.com\">链接1</a><a href=\"https://test.com\">链接2</a>"
设 链接列表 = 提取链接(链接HTML)
输出 "链接数量: " + 转字符串(长度(链接列表))
输出 ""

// 提取图片
输出 "--- 提取图片 ---"
设 图片HTML = "<img src=\"img1.png\" alt=\"图片1\"><img src=\"img2.png\" alt=\"图片2\">"
设 图片列表 = 提取图片(图片HTML)
输出 "图片数量: " + 转字符串(长度(图片列表))
输出 ""

输出 "=== 示例完成 ==="
输出 ""
