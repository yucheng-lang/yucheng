// Unicode库示例
// 演示Unicode字符分类、转换功能

导入 "库/Unicode"

输出 "=== Unicode库示例 ==="
输出 ""

// 字母判断
输出 "--- 字母判断 ---"
设 结果1 = 是字母("A")
输出 "'A' 是字母: " + 转字符串(结果1)
设 结果2 = 是字母("中")
输出 "'中' 是字母: " + 转字符串(结果2)
输出 ""

// 数字判断
输出 "--- 数字判断 ---"
设 结果4 = 是数字("0")
输出 "'0' 是数字: " + 转字符串(结果4)
输出 ""

// 汉字判断
输出 "--- 汉字判断 ---"
设 结果6 = 是汉字("中")
输出 "'中' 是汉字: " + 转字符串(结果6)
输出 ""

// 空白字符判断
输出 "--- 空白字符判断 ---"
设 结果8 = 是空白字符(" ")
输出 "' ' 是空白字符: " + 转字符串(结果8)
输出 ""

// 字符码点
输出 "--- 字符码点 ---"
输出 "'A' 码点: " + 转字符串(字符码点("A"))
输出 "'中' 码点: " + 转字符串(字符码点("中"))
输出 ""

// 码点转字符
输出 "--- 码点转字符 ---"
输出 "码点65转字符: " + 码点转字符(65)
输出 "码点20013转字符: " + 码点转字符(20013)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
