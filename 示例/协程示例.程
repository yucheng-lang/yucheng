// 协程示例 - 协作式多任务调度
导入 "库/协程.程"

// 示例1: 创建协程和调度器
设 任务1 = 创建协程(空, "任务1")
输出 "协程名称: " + 任务1.名称
输出 "协程状态: " + 任务1.状态

// 示例2: 调度器操作
设 调度器 = 创建调度器()
调度器 = 添加协程(调度器, 任务1)
输出 "协程数量: " + 转字符串(长度(调度器.协程列表))

// 示例3: 挂起和恢复
任务1 = 挂起(任务1, 1)
输出 "挂起后状态: " + 任务1.状态
任务1 = 恢复(任务1)
输出 "恢复后状态: " + 任务1.状态
