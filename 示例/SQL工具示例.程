// SQL工具库示例
// 演示SQL解析与生成功能

导入 "库/SQL工具"

输出 "=== SQL工具库示例 ==="
输出 ""

// SQL词法分析
输出 "--- SQL词法分析 ---"
设 SQL = "SELECT name FROM users"
设 词元列表 = SQL词法分析(SQL)
输出 "SQL: " + SQL
输出 "词元列表: " + 转字符串(词元列表)
输出 ""

// SQL转义
输出 "--- SQL转义 ---"
设 原始值 = "O'Brien"
设 转义值 = SQL转义字符串(原始值)
输出 "原始值: " + 原始值
输出 "转义后: " + 转义值
输出 ""

// SQL关键字检查
输出 "--- SQL关键字检查 ---"
输出 "SELECT 是关键字: " + 转字符串(是SQL关键字("SELECT"))
输出 "name 是关键字: " + 转字符串(是SQL关键字("name"))
输出 ""

// SQL压缩
输出 "--- SQL压缩 ---"
设 多行SQL = "SELECT  name,  age  FROM  users"
设 压缩后 = SQL压缩(多行SQL)
输出 "压缩后: " + 压缩后
输出 ""

输出 "=== 示例完成 ==="
输出 ""
