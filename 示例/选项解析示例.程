// 选项解析库示例
// 演示命令行选项解析工具

导入 "库/选项解析"

输出 "=== 选项解析库示例 ==="
输出 ""

// 模拟命令行参数
输出 "--- 模拟命令行参数 ---"
设 参数列表 = ["--name", "语程", "--version", "1.0", "-v", "--debug", "file.txt"]
输出 "参数: " + 转字符串(参数列表)
输出 ""

// 解析参数
输出 "--- 解析参数 ---"
设 解析结果 = 解析参数(参数列表)
输出 "解析完成"
输出 ""

// 查询选项
输出 "--- 查询选项 ---"
输出 "选项存在'name': " + 转字符串(选项存在(解析结果, "name"))
输出 "选项存在'help': " + 转字符串(选项存在(解析结果, "help"))
输出 ""

// 获取选项值
输出 "--- 获取选项值 ---"
输出 "name值: " + 选项值(解析结果, "name", "默认名")
输出 "version值: " + 选项值(解析结果, "version", "0.0")
输出 "help值(默认): " + 选项值(解析结果, "help", "显示帮助")
输出 ""

// 短选项
输出 "--- 短选项 ---"
输出 "v选项值: " + 选项值(解析结果, "v", "未设置")
输出 "debug选项值: " + 选项值(解析结果, "debug", "未设置")
输出 ""

// 参数值
输出 "--- 参数值 ---"
输出 "第一个参数: " + 参数值(解析结果, 0, "无")
输出 "参数数量: " + 转字符串(参数数量(解析结果))
输出 ""

// 实际应用
输出 "--- 实际应用示例 ---"
输出 "命令行格式: program --name 值 --version 值 -v 文件..."
输出 "支持格式:"
输出 "  --key 值"
输出 "  --key=值"
输出 "  -k 值"
输出 "  -k=值"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
