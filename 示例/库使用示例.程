// 语程 v0.4.0 - 库使用示例
// 演示如何导入和使用中文库文件

输出 "╔══════════════════════════════════╗"
输出 "║     语程中文库 - 综合示例         ║"
输出 "╚══════════════════════════════════╝"
输出 ""

// ===== 1. 导入数学工具库 =====
导入 "库/数学工具"

输出 "━━━ 数学工具库 ━━━"
输出 ""

// 阶乘
输出 "5 的阶乘: " + 转字符串(阶乘(5))
输出 "10 的阶乘: " + 转字符串(阶乘(10))
输出 ""

// 幂运算
输出 "2 的 10 次方: " + 转字符串(幂(2, 10))
输出 "3 的 4 次方: " + 转字符串(幂(3, 4))
输出 ""

// 斐波那契数列
输出 "斐波那契数列前 10 项:"
设 i = 0
循环 i < 10:
    输出 转字符串(斐波那契(i)) + " "
    i = i + 1
输出 ""

// 质数
输出 "50 以内的质数:"
输出 转字符串(质数列表(50))
输出 ""

// 最大公约数与最小公倍数
输出 "12 和 18 的最大公约数: " + 转字符串(最大公约数(12, 18))
输出 "12 和 18 的最小公倍数: " + 转字符串(最小公倍数(12, 18))
输出 ""

// 等差数列求和
输出 "1+2+...+100 = " + 转字符串(等差求和(1, 100, 100))
输出 ""

// ===== 2. 导入列表工具库 =====
导入 "库/列表工具"

输出 "━━━ 列表工具库 ━━━"
输出 ""

设 成绩 = [85, 92, 78, 95, 88, 73, 91, 86]
输出 "成绩列表: " + 转字符串(成绩)
输出 "总分: " + 转字符串(求和(成绩))
输出 "平均分: " + 转字符串(数组平均值(成绩))
输出 "最高分: " + 转字符串(最大项(成绩))
输出 "最低分: " + 转字符串(最小项(成绩))
输出 ""

// 高阶函数 - 内联函数
设 优秀 = 过滤(成绩, 函数(x): 返回 x >= 90)
输出 "优秀成绩(>=90): " + 转字符串(优秀)
输出 ""

// 映射：给每个成绩加5分
设 加分 = 映射(成绩, 函数(x): 返回 x + 5)
输出 "每人加5分: " + 转字符串(加分)
输出 ""

// 归约：求总分
设 总分 = 归约(成绩, 函数(a, b): 返回 a + b, 0)
输出 "归约求总分: " + 转字符串(总分)
输出 ""

// 去重
设 有重复 = [1, 3, 2, 3, 4, 2, 5, 1]
输出 "去重前: " + 转字符串(有重复)
输出 "去重后: " + 转字符串(去重(有重复))
输出 ""

// 连接为字符串
设 水果 = ["苹果", "香蕉", "橘子"]
输出 "水果连接: " + 连接(水果, "、")
输出 ""

// ===== 3. 导入字符串工具库 =====
导入 "库/字符串工具"

输出 "━━━ 字符串工具库 ━━━"
输出 ""

// 重复
输出 "重复: " + 重复("★", 10)
输出 ""

// 居中与填充
输出 居中("语程", 20, "═")
输出 左填充("123", 8, "0")
输出 右填充("你好", 10, ".")
输出 ""

// 格式化金额
输出 "金额格式化:"
输出 "  1234567 -> " + 格式化金额(1234567)
输出 "  9876543.21 -> " + 格式化金额(9876543.21)
输出 ""

// 表格
设 标题 = ["姓名", "语文", "数学", "总分"]
输出 表格分隔(4, 8)
输出 表格行(标题, 8)
输出 表格分隔(4, 8)
输出 表格行(["张三", "95", "88", "183"], 8)
输出 表格行(["李四", "82", "96", "178"], 8)
输出 表格行(["王五", "90", "92", "182"], 8)
输出 表格分隔(4, 8)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
