// 验证定时器回调中的绘图操作
导入 "窗口组件"
导入 "绘图"

设 配置 = 窗口("绘图测试", 400, 300)
设 句柄 = 创建窗口(配置)
设 上下文 = 获取绘图上下文(句柄)
设 计数 = 0

函程 回调(定时器ID):
    计数 = 计数 + 1
    打印("回调 " + 转文本(计数) + ": 上下文=" + 上下文)
    
    // 绘制
    _填充矩形(上下文, 0, 0, 400, 300, "#1a1a2e")
    绘制文本(上下文, "Hello! 帧数=" + 转文本(计数), 10, 10, "#00ff00", 24)
    
    如果 计数 >= 5:
        删除定时器(句柄, 1)
        打印("停止")
结束

设置定时器(句柄, 1, 500, 回调)
运行界面(句柄)
打印("结束, 共 " + 转文本(计数) + " 帧")
输出 ""
输出 "=== 示例完成 ==="
输出 ""
