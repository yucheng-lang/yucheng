// 操作系统示例 - 系统信息、命令执行、休眠等
导入 "库/操作系统.程"

// === 系统信息 ===
输出 "=== 系统信息 ==="
输出 "系统名称: " + 系统名称()
输出 "主机名: " + 主机名()
输出 "用户名: " + 用户名()
输出 "用户主目录: " + 用户主目录()
输出 "临时目录: " + 临时目录路径()
输出 "当前目录: " + 当前目录路径()
输出 "系统分隔符: " + 系统分隔符()
输出 "是Windows: " + 转文本(是Windows())
输出 "是Unix: " + 转文本(是Unix())

// === 系统资源 ===
输出 ""
输出 "=== 系统资源 ==="
输出 "系统架构: " + 系统架构()
输出 "处理器数量: " + 转文本(处理器数量())
输出 "Shell类型: " + Shell类型()
输出 "终端类型: " + 终端类型()

// === 命令执行 ===
输出 ""
输出 "=== 命令执行 ==="
设 输出结果 = 执行命令并返回("echo 你好语程")
输出 "echo输出: " + 输出结果

设 捕获结果 = 执行并捕获("echo 测试")
输出 "捕获输出: " + 捕获结果.输出
输出 "退出码: " + 转文本(捕获结果.退出码)

// === 环境查询 ===
输出 ""
输出 "=== 环境查询 ==="
输出 "工作目录: " + 工作目录()
输出 "当前时间戳: " + 转文本(当前时间戳())

// === 休眠 ===
输出 ""
输出 "=== 休眠测试 ==="
设 开始 = 系统时间()
休眠(100)
设 结束 = 系统时间()
输出 "休眠100ms实际耗时: " + 转文本(结束 - 开始) + "ms"

// === 环境报告 ===
输出 ""
输出 "=== 环境报告 ==="
设 报告 = 环境报告()
输出 "系统: " + 报告.系统
输出 "主机: " + 报告.主机
输出 "用户: " + 报告.用户
输出 "架构: " + 报告.架构
输出 "处理器数: " + 转文本(报告.处理器数)
输出 "Shell: " + 报告.Shell

// === 哔声 ===
输出 ""
输出 "=== 实用工具 ==="
输出 "哔声测试（可能无声）:"
哔声()
输出 ""
输出 "=== 示例完成 ==="
输出 ""
