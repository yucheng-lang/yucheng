// 编辑距离库示例
// 演示字符串相似度计算

导入 "库/编辑距离"

输出 "=== 编辑距离库示例 ==="
输出 ""

// 编辑距离
输出 "--- 编辑距离 ---"
设 距离1 = 编辑距离("语程", "语言")
输出 "'语程' 与 '语言' 的编辑距离: " + 转字符串(距离1)

设 距离2 = 编辑距离("kitten", "sitting")
输出 "'kitten' 与 'sitting' 的编辑距离: " + 转字符串(距离2)
输出 ""

// 相似度
输出 "--- 相似度 ---"
设 相似度1 = 相似度("语程", "语言")
输出 "'语程' 与 '语言' 的相似度: " + 转字符串(相似度1)

设 相似度2 = 相似度("hello", "hello")
输出 "'hello' 与 'hello' 的相似度: " + 转字符串(相似度2)
输出 ""

// 汉明距离
输出 "--- 汉明距离 ---"
设 汉明距离1 = 汉明距离("1010101", "1110010")
输出 "'1010101' 与 '1110010' 的汉明距离: " + 转字符串(汉明距离1)
输出 ""

// 最长公共子序列
输出 "--- 最长公共子序列 ---"
设 LCS结果 = 最长公共子序列("语程编程", "语言编程")
输出 "最长公共子序列长度: " + 转字符串(LCS结果)
输出 ""

// 模糊匹配
输出 "--- 模糊匹配 ---"
设 匹配结果 = 模糊匹配("acd", "abcde")
输出 "'acd' 是 'abcde' 的子序列: " + 转字符串(匹配结果)
输出 ""

输出 "=== 示例完成 ==="
