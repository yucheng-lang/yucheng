// 逻辑库示例
// 演示逻辑运算、条件判断工具

导入 "库/逻辑"

输出 "=== 逻辑库示例 ==="
输出 ""

// 基本逻辑运算
输出 "--- 基本逻辑运算 ---"
输出 "蕴含(真, 真): " + 转字符串(蕴含(真, 真))
输出 "蕴含(真, 假): " + 转字符串(蕴含(真, 假))
输出 "蕴含(假, 真): " + 转字符串(蕴含(假, 真))
输出 ""

// 等价
输出 "--- 等价 ---"
输出 "等价(真, 真): " + 转字符串(等价(真, 真))
输出 "等价(真, 假): " + 转字符串(等价(真, 假))
输出 ""

// 异或
输出 "--- 异或 ---"
输出 "异或(真, 假): " + 转字符串(异或(真, 假))
输出 "异或(真, 真): " + 转字符串(异或(真, 真))
输出 "异或(假, 假): " + 转字符串(异或(假, 假))
输出 ""

// 与非/或非
输出 "--- 与非/或非 ---"
输出 "与非(真, 真): " + 转字符串(与非(真, 真))
输出 "或非(假, 假): " + 转字符串(或非(假, 假))
输出 ""

// 三元条件
输出 "--- 三元条件 ---"
设 结果1 = 条件(真, "是", "否")
设 结果2 = 条件(假, "是", "否")
输出 "条件(真, '是', '否'): " + 结果1
输出 "条件(假, '是', '否'): " + 结果2
输出 ""

// 合取/析取
输出 "--- 合取/析取 ---"
设 值列表1 = [真, 真, 真]
设 值列表2 = [真, 假, 真]
输出 "合取([真,真,真]): " + 转字符串(合取(值列表1))
输出 "合取([真,假,真]): " + 转字符串(合取(值列表2))
输出 "析取([真,假,真]): " + 转字符串(析取(值列表2))
输出 ""

// 取反
输出 "--- 取反 ---"
设 原列表 = [真, 假, 真]
设 反列表 = 取反(原列表)
输出 "原列表: " + 转字符串(原列表)
输出 "取反后: " + 转字符串(反列表)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
