// 语程 v0.4.0 - 基础语法示例

// ===== 变量声明 =====
设 名字 = "语程"
设 版本 = 0.4
设 介绍 = "中文母语编程语言"
常量 PI = 3.14159

输出 "名字: " + 名字
输出 "版本: " + 转字符串(版本)
输出 "介绍: " + 介绍

// ===== 条件判断 =====
设 分数 = 85
如果 分数 >= 90:
    输出 "优秀"
否则如果 分数 >= 60:
    输出 "及格"
否则:
    输出 "不及格"

// ===== 循环（while） =====
设 计数 = 0
循环 计数 < 5:
    输出 "计数: " + 转字符串(计数)
    计数 = 计数 + 1

// ===== 遍历循环（for） =====
设 水果 = ["苹果", "香蕉", "橘子"]
遍 果 于 水果:
    输出 "水果: " + 果

// ===== 逻辑运算 =====
设 是学生 = 真
设 是老师 = 假
输出 "是学生 且 是老师: " + 转字符串(是学生 且 是老师)
输出 "是学生 或 是老师: " + 转字符串(是学生 或 是老师)
输出 "非 是老师: " + 转字符串(非 是老师)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
