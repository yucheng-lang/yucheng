// HTML工具库示例
// 演示HTML生成和转义功能

导入 "HTML工具"

输出 "=== HTML工具库示例 ==="
输出 ""

// HTML转义
输出 "--- HTML转义 ---"
设 原始文本 = "<script>alert('XSS')</script>"
输出 "原始文本: " + 原始文本

设 转义后 = HTML工具.转义HTML(原始文本)
输出 "转义后: " + 转义后

设 反转义 = HTML工具.反转义HTML(转义后)
输出 "反转义: " + 反转义
输出 ""

// 基础标签
输出 "--- 基础标签 ---"
设 段落标签 = HTML工具.段落("这是语程语言")
输出 "段落: " + 段落标签

设 标题标签 = HTML工具.标题("语程语言", 1)
输出 "标题: " + 标题标签

设 链接标签 = HTML工具.链接("https://example.com", "点击这里")
输出 "链接: " + 链接标签
输出 ""

// 自闭合标签
输出 "--- 自闭合标签 ---"
设 换行标签 = HTML工具.自闭合标签("br")
输出 "换行: " + 换行标签

设 图片标签 = HTML工具.图片("logo.png", "语程Logo")
输出 "图片: " + 图片标签

设 输入标签 = HTML工具.自闭合标签("input", {type: "text", name: "username"})
输出 "输入框: " + 输入标签
输出 ""

// 带属性的标签
输出 "--- 带属性的标签 ---"
设 带属性段落 = HTML工具.段落("红色文本", {style: "color:red", class: "highlight"})
输出 "带属性段落: " + 带属性段落

设 带ID标签 = HTML工具.标签("div", "内容区域", {id: "content", class: "container"})
输出 "带ID标签: " + 带ID标签
输出 ""

// 列表
输出 "--- 列表 ---"
设 无序列表 = HTML工具.列表(["项目1", "项目2", "项目3"], "无序")
输出 "无序列表: " + 无序列表

设 有序列表 = HTML工具.列表(["第一步", "第二步", "第三步"], "有序")
输出 "有序列表: " + 有序列表
输出 ""

// 表格
输出 "--- 表格 ---"
设 表格数据 = [
    ["姓名", "年龄", "城市"],
    ["张三", "25", "北京"],
    ["李四", "30", "上海"]
]
设 表格HTML = HTML工具.表格(表格数据)
输出 "表格: " + 表格HTML
输出 ""

// 表单
输出 "--- 表单 ---"
设 表单字段 = [
    {类型: "text", 名称: "用户名", 标签: "用户名"},
    {类型: "password", 名称: "密码", 标签: "密码"},
    {类型: "submit", 值: "登录"}
]
设 表单HTML = HTML工具.表单("/login", "POST", 表单字段)
输出 "表单: " + 表单HTML
输出 ""

// 文本样式
输出 "--- 文本样式 ---"
设 粗体 = HTML工具.粗体("重要内容")
输出 "粗体: " + 粗体

设 斜体 = HTML工具.斜体("强调文本")
输出 "斜体: " + 斜体

设 删除线 = HTML工具.删除线("已删除")
输出 "删除线: " + 删除线
输出 ""

// 完整页面
输出 "--- 完整页面 ---"
设 页面内容 = HTML工具.标题("欢迎") + HTML工具.段落("这是语程语言的HTML工具示例")
设 完整页面 = HTML工具.页面框架("语程示例", 页面内容)
输出 "完整页面:"
输出 完整页面
输出 ""

输出 "=== 示例完成 ==="
输出 ""
