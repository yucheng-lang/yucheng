// ============================================
// 列表视图测试
// ============================================

导入 "GUI组件库/窗口组件"
导入 "GUI组件库/列表视图"

// 创建窗口
设 窗口配置 = 窗口("列表视图测试", 700, 450)
设 窗口句柄 = 创建窗口(窗口配置)

// 创建列表视图
设 列表配置 = 列表视图(20, 20, 650, 350, 窗口句柄)
设 列表 = 创建列表视图(列表配置)

输出 "[调试] 列表视图句柄: " + 列表

// 添加5列
添加列(列表, "序号", 60)
添加列(列表, "名称", 150)
添加列(列表, "类型", 100)
添加列(列表, "大小", 100)
添加列(列表, "状态", 120)

输出 "[调试] 列已添加"

// 添加3行数据
添加行(列表, ["1", "项目文档.docx", "文档", "2.5 MB", "已完成"])
添加行(列表, ["2", "演示视频.mp4", "视频", "156 MB", "下载中"])
添加行(列表, ["3", "源代码.zip", "压缩包", "45 MB", "待处理"])

输出 "[调试] 行已添加"

// 获取行数
设 行数 = 获取行数(列表)
输出 "[调试] 行数: " + 转字符串(行数)

// 获取单元格内容测试
设 单元格内容 = 获取单元格(列表, 0, 1)
输出 "[调试] 第1行第2列: " + 单元格内容

// 显示窗口
显示窗口(窗口句柄)

// 运行界面
运行界面(窗口句柄)
