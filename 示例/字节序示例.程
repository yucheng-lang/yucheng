// 字节序库示例
// 演示字节序（大小端）操作

导入 "库/字节序"

输出 "=== 字节序库示例 ==="
输出 ""

// 检测系统字节序
输出 "--- 检测系统字节序 ---"
设 是小端 = 是小端序()
如果 是小端:
    输出 "当前系统是小端序"
否则:
    输出 "当前系统是大端序"
输出 ""

// 字节序交换
输出 "--- 字节序交换 ---"
设 值16 = 0x1234
设 交换16 = 交换字节序16(值16)
输出 "16位: 0x" + 转十六进制(值16) + " -> 0x" + 转十六进制(交换16)

设 值32 = 0x12345678
设 交换32 = 交换字节序32(值32)
输出 "32位: 0x" + 转十六进制(值32) + " -> 0x" + 转十六进制(交换32)
输出 ""

// 小端编码
输出 "--- 小端编码 ---"
设 整数 = 0x12345678
设 小端字节 = 小端编码32(整数)
输出 "整数 " + 转十六进制(整数) + " 小端编码: " + 转字符串(小端字节)
输出 ""

// 大端编码
输出 "--- 大端编码 ---"
设 大端字节 = 大端编码32(整数)
输出 "整数 " + 转十六进制(整数) + " 大端编码: " + 转字符串(大端字节)
输出 ""

// 小端解码
输出 "--- 小端解码 ---"
设 字节数据 = [0x78, 0x56, 0x34, 0x12]
设 解码值 = 小端解码32(字节数据)
输出 "小端解码结果: 0x" + 转十六进制(解码值)
输出 ""

// 大端解码
输出 "--- 大端解码 ---"
设 字节数据2 = [0x12, 0x34, 0x56, 0x78]
设 解码值2 = 大端解码32(字节数据2)
输出 "大端解码结果: 0x" + 转十六进制(解码值2)
输出 ""

// 网络字节序
输出 "--- 网络字节序 ---"
输出 "网络字节序使用大端序"
设 主机序 = 0x1234
设 网络序 = 主机序转网络序16(主机序)
输出 "主机序转网络序: 0x" + 转十六进制(主机序) + " -> 0x" + 转十六进制(网络序)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
