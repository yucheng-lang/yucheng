// CSV工具示例 - CSV解析与生成
导入 "库/CSV工具.程"

输出 "=== CSV解析 ==="
设 csv数据 = "姓名,年龄,城市" + "\n" + "张三,25,北京" + "\n" + "李四,30,上海" + "\n" + "王五,28,深圳"
设 行列表 = 解析CSV(csv数据)
输出 "行数: " + 转文本(行列表.长度())
输出 "表头: " + 行列表[0].连接(" | ")
输出 "数据行: " + 行列表[1].连接(" | ")

输出 ""
输出 "=== 带表头解析 ==="
设 记录列表 = 解析CSV带表头(csv数据)
输出 "张三的年龄: " + 记录列表[0].获取默认值("年龄", "")
输出 "李四的城市: " + 记录列表[1].获取默认值("城市", "")

输出 ""
输出 "=== CSV查询 ==="
设 找到 = CSV按列查找(记录列表, "姓名", "王五", "城市")
输出 "王五的城市: " + 找到

输出 ""
输出 "=== CSV生成 ==="
设 数据 = [["苹果", "5", "3.5"], ["香蕉", "8", "2.8"], ["橙子", "6", "4.2"]]
设 生成文本 = 生成CSV(数据)
输出 "生成CSV:"
输出 生成文本

输出 ""
输出 "=== CSV字段转义 ==="
输出 "转义: " + CSV转义字段("你好,世界")
输出 "转义: " + CSV转义字段("含\"引号\"字段")
输出 ""
输出 "=== 示例完成 ==="
输出 ""