// PEG解析库示例
// 演示解析表达式语法模式匹配

导入 "库/PEG解析"

输出 "=== PEG解析库示例 ==="
输出 ""

// 字面匹配
输出 "--- 字面匹配 ---"
设 文本1 = "Hello 语程"
设 结果1 = 字面匹配("Hello", 文本1, 0)
输出 "匹配'Hello': " + 转字符串(结果1)
输出 ""

// 字符类匹配
输出 "--- 字符类匹配 ---"
设 文本2 = "语程语言"
设 结果2 = 字符类匹配(["语", "言", "文"], 文本2, 0)
输出 "匹配字符类: " + 转字符串(结果2)
输出 ""

// 字符范围匹配
输出 "--- 字符范围匹配 ---"
设 文本3 = "abc123"
设 结果3 = 字符范围匹配("a", "z", 文本3, 0)
输出 "匹配a-z范围: " + 转字符串(结果3)
输出 ""

// 任意字符匹配
输出 "--- 任意字符匹配 ---"
设 结果4 = 任意字符匹配("语程", 0)
输出 "匹配任意字符: " + 转字符串(结果4)
输出 ""

// 数字匹配
输出 "--- 数字匹配 ---"
设 文本5 = "12345abc"
设 结果5 = 数字匹配(文本5, 0)
输出 "匹配数字: " + 转字符串(结果5)
输出 ""

// 字母匹配
输出 "--- 字母匹配 ---"
设 文本6 = "Hello123"
设 结果6 = 字母匹配(文本6, 0)
输出 "匹配字母: " + 转字符串(结果6)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
