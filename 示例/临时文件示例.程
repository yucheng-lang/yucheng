// 临时文件库示例
// 演示临时文件与目录管理

导入 "临时文件"

输出 "=== 临时文件库示例 ==="
输出 ""

// 获取临时目录
输出 "--- 临时目录 ---"
设 临时目录路径 = 临时目录()
输出 "系统临时目录: " + 临时目录路径
输出 ""

// 创建临时文件
输出 "--- 创建临时文件 ---"
设 临时文件路径 = 临时文件.创建临时文件()
输出 "创建临时文件: " + 临时文件路径

设 带前缀文件 = 临时文件.创建临时文件("测试_", ".txt")
输出 "带前缀临时文件: " + 带前缀文件

设 指定目录文件 = 临时文件.创建临时文件("语程_", ".log", "D:/")
输出 "指定目录临时文件: " + 指定目录文件
输出 ""

// 创建临时目录
输出 "--- 创建临时目录 ---"
设 临时目录1 = 临时文件.创建临时目录()
输出 "创建临时目录: " + 临时目录1

设 带前缀目录 = 临时文件.创建临时目录("项目_")
输出 "带前缀临时目录: " + 带前缀目录
输出 ""

// 创建带内容的临时文件
输出 "--- 创建带内容的临时文件 ---"
设 内容文件 = 临时文件.创建临时文件带内容("这是临时文件内容")
输出 "创建带内容文件: " + 内容文件
输出 "文件内容: " + 读取文件(内容文件)

设 文本文件 = 临时文件.创建临时文本文件("语程语言测试文本")
输出 "创建文本文件: " + 文本文件

设 JSON文件 = 临时文件.创建临时JSON文件("{\"name\":\"语程\"}")
输出 "创建JSON文件: " + JSON文件

设 HTML文件 = 临时文件.创建临时HTML文件("<html><body>测试</body></html>")
输出 "创建HTML文件: " + HTML文件
输出 ""

// 生成唯一标识
输出 "--- 生成唯一标识 ---"
设 UUID1 = 临时文件.生成唯一标识()
输出 "唯一标识1: " + UUID1

设 UUID2 = 临时文件.生成唯一标识()
输出 "唯一标识2: " + UUID2

设 文件名 = 临时文件.生成临时文件名("数据_", ".csv")
输出 "临时文件名: " + 文件名
输出 ""

// 使用临时文件
输出 "--- 使用临时文件 ---"
设 临时文件路径2 = 临时文件.创建临时文件()
写入文件(临时文件路径2, "处理中的数据")
设 文件内容 = 读取文件(临时文件路径2)
设 处理结果 = "处理结果: " + 文件内容
输出 处理结果
删除文件(临时文件路径2)
输出 "临时文件已自动删除"
输出 ""

// 使用临时目录
输出 "--- 使用临时目录 ---"
设 临时目录2 = 临时文件.创建临时目录()
写入文件(临时目录2 + "/data.txt", "目录中的数据")
写入文件(临时目录2 + "/config.json", "{\"key\":\"value\"}")
设 目录处理结果 = "创建了2个文件"
删除目录(临时目录2)
输出 目录处理结果
输出 "临时目录已自动删除"
输出 ""

// 清理测试文件
输出 "--- 清理 ---"
删除文件(临时文件路径)
删除文件(带前缀文件)
删除文件(内容文件)
删除文件(文本文件)
删除文件(JSON文件)
删除文件(HTML文件)
删除目录(临时目录1)
删除目录(带前缀目录)
输出 "清理完成"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
