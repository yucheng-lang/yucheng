// 字符串扫描库示例
// 演示类似scanf的字符串模式匹配

导入 "库/字符串扫描"

输出 "=== 字符串扫描库示例 ==="
输出 ""

// 扫描整数
输出 "--- 扫描整数 ---"
设 文本1 = "123abc"
设 结果1 = 扫描整数(文本1, 0)
输出 "文本: " + 文本1
输出 "扫描结果: " + 转字符串(结果1)
输出 ""

// 扫描浮点数
输出 "--- 扫描浮点数 ---"
设 文本2 = "3.14159xyz"
设 结果2 = 扫描浮点数(文本2, 0)
输出 "文本: " + 文本2
输出 "扫描结果: " + 转字符串(结果2)
输出 ""

// 扫描标识符
输出 "--- 扫描标识符 ---"
设 文本3 = "变量名123"
设 结果3 = 扫描标识符(文本3, 0)
输出 "文本: " + 文本3
输出 "扫描结果: " + 转字符串(结果3)
输出 ""

// 扫描直到
输出 "--- 扫描直到 ---"
设 文本4 = "Hello,World"
设 结果4 = 扫描直到(文本4, ",", 0)
输出 "扫描到逗号前: " + 结果4
输出 ""

// 扫描IP地址
输出 "--- 扫描IP地址 ---"
设 文本5 = "192.168.1.1"
设 结果5 = 扫描IP地址(文本5)
输出 "IP地址: " + 转字符串(结果5)
输出 ""

// 扫描日期
输出 "--- 扫描日期 ---"
设 文本6 = "2024-01-15"
设 结果6 = 扫描日期(文本6, 0)
输出 "日期: " + 转字符串(结果6)
输出 ""

// 扫描键值对
输出 "--- 扫描键值对 ---"
设 文本7 = "name=张三,age=25"
设 结果7 = 扫描键值对(文本7, "=", ",")
输出 "键值对: " + 转字符串(结果7)
输出 ""

// 分割扫描行
输出 "--- 分割扫描行 ---"
设 多行文本 = "第一行\n第二行\n第三行"
设 行列表 = 分割扫描行(多行文本)
输出 "行数: " + 转字符串(数组长度(行列表))
输出 ""

输出 "=== 示例完成 ==="
输出 ""