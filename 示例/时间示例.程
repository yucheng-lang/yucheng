// 时间示例 - 系统时间与日期

// === 系统时间 ===
输出 "=== 系统时间 ==="
设 开始 = 系统时间()
输出 "系统时间(毫秒): " + 转字符串(开始)

// === 时间计算 ===
设 计 = 0
循环 计 < 10000:
    计 = 计 + 1
设 结束 = 系统时间()
输出 "10000次循环耗时: " + 转字符串(结束 - 开始) + "毫秒"

// === 日期时间 ===
输出 "=== 日期时间 ==="
输出 "当前日期: " + 当前日期()
输出 "当前时间: " + 当前时间()
输出 "当前日期时间: " + 当前日期时间()
输出 ""
输出 "=== 示例完成 ==="
输出 ""
