// 位转换库示例
// 演示位与数值转换功能

导入 "位转换"

输出 "=== 位转换库示例 ==="
输出 ""

// 进制转换
输出 "--- 进制转换 ---"
设 值 = 255
输出 "转二进制(" + 转文本(值) + "): " + 位转换.转二进制(值)
输出 "转八进制(" + 转文本(值) + "): " + 位转换.转八进制(值)
输出 "转十六进制(" + 转文本(值) + "): " + 位转换.转十六进制(值)
输出 ""

// 浮点数与整数位转换
输出 "--- 浮点数与整数位转换 ---"
设 浮点值 = 3.14
设 整数位 = 位转换.浮点转整数位(浮点值)
输出 "浮点数 " + 转文本(浮点值) + " 的位表示: " + 转文本(整数位)

设 还原浮点 = 位转换.整数位转浮点(整数位)
输出 "还原后的浮点数: " + 转文本(还原浮点)
输出 ""

// 字节序交换
输出 "--- 字节序交换 ---"
设 值16 = 0x1234
设 交换16 = 位转换.交换字节序16(值16)
输出 "16位值交换: " + 位转换.转十六进制(值16) + " -> " + 位转换.转十六进制(交换16)

设 值32 = 0x12345678
设 交换32 = 位转换.交换字节序32(值32)
输出 "32位值交换: " + 位转换.转十六进制(值32) + " -> " + 位转换.转十六进制(交换32)
输出 ""

// ZigZag编码
输出 "--- ZigZag编码 ---"
设 正数 = 100
设 负数 = -100
设 编码正 = 位转换.ZigZag编码(正数)
设 编码负 = 位转换.ZigZag编码(负数)
输出 "正数 " + 转文本(正数) + " 编码后: " + 转文本(编码正)
输出 "负数 " + 转文本(负数) + " 编码后: " + 转文本(编码负)

设 解码正 = 位转换.ZigZag解码(编码正)
设 解码负 = 位转换.ZigZag解码(编码负)
输出 "解码还原: " + 转文本(解码正) + ", " + 转文本(解码负)
输出 ""

// 位计数
输出 "--- 位计数 ---"
设 计数值 = 位转换.位计数(0xFF)
输出 "0xFF的位计数: " + 转文本(计数值)

设 是2幂 = 位转换.是2的幂(64)
输出 "64是2的幂: " + 转文本(是2幂)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
