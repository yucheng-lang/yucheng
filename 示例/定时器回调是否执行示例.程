// 验证定时器回调是否执行的测试
导入 "窗口组件"

设 配置 = 窗口("定时器测试", 400, 300)
设 句柄 = 创建窗口(配置)
设 计数 = 0

函程 回调(定时器ID):
    计数 = 计数 + 1
    打印("回调执行: 第" + 转文本(计数) + "次")
    如果 计数 >= 3:
        删除定时器(句柄, 1)
        打印("停止定时器")
结束

设置定时器(句柄, 1, 500, 回调)
运行界面(句柄)
打印("窗口已关闭, 回调共执行 " + 转文本(计数) + " 次")
输出 ""
输出 "=== 示例完成 ==="
输出 ""
