// 单元测试库示例
// 演示单元测试框架的使用

导入 "库/单元测试"

输出 "=== 单元测试库示例 ==="
输出 ""

// 开始测试组
测试组("基本断言测试")

// 断言为真
断言为真(1 + 1 == 2, "1 + 1 应该等于 2")
断言为真(真, "真值测试")

// 断言为假
断言为假(假, "假值测试")
断言为假(1 > 2, "1 不应该大于 2")

输出 ""

// 开始新测试组
测试组("相等性测试")

// 断言相等
断言相等("hello", "hello", "字符串相等测试")
断言相等(100, 100, "数字相等测试")

// 断言不等
断言不等(1, 2, "1 和 2 不相等")

输出 ""

// 开始新测试组
测试组("比较测试")

// 断言大于
断言大于(10, 5, "10 大于 5")

// 断言小于
断言小于(3, 5, "3 小于 5")

// 断言接近（浮点数比较）
断言接近(3.14159, 3.14160, 0.001, "π值近似测试")

输出 ""

// 开始新测试组
测试组("容器测试")

// 断言包含
设 测试列表 = [1, 2, 3, 4, 5]
断言包含(测试列表, 3, "列表包含3")

// 断言为空
设 空列表 = []
断言为空(空列表, "空列表测试")

// 断言不为空
断言不为空(测试列表, "非空列表测试")

输出 ""

// 运行自定义测试
测试组("自定义测试函数")

函程 测试字符串长度():
    设 文本 = "语程"
    断言相等(长度(文本), 2, "语程长度应为2")

函程 测试列表操作():
    设 列表 = [1, 2, 3]
    列表.添加(4)
    断言相等(数组长度(列表), 4, "添加后长度应为4")

运行测试("字符串长度测试", 测试字符串长度)
运行测试("列表操作测试", 测试列表操作)

输出 ""

// 输出测试摘要
测试摘要()

// 检查是否全部通过
如果 全部通过():
    输出 "所有测试通过！"
否则:
    输出 "存在失败的测试"

输出 ""
输出 "=== 示例完成 ==="
输出 ""