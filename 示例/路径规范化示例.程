// 路径规范化库示例
// 演示路径清理与规范化工具

导入 "库/路径规范化"

输出 "=== 路径规范化库示例 ==="
输出 ""

// 清理路径
输出 "--- 清理路径 ---"
设 路径1 = "a/b/../c/./d"
设 清理后1 = 清理路径(路径1)
输出 "清理前: " + 路径1
输出 "清理后: " + 清理后1

设 路径2 = "/home/user/../user/./docs"
设 清理后2 = 清理路径(路径2)
输出 "清理前: " + 路径2
输出 "清理后: " + 清理后2
输出 ""

// 规范化路径
输出 "--- 规范化路径 ---"
设 路径3 = "C:\\Users\\..\\Users\\Admin"
设 规范后 = 规范化路径(路径3)
输出 "规范化: " + 规范后
输出 ""

// 连接路径
输出 "--- 连接路径 ---"
设 基础 = "/home/user"
设 相对 = "documents/file.txt"
设 连接后 = 连接路径(基础, 相对)
输出 "连接路径: " + 连接后

设 连接后2 = 连接路径("/path/to/", "/absolute/path")
输出 "连接绝对路径: " + 连接后2
输出 ""

// 是绝对路径
输出 "--- 是绝对路径 ---"
输出 "/home/user 是绝对路径: " + 转字符串(是绝对路径("/home/user"))
输出 "relative/path 是绝对路径: " + 转字符串(是绝对路径("relative/path"))
输出 ""

// 拆分路径
输出 "--- 拆分路径 ---"
设 完整路径 = "/home/user/docs/file.txt"
设 拆分结果 = 拆分路径(完整路径)
输出 "路径: " + 完整路径
输出 "拆分结果: " + 转字符串(拆分结果)
输出 ""

// 拆分扩展名
输出 "--- 拆分扩展名 ---"
设 文件路径 = "document.pdf"
设 扩展名结果 = 拆分扩展名(文件路径)
输出 "文件: " + 文件路径
输出 "扩展名结果: " + 转字符串(扩展名结果)
输出 ""

// 路径父目录
输出 "--- 路径父目录 ---"
设 子路径 = "/home/user/docs/file.txt"
设 父目录 = 路径父目录(子路径)
输出 "父目录: " + 父目录
输出 ""

// 路径文件名
输出 "--- 路径文件名 ---"
设 文件名 = 路径文件名(子路径)
输出 "文件名: " + 文件名
输出 ""

// 相对路径
输出 "--- 相对路径 ---"
设 从路径 = "/home/user/docs"
设 到路径 = "/home/user/images"
设 相对结果 = 相对路径(从路径, 到路径)
输出 "相对路径: " + 相对结果
输出 ""

输出 "=== 示例完成 ==="
输出 ""
