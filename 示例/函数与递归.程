// ===== 基本函数 =====
函程 问候(名字):
    输出 "你好, " + 名字 + "!"

问候("世界")
问候("语程")

// ===== 带返回值的函数 =====
函程 加(a, b):
    返回 a + b

函程 减(a, b):
    返回 a - b

函程 乘(a, b):
    返回 a * b

设 x = 10
设 y = 3
输出 "加: " + 转字符串(加(x, y))
输出 "减: " + 转字符串(减(x, y))
输出 "乘: " + 转字符串(乘(x, y))

// ===== 递归：阶乘 =====
函程 阶乘(n):
    如果 n <= 1:
        返回 1
    返回 n * 阶乘(n - 1)

输出 "5的阶乘: " + 转字符串(阶乘(5))

// ===== 递归：斐波那契数列 =====
函程 斐波那契(n):
    如果 n <= 1:
        返回 n
    返回 斐波那契(n - 1) + 斐波那契(n - 2)

设 n = 10
输出 "斐波那契(" + 转字符串(n) + ") = " + 转字符串(斐波那契(n))
