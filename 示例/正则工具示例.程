// 验证密码强度
函程 验证密码强度(密码):
    如果 字符串长度(密码) < 8:
        返回 "弱 - 长度不足8位"
    如果 非 匹配(密码, "[A-Z]"):
        返回 "弱 - 缺少大写字母"
    如果 非 匹配(密码, "[a-z]"):
        返回 "弱 - 缺少小写字母"
    如果 非 匹配(密码, "\\d"):
        返回 "弱 - 缺少数字"
    如果 非 匹配(密码, "[!@#$%^&*]"):
        返回 "中 - 缺少特殊字符"
    返回 "强"

设 密码1 = "abc123"
设 密码2 = "Abc12345"
设 密码3 = "Abc123!@#"
输出 "密码 " + 密码1 + ": " + 验证密码强度(密码1)
输出 "密码 " + 密码2 + ": " + 验证密码强度(密码2)
输出 "密码 " + 密码3 + ": " + 验证密码强度(密码3)
输出 ""

