// 编码示例 - 正则表达式与字符串工具
// 语程内置正则表达式函数和字符串操作

// === 正则表达式 ===
输出 "=== 正则表达式 ==="
设 文本 = "abc123def456"
输出 "正则匹配(数字): " + 转字符串(正则匹配(文本, "\\d+"))
输出 "正则查找(首个数字): " + 正则查找(文本, "\\d+")
设 所有数字 = 正则查找全部(文本, "\\d+")
输出 "正则查找全部: " + 转字符串(所有数字)
输出 "正则替换(数字为X): " + 正则替换(文本, "\\d", "X")
设 分割结果 = 正则分割("a1b2c3", "\\d")
输出 "正则分割: " + 转字符串(分割结果)

// === 字符串编码 ===
输出 "=== 字符串编码 ==="
输出 "转整数('42'): " + 转字符串(转整数("42"))
输出 "转浮点数('3.14'): " + 转字符串(转浮点数("3.14"))
输出 "转字符串(123): " + 转字符串(123)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
