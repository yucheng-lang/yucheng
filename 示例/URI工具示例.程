// URI工具库示例
// 演示URI解析与URL编解码功能

导入 "库/URI工具"

输出 "=== URI工具库示例 ==="
输出 ""

// URL编码
输出 "--- URL编码 ---"
设 原始URL = "语程语言 中文编程"
输出 "原始文本: " + 原始URL

设 编码后 = URI工具.编码URL(原始URL)
输出 "编码后: " + 编码后

设 解码后 = URI工具.解码URL(编码后)
输出 "解码后: " + 解码后
输出 ""

// URL编码（空格处理）
输出 "--- 空格编码方式 ---"
设 带空格 = "hello world"
设 加号编码 = URI工具.编码URL(带空格, 真)
输出 "加号编码: " + 加号编码

设 百分号编码 = URI工具.编码URL(带空格, 假)
输出 "百分号编码: " + 百分号编码
输出 ""

// 特殊字符编码
输出 "--- 特殊字符编码 ---"
设 特殊字符 = "a=1&b=2<c>d"
输出 "原始: " + 特殊字符
设 特殊编码 = URI工具.编码URL(特殊字符)
输出 "编码: " + 特殊编码
输出 ""

// 解析URI
输出 "--- 解析URI ---"
设 URI地址 = "https://用户:密码@example.com:8080/路径/文件?参数=值#锚点"
输出 "URI: " + URI地址

设 解析结果 = URI工具.解析URI(URI地址)
输出 "协议: " + 解析结果.协议
输出 "主机: " + 解析结果.主机
输出 "端口: " + 转字符串(解析结果.端口)
输出 "路径: " + 解析结果.路径
输出 "查询: " + 解析结果.查询
输出 "片段: " + 解析结果.片段
输出 ""

// 构建查询字符串
输出 "--- 构建查询字符串 ---"
设 参数表 = {
    名称: "语程",
    版本: "0.4",
    功能: "中文编程"
}
设 查询串 = URI工具.构建查询字符串(参数表)
输出 "参数表: " + 转字符串(参数表)
输出 "查询串: " + 查询串
输出 ""

// 解析查询字符串
输出 "--- 解析查询字符串 ---"
设 查询参数 = URI工具.解析查询字符串("name=语程&version=0.4&feature=中文")
输出 "查询参数: " + 转字符串(查询参数)
输出 ""

// 完整URL构建
输出 "--- 完整URL构建 ---"
设 URL组件 = {
    协议: "https",
    主机: "api.example.com",
    端口: 443,
    路径: "/v1/users",
    查询: "page=1&limit=10"
}
设 完整URL = URL组件.协议 + "://" + URL组件.主机 + ":" + 转字符串(URL组件.端口) + URL组件.路径 + "?" + URL组件.查询
输出 "完整URL: " + 完整URL
输出 ""

// URL安全检查
输出 "--- URL安全检查 ---"
设 安全URL = "https://example.com/path"
设 不安全URL = "javascript:alert(1)"

设 是否安全1 = URI工具.是安全URL(安全URL)
输出 安全URL + " 安全: " + 转字符串(是否安全1)

设 是否安全2 = URI工具.是安全URL(不安全URL)
输出 不安全URL + " 安全: " + 转字符串(是否安全2)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
