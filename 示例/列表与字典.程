// 语程 v0.4.0 - 列表、字典与内置函数示例

// ===== 列表操作 =====
设 数列 = [3, 1, 4, 1, 5, 9, 2, 6]
输出 "原列表: " + 转字符串(数列)
输出 "长度: " + 转字符串(数组长度(数列))
输出 "排序: " + 转字符串(排序(数列))
输出 "反转: " + 转字符串(反转(数列))
输出 "求和: " + 转字符串(数组求和(数列))
输出 "去重: " + 转字符串(数组去重(数列))
输出 "包含5: " + 转字符串(数组包含(数列, 5))
输出 "最大值: " + 转字符串(最大值(数列[0], 数列[1]))

// ===== 字典操作 =====
设 学生 = {"姓名": "张三", "年龄": 20, "成绩": 95}
输出 "学生: " + 转字符串(学生)
输出 "姓名: " + 学生.姓名
输出 "年龄: " + 转字符串(学生.年龄)

// ===== 字符串操作 =====
设 文本 = "  你好，语程！  "
输出 "原文: \"" + 文本 + "\""
输出 "去除空白: \"" + 去除空白(文本) + "\""
输出 "长度: " + 转字符串(字符串长度(文本))
输出 "包含'语程': " + 转字符串(包含(文本, "语程"))

// ===== 数学运算 =====
输出 "绝对值(-42): " + 转字符串(绝对值(-42))
输出 "平方根(2): " + 转字符串(平方根(2))
输出 "幂(2, 10): " + 转字符串(幂(2, 10))
输出 "四舍五入(3.14159): " + 转字符串(四舍五入(3.14159))
输出 "阶乘(6): " + 转字符串(阶乘(6))

// ===== 日期时间 =====
输出 "当前日期: " + 当前日期()
输出 "当前时间: " + 当前时间()
输出 "当前日期时间: " + 当前日期时间()
输出 "时间戳: " + 转字符串(时间戳())

// ===== 加密编码 =====
输出 "MD5('你好'): " + MD5("你好")
输出 "UUID: " + UUID()
输出 ""
输出 "=== 示例完成 ==="
输出 ""
