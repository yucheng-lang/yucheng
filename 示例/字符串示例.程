// 字符串示例 - 内置字符串函数演示

// === 基础操作 ===
输出 "=== 基础操作 ==="
设 文本 = "你好，语程！"
输出 "原文: " + 文本
输出 "长度: " + 转字符串(长度(文本))
输出 "子串(0,2): " + 子串(文本, 0, 2)
输出 "包含('语程'): " + 转字符串(包含(文本, "语程"))
输出 "查找('语程'): " + 转字符串(查找(文本, "语程"))
输出 "替换('语程','世界'): " + 替换(文本, "语程", "世界")

// === 分割 ===
输出 "=== 分割 ==="
设 列表 = 分割("苹果,香蕉,橘子", ",")
输出 "分割: " + 转字符串(列表)

// === 前缀后缀 ===
输出 "=== 前缀后缀 ==="
输出 "开头是('你好'): " + 转字符串(开头是(文本, "你好"))
输出 "结尾是('！'): " + 转字符串(结尾是(文本, "！"))

// === 重复与反转 ===
输出 "=== 重复与反转 ==="
输出 "重复('哈',3): " + 重复("哈", 3)
输出 "反转('abcdef'): " + 反转("abcdef")

// === 正则表达式 ===
输出 "=== 正则表达式 ==="
输出 "正则匹配('abc123','\\d+'): " + 转字符串(正则匹配("abc123", "\\d+"))
输出 "正则查找('abc123','\\d+'): " + 正则查找("abc123", "\\d+")
输出 "正则替换('abc123','\\d','X'): " + 正则替换("abc123", "\\d", "X")
输出 ""
输出 "=== 示例完成 ==="
输出 ""
