// 序列化库示例
// 演示数据序列化与反序列化功能

导入 "序列化"

输出 "=== 序列化库示例 ==="
输出 ""

// 序列化基本类型
输出 "--- 序列化基本类型 ---"
设 整数序列 = 序列化(42)
输出 "整数: " + 整数序列

设 浮点序列 = 序列化(3.14159)
输出 "浮点: " + 浮点序列

设 布尔序列 = 序列化(真)
输出 "布尔: " + 布尔序列

设 字符串序列 = 序列化("语程语言")
输出 "字符串: " + 字符串序列

设 空值序列 = 序列化(空)
输出 "空值: " + 空值序列
输出 ""

// 序列化列表
输出 "--- 序列化列表 ---"
设 列表数据 = [1, 2, 3, "语程", 真]
设 列表序列 = 序列化(列表数据)
输出 "列表: " + 列表序列

设 格式化列表 = 序列化(列表数据, 2)
输出 "格式化列表:"
输出 格式化列表
输出 ""

// 序列化字典
输出 "--- 序列化字典 ---"
设 字典数据 = {名称: "语程", 版本: 0.4, 特性: ["中文", "动态类型"]}
设 字典序列 = 序列化(字典数据)
输出 "字典: " + 字典序列

设 格式化字典 = 序列化(字典数据, 2)
输出 "格式化字典:"
输出 格式化字典
输出 ""

// 序列化嵌套结构
输出 "--- 序列化嵌套结构 ---"
设 嵌套数据 = {用户: {姓名: "张三", 年龄: 25, 联系方式: {邮箱: "zhang@example.com", 电话: "1234567890"}}, 订单列表: [{编号: "001", 金额: 100}, {编号: "002", 金额: 200}]}
设 嵌套序列 = 序列化(嵌套数据, 2)
输出 "嵌套结构:"
输出 嵌套序列
输出 ""

// 反序列化
输出 "--- 反序列化 ---"
设 序列文本 = "[1, 2, 3, \"语程\"]"
设 反序列结果 = 反序列化(序列文本)
输出 "原文本: " + 序列文本
输出 "反序列化: " + 转字符串(反序列结果)

设 字典文本 = "{\"名称\": \"语程\", \"版本\": 0.4}"
设 字典结果 = 反序列化(字典文本)
输出 "字典反序列化: " + 转字符串(字典结果)
输出 ""

// 字符串转义
输出 "--- 字符串转义 ---"
设 原始字符串 = "换行\n制表\t引号\"反斜杠\\"
输出 "原始: " + 原始字符串

设 转义后 = 转义字符串(原始字符串)
输出 "转义: " + 转义后

设 反转义 = 反转义字符串(转义后)
输出 "反转义: " + 反转义
输出 ""

// 序列化到文件
输出 "--- 序列化到文件 ---"
设 数据 = {项目: "语程", 描述: "中文编程语言"}
设 序列内容 = 序列化(数据, 2)
写入文件("data_serialized.txt", 序列内容)
输出 "已序列化到文件: data_serialized.txt"
输出 ""

// 从文件反序列化
输出 "--- 从文件反序列化 ---"
设 文件内容 = 读取文件("data_serialized.txt")
设 加载数据 = 反序列化(文件内容)
输出 "从文件加载: " + 转字符串(加载数据)

删除文件("data_serialized.txt")
输出 "清理完成"
输出 ""

输出 "=== 示例完成 ==="
输出 ""