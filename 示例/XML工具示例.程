// XML工具库示例
// 演示XML解析、生成、查询功能

导入 "库/XML工具"

输出 "=== XML工具库示例 ==="
输出 ""

// 创建XML节点
输出 "--- 创建XML节点 ---"
设 根节点 = 创建节点("根", {}, [], "")
设 子节点1 = 创建节点("用户", {id: "1", 名字: "张三"}, [], "")
设 子节点2 = 创建节点("用户", {id: "2", 名字: "李四"}, [], "")

节点添加子节点(根节点, 子节点1)
节点添加子节点(根节点, 子节点2)
输出 "XML节点创建成功"
输出 ""

// 设置属性
输出 "--- 设置属性 ---"
节点设置属性(子节点1, "年龄", "25")
节点设置属性(子节点2, "年龄", "30")
输出 "属性设置完成"
输出 ""

// 获取属性
输出 "--- 获取属性 ---"
设 名字 = 节点获取属性(子节点1, "名字")
设 年龄 = 节点获取属性(子节点1, "年龄")
输出 "用户1名字: " + 名字
输出 "用户1年龄: " + 年龄
输出 ""

// 查找子节点
输出 "--- 查找子节点 ---"
设 用户列表 = 查找子节点(根节点, "用户")
输出 "找到用户数量: " + 转字符串(数组长度(用户列表))
输出 ""

// XML转字符串
输出 "--- XML转字符串 ---"
设 XML字符串 = 节点转字符串(根节点)
输出 XML字符串
输出 ""

// 解析XML字符串
输出 "--- 解析XML字符串 ---"
设 XML文本 = "<书><标题>语程入门</标题><作者>语程团队</作者></书>"
设 解析结果 = 解析XML(XML文本)
输出 "解析成功: " + 转字符串(解析结果 != 空)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
