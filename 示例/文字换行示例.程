// 文字换行库示例
// 演示文字排版与换行工具

导入 "库/文字换行"

输出 "=== 文字换行库示例 ==="
输出 ""

// 基本换行
输出 "--- 基本换行 ---"
设 长文本 = "语程是一门中文编程语言，由Rust语言实现，具有简洁的中文语法和强大的功能。"
设 换行后 = 换行(长文本, 20)
输出 "原始文本: " + 长文本
输出 "换行后(宽度20):"
输出 换行后
输出 ""

// 左对齐
输出 "--- 左对齐 ---"
设 左对齐文本 = 左对齐("语程", 20)
输出 "左对齐: '" + 左对齐文本 + "'"
输出 ""

// 右对齐
输出 "--- 右对齐 ---"
设 右对齐文本 = 右对齐("语程", 20)
输出 "右对齐: '" + 右对齐文本 + "'"
输出 ""

// 缩进
输出 "--- 缩进 ---"
设 原文 = "第一行\n第二行\n第三行"
设 缩进后 = 缩进(原文, "    ")
输出 "缩进后:"
输出 缩进后
输出 ""

// 去缩进
输出 "--- 去缩进 ---"
设 缩进文本 = "    缩进的文本"
设 去缩后 = 去缩进(缩进文本, 4)
输出 "去缩进: '" + 去缩后 + "'"
输出 ""

// 截断文本
输出 "--- 截断文本 ---"
设 截断后 = 截断文本(长文本, 15)
输出 "截断(15字符): " + 截断后
输出 ""

// 省略文本
输出 "--- 省略文本 ---"
设 省略后 = 省略文本(长文本, 20)
输出 "省略(20字符): " + 省略后
输出 ""

输出 "=== 示例完成 ==="
输出 ""
