// 命令行库示例
// 演示命令行参数访问和解析功能

导入 "库/命令行"

输出 "=== 命令行库示例 ==="
输出 ""

// 获取参数信息
输出 "--- 参数信息 ---"
设 参数个数结果 = 参数个数()
输出 "参数个数: " + 转字符串(参数个数结果)

设 程序名结果 = 程序名()
输出 "程序名: " + 程序名结果

设 所有参数结果 = 所有参数()
输出 "所有参数: " + 转字符串(所有参数结果)
输出 ""

// 获取特定参数
输出 "--- 获取特定参数 ---"
设 i = 0
循环 i < 参数个数结果:
    设 参数 = 参数值(i + 1)
    输出 "参数" + 转字符串(i + 1) + ": " + 参数
    i = i + 1
输出 ""

// 解析命令行字符串
输出 "--- 解析命令行字符串 ---"
设 命令串 = "yucheng --input 文件.程 --output 结果.txt -v"
输出 "命令字符串: " + 命令串

设 解析结果 = 解析命令行(命令串)
输出 "解析结果: " + 转字符串(解析结果)
输出 ""

// 解析带引号的命令
设 带引号命令 = "program \"hello world\" --name \"语程语言\""
输出 "带引号命令: " + 带引号命令

设 引号解析 = 解析命令行(带引号命令)
输出 "解析结果: " + 转字符串(引号解析)
输出 ""

// 获取标志参数
输出 "--- 标志参数 ---"
设 有详细标志 = 标志参数(所有参数结果, "-v")
输出 "是否有-v标志: " + 转字符串(有详细标志)

设 有帮助标志 = 标志参数(所有参数结果, "--help")
输出 "是否有--help标志: " + 转字符串(有帮助标志)
输出 ""

// 获取命名参数
输出 "--- 命名参数 ---"
设 输入文件 = 命名参数(所有参数结果, "--input", "默认输入.程")
输出 "输入文件: " + 输入文件

设 输出文件 = 命名参数(所有参数结果, "--output", "默认输出.txt")
输出 "输出文件: " + 输出文件
输出 ""

// 获取位置参数
输出 "--- 位置参数 ---"
设 位置参数列表 = 位置参数(所有参数结果)
输出 "位置参数: " + 转字符串(位置参数列表)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
输出 "提示: 运行此示例时可以添加命令行参数测试"
输出 "例如: yucheng 命令行示例.程 arg1 arg2 --name 测试"
输出 ""
输出 "=== 示例完成 ==="
输出 ""
