// 语程 - JSON与编码示例
导入 "库/JSON工具.程"
导入 "库/列表工具.程"

输出 "=== JSON与编码示例 ==="

// JSON解析
设 json字符串 = "{\"名字\":\"语程\",\"版本\":\"0.4.0\",\"特性\":[\"中文编程\",\"动态类型\",\"丰富的标准库\"]}"
设 数据 = JSON解析(json字符串)
输出 "解析JSON："
输出 "  名字：" + 数据["名字"]
输出 "  版本：" + 数据["版本"]
设 特性列表 = 数据["特性"]
设 特性文本 = 连接(特性列表, "、")
输出 "  特性：" + 特性文本

// JSON生成
设 配置 = {数据库: "localhost", 端口: 3306, 调试: 真}
设 json输出 = 生成JSON(配置)
输出 "\n生成JSON：" + json输出

// 紧凑JSON
设 紧凑 = 紧凑JSON(配置)
输出 "\n紧凑JSON：" + 紧凑

// JSON值操作
输出 ""
输出 "=== JSON值操作 ==="
设 用户 = {姓名: "张三", 年龄: 25, 城市: "北京"}
输出 "取JSON值(姓名): " + 取JSON值(用户, "姓名")
设 修改后 = 设JSON值(用户, "年龄", 26)
输出 "设JSON值(年龄=26): " + 转文本(修改后.年龄)
输出 "JSON键存在(姓名): " + 转文本(JSON键存在(用户, "姓名"))
输出 "JSON键存在(邮箱): " + 转文本(JSON键存在(用户, "邮箱"))

// 取嵌套值
输出 ""
输出 "=== JSON嵌套查询 ==="
设 嵌套数据 = {用户: {地址: {城市: "上海", 邮编: "200000"}}}
设 城市 = 取嵌套值(嵌套数据, ["用户", "地址", "城市"])
输出 "取嵌套值(用户.地址.城市): " + 城市

// JSON数组操作
输出 ""
输出 "=== JSON数组操作 ==="
设 数组 = [10, 20, 30]
输出 "JSON数组长度: " + 转文本(JSON数组长度(数组))
输出 "JSON数组项(1): " + 转文本(JSON数组项(数组, 1))

// 合并JSON
输出 ""
输出 "=== 合并JSON ==="
设 基础 = {a: 1, b: 2}
设 覆盖 = {b: 3, c: 4}
设 合并结果 = 合并JSON(基础, 覆盖)
输出 "合并后: a=" + 转文本(合并结果.a) + " b=" + 转文本(合并结果.b) + " c=" + 转文本(合并结果.c)

// Base64编码
输出 ""
输出 "=== 编码与加密 ==="
设 原文 = "语程编程语言"
设 编码结果 = Base64编码(原文)
输出 "Base64编码：" + 编码结果
输出 "Base64解码：" + Base64解码(编码结果)

// URL编码
设 网址 = "https://example.com/搜索?q=语程编程"
设 编码网址 = URL编码(网址)
输出 "\nURL编码：" + 编码网址
输出 "URL解码：" + URL解码(编码网址)

// 哈希
输出 "\n=== 哈希计算 ==="
输出 "MD5：" + MD5(原文)
输出 "SHA256：" + SHA256(原文)

// UUID生成
输出 "\nUUID：" + UUID()
输出 ""
输出 "=== 示例完成 ==="
输出 ""
