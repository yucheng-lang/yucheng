// 进程库示例
// 演示进程管理功能

导入 "进程"

输出 "=== 进程库示例 ==="
输出 ""

// 获取进程信息
输出 "--- 进程信息 ---"
设 当前PID = 当前进程编号()
输出 "当前进程号: " + 转文本(当前PID)

设 父PID = 父进程编号()
输出 "父进程号: " + 转文本(父PID)
输出 ""

// 创建进程
输出 "--- 创建进程 ---"
设 新进程 = 创建进程("echo", ["Hello, 语程!"])
输出 "创建进程: " + 新进程.命令
输出 ""

// 启动进程
输出 "--- 启动进程 ---"
设 运行进程 = 启动(新进程)
输出 "进程输出: " + 运行进程.标准输出
输出 "退出码: " + 转文本(运行进程.退出码)
输出 ""

// 快速执行程序
输出 "--- 快速执行程序 ---"
设 输出结果 = 执行程序("echo", ["语程语言"])
输出 "执行结果: " + 输出结果
输出 ""

// 进程查询
输出 "--- 进程查询 ---"
设 是否运行 = 进程是否运行(当前PID)
输出 "当前进程是否运行: " + 转文本(是否运行)
输出 ""

// 查找进程
输出 "--- 查找进程 ---"
设 进程列表 = 查找进程("yucheng")
输出 "查找'yucheng'进程: " + 转文本(进程列表)
输出 ""

// 列出进程
输出 "--- 进程列表 ---"
设 所有进程文本 = 列出进程()
输出 "进程列表前100字符: " + 所有进程文本.子串(0, 100)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
