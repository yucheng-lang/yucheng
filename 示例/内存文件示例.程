// 内存文件示例 - 基于字符串缓冲的内存映射文件
导入 "库/内存文件.程"

// 示例1: 创建内存文件
设 文件 = 创建内存文件("你好世界！这是内存文件测试。", "测试文件")
输出 "文件名: " + 文件.文件名
输出 "大小: " + 转字符串(文件.大小)
输出 "位置: " + 转字符串(文件.位置)

// 示例2: 读取数据
设 读取结果 = 内存读取(文件, 4)
文件 = 读取结果.文件
输出 "读取4字节: " + 读取结果.数据
输出 "当前位置: " + 转字符串(文件.位置)

// 示例3: 读取全部
输出 "全部内容: " + 内存读取全部(文件)

// 示例4: 设置位置
文件 = 设置位置(文件, 0)
输出 "重置后位置: " + 转字符串(文件.位置)

// 示例5: 写入数据
文件 = 设置位置(文件, 文件.大小)
文件 = 内存写入(文件, " 追加的数据")
输出 "写入后大小: " + 转字符串(文件.大小)
输出 "写入后内容: " + 内存读取全部(文件)

// 示例6: 读取行
文件 = 设置位置(文件, 0)
设 行结果 = 内存读取行(文件)
文件 = 行结果.文件
输出 "第一行: " + 行结果.数据

// 示例7: 调整大小
文件 = 调整大小(文件, 5)
输出 "调整后大小: " + 转字符串(文件.大小)
输出 "调整后内容: " + 内存读取全部(文件)
输出 ""
输出 "=== 示例完成 ==="
输出 ""