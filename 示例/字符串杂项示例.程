// 字符串杂项库示例
// 演示字符串的杂项处理函数

导入 "库/字符串杂项"

输出 "=== 字符串杂项库示例 ==="
输出 ""

// 取左边/右边/中间
输出 "--- 取左边/右边/中间 ---"
设 文本 = "语程编程语言"
输出 "原文本: " + 文本
输出 "取左边(2): " + 取左边(文本, 2)
输出 "取右边(2): " + 取右边(文本, 2)
输出 "取中间(2, 2): " + 取中间(文本, 2, 2)
输出 ""

// 出现次数
输出 "--- 出现次数 ---"
设 句子 = "语程是一门中文编程语言，语程由Rust实现"
设 次数 = 出现次数(句子, "语程")
输出 "'语程'出现次数: " + 转字符串(次数)
输出 ""

// 第N次出现
输出 "--- 第N次出现 ---"
设 位置1 = 第N次出现(句子, "语程", 1)
设 位置2 = 第N次出现(句子, "语程", 2)
输出 "第1次出现位置: " + 转字符串(位置1)
输出 "第2次出现位置: " + 转字符串(位置2)
输出 ""

// 全部位置
输出 "--- 全部位置 ---"
设 所有位置 = 全部位置(句子, "语程")
输出 "所有出现位置: " + 转字符串(所有位置)
输出 ""

// 翻转字符串
输出 "--- 翻转字符串 ---"
设 反转后 = 翻转("语程")
输出 "翻转'语程': " + 反转后
输出 ""

// 首字母大写
输出 "--- 首字母大写 ---"
输出 首字母大写("hello world")
输出 首字母大写("语程编程")
输出 ""

// 脱敏
输出 "--- 脱敏 ---"
输出 "手机号脱敏: " + 手机号脱敏("13812345678")
输出 "邮箱脱敏: " + 邮箱脱敏("test@example.com")
输出 ""

输出 "=== 示例完成 ==="
输出 ""
