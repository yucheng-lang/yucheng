// 配置解析库示例
// 演示配置文件解析与生成

导入 "库/配置解析"

输出 "=== 配置解析库示例 ==="
输出 ""

// 解析INI
输出 "--- 解析INI ---"
设 INI文本 = """
[数据库]
host = localhost
port = 3306
name = mydb

[应用]
name = 语程应用
debug = true
"""
设 配置 = 解析INI(INI文本)
输出 "INI解析结果: " + 转字符串(配置)
输出 ""

// 获取配置值
输出 "--- 获取配置值 ---"
设 数据库配置 = 配置["数据库"]
输出 "数据库host: " + 取配置值(配置, "数据库", "host", "默认主机")
输出 "数据库port: " + 取配置值(配置, "数据库", "port", "0")
输出 "应用名: " + 取配置值(配置, "应用", "name", "默认应用")
输出 ""

// 生成INI
输出 "--- 生成INI ---"
设 新配置 = {
    默认: {},
    服务器: {地址: "127.0.0.1", 端口: "8080"},
    日志: {级别: "info", 文件: "app.log"}
}
设 INI输出 = 生成INI(新配置)
输出 "生成的INI:"
输出 INI输出
输出 ""

// 解析键值对
输出 "--- 解析键值对 ---"
设 键值文本 = "name=语程\nversion=1.0\nauthor=语程团队"
设 键值配置 = 解析键值对(键值文本)
输出 "键值对解析: " + 转字符串(键值配置)
输出 ""

// 解析CSV行
输出 "--- 解析CSV行 ---"
设 CSV行 = "张三,25,北京,工程师"
设 CSV字段 = 解析CSV行(CSV行)
输出 "CSV字段: " + 转字符串(CSV字段)
输出 ""

// 解析CSV
输出 "--- 解析CSV ---"
设 CSV文本 = "姓名,年龄,城市\n张三,25,北京\n李四,30,上海"
设 CSV数据 = 解析CSV(CSV文本)
输出 "CSV行数: " + 转字符串(数组长度(CSV数据))
输出 ""

// 生成CSV行
输出 "--- 生成CSV行 ---"
设 字段列表 = ["王五", "28", "广州", "设计师"]
设 CSV输出 = 生成CSV行(字段列表)
输出 "生成的CSV行: " + CSV输出
输出 ""

输出 "=== 示例完成 ==="
输出 ""
