// 浮点环境库示例
// 演示浮点精度与舍入控制

导入 "库/浮点环境"

输出 "=== 浮点环境库示例 ==="
输出 ""

// 浮点常量
输出 "--- 浮点常量 ---"
输出 "单精度最大值: " + 转文本(单精度最大值)
输出 "单精度最小值: " + 转文本(单精度最小值)
输出 "单精度机器精度: " + 转文本(单精度机器精度)
输出 ""

输出 "双精度最大值: " + 转文本(双精度最大值)
输出 "双精度最小值: " + 转文本(双精度最小值)
输出 "双精度机器精度: " + 转文本(双精度机器精度)
输出 ""

// 舍入模式
输出 "--- 舍入模式 ---"
设 当前模式 = 获取舍入模式()
输出 "当前舍入模式: " + 当前模式

设置舍入模式("向上")
输出 "设置舍入模式为: " + 获取舍入模式()

设置舍入模式("最近")
输出 "恢复舍入模式为: " + 获取舍入模式()
输出 ""

// 浮点异常
输出 "--- 浮点异常 ---"
清除异常()
输出 "异常已清除"

触发异常("除零")
输出 "触发除零异常"

设 有除零异常 = 测试异常("除零")
输出 "测试除零异常: " + 转文本(有除零异常)
输出 ""

// 安全浮点运算
输出 "--- 安全浮点运算 ---"
设 结果1 = 安全除法(10.0, 2.0)
输出 "安全除法 10/2: " + 转文本(结果1)

设 结果2 = 安全除法(10.0, 0.0)
输出 "安全除法 10/0: " + 转文本(结果2)
输出 ""

// 浮点分类
输出 "--- 浮点分类 ---"
设 值1 = 0.0
设 值2 = -0.0
设 值3 = 正无穷()
设 值4 = 非数值()

输出 "0.0 是零: " + 转文本(是零(值1))
输出 "-0.0 是零: " + 转文本(是零(值2))
输出 "正无穷 是无穷: " + 转文本(是无穷(值3))
输出 "NaN 是非数值: " + 转文本(是非数值(值4))
输出 ""
输出 "=== 示例完成 ==="
输出 ""
