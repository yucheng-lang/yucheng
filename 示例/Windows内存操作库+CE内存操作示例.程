// 测试 Windows内存操作 和 CE内存操作 库
输出 "=== 测试 Windows内存操作库 ==="

导入 "Windows内存操作"

// 测试获取所有进程
输出 "--- 获取所有进程(前5个) ---"
设 进程列表 = 获取所有进程()
设 i = 0
循环 当 i < 5 且 i < 进程列表.长度():
    输出 转文本(取整(进程列表[i].取值("进程ID"))) + " - " + 进程列表[i].取值("进程名")
    i = i + 1

// 测试获取当前进程信息
输出 "--- 当前进程信息 ---"
输出 "进程编号: " + 转文本(进程编号())
输出 "父进程编号: " + 转文本(父进程编号())

// 测试进程内存信息
输出 "--- 当前进程内存信息 ---"
设 内存信息 = 获取进程内存信息(进程编号())
如果 内存信息 != 空:
    输出 "工作集: " + 格式化字节数(内存信息.取值("工作集"))
    输出 "私有内存: " + 格式化字节数(内存信息.取值("私有内存"))

// 测试十六进制工具
输出 "--- 十六进制工具 ---"
输出 "解析十六进制: " + 转文本(解析十六进制("0xFF"))
输出 "格式化十六进制: " + 格式化十六进制(255, 4)

// 测试格式化字节数
输出 "--- 格式化字节数 ---"
输出 "1024: " + 格式化字节数(1024)
输出 "1048576: " + 格式化字节数(1048576)
输出 "1073741824: " + 格式化字节数(1073741824)

输出 ""
输出 "=== 测试 CE内存操作库 ==="

导入 "CE内存操作"

// 测试数据类型
输出 "--- 数据类型 ---"
设 类型列表 = 数据类型列表()
设 类型文本 = ""
设 j = 0
循环 当 j < 类型列表.长度():
    如果 j > 0:
        类型文本 = 类型文本 + ", "
    类型文本 = 类型文本 + 转文本(类型列表[j])
    j = j + 1
输出 "支持类型: " + 类型文本

// 测试数据大小
输出 "--- 数据大小 ---"
输出 "整数大小: " + 转文本(数据大小("整数")) + " 字节"
输出 "双精度大小: " + 转文本(数据大小("双精度")) + " 字节"

// 测试保护属性
输出 "--- 内存保护属性 ---"
输出 "读写: " + 保护属性名称(内存保护_读写())
输出 "执行读写: " + 保护属性名称(内存保护_执行读写())
输出 "只读是否可读: " + 转文本(是否可读(内存保护_只读()))
输出 "只读是否可写: " + 转文本(是否可写(内存保护_只读()))

// 测试格式化数值
输出 "--- 格式化数值 ---"
输出 "整数: " + 格式化数值(42, "整数")
输出 "浮点: " + 格式化数值(3.14159, "浮点")

// 测试地址列表管理
输出 "--- 地址列表管理 ---"
设 地址表 = 创建地址列表()
地址表 = 添加地址(地址表, "生命值", "0x12345678", "整数")
地址表 = 添加地址(地址表, "魔法值", "0x12345680", "浮点")
输出 "地址数量: " + 转文本(地址表.取值("地址项").长度())

// 测试冻结
地址表 = 冻结地址(地址表, 0, "100")
输出 "冻结项数: " + 转文本(地址表.取值("冻结项").长度())

// 解冻
地址表 = 解冻地址(地址表, 0)
输出 "解冻后冻结项数: " + 转文本(地址表.取值("冻结项").长度())

// 测试扫描会话
输出 "--- 扫描会话 ---"
设 会话 = 创建扫描会话(进程编号())
输出 "扫描次数: " + 转文本(会话.取值("扫描次数"))
设 统计 = 扫描统计(会话)
输出 "统计: 扫描" + 转文本(统计.取值("扫描次数")) + "次"

// 测试常量
输出 "--- 常量 ---"
输出 "内存保护_读写: " + 转文本(内存保护_读写())
输出 "进程权限_全部访问: " + 转文本(进程权限_全部访问())

输出 ""
输出 "=== 所有测试完成 ==="
输出 ""
