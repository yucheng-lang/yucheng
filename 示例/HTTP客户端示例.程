// HTTP客户端库示例
// 演示HTTP请求发送功能

导入 "库/HTTP客户端"

输出 "=== HTTP客户端库示例 ==="
输出 ""

// 发送GET请求
输出 "--- 发送GET请求 ---"
设 响应1 = HTTP获取("https://httpbin.org/get")
输出 "状态码: " + 转字符串(响应1.状态码)
输出 "状态文本: " + 响应1.状态文本
输出 ""

// 发送带参数的GET请求
输出 "--- 带参数的GET请求 ---"
设 响应2 = HTTP获取("https://httpbin.org/get?name=语程&version=1.0")
输出 "状态码: " + 转字符串(响应2.状态码)
输出 ""

// 发送POST请求
输出 "--- 发送POST请求 ---"
设 数据 = "{\"name\":\"语程\",\"type\":\"编程语言\"}"
设 头部 = {"Content-Type": "application/json"}
设 响应3 = HTTP提交("https://httpbin.org/post", 数据, 头部)
输出 "状态码: " + 转字符串(响应3.状态码)
输出 ""

// 其他HTTP方法
输出 "--- 其他HTTP方法 ---"
设 响应4 = HTTP更新("https://httpbin.org/put", "更新数据")
输出 "PUT状态码: " + 转字符串(响应4.状态码)

设 响应5 = HTTP删除("https://httpbin.org/delete")
输出 "DELETE状态码: " + 转字符串(响应5.状态码)
输出 ""

// 请求选项
输出 "--- 请求选项 ---"
输出 "超时设置: 30秒"
输出 "支持方法: GET, POST, PUT, DELETE, PATCH, HEAD"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
