// 异步文件示例 - 基于回调模式的文件读写
导入 "库/异步文件.程"

// 示例1: 打开文件
设 文件 = 打开异步文件("测试文件_异步.txt", "读写")
输出 "文件已打开: " + 转字符串(文件.已打开)
输出 "文件模式: " + 文件.模式

// 示例2: 写入数据
设 写入结果 = 异步写入(文件, "你好，异步文件！")
文件 = 写入结果.文件
输出 "写入字节数: " + 转字符串(写入结果.写入数)
输出 "写入错误: " + 转字符串(写入结果.错误)

// 示例3: 读取全部
设 读取结果 = 异步读取全部(文件)
输出 "全部内容: " + 读取结果.数据

// 示例4: 设置位置后读取
文件 = 设置文件位置(文件, 0)
设 部分读取 = 异步读取(文件, 4)
文件 = 部分读取.文件
输出 "部分读取: " + 部分读取.数据
输出 "读取后位置: " + 转字符串(文件.位置)

// 示例5: 批量写入
设 批量 = [{路径: "测试1.txt", 内容: "文件1"}, {路径: "测试2.txt", 内容: "文件2"}]
设 批量结果 = 批量异步写入(批量)
输出 "批量写入数: " + 转字符串(长度(批量结果))
输出 ""
输出 "=== 示例完成 ==="
输出 ""
