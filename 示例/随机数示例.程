// ===== 随机数示例 =====
// 演示 随机数 库的功能

导入 "库/随机数"

// --- 基本随机数 ---
输出 "=== 基本随机数 ==="
输出 "随机整数(10): " + 转字符串(随机整数(10))
输出 "随机浮点(): " + 转字符串(随机浮点())
输出 "随机范围(1, 6): " + 转字符串(随机范围(1, 6)) + " (模拟骰子)"
输出 "随机布尔(): " + 转字符串(随机布尔())

// --- 随机抽样 ---
输出 ""
输出 "=== 随机抽样 ==="
设 水果 = ["苹果", "香蕉", "橙子", "葡萄", "西瓜"]
输出 "随机选一个: " + 随机抽样(水果)
输出 "随机选3个: "
设 样本 = 随机抽样n(水果, 3)
设 i = 0
循环 i < 数组长度(样本):
    输出 "  " + 样本[i]
    i = i + 1

// --- 随机洗牌 ---
输出 ""
输出 "=== 随机洗牌 ==="
设 数字 = [1, 2, 3, 4, 5]
设 洗后 = 随机洗牌(数字)
设 结果 = ""
设 j = 0
循环 j < 数组长度(洗后):
    如果 j > 0:
        结果 = 结果 + ", "
    结果 = 结果 + 转字符串(洗后[j])
    j = j + 1
输出 "洗牌后: " + 结果

// --- 随机字符串 ---
输出 ""
输出 "=== 随机字符串 ==="
输出 "随机字符串(8): " + 随机字符串(8)
输出 "随机数字字符串(6): " + 随机数字字符串(6)

// --- 加权随机 ---
输出 ""
输出 "=== 加权随机 ==="
设 选项 = ["常见", "普通", "稀有", "传说"]
设 权重 = [40, 30, 20, 10]
设 抽到 = 加权随机(选项, 权重)
输出 "加权抽取结果: " + 抽到
输出 ""
输出 "=== 示例完成 ==="
输出 ""
