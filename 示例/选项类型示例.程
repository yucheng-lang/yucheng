// 选项类型库示例
// 演示Optional类型的使用

导入 "库/选项类型"

输出 "=== 选项类型库示例 ==="
输出 ""

// 创建选项
输出 "--- 创建选项 ---"
设 有值选项 = 某些(42)
输出 "某些(42): " + 转字符串(有值选项)

设 空选项 = 无()
输出 "无(): " + 转字符串(空选项)

设 从值创建 = 选项(100)
输出 "选项(100): " + 转字符串(从值创建)
输出 ""

// 检查选项状态
输出 "--- 检查选项状态 ---"
设 有值 = 有值(有值选项)
输出 "某些(42)有值: " + 转字符串(有值)

设 无值结果 = 无值(空选项)
输出 "无()无值: " + 转字符串(无值结果)
输出 ""

// 获取值
输出 "--- 获取值 ---"
设 值1 = 获取(有值选项)
输出 "获取某些(42): " + 转字符串(值1)

设 默认值 = 获取或默认(空选项, 0)
输出 "获取或默认(空选项, 0): " + 转字符串(默认值)
输出 ""

// 映射操作
输出 "--- 映射操作 ---"

函程 加倍(x):
    返回 x * 2

设 映射后 = 映射(有值选项, 加倍)
设 映射值 = 获取或默认(映射后, 0)
输出 "某些(42)映射(×2): " + 转字符串(映射值)
输出 ""

// 实际应用：安全除法
输出 "--- 实际应用：安全除法 ---"
函程 安全除法(被除数, 除数):
    如果 除数 == 0:
        返回 无()
    否则:
        返回 某些(被除数 / 除数)

设 结果1 = 安全除法(10, 2)
输出 "10 / 2 = " + 转字符串(获取或默认(结果1, 0))

设 结果2 = 安全除法(10, 0)
输出 "10 / 0 = " + 转字符串(获取或默认(结果2, "除数不能为0"))
输出 ""
输出 "=== 示例完成 ==="
输出 ""
