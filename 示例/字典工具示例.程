// 字典工具库示例
// 演示字典操作常用函数

导入 "库/字典工具"

输出 "=== 字典工具库示例 ==="
输出 ""

// 创建测试字典
设 用户信息 = {
    姓名: "张三",
    年龄: 25,
    城市: "北京",
    职业: "工程师"
}

设 分数表 = {
    语文: 85,
    数学: 92,
    英语: 78
}

输出 "用户信息: " + 转字符串(用户信息)
输出 "分数表: " + 转字符串(分数表)
输出 ""

// 基本操作
输出 "--- 基本操作 ---"
设 所有键列表 = 所有键(用户信息)
输出 "所有键: " + 转字符串(所有键列表)

设 所有值列表 = 所有值(用户信息)
输出 "所有值: " + 转字符串(所有值列表)

设 键存在结果 = 键存在(用户信息, "姓名")
输出 "键'姓名'存在: " + 转字符串(键存在结果)

设 取值结果 = 取值(用户信息, "年龄", 0)
输出 "取值'年龄': " + 转字符串(取值结果)

设 默认值结果 = 取值(用户信息, "工资", "未设置")
输出 "取值'工资'(默认): " + 转字符串(默认值结果)
输出 ""

// 字典大小
输出 "--- 字典信息 ---"
设 大小 = 字典大小(用户信息)
输出 "字典大小: " + 转字符串(大小)

设 为空 = 字典为空(用户信息)
输出 "字典为空: " + 转字符串(为空)
输出 ""

// 合并操作
输出 "--- 合并操作 ---"
设 扩展信息 = {工资: 10000, 部门: "研发"}
设 合并后 = 合并字典(用户信息, 扩展信息)
输出 "合并后: " + 转字符串(合并后)
输出 ""

// 映射与过滤
输出 "--- 映射与过滤 ---"

设 分数加成 = 映射值(分数表, 函数(v): 返回 v + 5)
输出 "分数加5分: " + 转字符串(分数加成)

设 高分科目 = 过滤字典(分数表, 函数(k, v): 返回 v >= 80)
输出 "80分以上科目: " + 转字符串(高分科目)
输出 ""

// 查找操作
输出 "--- 查找操作 ---"
设 查找键结果 = 查找键(分数表, 92)
输出 "查找分数92的科目: " + 查找键结果
输出 ""

// 删除操作
输出 "--- 删除操作 ---"
设 删除后 = 删除键(用户信息, "职业")
输出 "删除'职业'后: " + 转字符串(删除后)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
