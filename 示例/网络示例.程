// 网络库示例
// 演示网络与套接字操作

导入 "网络"

输出 "=== 网络库示例 ==="
输出 ""

// IP地址解析
输出 "--- IP地址解析 ---"
设 IPv4地址 = 解析IPv4地址("192.168.1.1")
输出 "解析IPv4: " + 转文本(IPv4地址)

设 IPv6地址 = 解析IPv6地址("::1")
输出 "解析IPv6: " + 转文本(IPv6地址)

设 通用IP = 解析IP地址("127.0.0.1")
输出 "通用解析: " + 转文本(通用IP)
输出 ""

// IP地址验证
输出 "--- IP地址验证 ---"
设 是IP1 = 是IP地址("192.168.1.1")
输出 "'192.168.1.1' 是IP地址: " + 转文本(是IP1)

设 是IP2 = 是IP地址("localhost")
输出 "'localhost' 是IP地址: " + 转文本(是IP2)

设 是IPv4 = 是IPv4地址("10.0.0.1")
输出 "'10.0.0.1' 是IPv4: " + 转文本(是IPv4)

设 是IPv6 = 是IPv6地址("fe80::1")
输出 "'fe80::1' 是IPv6: " + 转文本(是IPv6)
输出 ""

// 特殊地址
输出 "--- 特殊地址 ---"
设 任意地址 = IPv4任意地址()
输出 "IPv4任意地址: " + 转文本(任意地址)

设 回环地址 = IPv4回环地址()
输出 "IPv4回环地址: " + 转文本(回环地址)

设 广播地址 = IPv4广播地址()
输出 "IPv4广播地址: " + 转文本(广播地址)

设 IPv6任意 = IPv6任意地址()
输出 "IPv6任意地址: " + 转文本(IPv6任意)

设 IPv6回环 = IPv6回环地址()
输出 "IPv6回环地址: " + 转文本(IPv6回环)
输出 ""

// 套接字操作
输出 "--- 套接字操作 ---"
设 套接字 = 创建套接字("IPv4", "流", "TCP")
输出 "创建套接字成功"

绑定地址(套接字, 8080, "0.0.0.0")
输出 "绑定地址: 0.0.0.0:8080"

监听(套接字, 128)
输出 "开始监听，积压连接数: 128"
输出 ""

// TCP客户端示例
输出 "--- TCP客户端示例 ---"
设 客户端 = 创建套接字()
输出 "创建客户端套接字成功"

连接(客户端, "127.0.0.1", 80)
输出 "连接到: 127.0.0.1:80"
输出 ""

// 关闭套接字
输出 "--- 关闭连接 ---"
关闭套接字(客户端)
输出 "客户端套接字已关闭"

关闭套接字(套接字)
输出 "服务端套接字已关闭"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
