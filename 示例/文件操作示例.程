// 语程 - 文件操作示例

输出 "=== 文件操作示例 ==="

// 写入文件
设 内容 = "这是语程文件操作示例\n第二行内容\n第三行内容\n"
写入文件("测试文件.txt", 内容)
输出 "已写入文件：测试文件.txt"

// 读取文件
设 读取内容 = 读取文件("测试文件.txt")
输出 "读取到内容：" + 读取内容

// 追加内容
追加文件("测试文件.txt", "追加的第四行\n")
输出 "已追加内容"

// 再次读取验证
设 验证内容 = 读取文件("测试文件.txt")
输出 "验证读取：" + 验证内容

// 文件存在性检查
设 存在 = 文件存在("测试文件.txt")
输出 "文件存在：" + 转文本(存在)

设 不存在 = 文件存在("不存在的文件.txt")
输出 "不存在的文件：" + 转文本(不存在)

// 列出目录内容
输出 "\n=== 目录操作 ==="
设 文件列表 = 目录列表(".")
输出 "当前目录文件："
遍 文件 于 文件列表:
    输出 "  " + 文件
结束

// 获取文件大小
设 大小 = 文件大小("测试文件.txt")
输出 "测试文件大小：" + 转文本(大小) + " 字节"

// 清理测试文件
删除文件("测试文件.txt")
输出 "\n已清理测试文件"
输出 ""

输出 "=== 示例完成 ==="
输出 ""