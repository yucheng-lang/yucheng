// 游戏引擎库独立窗口测试
导入 "游戏引擎库"

设 配置 = 游戏窗口("游戏引擎测试", 800, 600)
设 句柄 = 创建窗口(配置)
设 上下文 = 获取绘图上下文(句柄)

// 玩家状态
设 玩家X = 375.0
设 玩家Y = 520.0
设 速度Y = 0.0
设 跳跃中 = 假

// 键码常量
常量 键码左 = 37
常量 键码上 = 38
常量 键码右 = 39

// 游戏帧函数（定时器回调，参数为定时器ID，忽略）
函程 游戏帧(定时器ID):
    设 增量 = 16.0 / 1000.0

    // === 更新 ===
    如果 按键按下(键码左):
        玩家X = 玩家X - 200 * 增量
    如果 按键按下(键码右):
        玩家X = 玩家X + 200 * 增量
    如果 按键按下(键码上) 且 非 跳跃中:
        速度Y = -350.0
        跳跃中 = 真

    速度Y = 速度Y + 500.0 * 增量
    玩家Y = 玩家Y + 速度Y * 增量

    如果 玩家Y > 520:
        玩家Y = 520
        速度Y = 0
        跳跃中 = 假
    如果 玩家X < 0:
        玩家X = 0
    如果 玩家X > 760:
        玩家X = 760

    // === 渲染 ===
    清除区域(上下文, 0, 0, 800, 600, "#1a1a2e")

    // 地面
    _填充矩形(上下文, 0, 550, 800, 600, "#16213e")
    _绘制矩形边框(上下文, 0, 550, 800, 600, "#0f3460")

    // 平台
    _填充矩形(上下文, 100, 430, 250, 450, "#16213e")
    _绘制矩形边框(上下文, 100, 430, 250, 450, "#0f3460")
    _填充矩形(上下文, 350, 350, 500, 370, "#16213e")
    _绘制矩形边框(上下文, 350, 350, 500, 370, "#0f3460")
    _填充矩形(上下文, 550, 270, 700, 290, "#16213e")
    _绘制矩形边框(上下文, 550, 270, 700, 290, "#0f3460")

    // 收集物
    _填充圆形(上下文, 170, 408, 8, "#e94560")
    _填充圆形(上下文, 420, 328, 8, "#e94560")
    _填充圆形(上下文, 620, 248, 8, "#e94560")

    // 玩家
    _填充矩形(上下文, 玩家X, 玩家Y, 玩家X + 30, 玩家Y + 30, "#00d2ff")
    _绘制矩形边框(上下文, 玩家X, 玩家Y, 玩家X + 30, 玩家Y + 30, "#0099cc")

    // 提示
    绘制文本(上下文, "方向键移动/跳跃", 10, 10, "#aaaaaa", 14)
结束

启动游戏循环(句柄, 游戏帧, 60)
运行界面(句柄)
