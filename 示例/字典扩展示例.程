// 字典扩展库示例
// 演示高级字典操作工具

导入 "库/字典扩展"

输出 "=== 字典扩展库示例 ==="
输出 ""

// 计数表
输出 "--- 计数表 ---"
设 计数器 = 创建计数表()
计数表增量(计数器, "苹果")
计数表增量(计数器, "苹果")
计数表增量(计数器, "香蕉")
计数表增量(计数器, "苹果")
计数表增量(计数器, "橙子")
输出 "计数结果: " + 转字符串(计数器)

设 最常见 = 计数表最常见(计数器, 3)
输出 "最常见的3项: " + 转字符串(最常见)
输出 ""

// 字典合并
输出 "--- 字典合并 ---"
设 字典1 = {a: 1, b: 2}
设 字典2 = {b: 3, c: 4}
设 合并结果 = 字典合并(字典1, 字典2)
输出 "合并结果: " + 转字符串(合并结果)
输出 ""

// 字典翻转
输出 "--- 字典翻转 ---"
设 原字典 = {name: "张三", age: "25", city: "北京"}
设 翻转后 = 字典翻转(原字典)
输出 "原字典: " + 转字符串(原字典)
输出 "翻转后: " + 转字符串(翻转后)
输出 ""

// 字典过滤
输出 "--- 字典过滤 ---"
设 分数 = {语文: 85, 数学: 92, 英语: 78, 物理: 88}

函程 是高分(值):
    返回 值 >= 85

设 高分科目 = 字典过滤值(分数, 是高分)
输出 "高分科目: " + 转字符串(高分科目)
输出 ""

// 字典映射值
输出 "--- 字典映射值 ---"

函程 加分(值):
    返回 值 + 5

设 加分后 = 字典映射值(分数, 加分)
输出 "加分后: " + 转字符串(加分后)
输出 ""

// 取值默认
输出 "--- 取值默认 ---"
设 配置 = {host: "localhost", port: 8080}
输出 "host: " + 字典取值默认(配置, "host", "127.0.0.1")
输出 "user: " + 字典取值默认(配置, "user", "admin")
输出 ""

// 字典深拷贝
输出 "--- 字典深拷贝 ---"
设 原始 = {a: 1, b: {c: 2}}
设 拷贝 = 字典深拷贝(原始)
输出 "深拷贝完成，修改拷贝不影响原始"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
