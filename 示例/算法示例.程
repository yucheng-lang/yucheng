// ===== 算法示例 =====
// 演示 算法 库的排序、搜索、排列组合功能

导入 "库/算法"

// 辅助函数
函程 列表转文本(列表):
    设 结果 = "["
    设 i = 0
    循环 i < 数组长度(列表):
        如果 i > 0:
            结果 = 结果 + ", "
        结果 = 结果 + 转字符串(列表[i])
        i = i + 1
    返回 结果 + "]"

// --- 排序算法 ---
输出 "=== 排序算法 ==="
设 数据 = [64, 34, 25, 12, 22, 11, 90]

输出 "冒泡排序: " + 列表转文本(冒泡排序(数据))
输出 "插入排序: " + 列表转文本(插入排序(数据))
输出 "选择排序: " + 列表转文本(选择排序(数据))
输出 "归并排序: " + 列表转文本(归并排序(数据))
输出 "降序排序: " + 列表转文本(降序排序(数据))

// --- 搜索算法 ---
输出 ""
输出 "=== 搜索算法 ==="
设 有序 = 排序(数据)
输出 "有序列表: " + 列表转文本(有序)
输出 "二分查找(25): 位置=" + 转字符串(二分查找(有序, 25))
输出 "线性查找(90): 位置=" + 转字符串(线性查找(数据, 90))

// --- 列表变换 ---
输出 ""
输出 "=== 列表变换 ==="
输出 "反转: " + 列表转文本(反转(数据))
输出 "右旋转2步: " + 列表转文本(右旋转(数据, 2))
输出 "左旋转2步: " + 列表转文本(左旋转(数据, 2))

// --- 排列组合 ---
输出 ""
输出 "=== 排列组合 ==="
输出 "5! = " + 转字符串(阶乘(5))
输出 "P(5,3) = " + 转字符串(排列数(5, 3))
输出 "C(5,2) = " + 转字符串(组合数(5, 2))

设 字母 = ["A", "B", "C"]
输出 "有序去重: " + 列表转文本(有序去重([1, 2, 2, 3, 3, 3]))
输出 "计数(3出现次数): " + 转字符串(计数([1, 2, 2, 3, 3, 3], 3))
输出 ""
输出 "=== 示例完成 ==="
输出 ""
