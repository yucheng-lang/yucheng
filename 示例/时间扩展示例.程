// 时间扩展库示例
// 演示时间操作扩展函数

导入 "库/时间扩展"

输出 "=== 时间扩展库示例 ==="
输出 ""

// 中文日期时间
输出 "--- 中文日期时间 ---"
输出 "完整时间: " + 完整时间()
输出 "中文日期: " + 中文日期()
输出 "中文时间: " + 中文时间()
输出 "中文日期时间: " + 中文日期时间()
输出 ""

// 星期
输出 "--- 星期 ---"
输出 "星期名: " + 星期名()
输出 "是工作日: " + 转字符串(是工作日())
输出 ""

// 季节
输出 "--- 季节 ---"
输出 "当前季节: " + 当前季节()
输出 ""

// 毫秒时间戳
输出 "--- 毫秒时间戳 ---"
输出 "毫秒时间戳: " + 转字符串(毫秒时间戳())
输出 ""

// 计时器
输出 "--- 计时器 ---"
创建计时器("测试")
输出 "计时器已创建"
休眠(100)
设 耗时 = 计时器耗时("测试")
输出 "耗时: " + 格式化耗时(耗时)
输出 ""

// 月天数
输出 "--- 月天数 ---"
输出 "2024年2月天数: " + 转字符串(月天数(2024, 2))
输出 "2024年6月天数: " + 转字符串(月天数(2024, 6))
输出 ""

// 年内天数
输出 "--- 年内天数 ---"
输出 "2024年3月1日的年内天数: " + 转字符串(年内天数(2024, 3, 1))
输出 ""

// 格式化日期
输出 "--- 格式化日期 ---"
输出 "格式化日期: " + 格式化日期("%Y年%m月%d日 %H:%M:%S")
输出 ""

// 年底剩余
输出 "--- 年底剩余 ---"
输出 "2024年12月1日年底剩余: " + 转字符串(年底剩余(2024, 12, 1)) + " 天"
输出 ""

输出 "=== 示例完成 ==="
输出 ""
