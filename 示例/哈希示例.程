// ===== 哈希示例 =====
// 演示 哈希 库的哈希计算功能

导入 "库/哈希"

设 文本 = "Hello, 语程!"

// --- 哈希计算 ---
输出 "=== 哈希计算 ==="
输出 "原文: " + 文本
输出 "MD5:    " + 计算MD5(文本)
输出 "SHA1:   " + 计算SHA1(文本)
输出 "SHA256: " + 计算SHA256(文本)
输出 "CRC32:  " + 转字符串(计算CRC32(文本))

// --- 哈希校验 ---
输出 ""
输出 "=== 哈希校验 ==="
设 期望 = 计算MD5(文本)
输出 "验证MD5 (正确): " + 转字符串(验证MD5(文本, 期望))
输出 "验证MD5 (错误): " + 转字符串(验证MD5("别的文本", 期望))

// --- 密码哈希 ---
输出 ""
输出 "=== 密码哈希 ==="
设 盐 = "random_salt_123"
输出 "加盐哈希: " + 加盐哈希(文本, 盐)
输出 "双重哈希: " + 双重哈希(文本)

// --- 简短哈希 ---
输出 ""
输出 "=== 简短哈希 ==="
输出 "简短哈希: " + 简短哈希(文本) + " (MD5前8位)"

// --- 组合哈希 ---
输出 ""
输出 "=== 组合哈希 ==="
输出 "组合哈希([1,2,3]): " + 组合哈希([1, 2, 3])
输出 ""
输出 "=== 示例完成 ==="
输出 ""
