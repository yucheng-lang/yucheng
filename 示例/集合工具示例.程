// 集合工具库示例
// 演示集合运算功能

导入 "库/集合工具"

输出 "=== 集合工具库示例 ==="
输出 ""

// 创建测试集合
设 集合A = [1, 2, 3, 4, 5]
设 集合B = [4, 5, 6, 7, 8]
设 集合C = [1, 2, 3]

输出 "集合A: " + 转字符串(集合A)
输出 "集合B: " + 转字符串(集合B)
输出 "集合C: " + 转字符串(集合C)
输出 ""

// 集合基本操作
输出 "--- 集合基本操作 ---"
设 大小 = 集合大小(集合A)
输出 "集合A大小: " + 转字符串(大小)

设 包含3 = 集合包含(集合A, 3)
输出 "集合A包含3: " + 转字符串(包含3)

设 包含9 = 集合包含(集合A, 9)
输出 "集合A包含9: " + 转字符串(包含9)
输出 ""

// 集合相等判断
输出 "--- 集合相等判断 ---"
设 相等结果 = 集合相等(集合A, 集合B)
输出 "集合A == 集合B: " + 转字符串(相等结果)

设 相等结果2 = 集合相等(集合A, 集合A)
输出 "集合A == 集合A: " + 转字符串(相等结果2)
输出 ""

// 集合运算
输出 "--- 集合运算 ---"
设 并集 = 集合并(集合A, 集合B)
输出 "A 并 B: " + 转字符串(并集)

设 交集 = 集合交(集合A, 集合B)
输出 "A 交 B: " + 转字符串(交集)

设 差集 = 集合差(集合A, 集合B)
输出 "A - B: " + 转字符串(差集)

设 对称差 = 集合对称差(集合A, 集合B)
输出 "A 对称差 B: " + 转字符串(对称差)
输出 ""

// 列表去重
输出 "--- 列表去重 ---"
设 有重复列表 = [1, 2, 2, 3, 3, 3, 4, 4, 4, 4]
输出 "原列表: " + 转字符串(有重复列表)

设 去重后 = 列表去重集(有重复列表)
输出 "去重后: " + 转字符串(去重后)
输出 ""

// 字符串集合
输出 "--- 字符串集合 ---"
设 语言集合1 = ["中文", "英文", "日文"]
设 语言集合2 = ["英文", "法文", "德文"]

设 语言并集 = 集合并(语言集合1, 语言集合2)
输出 "语言并集: " + 转字符串(语言并集)

设 语言交集 = 集合交(语言集合1, 语言集合2)
输出 "语言交集: " + 转字符串(语言交集)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
