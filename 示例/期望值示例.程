// 期望值库示例
// 演示Result类型（表示成功值或错误）

导入 "库/期望值"

输出 "=== 期望值库示例 ==="
输出 ""

// 创建期望值
输出 "--- 创建期望值 ---"
设 成功值 = 成功(42)
设 失败值 = 失败("出错了")
输出 "成功值: " + 期望值转文本(成功值)
输出 "失败值: " + 期望值转文本(失败值)
输出 ""

// 检查状态
输出 "--- 检查状态 ---"
输出 "成功值是成功: " + 转文本(是成功(成功值))
输出 "成功值是失败: " + 转文本(是失败(成功值))
输出 "失败值是成功: " + 转文本(是成功(失败值))
输出 "失败值是失败: " + 转文本(是失败(失败值))
输出 ""

// 获取值
输出 "--- 获取值 ---"
设 值 = 取期望值(成功值)
输出 "成功值的值: " + 转文本(值)

设 默认值 = 取值或默认(失败值, 0)
输出 "失败值的默认值: " + 转文本(默认值)
输出 ""

// 映射操作
输出 "--- 映射操作 ---"

函程 加倍(x):
    返回 x * 2

设 映射后 = 映射(成功值, 加倍)
输出 "成功值映射后: " + 转文本(取期望值(映射后))
输出 ""

// 链式操作
输出 "--- 链式操作 ---"

函程 验证正数(x):
    如果 x > 0:
        返回 成功(x)
    否则:
        返回 失败("值必须为正数")

设 链式结果 = 然后调用(成功值, 验证正数)
输出 "链式验证结果: " + 转文本(是成功(链式结果))
输出 ""

// 实际应用：安全除法
输出 "--- 实际应用：安全除法 ---"
函程 安全除法(被除数, 除数):
    如果 除数 == 0:
        返回 失败("除数不能为零")
    否则:
        返回 成功(被除数 / 除数)

设 结果1 = 安全除法(10, 2)
设 结果2 = 安全除法(10, 0)

如果 是成功(结果1):
    输出 "10 / 2 = " + 转文本(取期望值(结果1))
否则:
    输出 "错误: " + 取错误(结果1)

如果 是成功(结果2):
    输出 "10 / 0 = " + 转文本(取期望值(结果2))
否则:
    输出 "错误: " + 取错误(结果2)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
