// 解析工具库示例
// 演示字符串解析工具函数

导入 "库/解析工具"

输出 "=== 解析工具库示例 ==="
输出 ""

// 跳过空白
输出 "--- 跳过空白 ---"
设 文本1 = "   Hello"
设 跳过数 = 跳过空白(文本1, 0)
输出 "跳过空白字符数: " + 转字符串(跳过数)
输出 ""

// 跳过令牌
输出 "--- 跳过令牌 ---"
设 文本2 = "Hello World"
设 匹配数 = 跳过令牌(文本2, "Hello", 0)
输出 "跳过'Hello'字符数: " + 转字符串(匹配数)
输出 ""

// 解析整数
输出 "--- 解析整数 ---"
设 文本3 = "123abc"
设 结果3 = 解析整数(文本3, 0)
输出 "解析整数: " + 转字符串(结果3)
输出 ""

// 解析浮点数
输出 "--- 解析浮点数 ---"
设 文本4 = "3.14xyz"
设 结果4 = 解析浮点数(文本4, 0)
输出 "解析浮点数: " + 转字符串(结果4)
输出 ""

// 解析二进制
输出 "--- 解析二进制 ---"
设 文本5 = "1010abc"
设 结果5 = 解析二进制(文本5, 0)
输出 "解析二进制: " + 转字符串(结果5)
输出 ""

// 解析十六进制
输出 "--- 解析十六进制 ---"
设 文本6 = "FFabc"
设 结果6 = 解析十六进制(文本6, 0)
输出 "解析十六进制: " + 转字符串(结果6)
输出 ""

// 解析标识符
输出 "--- 解析标识符 ---"
设 文本7 = "变量名123"
设 结果7 = 解析标识符(文本7, 0)
输出 "解析标识符: " + 转字符串(结果7)
输出 ""

// 捕获之间
输出 "--- 捕获之间 ---"
设 文本8 = "<内容>"
设 结果8 = 捕获之间(文本8, "<", ">")
输出 "捕获<>之间: " + 结果8
输出 ""

// 解析尺寸
输出 "--- 解析尺寸 ---"
设 文本9 = "1920x1080"
设 结果9 = 解析尺寸(文本9, 0)
输出 "解析尺寸: " + 转字符串(结果9)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
