// ===== 统计示例 =====
// 演示 统计 库的描述统计与线性回归功能

导入 "库/统计"

设 数据 = [23, 45, 12, 67, 34, 56, 78, 19, 42, 31]

// --- 描述统计 ---
输出 "=== 描述统计 ==="
输出 "数据: [23, 45, 12, 67, 34, 56, 78, 19, 42, 31]"
输出 "计数: " + 转字符串(计数(数据))
输出 "求和: " + 转字符串(求和(数据))
输出 "平均值: " + 转字符串(平均值(数据))
输出 "中位数: " + 转字符串(中位数(数据))
输出 "众数: " + 转字符串(众数(数据))
输出 "最小: " + 转字符串(最小(数据))
输出 "最大: " + 转字符串(最大(数据))
输出 "极差: " + 转字符串(极差(数据))

// --- 离散程度 ---
输出 ""
输出 "=== 离散程度 ==="
输出 "方差: " + 转字符串(方差(数据))
输出 "标准差: " + 转字符串(标准差(数据))
输出 "样本方差: " + 转字符串(样本方差(数据))
输出 "样本标准差: " + 转字符串(样本标准差(数据))

// --- 分位数 ---
输出 ""
输出 "=== 分位数 ==="
输出 "下四分位(Q1): " + 转字符串(下四分位(数据))
输出 "中四分位(Q2): " + 转字符串(中四分位(数据))
输出 "上四分位(Q3): " + 转字符串(上四分位(数据))
输出 "四分位距(IQR): " + 转字符串(四分位距(数据))
输出 "第90百分位: " + 转字符串(百分位数(数据, 90))

// --- 线性回归 ---
输出 ""
输出 "=== 线性回归 ==="
设 x = [1, 2, 3, 4, 5]
设 y = [2.1, 4.0, 5.9, 8.1, 10.0]
输出 "x = [1, 2, 3, 4, 5]"
输出 "y = [2.1, 4.0, 5.9, 8.1, 10.0]"
输出 "回归斜率: " + 转字符串(回归斜率(x, y))
输出 "回归截距: " + 转字符串(回归截距(x, y))
输出 "相关系数: " + 转字符串(相关系数(x, y))
输出 "预测x=6时: " + 转字符串(回归预测(x, y, 6))

// --- 统计摘要 ---
输出 ""
输出 "=== 统计摘要 ==="
统计摘要(数据)
输出 ""
输出 "=== 示例完成 ==="
输出 ""
