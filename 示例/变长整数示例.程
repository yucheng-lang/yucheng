// 变长整数库示例
// 演示VarInt编码实现

导入 "库/变长整数"

输出 "=== 变长整数库示例 ==="
输出 ""

// 写入变长整数
输出 "--- 写入变长整数 ---"
设 小值 = 100
设 中值 = 10000
设 大值 = 1000000

设 字节1 = 写入变长整数(小值)
输出 "值 " + 转字符串(小值) + " 编码为 " + 转字符串(数组长度(字节1)) + " 字节"

设 字节2 = 写入变长整数(中值)
输出 "值 " + 转字符串(中值) + " 编码为 " + 转字符串(数组长度(字节2)) + " 字节"

设 字节3 = 写入变长整数(大值)
输出 "值 " + 转字符串(大值) + " 编码为 " + 转字符串(数组长度(字节3)) + " 字节"
输出 ""

// 读取变长整数
输出 "--- 读取变长整数 ---"
设 结果1 = 读取变长整数(字节1)
输出 "解码结果: " + 转字符串(结果1.值)

设 结果2 = 读取变长整数(字节2)
输出 "解码结果: " + 转字符串(结果2.值)

设 结果3 = 读取变长整数(字节3)
输出 "解码结果: " + 转字符串(结果3.值)
输出 ""

// ZigZag编码
输出 "--- ZigZag编码 ---"
设 正数列表 = [0, 1, 2, 3, 4]
设 负数列表 = [-1, -2, -3, -4]

循环 值 于 正数列表:
    设 编码 = ZigZag编码(值)
    输出 "ZigZag(" + 转字符串(值) + ") = " + 转字符串(编码)

循环 值 于 负数列表:
    设 编码 = ZigZag编码(值)
    输出 "ZigZag(" + 转字符串(值) + ") = " + 转字符串(编码)
输出 ""

// ZigZag解码
输出 "--- ZigZag解码 ---"
循环 值 于 正数列表:
    设 编码 = ZigZag编码(值)
    设 解码 = ZigZag解码(编码)
    输出 "解码 " + 转字符串(编码) + " -> " + 转字符串(解码)
输出 ""

// 整数与字节列表转换
输出 "--- 整数与字节列表转换 ---"
设 原始整数 = 12345678
设 字节列表 = 整数转字节列表(原始整数)
设 还原整数 = 字节列表转整数(字节列表)
输出 "原始: " + 转字符串(原始整数)
输出 "还原: " + 转字符串(还原整数)
输出 ""

输出 "=== 示例完成 ==="
