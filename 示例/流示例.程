// 流操作库示例
// 演示字符串流的基本功能

导入 "流"

输出 "=== 流操作库示例 ==="
输出 ""

// 创建字符串流
输出 "--- 创建字符串流 ---"
设 s = 流.创建字符串流("Hello 语程!")
输出 "创建成功，内容: " + s.内容
输出 "流位置: " + 转文本(流.流位置(s))
输出 ""

// 流读取
输出 "--- 流读取 ---"
设 结果 = 流.流读取(s, 5)
设 数据 = 结果[0]
设 s = 结果[1]
输出 "读取5字节: " + 数据
输出 "当前位置: " + 转文本(流.流位置(s))
输出 ""

// 继续读取
输出 "--- 继续读取 ---"
设 结果2 = 流.流读取(s, 100)
设 数据2 = 结果2[0]
设 s = 结果2[1]
输出 "读取剩余: " + 数据2
输出 "当前位置: " + 转文本(流.流位置(s))
输出 ""

// 流写入
输出 "--- 流写入 ---"
设 s = 流.创建字符串流("")
设 s = 流.流写入(s, "你好")
设 s = 流.流写入(s, "世界")
输出 "写入后内容: " + s.内容
输出 ""

// 流定位
输出 "--- 流定位 ---"
设 s = 流.创建字符串流("ABCDEFGHIJ")
设 s = 流.流定位(s, 3)
设 结果3 = 流.流读取(s, 3)
输出 "从位置3读取3字节: " + 结果3[0]
输出 ""

// 读取行
输出 "--- 读取行 ---"
设 s = 流.创建字符串流("第一行\n第二行\n第三行")
设 结果4 = 流.流读取行(s)
输出 "第一行: " + 结果4[0]
设 s = 结果4[1]
设 结果5 = 流.流读取行(s)
输出 "第二行: " + 结果5[0]
设 s = 结果5[1]
设 结果6 = 流.流读取行(s)
输出 "第三行: " + 结果6[0]
输出 ""

// 流跳过
输出 "--- 流跳过 ---"
设 s = 流.创建字符串流("ABCDEFGHIJ")
设 s = 流.流跳过(s, 3)
设 结果7 = 流.流读取(s, 3)
输出 "跳过3字节后读取: " + 结果7[0]
输出 ""

// 流回到开头
输出 "--- 流回到开头 ---"
设 s = 流.创建字符串流("Hello World")
设 结果8 = 流.流读取(s, 5)
设 s = 结果8[1]
输出 "读取5字节后位置: " + 转文本(流.流位置(s))
设 s = 流.流回到开头(s)
输出 "回到开头后位置: " + 转文本(流.流位置(s))
输出 ""

// 流大小和流结束判断
输出 "--- 流信息 ---"
设 s = 流.创建字符串流("测试文本")
输出 "流大小: " + 转文本(流.流大小(s))
输出 "是否结束: " + 转文本(非 流.非流结束(s))
输出 ""

// 创建内存流
输出 "--- 内存流 ---"
设 ms = 流.创建内存流()
设 ms = 流.流写入(ms, "内存流测试")
输出 "内存流内容: " + ms.内容
输出 ""

// 字符串转流
输出 "--- 字符串转流 ---"
设 s2 = 流.字符串转流("转换测试")
输出 "转换后内容: " + s2.内容
输出 ""

// 流清空
输出 "--- 流清空 ---"
设 s = 流.创建字符串流("待清空")
设 s = 流.流清空(s)
输出 "清空后内容: \"" + s.内容 + "\""
输出 ""

输出 "=== 示例完成 ==="
输出 ""
