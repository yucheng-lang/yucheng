// 序列工具库示例
// 演示函数式序列操作

导入 "库/序列工具"

输出 "=== 序列工具库示例 ==="
输出 ""

// 拉链
输出 "--- 拉链 ---"
设 列表1 = ["a", "b", "c"]
设 列表2 = [1, 2, 3]
设 拉链结果 = 拉链(列表1, 列表2)
输出 "拉链结果: " + 转字符串(拉链结果)
输出 ""

// 去假值
输出 "--- 去假值 ---"
设 混合列表 = [1, 0, "hello", "", 真, 假]
设 去假后 = 去假值(混合列表)
输出 "去假值后: " + 转字符串(去假后)
输出 ""

// 展平
输出 "--- 展平 ---"
设 嵌套列表 = [[1, 2], [3, 4], [5]]
设 展平后 = 展平(嵌套列表)
输出 "展平后: " + 转字符串(展平后)
输出 ""

// 序列最大值/最小值
输出 "--- 序列最大值/最小值 ---"
设 数字列表 = [1, 2, 3, 4, 5]
输出 "最大值: " + 转字符串(序列最大值(数字列表))
输出 "最小值: " + 转字符串(序列最小值(数字列表))
输出 ""

// 重复序列
输出 "--- 重复序列 ---"
设 重复结果 = 重复序列("语程", 3)
输出 "重复序列('语程', 3): " + 转字符串(重复结果)
输出 ""

// 范围序列
输出 "--- 范围序列 ---"
设 范围结果 = 范围序列(1, 6, 1)
输出 "范围序列(1, 6, 1): " + 转字符串(范围结果)
输出 ""

// 序列求和
输出 "--- 序列求和 ---"
输出 "求和: " + 转字符串(序列求和(数字列表))
输出 ""

// 去重复
输出 "--- 去重复 ---"
设 有重复 = [1, 2, 2, 3, 3, 3, 4]
设 去重后 = 去重复(有重复)
输出 "去重复后: " + 转字符串(去重后)
输出 ""

输出 "=== 示例完成 ==="
输出 ""
